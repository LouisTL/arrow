// ═══════════════════════════════════════════
//  Arrow Lang -- Self-Hosted Compiler
//  Emits LLVM IR text (.ll), then shells out
//  to clang for AOT compilation.
//
//  Usage: python lang.py compiler.arrow <file.arrow>
//  Or:    compiler.exe <file.arrow>
//  Compiles <file.arrow> to <file>.ll and <file>.exe
//
//  Type tracking: emit_expr returns {reg, type}
//  where type is "int" or "str".
// ═══════════════════════════════════════════

// Type system primitives and pure type-level helpers live in their own
// module. Imported as `T` — usage looks like `T.mk_int()`, `T.types_join(a,b)`,
// `T.types_compat(annot, actual)`. The resolver loads compiler/types.arrow
// via the search-path fallback (next to the arrow executable) so this
// works regardless of where the user invoked the compiler from.
import "compiler/types" as T;
import "compiler/lexer" as lex;
import "compiler/ir_render" as irr;

// ── Parser ──────────────────────────────
var toks<-[];var pos<-[0];
var type_aliases<-[[]]; // structural type aliases (3d): [{name, atype}]

// Parse errors are accumulated rather than printed. Like type_errors and
// import_errors, they're flushed at the end of compilation; if any are
// present, compilation aborts cleanly before emitting IR. Per-error
// metadata: source file (so import-time parses can be tagged), line, col.
var parse_errors <- [];
var parse_src_file <- ["<unknown>"];  // updated per-parse so each error knows its file
// Once we've registered a parse error in the current statement, suppress
// further errors until the statement-level recovery in pp() resyncs. This
// turns "missing ) inside a fn header" from a cascade of 2-3 errors into a
// single one pointing at the actual cause. Reset at the start of each
// top-level statement.
var panic_mode <- [false];

fn parse_error(line: int, col: int, msg: str) {
    if (panic_mode[0]) { return false; }
    push(parse_errors, {file: parse_src_file[0], line: line, col: col, msg: msg});
    panic_mode[0] <- true;
    return false;
}

fn ci(e: str): int{return toks[pos[0]].type=e;}
fn pi(o: int,e: str): int{var x<-pos[0]+o;if(x<len(toks)){return toks[x].type=e;}return false;}
fn adv(){pos[0]<-pos[0]+1;}
fn cv(): str{return toks[pos[0]].value;}
fn eat(e: str){
    var t<-toks[pos[0]];
    if(t.type!=e){parse_error(t.line, t.col, "expected " + e + ", got " + t.type);}
    pos[0]<-pos[0]+1;
    return t;
}
fn ev(e: str): str{var t<-toks[pos[0]];pos[0]<-pos[0]+1;return t.value;}

// Skip tokens until we reach a likely statement boundary. Used to recover
// from a parse error: discard the rest of the broken statement, then resume
// parsing fresh from the next plausible start point. Sync points:
//   - SEMI       — end of an expression statement / assignment; consume it
//   - RBRACE     — end of a block; stop before it so the enclosing parser
//                  (if/while/fn) sees it cleanly
//   - top-level  — fn, if, while, for, return, print, import — start of a
//     keyword     new statement; stop before it
//   - EOF        — end of file; stop
fn sync_to_stmt_boundary() {
    while (!ci("EOF") && !ci("SEMI") && !ci("RBRACE")
            && !ci("fn") && !ci("if") && !ci("while") && !ci("for")
            && !ci("return") && !ci("print") && !ci("import")) {
        adv();
    }
    if (ci("SEMI")) { adv(); }
}

fn pp(){
    var ss<-[];
    while(!ci("EOF")){
        var start_pos <- pos[0];
        var start_errs <- len(parse_errors);
        panic_mode[0] <- false;  // fresh statement → fresh error budget
        if (ci("IDENT") && cv() = "type" && pi(1, "IDENT") && pi(2, "ARROW")) {
            // type Name <- Type;  register the structural alias (3d); it
            // yields no AST node, so nothing downstream needs to handle it.
            ptype_decl();
            if (len(parse_errors) > start_errs) {
                if (pos[0] = start_pos) { adv(); }
                sync_to_stmt_boundary();
            }
        } else {
            var s <- ps();
            if (len(parse_errors) > start_errs) {
                // This statement registered new parse errors. Skip whatever the
                // sub-parsers consumed and resync to the next statement so we
                // can report independent errors instead of a cascade. Force one
                // advance if the parser didn't move at all (defensive against
                // an infinite loop on a corrupt token stream).
                if (pos[0] = start_pos) { adv(); }
                sync_to_stmt_boundary();
            } else {
                push(ss, s);
            }
        }
    }
    return ss;
}
fn ps(){
    if(ci("fn")){return pfd();}if(ci("return")){return prt();}
    if(ci("if")){return pif();}if(ci("while")){return pwh();}if(ci("match")){return pmatch();}
    if(ci("for")){return pfi();}if(ci("print")){return ppr();}
    if(ci("import")){return pim();}
    if(ci("var")){return pvd();}
    if(ci("LBRACE")){if(isl()){var e<-pe();eat("SEMI");return e;}return{node:"Block",stmts:pb()};}
    if(ci("IDENT")){if(pi(1,"ARROW")){return pas();}if(pi(1,"COLON")){return ptd();}if(pi(1,"LBRACKET")||pi(1,"DOT")){return ppa();}}
    var e<-pe();eat("SEMI");return e;
}
// Module import: `import "path/to/file";` — the file (with `.arrow` appended)
// is loaded relative to the importing file's directory. The basename without
// extension becomes the namespace name used at access sites (`base.symbol`).
// Optional `as <ident>` overrides the namespace name:
//   import "lib/strings" as str;
// `as` is not a reserved keyword — it's only recognized contextually here,
// so users can still name a variable `as`.
fn pim(){
    var ln<-toks[pos[0]].line;var cl<-toks[pos[0]].col;
    eat("import");
    var pt<-toks[pos[0]];
    if(pt.type!="STRING"){parse_error(pt.line, pt.col, "import expects a string path, got " + pt.type);adv();return{node:"NumberLit",value:"0"};}
    var pth<-pt.value;
    adv();
    // Default namespace name: basename of path with .arrow stripped.
    var base<-pth;
    var bl<-len(base);
    if(bl>6&&substring(base,bl-6,bl)=".arrow"){base<-substring(base,0,bl-6);bl<-bl-6;}
    var si<-bl-1;
    while(si>=0&&char_at(base,si)!="/"&&char_at(base,si)!="\\"){si<-si-1;}
    if(si>=0){base<-substring(base,si+1,bl);}
    // Optional `as <ident>` override. Recognized by contextual lookahead on
    // the identifier value, not as a reserved keyword.
    if(ci("IDENT")&&cv()="as"){
        adv();
        if(!ci("IDENT")){
            var t<-toks[pos[0]];
            parse_error(t.line, t.col, "`as` expects an identifier, got " + t.type);
        } else {
            base<-cv();
            adv();
        }
    }
    eat("SEMI");
    return{node:"ImportStmt",path:pth,name:base,line:ln,col:cl};
}
fn isl(): int{if(pi(1,"RBRACE")){return true;}if(pi(1,"IDENT")&&pi(2,"COLON")){return true;}return false;}
fn pb(){eat("LBRACE");var ss<-[];while(!ci("RBRACE")){push(ss,ps());}eat("RBRACE");return ss;}
fn pty(){var t<-pty_one();if(ci("PIPE")){var ms<-[t];while(ci("PIPE")){eat("PIPE");push(ms,pty_one());}return T.mk_union(ms);}return t;}
fn pty_one(){if(ci("LBRACKET")){eat("LBRACKET");var et<-pty();eat("RBRACKET");return T.mk_array(et);}if(ci("LBRACE")){eat("LBRACE");var fs<-[];if(!ci("RBRACE")){var fn1<-ev("IDENT");eat("COLON");var ft<-pty();push(fs,{name:fn1,type:ft});while(ci("COMMA")){eat("COMMA");if(ci("RBRACE")){eat("RBRACE");return T.mk_struct_lit(fs);}var fn2<-ev("IDENT");eat("COLON");var ft2<-pty();push(fs,{name:fn2,type:ft2});}}eat("RBRACE");return T.mk_struct_lit(fs);}var n<-ev("IDENT");if(n="int"){return{kind:"int"};}if(n="str"){return{kind:"str"};}if(n="bool"){return{kind:"bool"};}if(n="float"){return{kind:"float"};}if(n="any"){return{kind:"any"};}if(n="struct"){return{kind:"struct"};}if(n="fn"){return{kind:"fn"};}var al<-get_type_alias(n);if(al.kind!="none"){return T.mk_named(al,n);}report_error(toks[pos[0]-1].line,toks[pos[0]-1].col,"unknown type '"+n+"'");return{kind:"any"};}
fn set_type_alias(name: str, t){var a<-type_aliases[0];var i<-0;while(i<len(a)){if(a[i].name=name){a[i]<-{name:name,atype:t};return false;}i<-i+1;}push(type_aliases[0],{name:name,atype:t});return false;}
fn get_type_alias(name: str){var a<-type_aliases[0];var i<-0;while(i<len(a)){if(a[i].name=name){return a[i].atype;}i<-i+1;}return{kind:"none"};}
// type Name <- Type;  structural alias (3d). Registers the alias and is
// elided from the AST (handled in pp), so no later pass sees a new node.
fn ptype_decl(){var ln<-toks[pos[0]].line;var cl<-toks[pos[0]].col;var kw<-ev("IDENT");var name<-ev("IDENT");eat("ARROW");var ty<-pty();eat("SEMI");set_type_alias(name,ty);return{node:"TypeDecl",name:name,atype:ty,line:ln,col:cl};}
fn pas(){var ln<-toks[pos[0]].line;var cl<-toks[pos[0]].col;var n<-ev("IDENT");eat("ARROW");var e<-pe();eat("SEMI");return{node:"Assignment",name:n,expr:e,type_ann:{kind:"none"},is_decl:false,line:ln,col:cl};}
fn ptd(){var ln<-toks[pos[0]].line;var cl<-toks[pos[0]].col;var n<-ev("IDENT");eat("COLON");var ta<-pty();eat("ARROW");var e<-pe();eat("SEMI");return{node:"Assignment",name:n,expr:e,type_ann:ta,is_decl:false,line:ln,col:cl};}
// var x [: type] <- expr;  — declaration; carries is_decl:true so the
// scope checker can enforce same-scope no-redeclaration and reject bare
// reassignments to names that were never declared (strict mode).
fn pvd(){var ln<-toks[pos[0]].line;var cl<-toks[pos[0]].col;eat("var");
    // Check IDENT explicitly so we can bail out early on `var <- 5;`-style
    // malformed input. Without this, eat() records the error but keeps
    // advancing, and the rest of pvd can race past EOF into a crash
    // before parse_errors gets a chance to be reported.
    if (!ci("IDENT")) {
        parse_error(toks[pos[0]].line, toks[pos[0]].col, "expected IDENT, got " + toks[pos[0]].type);
        // Return a stub Assignment so pp()'s resync sees a recorded error
        // and skips to the next statement boundary.
        return {node:"Assignment",name:"<error>",expr:{node:"NumberLit",value:0},type_ann:{kind:"none"},is_decl:true,line:ln,col:cl};
    }
    var nt<-eat("IDENT");var n<-nt.value;var ta<-{kind:"none"};if(ci("COLON")){eat("COLON");ta<-pty();}eat("ARROW");var e<-pe();eat("SEMI");return{node:"Assignment",name:n,expr:e,type_ann:ta,is_decl:true,line:ln,col:cl};
}
fn ppa(){var e<-pe();if(ci("ARROW")){eat("ARROW");var v<-pe();eat("SEMI");if(e.node="IndexExpr"){return{node:"IndexAssign",obj:e.obj,index:e.index,value:v};}if(e.node="DotExpr"){return{node:"DotAssign",obj:e.obj,field:e.field,value:v};}}eat("SEMI");return e;}
fn ppr(){eat("print");eat("LPAREN");var e<-pe();eat("RPAREN");eat("SEMI");return{node:"PrintStmt",expr:e};}
fn prt(){var ln<-toks[pos[0]].line;var cl<-toks[pos[0]].col;eat("return");if(ci("SEMI")){eat("SEMI");return{node:"ReturnStmt",expr:false,line:ln,col:cl};}var e<-pe();eat("SEMI");return{node:"ReturnStmt",expr:e,line:ln,col:cl};}
fn pfd(){var ln<-toks[pos[0]].line;var cl<-toks[pos[0]].col;eat("fn");var n<-ev("IDENT");eat("LPAREN");var p<-[];var pt<-[];if(!ci("RPAREN")){var pn<-ev("IDENT");push(p,pn);if(ci("COLON")){eat("COLON");push(pt,pty());}else{push(pt,{kind:"none"});}while(ci("COMMA")){eat("COMMA");pn<-ev("IDENT");push(p,pn);if(ci("COLON")){eat("COLON");push(pt,pty());}else{push(pt,{kind:"none"});}}}eat("RPAREN");var rt<-{kind:"none"};if(ci("COLON")){eat("COLON");rt<-pty();}var b<-pb();return{node:"FnDecl",name:n,params:p,param_types_ann:pt,ret_type_ann:rt,body:b,line:ln,col:cl};}
fn ppl(){eat("LPAREN");var p<-[];var pt<-[];if(!ci("RPAREN")){push(p,ev("IDENT"));if(ci("COLON")){eat("COLON");push(pt,pty());}else{push(pt,{kind:"none"});}while(ci("COMMA")){eat("COMMA");push(p,ev("IDENT"));if(ci("COLON")){eat("COLON");push(pt,pty());}else{push(pt,{kind:"none"});}}}eat("RPAREN");return{params:p,param_types_ann:pt};}
fn pif(){eat("if");eat("LPAREN");var c<-pe();eat("RPAREN");var tb<-pb();var eb<-[];if(ci("else")){eat("else");if(ci("if")){eb<-[pif()];}else{eb<-pb();}}return{node:"IfStmt",cond:c,then_body:tb,else_body:eb};}
fn pwh(){eat("while");eat("LPAREN");var c<-pe();eat("RPAREN");var b<-pb();return{node:"WhileStmt",cond:c,body:b};}
fn pfi(){eat("for");eat("LPAREN");var v<-ev("IDENT");eat("in");var it<-pe();eat("RPAREN");var b<-pb();return{node:"ForInStmt",var_name:v,iterable:it,body:b};}
fn match_destructure_body(bindName: str, ptype, body, ln: int, cl: int){var out<-[];var i<-0;while(i<len(ptype.fields)){var fname<-ptype.fields[i].name;push(out,{node:"Assignment",name:fname,expr:{node:"DotExpr",obj:{node:"Identifier",name:bindName,line:ln,col:cl},field:fname},type_ann:{kind:"none"},is_decl:true,line:ln,col:cl});i<-i+1;}var j<-0;while(j<len(body)){push(out,body[j]);j<-j+1;}return out;}
fn pmatch(){var ln<-toks[pos[0]].line;var cl<-toks[pos[0]].col;eat("match");eat("LPAREN");var sc<-pe();eat("RPAREN");eat("LBRACE");var arms<-[];while(!ci("RBRACE")){var pat<-parse_arm_pattern();eat("FAT_ARROW");var body<-pb();if(pat.ptype.kind="struct_lit"&&!pat.wild){var bn<-pat.name;if(bn=""&&sc.node="Identifier"){bn<-sc.name;}if(bn!=""){body<-match_destructure_body(bn,pat.ptype,body,ln,cl);}}push(arms,{ptype:pat.ptype,name:pat.name,body:body,wild:pat.wild,is_lit:pat.is_lit,lit:pat.lit,lit_kind:pat.lit_kind});if(ci("COMMA")){eat("COMMA");}}eat("RBRACE");return{node:"MatchStmt",scrutinee:sc,arms:arms,line:ln,col:cl};}
fn parse_arm_pattern(){var nm<-"";var wild<-false;var pt<-{kind:"none"};var is_lit<-false;var lit<-"";var lit_kind<-"";if(ci("IDENT")&&cv()="_"&&pos[0]+1<len(toks)&&toks[pos[0]+1].type="FAT_ARROW"){wild<-true;adv();}else if(ci("NUMBER")){is_lit<-true;lit_kind<-"int";lit<-cv();adv();pt<-{kind:"int"};}else if(ci("STRING")){is_lit<-true;lit_kind<-"str";lit<-cv();adv();pt<-{kind:"str"};}else if(ci("BOOL")){is_lit<-true;lit_kind<-"bool";lit<-cv();adv();pt<-{kind:"bool"};}else if(ci("MINUS")&&pos[0]+1<len(toks)&&toks[pos[0]+1].type="NUMBER"){adv();is_lit<-true;lit_kind<-"int";lit<-"-"+cv();adv();pt<-{kind:"int"};}else{if(ci("IDENT")&&pos[0]+1<len(toks)&&toks[pos[0]+1].type="COLON"){nm<-cv();adv();eat("COLON");}pt<-pty_one();}return{ptype:pt,name:nm,wild:wild,is_lit:is_lit,lit:lit,lit_kind:lit_kind};}
fn pmatch_expr(){var ln<-toks[pos[0]].line;var cl<-toks[pos[0]].col;eat("match");eat("LPAREN");var sc<-pe();eat("RPAREN");eat("LBRACE");var arms<-[];while(!ci("RBRACE")){var pat<-parse_arm_pattern();eat("FAT_ARROW");var val<-pe();push(arms,{ptype:pat.ptype,name:pat.name,value:val,wild:pat.wild,is_lit:pat.is_lit,lit:pat.lit,lit_kind:pat.lit_kind});if(!ci("RBRACE")){eat("COMMA");}}eat("RBRACE");return{node:"MatchExpr",scrutinee:sc,arms:arms,line:ln,col:cl};}
fn pe(){if(ci("LPAREN")&&iaf()){return paf();}return por();}
fn iaf(): int{var d<-0;var i<-pos[0];while(i<len(toks)){var t<-toks[i].type;if(t="LPAREN"){d<-d+1;}else if(t="RPAREN"){d<-d-1;if(d=0){var j<-i+1;if(j<len(toks)&&toks[j].type="COLON"){j<-j+1;while(j<len(toks)&&toks[j].type!="FAT_ARROW"&&toks[j].type!="LBRACE"&&toks[j].type!="SEMI"){j<-j+1;}}if(j<len(toks)){return toks[j].type="FAT_ARROW";}return false;}}i<-i+1;}return false;}
fn paf(){var pl<-ppl();var rt<-{kind:"none"};if(ci("COLON")){eat("COLON");rt<-pty();}eat("FAT_ARROW");if(ci("LBRACE")&&!isl()){var b<-pb();return{node:"ArrowFn",params:pl.params,param_types_ann:pl.param_types_ann,ret_type_ann:rt,body:b,is_expr:false};}var e<-pe();return{node:"ArrowFn",params:pl.params,param_types_ann:pl.param_types_ann,ret_type_ann:rt,body:e,is_expr:true};}
fn por(){var l<-pan();while(ci("OR")){eat("OR");l<-{node:"BinOp",op:"||",left:l,right:pan()};}return l;}
fn pan(){var l<-peq();while(ci("AND")){eat("AND");l<-{node:"BinOp",op:"&&",left:l,right:peq()};}return l;}
fn peq(){var l<-pcm();while(ci("EQ")||ci("NEQ")){var o<-cv();adv();l<-{node:"BinOp",op:o,left:l,right:pcm()};}return l;}
fn pcm(){var l<-ppad();while(ci("LT")||ci("GT")||ci("LTE")||ci("GTE")){var o<-cv();adv();l<-{node:"BinOp",op:o,left:l,right:ppad()};}return l;}
fn ppad(){var l<-pmu();while(ci("PLUS")||ci("MINUS")){var o<-cv();adv();l<-{node:"BinOp",op:o,left:l,right:pmu()};}return l;}
fn pmu(){var l<-pun();while(ci("STAR")||ci("SLASH")||ci("PERCENT")){var o<-cv();adv();l<-{node:"BinOp",op:o,left:l,right:pun()};}return l;}
fn pun(){if(ci("MINUS")){adv();return{node:"UnaryOp",op:"-",operand:pun()};}if(ci("NOT")){adv();return{node:"UnaryOp",op:"!",operand:pun()};}return ppf();}
fn ppf(){var e<-ppm();var dn<-false;while(!dn){if(ci("LPAREN")){var cln<-toks[pos[0]].line;var ccl<-toks[pos[0]].col;eat("LPAREN");var a<-[];if(!ci("RPAREN")){push(a,pe());while(ci("COMMA")){eat("COMMA");push(a,pe());}}eat("RPAREN");e<-{node:"CallExpr",callee:e,args:a,line:cln,col:ccl};}
    else if(ci("LBRACKET")){eat("LBRACKET");var x<-pe();eat("RBRACKET");e<-{node:"IndexExpr",obj:e,index:x};}
    else if(ci("DOT")){eat("DOT");var f<-ev("IDENT");e<-{node:"DotExpr",obj:e,field:f};}
    else{dn<-true;}}return e;}
fn ppm(){
    if(ci("match")){return pmatch_expr();}
    if(ci("NUMBER")){var v<-cv();adv();return{node:"NumberLit",value:v};}
    if(ci("FLOAT")){var v<-cv();adv();return{node:"FloatLit",value:v};}
    if(ci("STRING")){var v<-cv();adv();return{node:"StringLit",value:v};}
    if(ci("BOOL")){var v<-cv();adv();return{node:"BoolLit",value:v};}
    if(ci("IDENT")){var ln<-toks[pos[0]].line;var cl<-toks[pos[0]].col;var v<-cv();adv();return{node:"Identifier",name:v,line:ln,col:cl};}
    if(ci("LBRACKET")){eat("LBRACKET");var el<-[];if(!ci("RBRACKET")){push(el,pe());while(ci("COMMA")){eat("COMMA");push(el,pe());}}eat("RBRACKET");return{node:"ArrayLit",elements:el};}
    if(ci("LBRACE")){eat("LBRACE");var fs<-[];if(!ci("RBRACE")){var k<-ev("IDENT");eat("COLON");var v<-pe();push(fs,{key:k,val:v});while(ci("COMMA")){eat("COMMA");if(ci("RBRACE")){eat("RBRACE");return{node:"StructLit",fields:fs};}k<-ev("IDENT");eat("COLON");v<-pe();push(fs,{key:k,val:v});}}eat("RBRACE");return{node:"StructLit",fields:fs};}
    if(ci("LPAREN")){eat("LPAREN");var e<-pe();eat("RPAREN");return e;}
    parse_error(toks[pos[0]].line, toks[pos[0]].col, "unexpected " + toks[pos[0]].type);adv();return{node:"NumberLit",value:"0"};
}


// ═══════════════════════════════════════════
//  MODULE RESOLVER
//
//  `import "path";` brings a `.arrow` file's top-level declarations into
//  scope under a namespace. The resolver runs after parsing and produces
//  a fully-flattened statement list with no ImportStmts left:
//
//   1. For each ImportStmt, read+tokenize+parse the target file.
//   2. Validate: only FnDecl, Assignment, and (nested) ImportStmt are
//      allowed at the top level of an imported file. Side-effecting
//      statements (prints, calls, control flow) are rejected — they would
//      otherwise run at import time, which we don't support.
//   3. Recursively resolve the imported file's own imports.
//   4. Rename every top-level symbol to `__mod_<modname>__<orig>` and
//      rewrite internal references (e.g. recursive calls inside the
//      module) to match. Bodies that introduce a parameter or local
//      variable shadowing a top-level name are left alone for that name
//      via scope tracking.
//   5. Splice the renamed declarations in place of the ImportStmt.
//   6. Record the namespace name so the main module's `mod.sym` access
//      pattern can be rewritten to the mangled identifier.
//
//  Modules import each other lazily via the same recursion. Already-resolved
//  files are cached (so importing utils twice doesn't duplicate symbols)
//  and an active-import stack provides cycle detection.

// Strip ".arrow" suffix if present, then take the basename for namespace use.
fn module_basename(path: str): str {
    var bl <- len(path);
    var base <- path;
    if (bl > 6 && substring(base, bl - 6, bl) = ".arrow") {
        base <- substring(base, 0, bl - 6);
        bl <- bl - 6;
    }
    var si <- bl - 1;
    while (si >= 0 && char_at(base, si) != "/" && char_at(base, si) != "\\") { si <- si - 1; }
    if (si >= 0) { base <- substring(base, si + 1, bl); }
    return base;
}

// Return everything up to and including the last "/" or "\\" — handle both
// so Windows paths like ".\examples\foo.arrow" produce ".\examples\\".
fn dirname(path: str): str {
    var bl <- len(path);
    var i <- bl - 1;
    while (i >= 0 && char_at(path, i) != "/" && char_at(path, i) != "\\") { i <- i - 1; }
    if (i < 0) { return ""; }
    return substring(path, 0, i + 1);
}

// Global state for the resolver.
var imported_paths <- [];        // [str] — paths we've already resolved (dedup)
var imported_mod_names <- [];    // [str] — namespace names exposed to caller
var import_in_progress <- [];    // [str] — stack used for cycle detection
var import_errors <- [];         // [str] — accumulated import-time errors

// Reject anything that would have a side effect at import time.
fn validate_module(stmts, path: str) {
    var i <- 0;
    while (i < len(stmts)) {
        var s <- stmts[i];
        var ok <- (s.node = "FnDecl" || s.node = "Assignment" || s.node = "ImportStmt");
        if (!ok) {
            var ln <- 0;
            if (s.line != false) { ln <- s.line; }
            push(import_errors, path + ":" + ln + ": module may only contain fn declarations, assignments, or imports (got " + s.node + ")");
        }
        i <- i + 1;
    }
}

// Maps a namespace name (the "as" alias, or the default basename) to the
// canonical name under which the module's symbols were actually renamed.
// When you `import "x" as foo; import "x" as bar;`, the first import wins
// the canonical name and the second is recorded here as bar→foo so that
// `bar.fn()` resolves to the same `__mod_foo__fn` definition. For the common
// case (one import per file), every alias maps to itself, and this table
// becomes a no-op identity.
var canonical_for <- [];

fn canonical_of(name: str): str {
    var i <- 0;
    while (i < len(canonical_for)) {
        if (canonical_for[i].name = name) { return canonical_for[i].canonical; }
        i <- i + 1;
    }
    return name;
}

// Walk a stmt list rewriting Identifier and CallExpr-callee references to
// top-level names in this module to their mangled form. Tracks a scope of
// parameter / local-variable names that should NOT be rewritten because
// they shadow the top-level binding.
fn mod_rewrite_stmts(stmts, top_names, scope, mod_name) {
    var i <- 0;
    while (i < len(stmts)) {
        mod_rewrite_stmt(stmts[i], top_names, scope, mod_name);
        i <- i + 1;
    }
    return 0;
}

fn mod_rewrite_stmt(s, top_names, scope, mod_name) {
    if (s.node = "Assignment") {
        mod_rewrite_expr(s.expr, top_names, scope, mod_name);
        return 0;
    }
    if (s.node = "ReturnStmt") {
        if (s.expr != false) { mod_rewrite_expr(s.expr, top_names, scope, mod_name); }
        return 0;
    }
    if (s.node = "PrintStmt") {
        mod_rewrite_expr(s.expr, top_names, scope, mod_name);
        return 0;
    }
    if (s.node = "IfStmt") {
        mod_rewrite_expr(s.cond, top_names, scope, mod_name);
        mod_rewrite_stmts(s.then_body, top_names, scope, mod_name);
        mod_rewrite_stmts(s.else_body, top_names, scope, mod_name);
        return 0;
    }
    if (s.node = "MatchStmt") {
        mod_rewrite_expr(s.scrutinee, top_names, scope, mod_name);
        var mi <- 0;
        while (mi < len(s.arms)) { mod_rewrite_stmts(s.arms[mi].body, top_names, scope, mod_name); mi <- mi + 1; }
        return 0;
    }
    if (s.node = "WhileStmt") {
        mod_rewrite_expr(s.cond, top_names, scope, mod_name);
        mod_rewrite_stmts(s.body, top_names, scope, mod_name);
        return 0;
    }
    if (s.node = "ForInStmt") {
        mod_rewrite_expr(s.iterable, top_names, scope, mod_name);
        // Loop variable shadows top-level name within the body
        var sub <- [];
        var i <- 0;
        while (i < len(scope)) { push(sub, scope[i]); i <- i + 1; }
        push(sub, s.var_name);
        mod_rewrite_stmts(s.body, top_names, sub, mod_name);
        return 0;
    }
    if (s.node = "Block") {
        mod_rewrite_stmts(s.stmts, top_names, scope, mod_name);
        return 0;
    }
    if (s.node = "IndexAssign") {
        mod_rewrite_expr(s.obj, top_names, scope, mod_name);
        mod_rewrite_expr(s.index, top_names, scope, mod_name);
        mod_rewrite_expr(s.value, top_names, scope, mod_name);
        return 0;
    }
    if (s.node = "DotAssign") {
        mod_rewrite_expr(s.obj, top_names, scope, mod_name);
        mod_rewrite_expr(s.value, top_names, scope, mod_name);
        return 0;
    }
    // Bare expression as statement (CallExpr, BinOp, etc.)
    mod_rewrite_expr(s, top_names, scope, mod_name);
    return 0;
}

fn name_in(names, n: str): int {
    var i <- 0;
    while (i < len(names)) {
        if (names[i] = n) { return true; }
        i <- i + 1;
    }
    return false;
}

fn mod_rewrite_expr(e, top_names, scope, mod_name) {
    if (e.node = "MatchExpr") {
        mod_rewrite_expr(e.scrutinee, top_names, scope, mod_name);
        var mxi <- 0;
        while (mxi < len(e.arms)) { mod_rewrite_expr(e.arms[mxi].value, top_names, scope, mod_name); mxi <- mxi + 1; }
        return 0;
    }
    if (e.node = "Identifier") {
        if (name_in(top_names, e.name) && !name_in(scope, e.name)) {
            e.name <- "__mod_" + mod_name + "__" + e.name;
        }
        return 0;
    }
    if (e.node = "BinOp") {
        mod_rewrite_expr(e.left, top_names, scope, mod_name);
        mod_rewrite_expr(e.right, top_names, scope, mod_name);
        return 0;
    }
    if (e.node = "UnaryOp") {
        mod_rewrite_expr(e.operand, top_names, scope, mod_name);
        return 0;
    }
    if (e.node = "CallExpr") {
        mod_rewrite_expr(e.callee, top_names, scope, mod_name);
        var j <- 0;
        while (j < len(e.args)) {
            mod_rewrite_expr(e.args[j], top_names, scope, mod_name);
            j <- j + 1;
        }
        return 0;
    }
    if (e.node = "IndexExpr") {
        mod_rewrite_expr(e.obj, top_names, scope, mod_name);
        mod_rewrite_expr(e.index, top_names, scope, mod_name);
        return 0;
    }
    if (e.node = "DotExpr") {
        mod_rewrite_expr(e.obj, top_names, scope, mod_name);
        return 0;
    }
    if (e.node = "ArrayLit") {
        var j <- 0;
        while (j < len(e.elements)) {
            mod_rewrite_expr(e.elements[j], top_names, scope, mod_name);
            j <- j + 1;
        }
        return 0;
    }
    if (e.node = "StructLit") {
        var j <- 0;
        while (j < len(e.fields)) {
            mod_rewrite_expr(e.fields[j].val, top_names, scope, mod_name);
            j <- j + 1;
        }
        return 0;
    }
    if (e.node = "ArrowFn") {
        // Params shadow top-level names within the arrow body
        var sub <- [];
        var i <- 0;
        while (i < len(scope)) { push(sub, scope[i]); i <- i + 1; }
        i <- 0;
        while (i < len(e.params)) { push(sub, e.params[i]); i <- i + 1; }
        if (e.is_expr) {
            mod_rewrite_expr(e.body, top_names, sub, mod_name);
        } else {
            mod_rewrite_stmts(e.body, top_names, sub, mod_name);
        }
        return 0;
    }
    // Literals (NumberLit, FloatLit, StringLit, BoolLit) — nothing to do.
    return 0;
}

// Rename top-level FnDecls and Assignments. Returns the same list with
// names mangled and bodies rewritten.
fn rename_module(stmts, mod_name: str) {
    // First pass: collect every top-level name (these are the names that
    // get mangled AND that internal references should be rewritten to).
    var top_names <- [];
    var i <- 0;
    while (i < len(stmts)) {
        var s <- stmts[i];
        if (s.node = "FnDecl") { push(top_names, s.name); }
        if (s.node = "Assignment") { push(top_names, s.name); }
        i <- i + 1;
    }
    // Second pass: mangle names + rewrite bodies/expressions.
    i <- 0;
    while (i < len(stmts)) {
        var s <- stmts[i];
        if (s.node = "FnDecl") {
            s.name <- "__mod_" + mod_name + "__" + s.name;
            var scope <- [];
            var j <- 0;
            while (j < len(s.params)) { push(scope, s.params[j]); j <- j + 1; }
            mod_rewrite_stmts(s.body, top_names, scope, mod_name);
        }
        if (s.node = "Assignment") {
            s.name <- "__mod_" + mod_name + "__" + s.name;
            mod_rewrite_expr(s.expr, top_names, [], mod_name);
        }
        i <- i + 1;
    }
    return stmts;
}

// Walk a stmt list and append each ImportStmt's resolved target onto the
// shared work lists. Pure: doesn't read or tokenize files itself — that
// has to happen at __main_logic level so the global parser state can be
// re-written. Returns the input list with ImportStmt entries filtered out.
//
// The work item carries both the relative-to-importer path AND the raw
// import string. If the relative resolution doesn't find the file, the
// work-loop body retries against a search-path fallback (the directory
// containing the arrow executable — useful for std lib lookups).
fn extract_imports(stmts, dir: str, work_paths, work_dirs, mod_names) {
    var out <- [];
    var i <- 0;
    while (i < len(stmts)) {
        var s <- stmts[i];
        if (s.node = "ImportStmt") {
            var target_path <- dir + s.path + ".arrow";
            push(work_paths, {path: target_path, raw_path: s.path, name: s.name, line: s.line, col: s.col});
            push(work_dirs, dir);
            if (!name_in(mod_names, s.name)) { push(mod_names, s.name); }
        } else {
            push(out, s);
        }
        i <- i + 1;
    }
    return out;
}

// After resolution, the main module's source still has `mod.sym` DotExpr
// nodes referring to imported namespaces. Rewrite them to direct Identifier
// references with the mangled name, so the rest of the compiler (typeof,
// scan_fns, IR emit) finds them via the usual lookup paths.
fn main_rewrite_stmts(stmts, mod_names) {
    var i <- 0;
    while (i < len(stmts)) {
        stmts[i] <- main_rewrite_stmt(stmts[i], mod_names);
        i <- i + 1;
    }
    return 0;
}

// Rewrites a single statement in place where possible, but returns the
// (possibly new) statement node — callers must replace the slot they
// pulled it from. The fallback path covers bare expression statements
// (e.g. `T.helper();`): the parser stores those as the raw expression
// node, so without this walk the rewriter would miss DotExprs inside.
fn main_rewrite_stmt(s, mod_names) {
    if (s.node = "Assignment") { s.expr <- main_rewrite_value(s.expr, mod_names); return s; }
    if (s.node = "ReturnStmt") {
        if (s.expr != false) { s.expr <- main_rewrite_value(s.expr, mod_names); }
        return s;
    }
    if (s.node = "PrintStmt") { s.expr <- main_rewrite_value(s.expr, mod_names); return s; }
    if (s.node = "IfStmt") {
        s.cond <- main_rewrite_value(s.cond, mod_names);
        main_rewrite_stmts(s.then_body, mod_names);
        main_rewrite_stmts(s.else_body, mod_names);
        return s;
    }
    if (s.node = "MatchStmt") {
        s.scrutinee <- main_rewrite_value(s.scrutinee, mod_names);
        var mi <- 0;
        while (mi < len(s.arms)) { main_rewrite_stmts(s.arms[mi].body, mod_names); mi <- mi + 1; }
        return s;
    }
    if (s.node = "WhileStmt") {
        s.cond <- main_rewrite_value(s.cond, mod_names);
        main_rewrite_stmts(s.body, mod_names);
        return s;
    }
    if (s.node = "ForInStmt") {
        s.iterable <- main_rewrite_value(s.iterable, mod_names);
        main_rewrite_stmts(s.body, mod_names);
        return s;
    }
    if (s.node = "Block") { main_rewrite_stmts(s.stmts, mod_names); return s; }
    if (s.node = "FnDecl") { main_rewrite_stmts(s.body, mod_names); return s; }
    if (s.node = "IndexAssign") {
        s.obj <- main_rewrite_value(s.obj, mod_names);
        s.index <- main_rewrite_value(s.index, mod_names);
        s.value <- main_rewrite_value(s.value, mod_names);
        return s;
    }
    if (s.node = "DotAssign") {
        s.obj <- main_rewrite_value(s.obj, mod_names);
        s.value <- main_rewrite_value(s.value, mod_names);
        return s;
    }
    // Bare-expression statement: walk through the value rewriter so any
    // DotExprs inside (`T.foo()`, `mod.bar`, etc.) get mangled too.
    return main_rewrite_value(s, mod_names);
}

// Recursively rewrite an expression. Returns the (possibly new) node — for
// DotExpr-on-imported-namespace we substitute a fresh Identifier node.
fn main_rewrite_value(e, mod_names) {
    if (e.node = "MatchExpr") {
        e.scrutinee <- main_rewrite_value(e.scrutinee, mod_names);
        var mxi <- 0;
        while (mxi < len(e.arms)) { e.arms[mxi].value <- main_rewrite_value(e.arms[mxi].value, mod_names); mxi <- mxi + 1; }
        return e;
    }
    if (e.node = "DotExpr") {
        // If the base is an imported namespace, replace `mod.sym` with the
        // mangled identifier. Otherwise recurse into the base for nested
        // rewrites (e.g. `x.field` where x is a normal struct). The
        // namespace name may be an alias from `import "x" as y` — look up
        // the canonical name so all aliases pointing at the same file
        // resolve to the same definitions.
        if (e.obj.node = "Identifier" && name_in(mod_names, e.obj.name)) {
            return {node: "Identifier", name: "__mod_" + canonical_of(e.obj.name) + "__" + e.field};
        }
        e.obj <- main_rewrite_value(e.obj, mod_names);
        return e;
    }
    if (e.node = "BinOp") {
        e.left <- main_rewrite_value(e.left, mod_names);
        e.right <- main_rewrite_value(e.right, mod_names);
        return e;
    }
    if (e.node = "UnaryOp") {
        e.operand <- main_rewrite_value(e.operand, mod_names);
        return e;
    }
    if (e.node = "CallExpr") {
        e.callee <- main_rewrite_value(e.callee, mod_names);
        var j <- 0;
        while (j < len(e.args)) {
            e.args[j] <- main_rewrite_value(e.args[j], mod_names);
            j <- j + 1;
        }
        return e;
    }
    if (e.node = "IndexExpr") {
        e.obj <- main_rewrite_value(e.obj, mod_names);
        e.index <- main_rewrite_value(e.index, mod_names);
        return e;
    }
    if (e.node = "ArrayLit") {
        var j <- 0;
        while (j < len(e.elements)) {
            e.elements[j] <- main_rewrite_value(e.elements[j], mod_names);
            j <- j + 1;
        }
        return e;
    }
    if (e.node = "StructLit") {
        var j <- 0;
        while (j < len(e.fields)) {
            e.fields[j].val <- main_rewrite_value(e.fields[j].val, mod_names);
            j <- j + 1;
        }
        return e;
    }
    if (e.node = "ArrowFn") {
        if (e.is_expr) {
            e.body <- main_rewrite_value(e.body, mod_names);
        } else {
            main_rewrite_stmts(e.body, mod_names);
        }
        return e;
    }
    return e;
}

// ═══════════════════════════════════════════
//  LLVM IR EMITTER
//  Strategy: everything is i64. Strings are
//  i8* cast to i64. Simple and uniform.
//
//  Type tracking: emit_expr returns {reg, type}
//  where type is "int" or "str".
// ═══════════════════════════════════════════

// Output buffer: array of lines
var ir_lines <- [""];  // init with "" so global type tracking knows it holds strings
var deferred_ir <- [""];  // buffer for arrow function definitions
var emit_target <- [0];  // 0 = ir_lines, 1 = deferred_ir

// Platform detection. is_win = 1 on Windows; is_mac = 1 on macOS; both 0 on Linux.
// is_mac matters because macOS doesn't expose `stdin` as a real symbol — the
// underlying name is __stdinp.
var is_win <- [1]; // default Windows, overridden at startup
var is_mac <- [0];

fn emit(s: str) {
    if (emit_target[0] = 0) {
        push(ir_lines, s);
    } else {
        push(deferred_ir, s);
    }
}

fn write_ir_lines(path: str) {
    // Write IR directly to file in chunks without building one huge string
    // First write truncates (wb), subsequent writes append (ab)
    var chunk <- "";
    var count <- 0;
    var first <- 1;
    var i <- 0;
    while (i < len(ir_lines)) {
        if (str_len(ir_lines[i]) > 0) {
            chunk <- chunk + ir_lines[i] + from_char_code(10);
            count <- count + 1;
        }
        if (count >= 200) {
            if (first = 1) {
                write_file(path, chunk);
                first <- 0;
            } else {
                append_file(path, chunk);
            }
            chunk <- "";
            count <- 0;
        }
        i <- i + 1;
    }
    if (str_len(chunk) > 0) {
        if (first = 1) {
            write_file(path, chunk);
        } else {
            append_file(path, chunk);
        }
    }
}

// Counter for unique names
var tmp_counter <- [0];
fn fresh(prefix: str): str {
    tmp_counter[0] <- tmp_counter[0] + 1;
    return prefix + tmp_counter[0];
}

// Label counter
var lbl_counter <- [0];
fn fresh_lbl(prefix: str): str {
    lbl_counter[0] <- lbl_counter[0] + 1;
    return prefix + lbl_counter[0];
}

// Track which variables have been allocated in current function
var fn_vars <- []; // {name, depth} entries for locals allocated in the current function
var current_fn <- [""]; // name of function being compiled

// Arrow function counter
var arrow_fn_counter <- [0];

// Map variable names to arrow function names for return type lookup
var arrow_fn_map <- []; // [{var_name, fn_name}]

fn set_arrow_fn_var(var_name: str, fn_name: str) {
    push(arrow_fn_map, {var_name: var_name, fn_name: fn_name});
}

fn get_arrow_fn_name(var_name: str): str {
    var i <- len(arrow_fn_map) - 1;
    while (i >= 0) {
        if (arrow_fn_map[i].var_name = var_name) { return arrow_fn_map[i].fn_name; }
        i <- i - 1;
    }
    return "";
}

// String constants
var str_constants <- []; // [{id, text}]
var str_counter <- [0];

fn add_string(text: str): str {
    str_counter[0] <- str_counter[0] + 1;
    var id <- "str" + str_counter[0];
    push(str_constants, {id: id, text: text});
    return id;
}

// Track allocated variables per function — boxed in array
var alloc_vars <- [[]]; // alloc_vars[0] is the current var list [{name, reg}]

// Track variable types: var_name -> "int" or "str"
var var_types <- [[]]; // var_types[0] is list of [{name, vtype}]

// Track each variable's DECLARED type (fixed-type rule, 3b). Unlike
// var_types this is NOT refined by later reassignments: it is the fixed
// type a bare reassignment must fit. any/union declared types accept all.
var decl_types <- [[]]; // decl_types[0] is list of [{name, dtype}]

// Shadowing rule registry: one {name, dtype} per name per function,
// recording the FIRST declaration's type (annotation, else the inferred
// RHS type at the declaration point). The typing maps are function-flat,
// so a same-name re-declaration whose type differs cannot be compiled
// faithfully — the checker rejects it instead (see shadow_declare).
var shadow_decls <- [[]];

// Track global variables (top-level)
var global_vars <- []; // list of variable name strings

fn is_global(name: str): int {
    var i <- 0;
    while (i < len(global_vars)) {
        if (global_vars[i] = name) { return true; }
        i <- i + 1;
    }
    return false;
}

fn find_var(name: str): str {
    var vars <- alloc_vars[0];
    var i <- len(vars) - 1;
    while (i >= 0) {
        if (vars[i].name = name) { return vars[i].reg; }
        i <- i - 1;
    }
    // Fall back to global
    if (is_global(name)) { return "@g_" + name; }
    return "";
}

fn add_var(name: str): str {
    var reg <- "%" + name;
    if (find_var(name) != "") { return find_var(name); }
    push(alloc_vars[0], {name: name, reg: reg});
    return reg;
}

fn set_var_type(name: str, vtype) {
    var types <- var_types[0];
    var i <- 0;
    while (i < len(types)) {
        if (types[i].name = name) {
            types[i] <- {name: name, vtype: vtype};
            return false;
        }
        i <- i + 1;
    }
    push(var_types[0], {name: name, vtype: vtype});
    return false;
}

fn get_var_type(name: str): any {
    var types <- var_types[0];
    var i <- len(types) - 1;
    while (i >= 0) {
        if (types[i].name = name) { return types[i].vtype; }
        i <- i - 1;
    }
    return T.mk_any();
}

fn set_decl_type(name: str, t) {
    var types <- decl_types[0];
    var i <- 0;
    while (i < len(types)) {
        if (types[i].name = name) {
            types[i] <- {name: name, dtype: t};
            return false;
        }
        i <- i + 1;
    }
    push(decl_types[0], {name: name, dtype: t});
    return false;
}

fn get_decl_type(name: str): any {
    var types <- decl_types[0];
    var i <- len(types) - 1;
    while (i >= 0) {
        if (types[i].name = name) { return types[i].dtype; }
        i <- i - 1;
    }
    return T.mk_none();
}

// Equality for the shadowing rule. int and bool share the i64
// representation and every raw-tier operation, so shadowing across them
// cannot misfire the emitters; everything else must match structurally.
fn shadow_eq(a, b): int {
    if (T.type_eq(a, b)) { return true; }
    if (a.kind = "int" && b.kind = "bool") { return true; }
    if (a.kind = "bool" && b.kind = "int") { return true; }
    return false;
}

// Record / verify a declaration for the shadowing rule. First declaration
// of a name records its type. A re-declaration whose type differs from
// the recorded one is a checker error: the flat per-function typing maps
// give every same-name declaration one shared slot, so the emitters would
// type the earlier blocks by the later declaration (or vice versa).
// `none` is a wildcard on either side — the raw tier is not type checked
// — and a none record is refined in place by a later concrete decl.
fn shadow_declare(name: str, t, line: int, col: int) {
    var lst <- shadow_decls[0];
    var i <- 0;
    while (i < len(lst)) {
        if (lst[i].name = name) {
            var prev <- lst[i].dtype;
            if (prev.kind != "none" && t.kind != "none" && !shadow_eq(prev, t)) {
                report_error(line, col, "re-declaration of '" + name + "' changes its type from " + T.type_str(prev) + " to " + T.type_str(t) + "; shadowing may not change a variable's type (rename the variable)");
            }
            if (prev.kind = "none" && t.kind != "none") {
                lst[i] <- {name: name, dtype: t};
            }
            return false;
        }
        i <- i + 1;
    }
    push(shadow_decls[0], {name: name, dtype: t});
    return false;
}

// Track struct field layouts: var_name -> [{fname, ftype}]
var struct_layouts <- [[]]; // struct_layouts[0] is list of [{var_name, fields}]

fn set_struct_layout(var_name: str, fields) {
    var layouts <- struct_layouts[0];
    var i <- 0;
    while (i < len(layouts)) {
        if (layouts[i].var_name = var_name) {
            layouts[i] <- {var_name: var_name, fields: fields};
            return false;
        }
        i <- i + 1;
    }
    push(struct_layouts[0], {var_name: var_name, fields: fields});
    return false;
}

fn get_struct_layout(var_name: str) {
    var layouts <- struct_layouts[0];
    var i <- len(layouts) - 1;
    while (i >= 0) {
        if (layouts[i].var_name = var_name) { return layouts[i].fields; }
        i <- i - 1;
    }
    return false;
}

fn get_field_type(fields, fname: str) {
    var i <- 0;
    while (i < len(fields)) {
        if (fields[i].fname = fname) {
            var ft <- fields[i].ftype;
            if (ft = "int") { return T.mk_int(); }
            if (ft = "str") { return T.mk_str(); }
            if (ft = "struct") { return T.mk_struct(); }
            if (ft = "fn") { return T.mk_fn(); }
            // Unrecognized recorded kind: raw tier.
            return T.mk_none();
        }
        i <- i + 1;
    }
    // Miss: raw tier.
    return T.mk_none();
}

// Track array element types: var_name -> elem_type ("int" or "str")
var array_elem_types <- [[]]; // array_elem_types[0] is list of [{var_name, elem_type}]
var global_array_types <- []; // persistent list for globals [{var_name, elem_type}]

fn set_array_elem_type(var_name: str, etype: str) {
    var types <- array_elem_types[0];
    var i <- 0;
    while (i < len(types)) {
        if (types[i].var_name = var_name) {
            if (etype = "str") {
                types[i] <- {var_name: var_name, elem_type: etype};
            }
            return false;
        }
        i <- i + 1;
    }
    push(array_elem_types[0], {var_name: var_name, elem_type: etype});
    return false;
}

fn set_global_array_type(var_name: str, etype: str) {
    var i <- 0;
    while (i < len(global_array_types)) {
        if (global_array_types[i].var_name = var_name) {
            if (etype = "str") {
                global_array_types[i] <- {var_name: var_name, elem_type: etype};
            }
            return false;
        }
        i <- i + 1;
    }
    push(global_array_types, {var_name: var_name, elem_type: etype});
    return false;
}

fn get_array_elem_type(var_name: str) {
    // Check local scope first
    var types <- array_elem_types[0];
    var i <- len(types) - 1;
    while (i >= 0) {
        if (types[i].var_name = var_name) {
            if (types[i].elem_type = "str") { return T.mk_str(); }
            return T.mk_int();
        }
        i <- i - 1;
    }
    // Fall back to global array types
    i <- 0;
    while (i < len(global_array_types)) {
        if (global_array_types[i].var_name = var_name) {
            if (global_array_types[i].elem_type = "str") { return T.mk_str(); }
            return T.mk_int();
        }
        i <- i + 1;
    }
    // Miss: raw tier.
    return T.mk_none();
}

// Function declarations we need to track
var declared_fns <- []; // [{name, param_count, ret_type, ret_fields, param_types}]

// Side-table: functions whose body always returns one specific parameter
// unchanged (like `fn sort(arr) { ...mutations... return arr; }`). For these,
// the static return type can be specialized at each call site to the type of
// the corresponding argument — `sort([int])` returns `[int]`, `sort([str])`
// returns `[str]`, even though the function's param/return annotation is
// missing. Set by scan_fn_param_returns during compile_via_ir's pre-pass.
var fn_returns_param <- [];

fn set_fn_returns_param(name: str, idx: int) {
    var i <- 0;
    while (i < len(fn_returns_param)) {
        if (fn_returns_param[i].name = name) {
            fn_returns_param[i] <- {name: name, idx: idx};
            return false;
        }
        i <- i + 1;
    }
    push(fn_returns_param, {name: name, idx: idx});
    return false;
}

fn get_fn_returns_param(name: str): int {
    var i <- 0;
    while (i < len(fn_returns_param)) {
        if (fn_returns_param[i].name = name) { return fn_returns_param[i].idx; }
        i <- i + 1;
    }
    return -1;
}

fn find_fn(name: str) {
    var i <- 0;
    while (i < len(declared_fns)) {
        if (declared_fns[i].name = name) { return declared_fns[i]; }
        i <- i + 1;
    }
    return false;
}

fn set_fn_ret_type(name: str, rtype, rfields) {
    var i <- 0;
    while (i < len(declared_fns)) {
        if (declared_fns[i].name = name) {
            // Don't override explicit user annotations — let the checker complain instead
            if (declared_fns[i].ret_type_ann.kind != "none") {
                return false;
            }
            declared_fns[i] <- {name: name, param_count: declared_fns[i].param_count, ret_type: rtype, ret_fields: rfields, param_types: declared_fns[i].param_types, param_types_ann: declared_fns[i].param_types_ann, ret_type_ann: declared_fns[i].ret_type_ann, is_arrow_var: declared_fns[i].is_arrow_var};
            return false;
        }
        i <- i + 1;
    }
    return false;
}

// Set a parameter type for a function (from call-site analysis)
fn set_fn_param_type(fn_name: str, param_idx: int, ptype) {
    var fi <- find_fn(fn_name);
    if (fi = false) { return false; }
    if (param_idx < len(fi.param_types)) {
        // Don't override explicit user annotations — let the checker complain instead
        if (param_idx < len(fi.param_types_ann)) {
            if (fi.param_types_ann[param_idx].kind != "none") {
                return false;
            }
        }
        // Upgrade from "any" or "int" to a more specific type, never downgrade from "str"
        if (fi.param_types[param_idx].kind != "str") {
            fi.param_types[param_idx] <- ptype;
        }
    }
    return false;
}

// Scan all statements for call sites to infer parameter types
fn scan_call_sites(stmts) {    var work <- [];
    var i <- 0;
    while (i < len(stmts)) {
        push(work, stmts[i]);
        i <- i + 1;
    }
    var wi <- 0;
    while (wi < len(work)) {
        var nd <- work[wi];
        wi <- wi + 1;
        work <- scs_handle(nd, work);
    }
}

fn scs_handle(nd, work) {
    work <- scs_stmt(nd, work);
    work <- scs_expr(nd, work);
    return work;
}

fn scs_stmt(nd, work) {
    if (nd.node = "Assignment") { push(work, nd.expr); }
    if (nd.node = "PrintStmt") { push(work, nd.expr); }
    if (nd.node = "ReturnStmt") { if (nd.expr != false) { push(work, nd.expr); } }
    if (nd.node = "IfStmt") {
        push(work, nd.cond);
        var i <- 0;
        while (i < len(nd.then_body)) { push(work, nd.then_body[i]); i <- i + 1; }
        i <- 0;
        while (i < len(nd.else_body)) { push(work, nd.else_body[i]); i <- i + 1; }
    }
    if (nd.node = "MatchStmt") {
        push(work, nd.scrutinee);
        var mi <- 0;
        while (mi < len(nd.arms)) { var mj <- 0; while (mj < len(nd.arms[mi].body)) { push(work, nd.arms[mi].body[mj]); mj <- mj + 1; } mi <- mi + 1; }
    }
    if (nd.node = "WhileStmt") {
        push(work, nd.cond);
        var i <- 0;
        while (i < len(nd.body)) { push(work, nd.body[i]); i <- i + 1; }
    }
    if (nd.node = "ForInStmt") {
        push(work, nd.iterable);
        var i <- 0;
        while (i < len(nd.body)) { push(work, nd.body[i]); i <- i + 1; }
    }
    if (nd.node = "IndexAssign") {
        push(work, nd.obj);
        push(work, nd.index);
        push(work, nd.value);
    }
    if (nd.node = "DotAssign") {
        push(work, nd.obj);
        push(work, nd.value);
    }
    if (nd.node = "Block") {
        var i <- 0;
        while (i < len(nd.stmts)) { push(work, nd.stmts[i]); i <- i + 1; }
    }
    if (nd.node = "FnDecl") {
        var i <- 0;
        while (i < len(nd.body)) { push(work, nd.body[i]); i <- i + 1; }
    }
    return work;
}

fn scs_expr(nd, work) {
    if (nd.node = "MatchExpr") {
        push(work, nd.scrutinee);
        var mxi <- 0;
        while (mxi < len(nd.arms)) { push(work, nd.arms[mxi].value); mxi <- mxi + 1; }
    }
    if (nd.node = "CallExpr") {
        if (nd.callee.node = "Identifier") {
            var fi <- find_fn(nd.callee.name);
            if (fi != false) {
                var j <- 0;
                while (j < len(nd.args)) {
                    if (j < fi.param_count) {
                        if (is_str_expr(nd.args[j])) {
                            set_fn_param_type(fi.name, j, T.mk_str());
                        }
                    }
                    j <- j + 1;
                }
            }
        }
        var j <- 0;
        while (j < len(nd.args)) { push(work, nd.args[j]); j <- j + 1; }
    }
    if (nd.node = "BinOp") { push(work, nd.left); push(work, nd.right); }
    if (nd.node = "UnaryOp") { push(work, nd.operand); }
    if (nd.node = "ArrayLit") {
        var j <- 0;
        while (j < len(nd.elements)) { push(work, nd.elements[j]); j <- j + 1; }
    }
    if (nd.node = "IndexExpr") { push(work, nd.obj); push(work, nd.index); }
    if (nd.node = "DotExpr") { push(work, nd.obj); }
    if (nd.node = "StructLit") {
        var j <- 0;
        while (j < len(nd.fields)) { push(work, nd.fields[j].val); j <- j + 1; }
    }
    if (nd.node = "ArrowFn") {
        // Scan arrow function body for call sites
        if (nd.is_expr = false) {
            var j <- 0;
            while (j < len(nd.body)) { push(work, nd.body[j]); j <- j + 1; }
        } else {
            push(work, nd.body);
        }
    }
    return work;
}

// ═══════════════════════════════════════════
//  TYPE REPRESENTATION (universe 1)
//  A Type is a struct {kind: str, ...}.
//  Kinds:
//    "int", "str", "any", "struct", "fn"     — primitive
//    "array" with field `elem: Type`           — [T]
//    "struct_lit" with field `fields: [...]`   — {name: T, ...}
//    "none"                                    — sentinel: no annotation
//  Stored in var_types and declared_fns; returned by typeof_expr.
//  Distinct from the .type string field on typed values (universe 2)
//  used by the IR emitter for codegen decisions.
// ═══════════════════════════════════════════

// Type system primitives, structural helpers, and pure type-level
// queries live in compiler/types.arrow (imported as T below).

// ── Typed result helpers (universe 2) ────
fn tv(reg: str, vtype: str) { return {reg: reg, type: vtype, fields: false}; }
fn tv_int(reg: str) { return {reg: reg, type: "int", fields: false}; }
fn tv_str(reg: str) { return {reg: reg, type: "str", fields: false}; }

// Convert a typed value to i64 (for storing, passing as arg, etc.)
// Strings are already i8*-as-i64 via ptrtoint, so no conversion needed.
// This just returns the reg — all values are i64 in our IR.
fn to_i64(t): str { return t.reg; }

// Convert an i64 value to a string (for string concat with non-strings)
// Calls our own arrow_itoa helper (no sprintf dependency)
fn int_to_str(reg: str): str {
    var r <- fresh("%i2s");
    var rp <- fresh("%i2sp");
    emit("  " + r + " = call ptr @arrow_itoa(i64 " + reg + ")");
    emit("  " + rp + " = ptrtoint ptr " + r + " to i64");
    return rp;
}

// Ensure a typed value is a string (i8* as i64)
// If it's already a string, return as-is; if int, convert via itoa
fn ensure_str(t): str {
    if (t.type = "str") { return t.reg; }
    return int_to_str(t.reg);
}

// Like ensure_str, but when we know the context is string-heavy,
// treat "int" as a string pointer (don't itoa it)
fn as_str_ptr(t): str {
    return t.reg; // i64 is already the right value — just use it as-is
}

// ── Pre-scan: collect all fn declarations ──
fn scan_fns(stmts) {
    var i <- 0;
    while (i < len(stmts)) {
        if (stmts[i].node = "FnDecl") {
            // param_types_ann from AST is already a list of Type values (T.mk_none() if absent)
            // param_types is the working type used for inference (starts at any, widens via call sites)
            var pt <- [];
            var j <- 0;
            while (j < len(stmts[i].params)) {
                var ann <- T.mk_none();
                if (j < len(stmts[i].param_types_ann)) {
                    ann <- stmts[i].param_types_ann[j];
                }
                if (ann.kind != "none") {
                    push(pt, ann);
                } else {
                    push(pt, T.mk_any());
                }
                j <- j + 1;
            }
            // Use return type annotation if present (a Type value)
            var rt <- T.mk_any();
            if (stmts[i].ret_type_ann.kind != "none") {
                rt <- stmts[i].ret_type_ann;
            }
            push(declared_fns, {name: stmts[i].name, param_count: len(stmts[i].params), ret_type: rt, ret_fields: false, param_types: pt, param_types_ann: stmts[i].param_types_ann, ret_type_ann: stmts[i].ret_type_ann, is_arrow_var: false});
            var pj <- 0;
            while (pj < len(stmts[i].param_types_ann)) {
                var pct <- stmts[i].param_types_ann[pj];
                pj <- pj + 1;
            }
        }
        // Also register top-level arrow-fn assignments under the variable name.
        // This lets the type checker resolve `myVar(args)` calls where myVar holds
        // an ArrowFn. Uses the variable name directly (not the mangled "__arrow_N"
        // name chosen later at emit time) because the checker runs before emit.
        if (stmts[i].node = "Assignment") {
            if (stmts[i].expr.node = "ArrowFn") {
                var afn <- stmts[i].expr;
                var apt <- [];
                var apt_ann <- [];
                var k <- 0;
                while (k < len(afn.params)) {
                    var ann <- T.mk_none();
                    if (k < len(afn.param_types_ann)) {
                        ann <- afn.param_types_ann[k];
                    }
                    push(apt_ann, ann);
                    if (ann.kind != "none") {
                        push(apt, ann);
                    } else {
                        push(apt, T.mk_any());
                    }
                    k <- k + 1;
                }
                var art <- T.mk_any();
                if (afn.ret_type_ann.kind != "none") { art <- afn.ret_type_ann; }
                push(declared_fns, {name: stmts[i].name, param_count: len(afn.params), ret_type: art, ret_fields: false, param_types: apt, param_types_ann: apt_ann, ret_type_ann: afn.ret_type_ann, is_arrow_var: true});
            }
        }
        i <- i + 1;
    }
}

// Walk a function body and collect every ReturnStmt. Uses a flat work list
// so it descends into if/while/for-in/block bodies uniformly.
fn collect_returns(body, acc) {
    var work <- [];
    var i <- 0;
    while (i < len(body)) { push(work, body[i]); i <- i + 1; }
    var wi <- 0;
    while (wi < len(work)) {
        var nd <- work[wi];
        wi <- wi + 1;
        if (nd.node = "ReturnStmt") { push(acc, nd); }
        if (nd.node = "IfStmt") {
            var j <- 0;
            while (j < len(nd.then_body)) { push(work, nd.then_body[j]); j <- j + 1; }
            j <- 0;
            while (j < len(nd.else_body)) { push(work, nd.else_body[j]); j <- j + 1; }
        }
        if (nd.node = "MatchStmt") {
            var mi <- 0;
            while (mi < len(nd.arms)) { var mj <- 0; while (mj < len(nd.arms[mi].body)) { push(work, nd.arms[mi].body[mj]); mj <- mj + 1; } mi <- mi + 1; }
        }
        if (nd.node = "WhileStmt") {
            var j <- 0;
            while (j < len(nd.body)) { push(work, nd.body[j]); j <- j + 1; }
        }
        if (nd.node = "ForInStmt") {
            var j <- 0;
            while (j < len(nd.body)) { push(work, nd.body[j]); j <- j + 1; }
        }
        if (nd.node = "Block") {
            var j <- 0;
            while (j < len(nd.stmts)) { push(work, nd.stmts[j]); j <- j + 1; }
        }
    }
    return acc;
}

// For each FnDecl, detect the "return-passthrough" pattern: every return in
// the body returns the SAME parameter identifier (e.g. `return arr;` where
// `arr` is a param). If so, record the param index in fn_returns_param so
// call sites can specialize the return type to the caller's argument type.
//
// The detection is intentionally conservative: every ReturnStmt must match,
// and there must be at least one. A function with both `return arr` and
// `return []` won't qualify; nor will a function with no returns at all.
fn scan_fn_param_returns(stmts) {
    var i <- 0;
    while (i < len(stmts)) {
        if (stmts[i].node = "FnDecl") {
            var params <- stmts[i].params;
            var rets <- [];
            collect_returns(stmts[i].body, rets);
            if (len(rets) > 0) {
                var first_idx <- -1;
                var all_match <- true;
                var j <- 0;
                while (j < len(rets)) {
                    var r <- rets[j];
                    if (r.expr = false) { all_match <- false; }
                    else if (r.expr.node != "Identifier") { all_match <- false; }
                    else {
                        var k <- 0;
                        var idx <- -1;
                        while (k < len(params)) {
                            if (params[k] = r.expr.name) { idx <- k; }
                            k <- k + 1;
                        }
                        if (idx = -1) { all_match <- false; }
                        else if (first_idx = -1) { first_idx <- idx; }
                        else if (first_idx != idx) { all_match <- false; }
                    }
                    j <- j + 1;
                }
                if (all_match && first_idx != -1) {
                    set_fn_returns_param(stmts[i].name, first_idx);
                }
            }
        }
        i <- i + 1;
    }
}

// ── Pre-scan: collect top-level variable names as globals ──
fn scan_globals(nd) {
    if (nd.node = "Assignment") {
        if (!var_exists(global_vars, nd.name)) {
            push(global_vars, nd.name);
        }
        // Detect string arrays: x <- ["..."]
        if (nd.expr.node = "ArrayLit") {
            var i <- 0;
            while (i < len(nd.expr.elements)) {
                if (is_str_expr(nd.expr.elements[i])) {
                    set_global_array_type(nd.name, "str");
                }
                i <- i + 1;
            }
        }
    }
    else if (nd.node = "IfStmt") {
        scan_globals_list(nd.then_body);
        scan_globals_list(nd.else_body);
    }
    else if (nd.node = "MatchStmt") {
        var mi <- 0;
        while (mi < len(nd.arms)) { scan_globals_list(nd.arms[mi].body); mi <- mi + 1; }
    }
    else if (nd.node = "WhileStmt") {
        scan_globals_list(nd.body);
    }
    else if (nd.node = "ForInStmt") {
        if (!var_exists(global_vars, nd.var_name)) {
            push(global_vars, nd.var_name);
        }
        scan_globals_list(nd.body);
    }
    else if (nd.node = "Block") {
        scan_globals_list(nd.stmts);
    }
}

fn scan_globals_list(stmts) {
    var i <- 0;
    while (i < len(stmts)) {
        scan_globals(stmts[i]);
        i <- i + 1;
    }
}

fn var_exists(vars, name: str): int {
    var i <- 0;
    while (i < len(vars)) {
        if (vars[i] = name) { return true; }
        i <- i + 1;
    }
    return false;
}

// ── Collect all variables used in a function body ──
// Split into small handler functions to avoid large-function crashes
fn collect_vars(stmts, vars) {
    var work <- [];
    var i <- 0;
    while (i < len(stmts)) {
        push(work, stmts[i]);
        i <- i + 1;
    }
    var wi <- 0;
    while (wi < len(work)) {
        var nd <- work[wi];
        wi <- wi + 1;
        cv_handle(nd, work, vars);
    }
}

fn cv_handle(nd, work, vars) {
    cv_stmt(nd, work, vars);
    cv_expr(nd, work, vars);
}

fn cv_stmt(nd, work, vars) {
    if (nd.node = "Assignment") {
        // Only declarations (`var x <- ...`) introduce a local slot. Bare
        // reassignments to a global should NOT be pre-allocated as locals
        // here — that would shadow the global and break the function-writes-to-global path (a function
        // writing through a bare `<-` is supposed to mutate the global,
        // not silently create a local with the same name).
        if (nd.is_decl) {
            if (!var_exists(vars, nd.name)) { push(vars, nd.name); }
        }
        push(work, nd.expr);
    }
    if (nd.node = "PrintStmt") { push(work, nd.expr); }
    if (nd.node = "ReturnStmt") {
        if (nd.expr != false) { push(work, nd.expr); }
    }
    if (nd.node = "IfStmt") {
        push(work, nd.cond);
        var i <- 0;
        while (i < len(nd.then_body)) { push(work, nd.then_body[i]); i <- i + 1; }
        i <- 0;
        while (i < len(nd.else_body)) { push(work, nd.else_body[i]); i <- i + 1; }
    }
    if (nd.node = "MatchStmt") {
        push(work, nd.scrutinee);
        var mi <- 0;
        while (mi < len(nd.arms)) { var mj <- 0; while (mj < len(nd.arms[mi].body)) { push(work, nd.arms[mi].body[mj]); mj <- mj + 1; } mi <- mi + 1; }
    }
    if (nd.node = "WhileStmt") {
        push(work, nd.cond);
        var i <- 0;
        while (i < len(nd.body)) { push(work, nd.body[i]); i <- i + 1; }
    }
    if (nd.node = "ForInStmt") {
        if (!var_exists(vars, nd.var_name)) { push(vars, nd.var_name); }
        push(work, nd.iterable);
        var i <- 0;
        while (i < len(nd.body)) { push(work, nd.body[i]); i <- i + 1; }
    }
    if (nd.node = "Block") {
        var i <- 0;
        while (i < len(nd.stmts)) { push(work, nd.stmts[i]); i <- i + 1; }
    }
    if (nd.node = "IndexAssign") {
        push(work, nd.obj);
        push(work, nd.index);
        push(work, nd.value);
    }
    if (nd.node = "DotAssign") {
        push(work, nd.obj);
        push(work, nd.value);
    }
}

fn cv_expr(nd, work, vars) {
    if (nd.node = "MatchExpr") {
        push(work, nd.scrutinee);
        var mxi <- 0;
        while (mxi < len(nd.arms)) { push(work, nd.arms[mxi].value); mxi <- mxi + 1; }
    }
    if (nd.node = "BinOp") { push(work, nd.left); push(work, nd.right); }
    if (nd.node = "UnaryOp") { push(work, nd.operand); }
    if (nd.node = "CallExpr") {
        push(work, nd.callee);
        var i <- 0;
        while (i < len(nd.args)) { push(work, nd.args[i]); i <- i + 1; }
    }
    if (nd.node = "ArrayLit") {
        var i <- 0;
        while (i < len(nd.elements)) { push(work, nd.elements[i]); i <- i + 1; }
    }
    if (nd.node = "IndexExpr") { push(work, nd.obj); push(work, nd.index); }
    if (nd.node = "DotExpr") { push(work, nd.obj); }
    if (nd.node = "StructLit") {
        var i <- 0;
        while (i < len(nd.fields)) { push(work, nd.fields[i].val); i <- i + 1; }
    }
}

// ── Emit LLVM IR for expression ─────────
// Returns {reg, type} where type is "int" or "str"

// Check if an AST expression node is known to be a string
fn is_str_expr(nd): int {
    if (nd.node = "StringLit") { return true; }
    // Note: DotExpr used to return true here as a blanket heuristic ("struct fields
    // are usually strings in Arrow") but that's a lie for the majority of fields
    // (body, args, params, etc. are arrays). The lie was latent because len() and
    // other code paths defaulted to array ops regardless of the tag. Removing the
    // heuristic means some DotExpr-returning-str cases (field lookups that really
    // do return strings) fall through to T.mk_any() — which is fine for correctness,
    // just slightly less precise.
    if (nd.node = "BinOp") {
        if (nd.op = "+") {
            return is_str_expr(nd.left) || is_str_expr(nd.right);
        }
    }
    if (nd.node = "CallExpr") {
        if (nd.callee.node = "Identifier") {
            var nm <- nd.callee.name;
            if (nm = "char_at") { return true; }
            if (nm = "from_char_code") { return true; }
            if (nm = "substring") { return true; }
            if (nm = "input") { return true; }
            if (nm = "read_file") { return true; }
        }
    }
    return false;
}

// ── String concatenation ────────────────
// ── String comparison ───────────────────
// ── Emit statement ──────────────────────

// ── Struct support ──────────────────────

// Struct layout: [count, val0, val1, ..., name_ptr0, name_ptr1, ...]
// Total slots = 1 + 2*N.  All i64.

// Emit the struct_find helper function
// arrow_struct_find(ptr %sptr, ptr %name) -> i64 index. A missing field
// traps (message + exit 1) instead of returning -1: the two callers
// (struct_get / struct_set) would otherwise index with -1 and silently
// read or write the wrong slot. The interpreter raises the same message.
fn emit_struct_find_helper() {
    emit("@.rt.field = private constant [33 x i8] c\"Error: Struct has no field '%s'\\0A\\00\"");
    emit("define i64 @arrow_struct_find(ptr %sptr, ptr %name) {");
    emit("entry:");
    emit("  %count = load i64, ptr %sptr");
    emit("  %idx = alloca i64");
    emit("  store i64 0, ptr %idx");
    emit("  br label %cond");
    emit("cond:");
    emit("  %i = load i64, ptr %idx");
    emit("  %done = icmp slt i64 %i, %count");
    emit("  br i1 %done, label %body, label %notfound");
    emit("body:");
    emit("  %i2 = load i64, ptr %idx");
    // name slot = 1 + count + i
    emit("  %ns1 = add i64 1, %count");
    emit("  %ns2 = add i64 %ns1, %i2");
    emit("  %nsp = getelementptr i64, ptr %sptr, i64 %ns2");
    emit("  %ni = load i64, ptr %nsp");
    emit("  %np = inttoptr i64 %ni to ptr");
    emit("  %cmp = call i32 @strcmp(ptr %np, ptr %name)");
    emit("  %eq = icmp eq i32 %cmp, 0");
    emit("  br i1 %eq, label %found, label %next");
    emit("found:");
    emit("  %fi = load i64, ptr %idx");
    emit("  ret i64 %fi");
    emit("next:");
    emit("  %i3 = load i64, ptr %idx");
    emit("  %i4 = add i64 %i3, 1");
    emit("  store i64 %i4, ptr %idx");
    emit("  br label %cond");
    emit("notfound:");
    emit("  call i32 (ptr, ...) @printf(ptr @.rt.field, ptr %name)");
    emit("  call void @exit(i32 1)");
    emit("  unreachable");
    emit("}");
    emit("");
}

// Emit integer-to-string helper (no sprintf dependency)
// arrow_itoa(i64 %val) -> ptr
fn emit_itoa_helper() {
    emit("define ptr @arrow_itoa(i64 %val) {");
    emit("entry:");
    emit("  %buf = call ptr @arena_alloc(i64 24)");
    emit("  %tmp = call ptr @arena_alloc(i64 24)");
    emit("  %pos = alloca i64");
    emit("  %cur = alloca i64");
    emit("  %wp = alloca i64");
    emit("  store i64 0, ptr %wp");
    // Handle zero
    emit("  %is_zero = icmp eq i64 %val, 0");
    emit("  br i1 %is_zero, label %zero, label %check_neg");
    emit("zero:");
    emit("  store i8 48, ptr %buf");
    emit("  %zp = getelementptr i8, ptr %buf, i64 1");
    emit("  store i8 0, ptr %zp");
    emit("  ret ptr %buf");
    // Handle negative
    emit("check_neg:");
    emit("  %is_neg = icmp slt i64 %val, 0");
    emit("  br i1 %is_neg, label %neg, label %start");
    emit("neg:");
    emit("  store i8 45, ptr %buf");
    emit("  store i64 1, ptr %wp");
    emit("  %abs = sub i64 0, %val");
    emit("  store i64 %abs, ptr %cur");
    emit("  store i64 0, ptr %pos");
    emit("  br label %dloop");
    emit("start:");
    emit("  store i64 %val, ptr %cur");
    emit("  store i64 0, ptr %pos");
    emit("  br label %dloop");
    // Extract digits into tmp (reversed)
    emit("dloop:");
    emit("  %c = load i64, ptr %cur");
    emit("  %d = srem i64 %c, 10");
    emit("  %ch = add i64 %d, 48");
    emit("  %ch8 = trunc i64 %ch to i8");
    emit("  %p = load i64, ptr %pos");
    emit("  %tp = getelementptr i8, ptr %tmp, i64 %p");
    emit("  store i8 %ch8, ptr %tp");
    emit("  %p1 = add i64 %p, 1");
    emit("  store i64 %p1, ptr %pos");
    emit("  %nc = sdiv i64 %c, 10");
    emit("  store i64 %nc, ptr %cur");
    emit("  %more = icmp sgt i64 %nc, 0");
    emit("  br i1 %more, label %dloop, label %rev");
    // Reverse copy from tmp into buf (after optional '-')
    emit("rev:");
    emit("  %len = load i64, ptr %pos");
    emit("  %ri = alloca i64");
    emit("  store i64 0, ptr %ri");
    emit("  br label %rcond");
    emit("rcond:");
    emit("  %r = load i64, ptr %ri");
    emit("  %rdone = icmp slt i64 %r, %len");
    emit("  br i1 %rdone, label %rbody, label %rend");
    emit("rbody:");
    emit("  %r2 = load i64, ptr %ri");
    emit("  %src_idx = sub i64 %len, %r2");
    emit("  %src_idx2 = sub i64 %src_idx, 1");
    emit("  %sp = getelementptr i8, ptr %tmp, i64 %src_idx2");
    emit("  %sc = load i8, ptr %sp");
    emit("  %w = load i64, ptr %wp");
    emit("  %dst_idx = add i64 %w, %r2");
    emit("  %dp = getelementptr i8, ptr %buf, i64 %dst_idx");
    emit("  store i8 %sc, ptr %dp");
    emit("  %r3 = add i64 %r2, 1");
    emit("  store i64 %r3, ptr %ri");
    emit("  br label %rcond");
    emit("rend:");
    // Null terminate
    emit("  %w2 = load i64, ptr %wp");
    emit("  %total = add i64 %w2, %len");
    emit("  %ep = getelementptr i8, ptr %buf, i64 %total");
    emit("  store i8 0, ptr %ep");
    emit("  ret ptr %buf");
    emit("}");
    emit("");
}

// ── Capture detection ──────────────────
// Find variables referenced in an arrow fn body that aren't params or locally defined
// ── Type inference pass ────────────────
// Pure type computation — no IR emission. Used to populate var_types
// before emit_function runs its body, so emit_expr returns concrete
// types instead of "any" for local variables.

fn match_expr_result_type(nd) {
    var members <- [];
    var ai <- 0;
    while (ai < len(nd.arms)) {
        var arm <- nd.arms[ai];
        var vt <- T.mk_none();
        if (arm.wild) {
            vt <- typeof_expr(arm.value);
        } else {
            var bn <- match_bind_name(arm, nd.scrutinee);
            if (bn != "") {
                var saved <- get_var_type(bn);
                set_var_type(bn, arm.ptype);
                var fsv <- arm_destructure_set_types(arm.ptype);
                vt <- typeof_expr(arm.value);
                arm_destructure_restore_types(fsv);
                set_var_type(bn, saved);
            } else {
                vt <- typeof_expr(arm.value);
            }
        }
        if (vt.kind = "union") {
            var k <- 0;
            while (k < len(vt.members)) { push(members, vt.members[k]); k <- k + 1; }
        } else {
            push(members, vt);
        }
        ai <- ai + 1;
    }
    var norm <- T.union_normalize(members);
    if (len(norm) = 0) { return T.mk_none(); }
    if (len(norm) = 1) { return norm[0]; }
    return T.mk_union(norm);
}

fn check_match_coverage(ln, col, scrutinee, ut, arms) {
    var ms <- T.union_normalize(ut.members);
    var covered <- [];
    var ci2 <- 0;
    while (ci2 < len(ms)) { push(covered, false); ci2 <- ci2 + 1; }
    var has_wild <- false;
    var seen_lits <- [];
    var mi <- 0;
    while (mi < len(arms)) {
        if (arms[mi].wild) {
            if (has_wild) { report_error(ln, col, "duplicate wildcard arm '_'"); }
            has_wild <- true;
            if (mi != len(arms) - 1) { report_error(ln, col, "wildcard arm '_' must be the last arm"); }
            var all_cov <- true;
            var wc <- 0;
            while (wc < len(covered)) { if (!match_eff_covered(covered, ms, wc, seen_lits)) { all_cov <- false; } wc <- wc + 1; }
            if (all_cov) { report_error(ln, col, "unreachable wildcard arm '_': all members of " + T.type_str(ut) + " are already covered"); }
        } else {
            var pt <- arms[mi].ptype;
            var idx <- union_member_index(ut, pt);
            if (arms[mi].is_lit) {
                if (idx = -1) {
                    report_error(ln, col, "literal pattern of type " + T.type_str(pt) + " is not a member of " + T.type_str(ut));
                } else {
                    if (covered[idx]) {
                        report_error(ln, col, "unreachable literal pattern: " + T.type_str(pt) + " is already fully covered by an earlier arm");
                    } else {
                        var lkey <- arms[mi].lit_kind + ":" + arms[mi].lit;
                        if (name_in(seen_lits, lkey)) {
                            report_error(ln, col, "unreachable duplicate literal pattern");
                        } else {
                            push(seen_lits, lkey);
                        }
                    }
                }
            } else {
                if (idx = -1) {
                    report_error(ln, col, T.type_str(pt) + " is not a member of " + T.type_str(ut));
                } else {
                    if (covered[idx]) { report_error(ln, col, "duplicate match arm for " + T.type_str(pt)); }
                    covered[idx] <- true;
                }
                if (arms[mi].name = "" && scrutinee.node != "Identifier") {
                    report_error(ln, col, "matching an expression requires a binding name (use 'name: " + T.type_str(pt) + "')");
                }
            }
        }
        mi <- mi + 1;
    }
    if (!has_wild) {
        var ei <- 0;
        while (ei < len(covered)) {
            if (!match_eff_covered(covered, ms, ei, seen_lits)) { report_error(ln, col, "non-exhaustive match: missing arm for " + T.type_str(ms[ei])); }
            ei <- ei + 1;
        }
    }
}

fn typeof_expr(nd): any {
    if (nd.node = "MatchExpr") { return match_expr_result_type(nd); }
    if (nd.node = "NumberLit") { return T.mk_int(); }
    if (nd.node = "FloatLit") { return T.mk_float(); }
    if (nd.node = "StringLit") { return T.mk_str(); }
    if (nd.node = "BoolLit") { return T.mk_bool(); }
    if (nd.node = "Identifier") {
        var vt2 <- get_var_type(nd.name);
        if (vt2.kind = "any") {
            // A tracked `any` is only a tagged cell when the name is
            // DECLARED any (the tier key). A lookup miss also reads as
            // any: a bare function name is a closure value; anything
            // else is raw tier.
            if (get_decl_type(nd.name).kind != "any") {
                if (find_fn(nd.name) != false) { return T.mk_fn(); }
                return T.mk_none();
            }
        }
        return vt2;
    }
    if (nd.node = "BinOp") {
        var op <- nd.op;
        if (op = "&&" || op = "||") { return T.mk_bool(); }
        if (op = "=" || op = "!=" || op = "<" || op = ">" || op = "<=" || op = ">=") { return T.mk_bool(); }
        var lt <- typeof_expr(nd.left);
        var rt <- typeof_expr(nd.right);
        if (op = "+") {
            if (lt.kind = "str" || rt.kind = "str") { return T.mk_str(); }
            // Array concatenation. types_join handles mismatched element types
            // (different element kinds collapse to `any`); for matching types
            // it preserves the element type so a print of the result still
            // formats elements correctly.
            if (lt.kind = "array" && rt.kind = "array") {
                return T.mk_array(T.types_join(lt.elem, rt.elem));
            }
            if (lt.kind = "float" || rt.kind = "float") { return T.mk_float(); }
            return T.mk_int();
        }
        // Arithmetic — float-propagating: any float operand makes the result float.
        if (lt.kind = "float" || rt.kind = "float") { return T.mk_float(); }
        return T.mk_int();
    }
    if (nd.node = "UnaryOp") {
        if (nd.op = "!") { return T.mk_bool(); }
        // Unary `-` preserves the operand's numeric type (int or float).
        if (nd.op = "-") {
            var ot <- typeof_expr(nd.operand);
            if (ot.kind = "float") { return T.mk_float(); }
            return T.mk_int();
        }
        return T.mk_int();
    }
    if (nd.node = "CallExpr") {
        if (nd.callee.node = "Identifier") {
            var nm <- nd.callee.name;
            if (nm = "len") { return T.mk_int(); }
            if (nm = "str_len") { return T.mk_int(); }
            if (nm = "char_code") { return T.mk_int(); }
            if (nm = "char_at") { return T.mk_str(); }
            if (nm = "from_char_code") { return T.mk_str(); }
            if (nm = "substring") { return T.mk_str(); }
            if (nm = "input") { return T.mk_str(); }
            if (nm = "read_file") { return T.mk_str(); }
            if (nm = "write_file") { return T.mk_int(); }
            if (nm = "append_file") { return T.mk_int(); }
            if (nm = "exec_cmd") { return T.mk_int(); }
            if (nm = "push") { return T.mk_int(); }
            if (nm = "pop") {
                // Element type if known, else any
                if (len(nd.args) > 0) {
                    var at <- typeof_expr(nd.args[0]);
                    if (at.kind = "array") { return at.elem; }
                }
                return T.mk_none();
            }
            if (nm = "keys") { return T.mk_array(T.mk_str()); }
            if (nm = "print") { return T.mk_int(); }
            if (nm = "args") {
                if (len(nd.args) = 0) { return T.mk_int(); }
                return T.mk_str();
            }
            var fi <- find_fn(nm);
            if (fi != false) {
                // The annotation is the caller-visible truth: the return
                // site emits by it (wrapping for `any`, raw otherwise), so
                // callers type by it too. Without one, an inferred `any`
                // is raw-tier: nothing wrapped it, so callers must not
                // expect a tagged cell.
                if (fi.ret_type_ann.kind != "none") { return fi.ret_type_ann; }
                // Param-passthrough specialization: if this fn always returns
                // a specific parameter unchanged (set by scan_fn_param_returns),
                // the return type at this call site is the corresponding arg's
                // type. This recovers element types for patterns like
                //   fn sort(arr) { ... return arr; }
                //   sorted <- sort([1,2,3]);   // sorted typed as [int], not any
                var ridx <- get_fn_returns_param(nm);
                if (ridx != -1 && ridx < len(nd.args)) {
                    var arg_t <- typeof_expr(nd.args[ridx]);
                    // Only specialize when the arg has a more specific type
                    // than the declared return — never widen.
                    if (arg_t.kind != "any" && arg_t.kind != "none") {
                        return arg_t;
                    }
                }
                if (fi.ret_type.kind = "any") { return T.mk_none(); }
                return fi.ret_type;
            }
        }
        // Unknown callee (indirect / closure calls): raw tier.
        return T.mk_none();
    }
    if (nd.node = "ArrayLit") {
        // Empty array → element type not yet known (`none`). Push-refinement
        // (see infer_body) narrows this as elements get pushed, keeping the
        // idiom on the raw tier; a declared [any] never narrows — it is the
        // tagged tier by request.
        if (len(nd.elements) = 0) { return T.mk_array(T.mk_none()); }
        // Unify element types across the literal: matching kinds collapse to
        // that kind, mismatched primitives collapse to `any`, mismatched
        // composite shapes recurse field/elem-wise. So
        //   [{value: 1}, {value: "a"}, {value: 2}]
        // types as `[{value: any}]` instead of `[{value: int}]`.
        var et: any <- typeof_expr(nd.elements[0]);
        var i <- 1;
        while (i < len(nd.elements)) {
            et <- T.types_join(et, typeof_expr(nd.elements[i]));
            i <- i + 1;
        }
        // A join that lands on `any` is raw tier: nothing wraps these
        // elements, and raw-tier consumers (untyped functions receiving
        // the array) read them as raw words. Only an annotation-declared
        // [any] slot puts elements on the tagged tier (the coercion path
        // wraps them at the store).
        if (et.kind = "any") { et <- T.mk_none(); }
        return T.mk_array(et);
    }
    if (nd.node = "IndexExpr") {
        // Indexing a string yields a single-char string (char_at semantics).
        // Indexing an array yields the element type. Anything else is unknown.
        if (nd.obj.node = "Identifier") {
            var ot <- get_var_type(nd.obj.name);
            if (ot.kind = "str") { return T.mk_str(); }
            if (ot.kind = "array") { return ot.elem; }
            // Fall back to the side table for arrays we set up before var_types existed
            return get_array_elem_type(nd.obj.name);
        }
        // Index into a non-Identifier (e.g. nested [[int]] subscript)
        var ot <- typeof_expr(nd.obj);
        if (ot.kind = "str") { return T.mk_str(); }
        if (ot.kind = "array") { return ot.elem; }
        // Unknown base: raw tier — nothing wrapped this value.
        return T.mk_none();
    }
    if (nd.node = "DotExpr") {
        if (nd.obj.node = "Identifier") {
            // Prefer the struct_lit Type from var_types if present
            var ot <- get_var_type(nd.obj.name);
            if (ot.kind = "struct_lit") {
                var ft <- T.struct_field_type(ot.fields, nd.field);
                if (ft.kind != "none") { return ft; }
            }
            // Fall back to legacy struct_layouts side table
            var layout <- get_struct_layout(nd.obj.name);
            if (layout != false) {
                return get_field_type(layout, nd.field);
            }
        }
        // Index into a non-Identifier (e.g. arr[0].field where arr is [{...}])
        var ot <- typeof_expr(nd.obj);
        if (ot.kind = "struct_lit") {
            var ft <- T.struct_field_type(ot.fields, nd.field);
            if (ft.kind != "none") { return ft; }
        }
        // Unknown base or field: raw tier — nothing wrapped this value.
        return T.mk_none();
    }
    if (nd.node = "StructLit") {
        // Build a struct_lit type from the literal's fields
        var fs <- [];
        var i <- 0;
        while (i < len(nd.fields)) {
            var f <- nd.fields[i];
            var fvt <- typeof_expr(f.val);
            // A field value typed `any` is raw tier in a bare literal: the
            // record may cross into raw-tier scopes, whose readers expect
            // raw words. An annotated struct slot wraps fields through the
            // coercion path instead.
            if (fvt.kind = "any") { fvt <- T.mk_none(); }
            push(fs, {name: f.key, type: fvt});
            i <- i + 1;
        }
        return T.mk_struct_lit(fs);
    }
    if (nd.node = "ArrowFn") { return T.mk_fn(); }
    // Unrecognized expression forms are raw tier: only positions the
    // emitter actually wraps may type as `any`.
    return T.mk_none();
}

// Walk a body of statements, updating var_types for each assignment
// Effective binding name for a match arm: the explicit `name:` if present,
// else the scrutinee variable name (a bare pattern shadows it), else "" — no
// binding (a bare pattern on a non-variable scrutinee, which the checker flags).
fn arm_destructure_set_types(ptype) {
    var sv <- [];
    if (ptype.kind = "struct_lit") {
        var i <- 0;
        while (i < len(ptype.fields)) {
            var fnm <- ptype.fields[i].name;
            push(sv, {name: fnm, ty: get_var_type(fnm)});
            set_var_type(fnm, ptype.fields[i].type);
            i <- i + 1;
        }
    }
    return sv;
}
fn arm_destructure_restore_types(sv) {
    var i <- 0;
    while (i < len(sv)) { set_var_type(sv[i].name, sv[i].ty); i <- i + 1; }
}
fn arm_destructure_scope_declare(scopes, ptype) {
    if (ptype.kind = "struct_lit") {
        var i <- 0;
        while (i < len(ptype.fields)) { scope_declare(scopes, ptype.fields[i].name); i <- i + 1; }
    }
}
fn arm_destructure_emit_bind(b, bn, ptype) {
    var pre <- len(b.locals);
    var saves <- [];
    if (ptype.kind = "struct_lit") {
        var i <- 0;
        while (i < len(ptype.fields)) {
            var fnm <- ptype.fields[i].name;
            var dot <- {node: "DotExpr", obj: {node: "Identifier", name: bn, line: 0, col: 0}, field: fnm};
            var fval <- ir_emit_expr(b, dot);
            var fslot <- ir_fresh_tmp(b, "mxfd");
            ir_push_inst(b.func.blocks[0], ii_alloca(fslot, T.mk_int()));
            ir_push_inst(b.cur_block, ii_store(fval, ir_reg(fslot, T.mk_int())));
            var swapped <- false;
            var swap_i <- 0;
            var sreg <- "";
            var sbox <- false;
            var li <- 0;
            while (li < len(b.locals)) {
                if (b.locals[li].name = fnm) { swapped <- true; swap_i <- li; }
                li <- li + 1;
            }
            if (swapped) {
                sreg <- b.locals[swap_i].reg;
                sbox <- b.locals[swap_i].boxed;
                b.locals[swap_i].reg <- fslot;
                b.locals[swap_i].boxed <- false;
            } else {
                push(b.locals, {name: fnm, reg: fslot, boxed: false, box_owned: false});
            }
            var svt <- get_var_type(fnm);
            set_var_type(fnm, ptype.fields[i].type);
            push(saves, {name: fnm, swapped: swapped, swap_i: swap_i, sreg: sreg, sbox: sbox, svt: svt});
            i <- i + 1;
        }
    }
    return {saves: saves, pre: pre};
}
fn arm_destructure_emit_restore(b, rec) {
    var saves <- rec.saves;
    var i <- 0;
    while (i < len(saves)) {
        var s <- saves[i];
        set_var_type(s.name, s.svt);
        if (s.swapped) {
            b.locals[s.swap_i].reg <- s.sreg;
            b.locals[s.swap_i].boxed <- s.sbox;
        }
        i <- i + 1;
    }
    var nl <- [];
    var k <- 0;
    while (k < rec.pre) { push(nl, b.locals[k]); k <- k + 1; }
    b.locals <- nl;
}
fn match_bind_name(arm, scrutinee): str {
    if (arm.name != "") { return arm.name; }
    if (scrutinee.node = "Identifier") { return scrutinee.name; }
    return "";
}
// Index of member type `mt` within the union's normalized members (-1 if none).
// This is the runtime tag value for that member.
fn union_member_index(u, mt): int {
    if (u.kind != "union") { return -1; }
    var ms <- T.union_normalize(u.members);
    var i <- 0;
    while (i < len(ms)) {
        if (T.type_eq(ms[i], mt)) { return i; }
        i <- i + 1;
    }
    // Second pass: a struct value whose field *types* are narrower than a
    // struct member's — e.g. {tag: int} fitting member {tag: int | str}.
    // Require the exact top-level field-name set (same field count, every
    // member field present in the value) so a width-subtyped value with
    // extra fields does NOT collapse onto a narrower member; only the field
    // types may differ, and they must be assignable.
    i <- 0;
    while (i < len(ms)) {
        if (ms[i].kind = "struct_lit" && mt.kind = "struct_lit") {
            if (len(ms[i].fields) = len(mt.fields) && T.types_compat(ms[i], mt)) { return i; }
        }
        i <- i + 1;
    }
    return -1;
}
fn infer_body(stmts) {
    var i <- 0;
    while (i < len(stmts)) {
        var s <- stmts[i];
        if (s.node = "Assignment") {
            // Use explicit type annotation if present (already a Type), otherwise infer
            if (s.type_ann.kind != "none") {
                set_var_type(s.name, s.type_ann);
                if (s.is_decl) {
                    set_decl_type(s.name, s.type_ann);
                    shadow_declare(s.name, s.type_ann, s.line, s.col);
                }
            } else {
                // A reassignment (no annotation) must not downgrade a variable
                // whose declared type carries a union — a top-level union or a
                // container holding one (array-of-union, struct-with-union-field,
                // nested). The stored value is coerced to the declared type, which
                // the variable keeps for the whole function.
                var existing <- get_var_type(s.name);
                var ty <- typeof_expr(s.expr);
                if (s.is_decl) {
                    set_decl_type(s.name, ty);
                    shadow_declare(s.name, ty, s.line, s.col);
                } else {
                    // Fixed-type rule (3b): a bare reassignment must fit the
                    // variable's declared type. any/union/union-container and
                    // not-yet-known (none) declared types are permissive.
                    var dt <- get_decl_type(s.name);
                    if (dt.kind != "none" && dt.kind != "any" && dt.kind != "union"
                        && !T.union_in_container(dt) && !T.types_compat(dt, ty)) {
                        report_error(s.line, s.col, "cannot assign " + T.type_str(ty) + " to '" + s.name + "' of type " + T.type_str(dt));
                    }
                }
                // Variables explicitly declared `any` keep tracked type any
                // for their whole lifetime: their slot holds a tagged cell,
                // and reads must stay statically any so consumers dispatch
                // on the tag instead of trusting a refined concrete type.
                // Symmetrically, a concrete-locked variable keeps its
                // type across an any-typed reassignment: the tagged value
                // stores THROUGH the slot (checked-unwrapped at runtime),
                // it does not retype the variable. Overwriting here used to
                // degrade the tracked type to any, which the emit-time tier
                // demote turned into none — routing the store through the
                // raw unchecked unwrap and skipping the trap.
                var rdt <- get_decl_type(s.name);
                if (!T.union_in_container(existing) && existing.kind != "union"
                    && rdt.kind != "any") {
                    if (ty.kind != "any" || rdt.kind = "none" || rdt.kind = "union"
                        || T.union_in_container(rdt)) {
                        set_var_type(s.name, ty);
                    }
                }
            }
            // Track struct layouts from struct literals — store ftype as kind string
            if (s.expr.node = "StructLit") {
                var layout <- [];
                var j <- 0;
                while (j < len(s.expr.fields)) {
                    var f <- s.expr.fields[j];
                    var fty <- typeof_expr(f.val);
                    push(layout, {fname: f.key, ftype: fty.kind});
                    j <- j + 1;
                }
                set_struct_layout(s.name, layout);
            }
            // Track array element types from array literals
            if (s.expr.node = "ArrayLit") {
                var j <- 0;
                while (j < len(s.expr.elements)) {
                    var ety <- typeof_expr(s.expr.elements[j]);
                    if (ety.kind = "str") {
                        set_array_elem_type(s.name, "str");
                    }
                    j <- j + 1;
                }
            }
        }
        if (s.node = "IfStmt") {
            infer_body(s.then_body);
            infer_body(s.else_body);
        }
        if (s.node = "MatchStmt") {
            var mi <- 0;
            while (mi < len(s.arms)) {
                // Match arms are the one construct the checker scopes for
                // real: the scrutinee binding is saved/restored per arm,
                // and the parser's synthesized field binders (see
                // match_destructure_body) re-bind the same field names in
                // every struct-pattern arm at that arm's field types.
                // Snapshot the shadowing registry around each arm so those
                // per-arm bindings do not read as function-wide
                // re-declarations; a declaration INSIDE an arm still
                // checks against names declared outside the match.
                var shadow_snap <- len(shadow_decls[0]);
                if (s.arms[mi].wild) {
                    infer_body(s.arms[mi].body);
                } else {
                    var bn <- match_bind_name(s.arms[mi], s.scrutinee);
                    if (bn != "") {
                        var saved <- get_var_type(bn);
                        set_var_type(bn, s.arms[mi].ptype);
                        infer_body(s.arms[mi].body);
                        set_var_type(bn, saved);
                    } else {
                        infer_body(s.arms[mi].body);
                    }
                }
                while (len(shadow_decls[0]) > shadow_snap) { pop(shadow_decls[0]); }
                mi <- mi + 1;
            }
        }
        if (s.node = "WhileStmt") { infer_body(s.body); }
        if (s.node = "ForInStmt") {
            // Loop variable: if iterable is a string, element is str char (a string)
            var it_ty <- typeof_expr(s.iterable);
            if (it_ty.kind = "str") {
                set_var_type(s.var_name, T.mk_str());
            } else {
                // Array iteration: elem type from array
                var et <- T.mk_none();
                if (s.iterable.node = "Identifier") {
                    et <- get_array_elem_type(s.iterable.name);
                }
                set_var_type(s.var_name, et);
            }
            infer_body(s.body);
        }
        if (s.node = "ReturnStmt") {
            if (s.expr != false) {
                var rt <- typeof_expr(s.expr);
                if (current_fn[0] != "") {
                    set_fn_ret_type(current_fn[0], rt, false);
                }
            }
        }
        // Push refinement: when a bare `push(arr, val)` appears, widen the
        // array's element type to include `typeof(val)`. The most common
        // shape we want to handle:
        //   items <- [];           // typed [any]
        //   push(items, "hello");  // refines to [str]
        //   push(items, "world");  // stays [str]
        // If a later push contributes a different type, types_join collapses
        // to `any`, which is the correct fallback.
        if (s.node = "CallExpr" && s.callee.node = "Identifier"
                && s.callee.name = "push" && len(s.args) >= 2) {
            var arr_arg <- s.args[0];
            var val_arg <- s.args[1];
            if (arr_arg.node = "Identifier") {
                var cur_t <- get_var_type(arr_arg.name);
                if (cur_t.kind = "array") {
                    var val_t <- typeof_expr(val_arg);
                    // A pushed value typed `any` keeps the array raw-tier:
                    // narrowing onto `any` would create a tagged array
                    // whose cells poison raw-tier readers in other scopes.
                    // The value itself unwraps at the push edge like any
                    // other any -> raw store.
                    if (val_t.kind = "any") { val_t <- T.mk_none(); }
                    // Treat current `any` as "unknown" (bottom) rather than
                    // "could be anything" (top): narrow toward the pushed
                    // type. Once we have a concrete element type, future
                    // pushes use types_join which correctly collapses to any
                    // if they conflict.
                    var new_elem <- T.mk_any();
                    if (cur_t.elem.kind = "none") {
                        new_elem <- val_t;
                    } else {
                        if (cur_t.elem.kind = "union") {
                            // Pushing a member into a [union] array keeps the
                            // union element type (the value is wrapped at codegen);
                            // don't let types_join collapse it to `any`.
                            new_elem <- cur_t.elem;
                        } else {
                            new_elem <- T.types_join(cur_t.elem, val_t);
                            // Mixed pushes joining to `any` stay raw-tier
                            // for the same reason — EXCEPT when the array
                            // is DECLARED [any]: that is the tagged tier by
                            // request, its elements wrap at the push edge,
                            // and it never narrows.
                            if (new_elem.kind = "any") {
                                var d_el <- get_decl_type(arr_arg.name);
                                var keep_any <- false;
                                if (d_el.kind = "array") {
                                    if (d_el.elem.kind = "any") { keep_any <- true; }
                                }
                                if (!keep_any) { new_elem <- T.mk_none(); }
                            }
                        }
                    }
                    set_var_type(arr_arg.name, T.mk_array(new_elem));
                    if (new_elem.kind = "str") { set_array_elem_type(arr_arg.name, "str"); }
                }
            }
        }
        if (s.node = "Block") { infer_body(s.stmts); }
        i <- i + 1;
    }
}

// ═══════════════════════════════════════════
//  TYPE CHECKER
//  Compares user-written annotations against
//  inferred types. Errors are accumulated and
//  printed at the end; compilation aborts if any.
// ═══════════════════════════════════════════

var type_errors <- [];
var src_filename <- ["<unknown>"];

fn report_error(line: int, col: int, msg: str) {
    push(type_errors, {line: line, col: col, msg: msg});
}

// ═══════════════════════════════════════════
//  SCOPE CHECKER
//  Enforces block-scope semantics by rejecting identifier reads that
//  refer to names not currently in scope. Mirrors the interpreter's
//  Environment chain: `<-` walks up scopes to find an existing binding
//  or declares in the current one; identifier reads must resolve to a
//  binding in some enclosing scope (within the current function), an
//  outer captured scope (across closure boundaries), a global, a
//  top-level function name, or a builtin. Otherwise: scope error.
// ═══════════════════════════════════════════

var scope_errors <- [];

fn report_scope_error(line: int, col: int, msg: str) {
    push(scope_errors, {line: line, col: col, msg: msg});
}

// Names that always resolve regardless of scope: builtins, arena/arrow
// runtime helpers, etc. Hard-coded list — the alternative would be
// threading a registry, but builtins don't change often enough to warrant
// the extra machinery.
fn is_builtin_name(n: str): int {
    return n = "print" || n = "len" || n = "push" || n = "pop" || n = "keys"
        || n = "read_file" || n = "write_file" || n = "append_file" || n = "input"
        || n = "char_at" || n = "char_code" || n = "from_char_code"
        || n = "substring" || n = "str_len"
        || n = "exec_cmd" || n = "args"
        || n = "true" || n = "false";
}

// Check if `name` is declared in any scope in the given stack. Each scope
// is a flat list of declared name strings. We walk inner-to-outer.
fn scope_stack_has(scopes, name: str): int {
    var i <- len(scopes) - 1;
    while (i >= 0) {
        var names <- scopes[i];
        var j <- 0;
        while (j < len(names)) {
            if (names[j] = name) { return true; }
            j <- j + 1;
        }
        i <- i - 1;
    }
    return false;
}

// Resolution lookup for an identifier read: search the local fn's scope
// stack, then the captured outer scopes (one entry per enclosing fn), then
// globals, then top-level function names, then builtins.
fn scope_resolves(name: str, fn_scopes, captured, globals_set, fn_names): int {
    if (scope_stack_has(fn_scopes, name)) { return true; }
    // captured is a list-of-scope-stacks for enclosing closures
    ci <- 0;
    while (ci < len(captured)) {
        if (scope_stack_has(captured[ci], name)) { return true; }
        ci <- ci + 1;
    }
    if (name_in(globals_set, name)) { return true; }
    if (name_in(fn_names, name)) { return true; }
    if (is_builtin_name(name)) { return true; }
    return false;
}

// Resolution check for the LHS of a bare `<-` reassignment. Differs from
// scope_resolves only by excluding builtins: shadowing a builtin requires
// `var`, since builtins are intrinsics, not bindings. Everything else —
// current-function scopes, captured outer-fn scopes, globals, top-level fn-names —
// is a valid mutation target.
fn scope_resolves_for_assign(name: str, fn_scopes, captured, globals_set, fn_names): int {
    if (scope_stack_has(fn_scopes, name)) { return true; }
    var ci <- 0;
    while (ci < len(captured)) {
        if (scope_stack_has(captured[ci], name)) { return true; }
        ci <- ci + 1;
    }
    if (name_in(globals_set, name)) { return true; }
    if (name_in(fn_names, name)) { return true; }
    return false;
}

// Check whether `name` is already bound in the *innermost* scope of
// fn_scopes — used to flag same-scope redeclarations (`var x; ... var x;`).
// Shadowing across nested scopes is allowed and not flagged here.
fn scope_innermost_has(fn_scopes, name: str): int {
    var inner <- fn_scopes[len(fn_scopes) - 1];
    var j <- 0;
    while (j < len(inner)) {
        if (inner[j] = name) { return true; }
        j <- j + 1;
    }
    return false;
}

// Declare `name` in the innermost scope of `fn_scopes` if not already
// resolvable within the current function. (Doesn't cross closure boundary
// — that's the function-root rule from the interpreter.)
fn scope_declare(fn_scopes, name: str) {
    if (scope_stack_has(fn_scopes, name)) { return false; }
    push(fn_scopes[len(fn_scopes) - 1], name);
    return false;
}

// Walk an expression checking that every Identifier resolves. Recurses
// into nested expressions; for ArrowFn, walks into the closure body with
// a fresh fn_scopes and the current fn_scopes appended to captured.
fn scope_check_expr(e, fn_scopes, captured, globals_set, fn_names) {
    if (e.node = "MatchExpr") {
        scope_check_expr(e.scrutinee, fn_scopes, captured, globals_set, fn_names);
        var mxi <- 0;
        while (mxi < len(e.arms)) {
            push(fn_scopes, []);
            if (!e.arms[mxi].wild) {
                var bn <- match_bind_name(e.arms[mxi], e.scrutinee);
                if (bn != "") { scope_declare(fn_scopes, bn); arm_destructure_scope_declare(fn_scopes, e.arms[mxi].ptype); }
            }
            scope_check_expr(e.arms[mxi].value, fn_scopes, captured, globals_set, fn_names);
            pop(fn_scopes);
            mxi <- mxi + 1;
        }
        return false;
    }
    if (e.node = "Identifier") {
        if (!scope_resolves(e.name, fn_scopes, captured, globals_set, fn_names)) {
            var ln <- 0;
            var cl <- 0;
            if (e.line != false) { ln <- e.line; }
            if (e.col != false) { cl <- e.col; }
            report_scope_error(ln, cl, "undefined variable '" + e.name + "'");
        }
        return false;
    }
    if (e.node = "BinOp") {
        scope_check_expr(e.left, fn_scopes, captured, globals_set, fn_names);
        scope_check_expr(e.right, fn_scopes, captured, globals_set, fn_names);
        return false;
    }
    if (e.node = "UnaryOp") {
        scope_check_expr(e.operand, fn_scopes, captured, globals_set, fn_names);
        return false;
    }
    if (e.node = "CallExpr") {
        scope_check_expr(e.callee, fn_scopes, captured, globals_set, fn_names);
        var j <- 0;
        while (j < len(e.args)) {
            scope_check_expr(e.args[j], fn_scopes, captured, globals_set, fn_names);
            j <- j + 1;
        }
        return false;
    }
    if (e.node = "IndexExpr") {
        scope_check_expr(e.obj, fn_scopes, captured, globals_set, fn_names);
        scope_check_expr(e.index, fn_scopes, captured, globals_set, fn_names);
        return false;
    }
    if (e.node = "DotExpr") {
        // The base must resolve; .field is just a field name, no scope check.
        scope_check_expr(e.obj, fn_scopes, captured, globals_set, fn_names);
        return false;
    }
    if (e.node = "ArrayLit") {
        var j <- 0;
        while (j < len(e.elements)) {
            scope_check_expr(e.elements[j], fn_scopes, captured, globals_set, fn_names);
            j <- j + 1;
        }
        return false;
    }
    if (e.node = "StructLit") {
        var j <- 0;
        while (j < len(e.fields)) {
            scope_check_expr(e.fields[j].val, fn_scopes, captured, globals_set, fn_names);
            j <- j + 1;
        }
        return false;
    }
    if (e.node = "ArrowFn") {
        // Step into the closure body. Reads in there can still see the
        // outer fn's scopes (push current fn_scopes onto captured), but
        // writes don't reach across — give the closure its own fn_scopes
        // initialized with just its parameters.
        var new_captured <- [];
        ci <- 0;
        while (ci < len(captured)) { push(new_captured, captured[ci]); ci <- ci + 1; }
        push(new_captured, fn_scopes);
        var new_fn_scopes <- [[]];
        var j <- 0;
        while (j < len(e.params)) {
            scope_declare(new_fn_scopes, e.params[j]);
            j <- j + 1;
        }
        if (e.is_expr) {
            // Expression body — single expression.
            scope_check_expr(e.body, new_fn_scopes, new_captured, globals_set, fn_names);
        } else {
            // Block body — list of statements.
            scope_check_stmts(e.body, new_fn_scopes, new_captured, globals_set, fn_names);
        }
        return false;
    }
    // Literals (NumberLit, StringLit, BoolLit) have no identifier reads.
    return false;
}

fn scope_check_stmts(stmts, fn_scopes, captured, globals_set, fn_names) {
    var i <- 0;
    while (i < len(stmts)) {
        scope_check_stmt(stmts[i], fn_scopes, captured, globals_set, fn_names);
        i <- i + 1;
    }
    return false;
}

fn scope_check_stmt(s, fn_scopes, captured, globals_set, fn_names) {
    if (s.node = "Assignment") {
        // RHS evaluated before LHS is bound, so check expression first.
        scope_check_expr(s.expr, fn_scopes, captured, globals_set, fn_names);
        if (s.is_decl) {
            // `var x <- expr;` — declaration. Same-scope redeclaration is
            // a hard error; shadowing across nested scopes is fine and
            // not flagged here. Top-level declarations land in the
            // outermost scope of fn_scopes (which doubles as globals for
            // the synthetic top-level frame).
            if (scope_innermost_has(fn_scopes, s.name)) {
                report_scope_error(s.line, s.col, "redeclaration of '" + s.name + "' in the same scope");
            } else {
                push(fn_scopes[len(fn_scopes) - 1], s.name);
            }
        } else {
            // Bare `x <- expr;` — reassignment. The name must resolve to
            // a binding inside the current function or to a global. If it
            // doesn't, this is the common typo-creates-new-binding bug;
            // we want a hard error so the user reaches for `var`.
            if (!scope_resolves_for_assign(s.name, fn_scopes, captured, globals_set, fn_names)) {
                report_scope_error(s.line, s.col, "cannot reassign undeclared variable '" + s.name + "' (did you mean: var " + s.name + " <- ...?)");
            }
        }
        return false;
    }
    if (s.node = "IndexAssign") {
        scope_check_expr(s.obj, fn_scopes, captured, globals_set, fn_names);
        scope_check_expr(s.index, fn_scopes, captured, globals_set, fn_names);
        scope_check_expr(s.value, fn_scopes, captured, globals_set, fn_names);
        return false;
    }
    if (s.node = "DotAssign") {
        scope_check_expr(s.obj, fn_scopes, captured, globals_set, fn_names);
        scope_check_expr(s.value, fn_scopes, captured, globals_set, fn_names);
        return false;
    }
    if (s.node = "PrintStmt") {
        scope_check_expr(s.expr, fn_scopes, captured, globals_set, fn_names);
        return false;
    }
    if (s.node = "ReturnStmt") {
        if (s.expr != false) {
            scope_check_expr(s.expr, fn_scopes, captured, globals_set, fn_names);
        }
        return false;
    }
    if (s.node = "IfStmt") {
        scope_check_expr(s.cond, fn_scopes, captured, globals_set, fn_names);
        push(fn_scopes, []);
        scope_check_stmts(s.then_body, fn_scopes, captured, globals_set, fn_names);
        pop(fn_scopes);
        push(fn_scopes, []);
        scope_check_stmts(s.else_body, fn_scopes, captured, globals_set, fn_names);
        pop(fn_scopes);
        return false;
    }
    if (s.node = "MatchStmt") {
        scope_check_expr(s.scrutinee, fn_scopes, captured, globals_set, fn_names);
        var mi <- 0;
        while (mi < len(s.arms)) {
            push(fn_scopes, []);
            if (!s.arms[mi].wild) {
                var bn <- match_bind_name(s.arms[mi], s.scrutinee);
                if (bn != "") { scope_declare(fn_scopes, bn); }
            }
            scope_check_stmts(s.arms[mi].body, fn_scopes, captured, globals_set, fn_names);
            pop(fn_scopes);
            mi <- mi + 1;
        }
        return false;
    }
    if (s.node = "WhileStmt") {
        scope_check_expr(s.cond, fn_scopes, captured, globals_set, fn_names);
        push(fn_scopes, []);
        scope_check_stmts(s.body, fn_scopes, captured, globals_set, fn_names);
        pop(fn_scopes);
        return false;
    }
    if (s.node = "ForInStmt") {
        scope_check_expr(s.iterable, fn_scopes, captured, globals_set, fn_names);
        // Push body scope with loop variable already declared in it.
        push(fn_scopes, [s.var_name]);
        scope_check_stmts(s.body, fn_scopes, captured, globals_set, fn_names);
        pop(fn_scopes);
        return false;
    }
    if (s.node = "FnDecl") {
        // Nested fn declaration. Treat its body as a fresh fn boundary.
        scope_check_fn(s, captured, globals_set, fn_names, fn_scopes);
        scope_declare(fn_scopes, s.name);
        return false;
    }
    if (s.node = "Block") {
        push(fn_scopes, []);
        scope_check_stmts(s.stmts, fn_scopes, captured, globals_set, fn_names);
        pop(fn_scopes);
        return false;
    }
    // Bare expression statement.
    scope_check_expr(s, fn_scopes, captured, globals_set, fn_names);
    return false;
}

// Check a single function declaration with its own fresh fn_scopes.
fn scope_check_fn(fn_decl, outer_captured, globals_set, fn_names, outer_fn_scopes) {
    var new_captured <- [];
    if (outer_captured != false) {
        ci <- 0;
        while (ci < len(outer_captured)) { push(new_captured, outer_captured[ci]); ci <- ci + 1; }
    }
    // Nested function declarations see their enclosing function's locals
    // as captured (read-only across the fn boundary, just like closures).
    if (outer_fn_scopes != false) { push(new_captured, outer_fn_scopes); }
    var fn_scopes <- [[]];
    var i <- 0;
    while (i < len(fn_decl.params)) {
        scope_declare(fn_scopes, fn_decl.params[i]);
        i <- i + 1;
    }
    scope_check_stmts(fn_decl.body, fn_scopes, new_captured, globals_set, fn_names);
    return false;
}

// Entry point: collect globals + top-level fn names, then check every
// FnDecl. Top-level assignments and references are checked too so a
// program that does `print(undeclared)` at top level fails cleanly.
fn scope_check_program(stmts) {
    // First pass: collect every top-level FnDecl name and every top-level
    // *declared* (is_decl=true) Assignment target. Both are visible from
    // any function body — order-of-appearance doesn't matter for reads, so
    // we collect them all up front. A bare top-level `x <- ...` (is_decl
    // false) is NOT added here; in strict mode that's a reassignment and
    // must resolve to an existing global, otherwise it's a typo and we
    // want to flag it.
    var globals_set <- [];
    var fn_names <- [];
    var i <- 0;
    while (i < len(stmts)) {
        var s <- stmts[i];
        if (s.node = "FnDecl") {
            if (!name_in(fn_names, s.name)) { push(fn_names, s.name); }
        }
        if (s.node = "Assignment" && s.is_decl) {
            if (!name_in(globals_set, s.name)) { push(globals_set, s.name); }
        }
        i <- i + 1;
    }
    // Second pass: check every FnDecl body, and check top-level non-FnDecl
    // statements as a synthetic top frame. The top_scopes here is its own
    // fresh list — kept distinct from globals_set so the same-scope
    // redeclaration check on `var` only catches actual within-pass
    // duplicates, not the globals already pre-collected above.
    var top_scopes <- [[]];
    i <- 0;
    while (i < len(stmts)) {
        var s <- stmts[i];
        if (s.node = "FnDecl") {
            scope_check_fn(s, false, globals_set, fn_names, false);
        } else {
            scope_check_stmt(s, top_scopes, [], globals_set, fn_names);
        }
        i <- i + 1;
    }
    return false;
}

fn check_body(stmts) {
    var i <- 0;
    while (i < len(stmts)) {
        check_stmt(stmts[i]);
        i <- i + 1;
    }
}

// A bool member is fully covered once BOTH literals `true` and `false` have
// appeared — bool has exactly two inhabitants, so the pair is total. Every
// other member is covered only by a type arm or `_` (literals merely refine).
fn match_eff_covered(covered, ms, i: int, seen_lits): int {
    if (covered[i]) { return true; }
    if (ms[i].kind = "bool" && name_in(seen_lits, "bool:true") && name_in(seen_lits, "bool:false")) { return true; }
    return false;
}
// Every element of an array-of-union literal must be a concrete member of
// the union; it is wrapped into that union at construction (see ir_emit_stmt).
fn check_array_union_elements(ln, col, ut, lit) {
    var i <- 0;
    while (i < len(lit.elements)) {
        var et <- typeof_expr(lit.elements[i]);
        if (et.kind = "union") {
            report_error(ln, col, "array element cannot itself yield a union (" + T.type_str(et) + "); each element must be a concrete member of " + T.type_str(ut));
        } else {
            if (union_member_index(ut, et) = -1) {
                report_error(ln, col, T.type_str(et) + " is not a member of " + T.type_str(ut));
            }
        }
        i <- i + 1;
    }
}
// Is `actual`/`src` an acceptable source for an array-of-union target whose
// element union is `ut`? Either an exactly-matching [union] array (same handle,
// already-wrapped cells, so reference semantics are preserved) or an empty array
// literal (nothing to wrap). No implicit element-wise widening.
fn array_union_src_ok(ut, actual, src): int {
    if (actual.kind = "array" && T.type_eq(actual.elem, ut)) { return true; }
    if (src.node = "ArrayLit") { if (len(src.elements) = 0) { return true; } }
    return false;
}
// Declaration-anchored static type of a store-target base expression. For
// identifiers, the declaration type wins over the narrowed/joined tracked
// type: an explicitly declared `[any]` array must stay an unchecked escape
// hatch even after push-refinement narrows what var_types reports.
// Everything else falls back to typeof_expr, which derives from
// declarations and annotations anyway.
// Field-name membership on a struct type's field list. Distinct from
// struct_field_type's none sentinel: a field can legitimately carry type
// `none` (raw-tier params and empty-literal arrays flow into struct
// fields), so "typed none" no longer implies "absent".
fn struct_has_field(fields, fname: str): int {
    var i <- 0;
    while (i < len(fields)) {
        if (fields[i].name = fname) { return true; }
        i <- i + 1;
    }
    return false;
}

fn declared_base_type(e) {
    if (e.node = "Identifier") {
        var dt <- get_decl_type(e.name);
        if (dt.kind != "none") { return dt; }
    }
    return typeof_expr(e);
}

fn check_stmt(s) {
    if (s.node = "Assignment") {
        if (s.type_ann.kind != "none") {
            if (s.type_ann.kind = "array" && s.type_ann.elem.kind = "union") {
                // Array-of-union slot. A literal RHS wraps its elements into the
                // union at construction; a non-literal RHS must already be an
                // exactly-matching [union] array — no implicit element
                // widening, which would silently copy and break reference
                // semantics. An empty literal trivially satisfies either path.
                if (s.expr.node = "ArrayLit") {
                    check_array_union_elements(s.line, s.col, s.type_ann.elem, s.expr);
                } else {
                    var aactual <- typeof_expr(s.expr);
                    if (!array_union_src_ok(s.type_ann.elem, aactual, s.expr)) {
                        report_error(s.line, s.col, "type mismatch: '" + s.name + "' annotated as " + T.type_str(s.type_ann) + " but assigned " + T.type_str(aactual) + " (an array-of-union slot requires an exactly matching [union] source)");
                    }
                }
            } else {
                var actual <- typeof_expr(s.expr);
                if (!T.types_compat(s.type_ann, actual)) {
                    report_error(s.line, s.col, "type mismatch: '" + s.name + "' annotated as " + T.type_str(s.type_ann) + " but assigned " + T.type_str(actual));
                }
            }
        }
        if (s.type_ann.kind = "none") {
            // Bare reassignment to an array-of-union variable: the variable keeps
            // its declared [union] type (see infer_body), so guard the new value
            // exactly like a declaration. A literal wraps and member-checks its
            // elements; any other source must be an exactly-matching [union] array
            // — no implicit element widening, which would store raw cells.
            var lvt <- get_var_type(s.name);
            if (lvt.kind = "array" && lvt.elem.kind = "union") {
                if (s.expr.node = "ArrayLit") {
                    check_array_union_elements(s.line, s.col, lvt.elem, s.expr);
                } else {
                    var rsa <- typeof_expr(s.expr);
                    if (!array_union_src_ok(lvt.elem, rsa, s.expr)) {
                        report_error(s.line, s.col, "cannot reassign '" + s.name + "' (declared " + T.type_str(lvt) + ") from " + T.type_str(rsa) + " (an array-of-union requires an exactly matching [union] source)");
                    }
                }
            } else if (T.union_in_container(lvt)) {
                // A struct-with-union-field (or nested container) keeps its declared
                // type on reassignment; validate the new value against it just like a
                // declaration. A struct/array literal has its union members wrapped at
                // construction; types_compat enforces that each value is a real member.
                var rsv <- typeof_expr(s.expr);
                if (!T.types_compat(lvt, rsv)) {
                    report_error(s.line, s.col, "type mismatch: '" + s.name + "' (declared " + T.type_str(lvt) + ") reassigned " + T.type_str(rsv));
                }
            }
        }
        check_expr(s.expr);
    }
    if (s.node = "CallExpr") {
        // Bare call statement. Only route `push` through the expression checker
        // (for the [union] member-check); general bare-call arg-checking is left
        // off deliberately to preserve the loosely-typed self-host.
        if (s.callee.node = "Identifier" && s.callee.name = "push") { check_expr(s); }
    }
    if (s.node = "PrintStmt") { check_expr(s.expr); }
    if (s.node = "ReturnStmt") {
        if (s.expr != false) {
            check_expr(s.expr);
            if (current_fn[0] != "") {
                var fi <- find_fn(current_fn[0]);
                if (fi != false) {
                    if (fi.ret_type_ann.kind != "none") {
                        var actual <- typeof_expr(s.expr);
                        if (fi.ret_type_ann.kind = "array" && fi.ret_type_ann.elem.kind = "union") {
                            if (!array_union_src_ok(fi.ret_type_ann.elem, actual, s.expr)) {
                                report_error(s.line, s.col, "return type mismatch in '" + current_fn[0] + "': declared " + T.type_str(fi.ret_type_ann) + " but returning " + T.type_str(actual) + " (an array-of-union requires an exactly matching [union] value or an empty array literal)");
                            }
                        } else {
                            if (!T.types_compat(fi.ret_type_ann, actual)) {
                                report_error(s.line, s.col, "return type mismatch in '" + current_fn[0] + "': declared " + T.type_str(fi.ret_type_ann) + " but returning " + T.type_str(actual));
                            }
                        }
                    }
                }
            }
        }
    }
    if (s.node = "IfStmt") {
        check_expr(s.cond);
        check_body(s.then_body);
        check_body(s.else_body);
    }
    if (s.node = "MatchStmt") {
        check_expr(s.scrutinee);
        var ut <- typeof_expr(s.scrutinee);
        if (ut.kind != "union") {
            report_error(s.line, s.col, "match requires a union value, got " + T.type_str(ut));
        } else {
            check_match_coverage(s.line, s.col, s.scrutinee, ut, s.arms);
            var mi <- 0;
            while (mi < len(s.arms)) {
                if (s.arms[mi].wild) {
                    check_body(s.arms[mi].body);
                } else {
                    var pt <- s.arms[mi].ptype;
                    var bn <- match_bind_name(s.arms[mi], s.scrutinee);
                    if (bn != "") {
                        var saved <- get_var_type(bn);
                        set_var_type(bn, pt);
                        check_body(s.arms[mi].body);
                        set_var_type(bn, saved);
                    } else {
                        check_body(s.arms[mi].body);
                    }
                }
                mi <- mi + 1;
            }
        }
    }
    if (s.node = "WhileStmt") {
        check_expr(s.cond);
        check_body(s.body);
    }
    if (s.node = "ForInStmt") {
        check_expr(s.iterable);
        check_body(s.body);
    }
    if (s.node = "Block") { check_body(s.stmts); }
    if (s.node = "IndexAssign") {
        check_expr(s.obj);
        check_expr(s.index);
        check_expr(s.value);
        // An element store must fit the array's declared element type
        // (declaration-anchored). `any`/`none` element types are the
        // unchecked escape hatch; a union element type accepts exactly its
        // members, mirroring the push rule.
        var ibt <- declared_base_type(s.obj);
        if (ibt.kind = "array") {
            var ivt <- typeof_expr(s.value);
            if (ibt.elem.kind = "union") {
                if (ivt.kind != "union") {
                    if (union_member_index(ibt.elem, ivt) = -1) {
                        report_error(expr_pos_line(s.obj), expr_pos_col(s.obj), T.type_str(ivt) + " is not a member of the array element type " + T.type_str(ibt.elem));
                    }
                }
            } else if (ibt.elem.kind != "any" && ibt.elem.kind != "none") {
                if (!T.types_compat(ibt.elem, ivt)) {
                    report_error(expr_pos_line(s.obj), expr_pos_col(s.obj), "type mismatch: array element is " + T.type_str(ibt.elem) + " but assigned " + T.type_str(ivt));
                }
            }
        }
    }
    if (s.node = "DotAssign") {
        check_expr(s.obj);
        check_expr(s.value);
        // The field must exist on the base's declared struct type (a miss
        // segfaults natively via the runtime name-search), and the stored
        // value must fit its declared type. Declaration-anchored on the
        // base; `any`-typed fields are the unchecked escape hatch, and
        // union-typed fields pass through types_compat's member acceptance
        // and are wrapped at codegen.
        var dot <- declared_base_type(s.obj);
        if (dot.kind = "struct_lit") {
            var fft <- T.struct_field_type(dot.fields, s.field);
            if (!struct_has_field(dot.fields, s.field)) {
                report_error(expr_pos_line(s.obj), expr_pos_col(s.obj), "unknown field '" + s.field + "' on " + T.type_str(dot));
            } else if (fft.kind != "any" && fft.kind != "none") {
                var dval <- typeof_expr(s.value);
                if (!T.types_compat(fft, dval)) {
                    report_error(expr_pos_line(s.obj), expr_pos_col(s.obj), "type mismatch: field '" + s.field + "' is " + T.type_str(fft) + " but assigned " + T.type_str(dval));
                }
            }
        }
    }
}

fn expr_pos_line(e): int {
    if (e.node = "Identifier") { return e.line; }
    if (e.node = "CallExpr") { return e.line; }
    if (e.node = "IndexExpr") { return expr_pos_line(e.obj); }
    if (e.node = "DotExpr") { return expr_pos_line(e.obj); }
    return 0;
}
fn expr_pos_col(e): int {
    if (e.node = "Identifier") { return e.col; }
    if (e.node = "CallExpr") { return e.col; }
    if (e.node = "IndexExpr") { return expr_pos_col(e.obj); }
    if (e.node = "DotExpr") { return expr_pos_col(e.obj); }
    return 0;
}
// Reject using a union value where a single concrete type is required. A union
// may only be stored, passed to a union parameter, returned from a union-typed
// function, or printed; anything else must narrow it first with a match.
fn check_no_union(e, what: str) {
    var t <- typeof_expr(e);
    if (t.kind = "union") {
        report_error(expr_pos_line(e), expr_pos_col(e), "cannot use union value of type " + T.type_str(t) + " " + what + "; narrow it to a single type first");
    }
}
fn check_expr(e) {
    if (e.node = "MatchExpr") {
        check_expr(e.scrutinee);
        var mut <- typeof_expr(e.scrutinee);
        if (mut.kind != "union") {
            report_error(e.line, e.col, "match requires a union value, got " + T.type_str(mut));
        } else {
            check_match_coverage(e.line, e.col, e.scrutinee, mut, e.arms);
            var mxi <- 0;
            while (mxi < len(e.arms)) {
                var marm <- e.arms[mxi];
                var mbn <- "";
                if (!marm.wild) { mbn <- match_bind_name(marm, e.scrutinee); }
                var msaved <- T.mk_none();
                var mfsv <- [];
                if (mbn != "") { msaved <- get_var_type(mbn); set_var_type(mbn, marm.ptype); mfsv <- arm_destructure_set_types(marm.ptype); }
                check_expr(marm.value);
                var mavt <- typeof_expr(marm.value);
                if (mavt.kind = "union") {
                    report_error(e.line, e.col, "match-expression arm cannot itself yield a union (" + T.type_str(mavt) + "); narrow it to a single type");
                }
                if (mbn != "") { arm_destructure_restore_types(mfsv); set_var_type(mbn, msaved); }
                mxi <- mxi + 1;
            }
        }
    }
    if (e.node = "BinOp") { check_no_union(e.left, "in arithmetic or comparison"); check_no_union(e.right, "in arithmetic or comparison"); check_expr(e.left); check_expr(e.right); }
    if (e.node = "UnaryOp") { check_no_union(e.operand, "in a unary operation"); check_expr(e.operand); }
    if (e.node = "CallExpr") {
        if (e.callee.node = "Identifier" && e.callee.name = "push" && len(e.args) >= 2) {
            var pat0 <- typeof_expr(e.args[0]);
            if (pat0.kind = "array" && pat0.elem.kind = "union") {
                var pvt <- typeof_expr(e.args[1]);
                if (pvt.kind != "union") {
                    if (union_member_index(pat0.elem, pvt) = -1) {
                        report_error(e.line, e.col, T.type_str(pvt) + " is not a member of the array element type " + T.type_str(pat0.elem));
                    }
                }
            }
            // Conformance for concrete element types: the pushed value must
            // fit the array's declared element type. Declaration-anchored so
            // an explicit `[any]` (and the empty-literal `[any]`) stays an
            // unchecked escape hatch even after push-refinement narrows the
            // tracked type; union elements are handled by the member check
            // above.
            var pdb <- declared_base_type(e.args[0]);
            if (pdb.kind = "array" && pdb.elem.kind != "union" && pdb.elem.kind != "any" && pdb.elem.kind != "none") {
                var pvd <- typeof_expr(e.args[1]);
                if (!T.types_compat(pdb.elem, pvd)) {
                    report_error(e.line, e.col, "type mismatch: pushed " + T.type_str(pvd) + " to array of " + T.type_str(pdb.elem));
                }
            }
        }
        if (e.callee.node = "Identifier") {
            var fi <- find_fn(e.callee.name);
            // If the direct lookup failed, the callee may be a variable holding
            // an arrow function — look up via the var-name → fn-name mapping.
            if (fi = false) {
                var afn_name <- get_arrow_fn_name(e.callee.name);
                if (afn_name != "") { fi <- find_fn(afn_name); }
            }
            if (fi != false) {
                var j <- 0;
                while (j < len(e.args)) {
                    if (j < fi.param_count) {
                        var ann <- fi.param_types_ann[j];
                        // Only check args against EXPLICIT annotations
                        if (ann.kind != "none") {
                            var actual <- typeof_expr(e.args[j]);
                            if (ann.kind = "array" && ann.elem.kind = "union") {
                                if (!array_union_src_ok(ann.elem, actual, e.args[j])) {
                                    report_error(e.line, e.col, "call to '" + e.callee.name + "': argument " + (j + 1) + " expected " + T.type_str(ann) + " but got " + T.type_str(actual) + " (an array-of-union requires an exactly matching [union] argument or an empty array literal)");
                                }
                            } else {
                                if (!T.types_compat(ann, actual)) {
                                    report_error(e.line, e.col, "call to '" + e.callee.name + "': argument " + (j + 1) + " expected " + T.type_str(ann) + " but got " + T.type_str(actual));
                                }
                            }
                        }
                    }
                    j <- j + 1;
                }
            } else {
                // No resolved user/arrow fn: this is a builtin call. No builtin
                // accepts a union argument — reject before it reaches codegen.
                var jb <- 0;
                while (jb < len(e.args)) {
                    check_no_union(e.args[jb], "as an argument to '" + e.callee.name + "'");
                    jb <- jb + 1;
                }
            }
        }
        var j <- 0;
        while (j < len(e.args)) { check_expr(e.args[j]); j <- j + 1; }
    }
    if (e.node = "ArrayLit") {
        var j <- 0;
        while (j < len(e.elements)) { check_expr(e.elements[j]); j <- j + 1; }
    }
    if (e.node = "IndexExpr") { check_no_union(e.obj, "as the target of an index"); check_no_union(e.index, "as an index"); check_expr(e.obj); check_expr(e.index); }
    if (e.node = "DotExpr") {
        check_no_union(e.obj, "as the target of a field access");
        check_expr(e.obj);
        // Reading a field the base's declared struct type doesn't have is
        // an error: natively the runtime name-search misses and the load
        // reads garbage. The declared type is the interface, so a field
        // hidden by width subtyping is inaccessible even when dynamically
        // present; `any`-typed bases stay unchecked.
        var dbt <- declared_base_type(e.obj);
        if (dbt.kind = "struct_lit") {
            if (!struct_has_field(dbt.fields, e.field)) {
                report_error(expr_pos_line(e.obj), expr_pos_col(e.obj), "unknown field '" + e.field + "' on " + T.type_str(dbt));
            }
        }
    }
    if (e.node = "StructLit") {
        var j <- 0;
        while (j < len(e.fields)) { check_expr(e.fields[j].val); j <- j + 1; }
    }
}

fn print_type_errors() {
    // Insertion sort by line for stable, source-order output.
    // Note: type_errors[j].line returns "any" via DotExpr, which would make
    // ">" emit strcmp. Pulling each side into a typed int local forces icmp.
    var i <- 1;
    while (i < len(type_errors)) {
        var j <- i;
        var keep_going <- 1;
        while (j > 0 && keep_going = 1) {
            var a: int <- type_errors[j - 1].line;
            var b: int <- type_errors[j].line;
            if (a > b) {
                var tmp <- type_errors[j - 1];
                type_errors[j - 1] <- type_errors[j];
                type_errors[j] <- tmp;
                j <- j - 1;
            } else {
                keep_going <- 0;
            }
        }
        i <- i + 1;
    }
    i <- 0;
    while (i < len(type_errors)) {
        var e <- type_errors[i];
        // file:line:col: msg (col omitted when 0 — old AST nodes without col
        // info still produce file:line: msg). Mirrors GCC/Clang convention so
        // editors that parse compiler output land at the right column.
        if (e.col > 0) {
            print(src_filename[0] + ":" + e.line + ":" + e.col + ": " + e.msg);
        } else {
            print(src_filename[0] + ":" + e.line + ": " + e.msg);
        }
        i <- i + 1;
    }
    if (len(type_errors) > 0) {
        print("--");
        print(len(type_errors) + " type error(s). Compilation aborted.");
    }
}


fn find_captures(body, params, is_expr: int) {
    var refs <- [];
    // Collect all Identifier references via worklist
    var work <- [];
    if (is_expr = false) {
        var i <- 0;
        while (i < len(body)) { push(work, body[i]); i <- i + 1; }
    } else {
        push(work, body);
    }
    var wi <- 0;
    while (wi < len(work)) {
        var nd <- work[wi];
        wi <- wi + 1;
        if (nd.node = "Identifier") {
            if (!var_exists(refs, nd.name)) { push(refs, nd.name); }
        }
        // Walk children
        if (nd.node = "Assignment") { push(work, nd.expr); }
        if (nd.node = "PrintStmt") { push(work, nd.expr); }
        if (nd.node = "ReturnStmt") { if (nd.expr != false) { push(work, nd.expr); } }
        if (nd.node = "IfStmt") {
            push(work, nd.cond);
            var i <- 0;
            while (i < len(nd.then_body)) { push(work, nd.then_body[i]); i <- i + 1; }
            i <- 0;
            while (i < len(nd.else_body)) { push(work, nd.else_body[i]); i <- i + 1; }
        }
        if (nd.node = "MatchStmt") {
            push(work, nd.scrutinee);
            var mi <- 0;
            while (mi < len(nd.arms)) { var mj <- 0; while (mj < len(nd.arms[mi].body)) { push(work, nd.arms[mi].body[mj]); mj <- mj + 1; } mi <- mi + 1; }
        }
        if (nd.node = "MatchExpr") {
            push(work, nd.scrutinee);
            var mxi <- 0;
            while (mxi < len(nd.arms)) { push(work, nd.arms[mxi].value); mxi <- mxi + 1; }
        }
        if (nd.node = "WhileStmt") {
            push(work, nd.cond);
            var i <- 0;
            while (i < len(nd.body)) { push(work, nd.body[i]); i <- i + 1; }
        }
        if (nd.node = "ForInStmt") {
            push(work, nd.iterable);
            var i <- 0;
            while (i < len(nd.body)) { push(work, nd.body[i]); i <- i + 1; }
        }
        if (nd.node = "BinOp") { push(work, nd.left); push(work, nd.right); }
        if (nd.node = "UnaryOp") { push(work, nd.operand); }
        if (nd.node = "CallExpr") {
            push(work, nd.callee);
            var i <- 0;
            while (i < len(nd.args)) { push(work, nd.args[i]); i <- i + 1; }
        }
        if (nd.node = "ArrayLit") {
            var i <- 0;
            while (i < len(nd.elements)) { push(work, nd.elements[i]); i <- i + 1; }
        }
        if (nd.node = "IndexExpr") { push(work, nd.obj); push(work, nd.index); }
        if (nd.node = "IndexAssign") { push(work, nd.obj); push(work, nd.index); push(work, nd.value); }
        if (nd.node = "DotExpr") { push(work, nd.obj); }
        if (nd.node = "DotAssign") { push(work, nd.obj); push(work, nd.value); }
        if (nd.node = "StructLit") {
            var i <- 0;
            while (i < len(nd.fields)) { push(work, nd.fields[i].val); i <- i + 1; }
        }
    }
    // Filter: keep refs that are NOT params and ARE in current enclosing scope
    var caps <- [];
    var i <- 0;
    while (i < len(refs)) {
        if (!var_exists(params, refs[i])) {
            if (find_var(refs[i]) != "") {
                push(caps, refs[i]);
            }
        }
        i <- i + 1;
    }
    return caps;
}

// Walk an arrow-fn body to find references to outer-scope variables — those
// names become the closure's captured environment. Checks the IR builder's
// locals list to distinguish parameters and inner declarations from outer
// references.
// Collect all identifier references in a body that are NOT in `params`. When
// walking encounters a nested ArrowFn, recurse into the inner's body — its own
// params shadow, but anything else its body references is a "free name" that
// the outer scope might need to provide. This is what enables transitive
// capture through nested closures: e.g. `(mult) => (x) => x + outer_var`
// must capture `outer_var` so the inner can read it from env.
//
// `params_in` is the list of names that shadow at this scope. The output is
// flat — outer-scope names that this body, or any nested ArrowFn body,
// references (after subtracting inner params).
fn ir_collect_refs(body, params_in, is_expr: int) {
    var refs <- [];
    var work <- [];
    if (is_expr = false) {
        var i <- 0;
        while (i < len(body)) { push(work, body[i]); i <- i + 1; }
    } else {
        push(work, body);
    }
    var wi <- 0;
    while (wi < len(work)) {
        var nd <- work[wi];
        wi <- wi + 1;
        if (nd.node = "Identifier") {
            if (!var_exists(params_in, nd.name) && !var_exists(refs, nd.name)) {
                push(refs, nd.name);
            }
        }
        if (nd.node = "ArrowFn") {
            // Inner's params shadow only inside the inner. Recurse with a
            // params list = current params ∪ inner.params, so refs the inner
            // makes to outer-scope names still bubble up.
            var combined <- [];
            var i <- 0; while (i < len(params_in)) { push(combined, params_in[i]); i <- i + 1; }
            i <- 0; while (i < len(nd.params)) { push(combined, nd.params[i]); i <- i + 1; }
            var inner_refs <- ir_collect_refs(nd.body, combined, nd.is_expr);
            i <- 0;
            while (i < len(inner_refs)) {
                if (!var_exists(refs, inner_refs[i])) { push(refs, inner_refs[i]); }
                i <- i + 1;
            }
        }
        if (nd.node = "BinOp")    { push(work, nd.left); push(work, nd.right); }
        if (nd.node = "UnaryOp")  { push(work, nd.operand); }
        if (nd.node = "Assignment") {
            if (!var_exists(params_in, nd.name) && !var_exists(refs, nd.name)) { push(refs, nd.name); }
            push(work, nd.expr);
        }
        if (nd.node = "ReturnStmt" && nd.expr != false) { push(work, nd.expr); }
        if (nd.node = "PrintStmt") { push(work, nd.expr); }
        if (nd.node = "IfStmt")    {
            push(work, nd.cond);
            var i <- 0; while (i < len(nd.then_body)) { push(work, nd.then_body[i]); i <- i + 1; }
            i <- 0; while (i < len(nd.else_body)) { push(work, nd.else_body[i]); i <- i + 1; }
        }
        if (nd.node = "MatchStmt") {
            push(work, nd.scrutinee);
            var mi <- 0; while (mi < len(nd.arms)) { var mj <- 0; while (mj < len(nd.arms[mi].body)) { push(work, nd.arms[mi].body[mj]); mj <- mj + 1; } mi <- mi + 1; }
        }
        if (nd.node = "MatchExpr") {
            push(work, nd.scrutinee);
            var mxi <- 0;
            while (mxi < len(nd.arms)) { push(work, nd.arms[mxi].value); mxi <- mxi + 1; }
        }
        if (nd.node = "WhileStmt") {
            push(work, nd.cond);
            var i <- 0; while (i < len(nd.body)) { push(work, nd.body[i]); i <- i + 1; }
        }
        if (nd.node = "ForInStmt") {
            push(work, nd.iterable);
            var i <- 0; while (i < len(nd.body)) { push(work, nd.body[i]); i <- i + 1; }
        }
        if (nd.node = "Block") {
            var i <- 0; while (i < len(nd.stmts)) { push(work, nd.stmts[i]); i <- i + 1; }
        }
        if (nd.node = "CallExpr") {
            push(work, nd.callee);
            var i <- 0; while (i < len(nd.args)) { push(work, nd.args[i]); i <- i + 1; }
        }
        if (nd.node = "ArrayLit") {
            var i <- 0; while (i < len(nd.elements)) { push(work, nd.elements[i]); i <- i + 1; }
        }
        if (nd.node = "IndexExpr")    { push(work, nd.obj); push(work, nd.index); }
        if (nd.node = "IndexAssign")  { push(work, nd.obj); push(work, nd.index); push(work, nd.value); }
        if (nd.node = "DotExpr")      { push(work, nd.obj); }
        if (nd.node = "DotAssign")    { push(work, nd.obj); push(work, nd.value); }
        if (nd.node = "StructLit")    {
            var i <- 0; while (i < len(nd.fields)) { push(work, nd.fields[i].val); i <- i + 1; }
        }
    }
    return refs;
}

fn ir_find_captures(b, body, params, is_expr: int) {
    // Collect refs (recursing into nested ArrowFn) then filter to those that
    // resolve in the outer builder's locals — those are the ones we need to
    // copy into the env for this closure.
    var refs <- ir_collect_refs(body, params, is_expr);
    var caps <- [];
    var i <- 0;
    while (i < len(refs)) {
        var j <- 0;
        var found <- false;
        while (j < len(b.locals)) {
            if (b.locals[j].name = refs[i]) { found <- true; }
            j <- j + 1;
        }
        if (found) { push(caps, refs[i]); }
        i <- i + 1;
    }
    return caps;
}

// walk the function body finding every nested ArrowFn, and union
// the set of OUR locals that any of them captures. The returned names
// are the ones we need to heap-box at function entry so closures can
// share writable state with us. (For top-level globals captured by a
// closure we don't box anything — globals are already by-reference via
// @g_<n> direct access.)
fn ir_find_my_captured_locals(b, body) {
    var captured <- [];
    // Walk body with the same shape ir_collect_refs uses, but only harvest
    // refs from inside ArrowFn nodes. Anything OUR body references at the
    // top level is just our own usage and doesn't need boxing.
    var work <- [];
    var i <- 0;
    while (i < len(body)) { push(work, body[i]); i <- i + 1; }
    var wi <- 0;
    while (wi < len(work)) {
        var nd <- work[wi];
        wi <- wi + 1;
        if (nd.node = "ArrowFn") {
            // ir_collect_refs descends into nested closures too, so we
            // get transitively-captured names in a single call.
            var refs <- ir_collect_refs(nd.body, nd.params, nd.is_expr);
            var ri <- 0;
            while (ri < len(refs)) {
                var nm <- refs[ri];
                var is_ours <- false;
                var li <- 0;
                while (li < len(b.locals)) {
                    if (b.locals[li].name = nm) { is_ours <- true; }
                    li <- li + 1;
                }
                if (is_ours && !var_exists(captured, nm)) { push(captured, nm); }
                ri <- ri + 1;
            }
        }
        // Descend through compound shapes to reach nested ArrowFns. Use
        // the same shape lookup as ir_collect_refs.
        if (nd.node = "BinOp")    { push(work, nd.left); push(work, nd.right); }
        if (nd.node = "UnaryOp")  { push(work, nd.operand); }
        if (nd.node = "Assignment") { push(work, nd.expr); }
        if (nd.node = "ReturnStmt" && nd.expr != false) { push(work, nd.expr); }
        if (nd.node = "PrintStmt") { push(work, nd.expr); }
        if (nd.node = "IfStmt")    {
            push(work, nd.cond);
            var k <- 0; while (k < len(nd.then_body)) { push(work, nd.then_body[k]); k <- k + 1; }
            k <- 0; while (k < len(nd.else_body)) { push(work, nd.else_body[k]); k <- k + 1; }
        }
        if (nd.node = "MatchStmt") {
            push(work, nd.scrutinee);
            var mi <- 0; while (mi < len(nd.arms)) { var mj <- 0; while (mj < len(nd.arms[mi].body)) { push(work, nd.arms[mi].body[mj]); mj <- mj + 1; } mi <- mi + 1; }
        }
        if (nd.node = "MatchExpr") {
            push(work, nd.scrutinee);
            var mxi <- 0;
            while (mxi < len(nd.arms)) { push(work, nd.arms[mxi].value); mxi <- mxi + 1; }
        }
        if (nd.node = "WhileStmt") {
            push(work, nd.cond);
            var k <- 0; while (k < len(nd.body)) { push(work, nd.body[k]); k <- k + 1; }
        }
        if (nd.node = "ForInStmt") {
            push(work, nd.iterable);
            var k <- 0; while (k < len(nd.body)) { push(work, nd.body[k]); k <- k + 1; }
        }
        if (nd.node = "Block") {
            var k <- 0; while (k < len(nd.stmts)) { push(work, nd.stmts[k]); k <- k + 1; }
        }
        if (nd.node = "CallExpr") {
            push(work, nd.callee);
            var k <- 0; while (k < len(nd.args)) { push(work, nd.args[k]); k <- k + 1; }
        }
        if (nd.node = "ArrayLit") {
            var k <- 0; while (k < len(nd.elements)) { push(work, nd.elements[k]); k <- k + 1; }
        }
        if (nd.node = "IndexExpr")    { push(work, nd.obj); push(work, nd.index); }
        if (nd.node = "IndexAssign")  { push(work, nd.obj); push(work, nd.index); push(work, nd.value); }
        if (nd.node = "DotExpr")      { push(work, nd.obj); }
        if (nd.node = "DotAssign")    { push(work, nd.obj); push(work, nd.value); }
        if (nd.node = "StructLit")    {
            var k <- 0; while (k < len(nd.fields)) { push(work, nd.fields[k].val); k <- k + 1; }
        }
    }
    return captured;
}

// ── Emit arena allocator helper ─────────

fn emit_arena_helper() {
    emit("@arena_base = global ptr null");
    emit("@arena_offset = global i64 0");
    emit("@arena_cap = global i64 0");
    emit("");
    emit("define void @arena_init(i64 %size) {");
    emit("entry:");
    emit("  %p = call ptr @malloc(i64 %size)");
    emit("  store ptr %p, ptr @arena_base");
    emit("  store i64 0, ptr @arena_offset");
    emit("  store i64 %size, ptr @arena_cap");
    emit("  ret void");
    emit("}");
    emit("");
    emit("define ptr @arena_alloc(i64 %size) {");
    emit("entry:");
    emit("  %off = load i64, ptr @arena_offset");
    emit("  %cap = load i64, ptr @arena_cap");
    emit("  %s1 = add i64 %size, 7");
    emit("  %aligned = and i64 %s1, -8");
    emit("  %new_off = add i64 %off, %aligned");
    emit("  %fits = icmp sle i64 %new_off, %cap");
    emit("  br i1 %fits, label %bump, label %fallback");
    emit("fallback:");
    emit("  %fb = call ptr @malloc(i64 %aligned)");
    emit("  ret ptr %fb");
    emit("bump:");
    emit("  %base = load ptr, ptr @arena_base");
    emit("  %ptr = getelementptr i8, ptr %base, i64 %off");
    emit("  store i64 %new_off, ptr @arena_offset");
    emit("  ret ptr %ptr");
    emit("}");
    emit("");
}

// ── Emit safe strcmp helper ─────────────
// Handles "any" type comparisons safely: if either value looks like
// a small integer (< 1MB), use pointer/integer comparison.
// Otherwise, treat as string pointers and use strcmp.
fn emit_safe_strcmp_helper() {
    emit("define i32 @arrow_safe_strcmp(ptr %a, ptr %b) {");
    emit("entry:");
    emit("  %ai = ptrtoint ptr %a to i64");
    emit("  %bi = ptrtoint ptr %b to i64");
    emit("  %a_small = icmp ult i64 %ai, 1048576");
    emit("  %b_small = icmp ult i64 %bi, 1048576");
    emit("  %either_small = or i1 %a_small, %b_small");
    emit("  br i1 %either_small, label %intcmp, label %strcmp");
    emit("strcmp:");
    emit("  %sr = call i32 @strcmp(ptr %a, ptr %b)");
    emit("  ret i32 %sr");
    emit("intcmp:");
    // Real 3-way compare so the result works for <, >, <=, >= as well as = / !=.
    // Returning i32 -1 / 0 / +1 mirrors strcmp's contract; the caller does
    // `icmp <pred> i64 sc, 0` and gets the right answer for every relational op.
    emit("  %lt = icmp slt i64 %ai, %bi");
    emit("  %gt = icmp sgt i64 %ai, %bi");
    emit("  %r1 = select i1 %lt, i32 -1, i32 0");
    emit("  %ir = select i1 %gt, i32 1, i32 %r1");
    emit("  ret i32 %ir");
    emit("}");
    emit("");

    // arrow_to_str: runtime conversion of "any" value to string pointer
    // If value < 1MB, it's an integer → convert via itoa
    // Otherwise, it's already a string pointer → use as-is
    emit("define ptr @arrow_to_str(i64 %val) {");
    emit("entry:");
    emit("  %small = icmp ult i64 %val, 1048576");
    emit("  br i1 %small, label %do_itoa, label %use_ptr");
    emit("do_itoa:");
    emit("  %s = call ptr @arrow_itoa(i64 %val)");
    emit("  ret ptr %s");
    emit("use_ptr:");
    emit("  %p = inttoptr i64 %val to ptr");
    emit("  ret ptr %p");
    emit("}");
    emit("");
}

// ── Emit push helper ────────────────────

fn emit_push_helper() {
    // arrow_push returns the (possibly reallocated) array pointer as i64
    emit("define i64 @arrow_push(i64 %arr.i, i64 %val) {");
    emit("entry:");
    emit("  %arr = inttoptr i64 %arr.i to ptr");
    emit("  %lenp = getelementptr i64, ptr %arr, i64 0");
    emit("  %len = load i64, ptr %lenp");
    emit("  %capp = getelementptr i64, ptr %arr, i64 1");
    emit("  %cap = load i64, ptr %capp");
    // Check if we need to grow
    emit("  %full = icmp sge i64 %len, %cap");
    emit("  br i1 %full, label %grow, label %store");
    emit("grow:");
    // Double capacity, realloc entire block
    emit("  %newcap = mul i64 %cap, 2");
    emit("  %newtotal = add i64 %newcap, 2");
    emit("  %newbytes = mul i64 %newtotal, 8");
    emit("  %newptr = call ptr @realloc(ptr %arr, i64 %newbytes)");
    // Update cap
    emit("  %ncapp = getelementptr i64, ptr %newptr, i64 1");
    emit("  store i64 %newcap, ptr %ncapp");
    // Store element
    emit("  %nlenp = getelementptr i64, ptr %newptr, i64 0");
    emit("  %nlen = load i64, ptr %nlenp");
    emit("  %noff = add i64 %nlen, 2");
    emit("  %nep = getelementptr i64, ptr %newptr, i64 %noff");
    emit("  store i64 %val, ptr %nep");
    emit("  %nlen2 = add i64 %nlen, 1");
    emit("  store i64 %nlen2, ptr %nlenp");
    emit("  %ri = ptrtoint ptr %newptr to i64");
    emit("  ret i64 %ri");
    emit("store:");
    emit("  %off = add i64 %len, 2");
    emit("  %ep = getelementptr i64, ptr %arr, i64 %off");
    emit("  store i64 %val, ptr %ep");
    emit("  %nlen3 = add i64 %len, 1");
    emit("  store i64 %nlen3, ptr %lenp");
    emit("  ret i64 %arr.i");
    emit("}");
    emit("");
}

// ── Emit array concat helper ────────────
// arrow_array_concat(a, b) allocates a fresh array containing the elements
// of `a` followed by `b`. Layout matches `arrow_push`: [len, cap, elems...]
// where each cell is i64. Used to lower `arr_a + arr_b` at the IR level.

fn emit_array_concat_helper() {
    emit("define i64 @arrow_array_concat(i64 %a.i, i64 %b.i) {");
    emit("entry:");
    emit("  %a = inttoptr i64 %a.i to ptr");
    emit("  %b = inttoptr i64 %b.i to ptr");
    emit("  %alenp = getelementptr i64, ptr %a, i64 0");
    emit("  %alen = load i64, ptr %alenp");
    emit("  %blenp = getelementptr i64, ptr %b, i64 0");
    emit("  %blen = load i64, ptr %blenp");
    emit("  %newlen = add i64 %alen, %blen");
    // total cells = header (2) + newlen elems
    emit("  %total = add i64 %newlen, 2");
    emit("  %bytes = mul i64 %total, 8");
    emit("  %newptr = call ptr @malloc(i64 %bytes)");
    // Write header: len, cap (cap = newlen, no slack).
    emit("  %nlenp = getelementptr i64, ptr %newptr, i64 0");
    emit("  store i64 %newlen, ptr %nlenp");
    emit("  %ncapp = getelementptr i64, ptr %newptr, i64 1");
    emit("  store i64 %newlen, ptr %ncapp");
    // Copy a's elements: for i in 0..alen, newptr[i+2] = a[i+2]
    emit("  %ai_slot = alloca i64");
    emit("  store i64 0, ptr %ai_slot");
    emit("  br label %a_cond");
    emit("a_cond:");
    emit("  %ai = load i64, ptr %ai_slot");
    emit("  %a_done = icmp sge i64 %ai, %alen");
    emit("  br i1 %a_done, label %b_start, label %a_body");
    emit("a_body:");
    emit("  %a_src_off = add i64 %ai, 2");
    emit("  %a_src = getelementptr i64, ptr %a, i64 %a_src_off");
    emit("  %a_val = load i64, ptr %a_src");
    emit("  %a_dst = getelementptr i64, ptr %newptr, i64 %a_src_off");
    emit("  store i64 %a_val, ptr %a_dst");
    emit("  %ai_next = add i64 %ai, 1");
    emit("  store i64 %ai_next, ptr %ai_slot");
    emit("  br label %a_cond");
    // Copy b's elements: for i in 0..blen, newptr[i+2+alen] = b[i+2]
    emit("b_start:");
    emit("  %bi_slot = alloca i64");
    emit("  store i64 0, ptr %bi_slot");
    emit("  br label %b_cond");
    emit("b_cond:");
    emit("  %bi = load i64, ptr %bi_slot");
    emit("  %b_done = icmp sge i64 %bi, %blen");
    emit("  br i1 %b_done, label %done, label %b_body");
    emit("b_body:");
    emit("  %b_src_off = add i64 %bi, 2");
    emit("  %b_src = getelementptr i64, ptr %b, i64 %b_src_off");
    emit("  %b_val = load i64, ptr %b_src");
    emit("  %b_dst_idx = add i64 %bi, %alen");
    emit("  %b_dst_off = add i64 %b_dst_idx, 2");
    emit("  %b_dst = getelementptr i64, ptr %newptr, i64 %b_dst_off");
    emit("  store i64 %b_val, ptr %b_dst");
    emit("  %bi_next = add i64 %bi, 1");
    emit("  store i64 %bi_next, ptr %bi_slot");
    emit("  br label %b_cond");
    emit("done:");
    emit("  %ri = ptrtoint ptr %newptr to i64");
    emit("  ret i64 %ri");
    emit("}");
    emit("");
}

fn emit_pop_helper() {
    // arrow_pop(arr) -> element at index len-1; decrements len in place.
    // On empty array: prints "Error: pop from empty array" and exits(1).
    emit("@.str.pop_empty = private constant [29 x i8] c\"Error: pop from empty array\\0A\\00\"");
    emit("define i64 @arrow_pop(i64 %arr.i) {");
    emit("entry:");
    emit("  %arr = inttoptr i64 %arr.i to ptr");
    emit("  %lenp = getelementptr i64, ptr %arr, i64 0");
    emit("  %len = load i64, ptr %lenp");
    emit("  %empty = icmp sle i64 %len, 0");
    emit("  br i1 %empty, label %fail, label %ok");
    emit("fail:");
    emit("  call i32 @printf(ptr @.str.pop_empty)");
    emit("  call void @exit(i32 1)");
    emit("  unreachable");
    emit("ok:");
    emit("  %newlen = sub i64 %len, 1");
    emit("  %off = add i64 %newlen, 2");
    emit("  %ep = getelementptr i64, ptr %arr, i64 %off");
    emit("  %val = load i64, ptr %ep");
    emit("  store i64 %newlen, ptr %lenp");
    emit("  ret i64 %val");
    emit("}");
    emit("");
}

// ── Emit runtime trap helpers ───────────
//
// Bounds-checked element access, checked string indexing, and
// zero-checked integer division/modulo. On an invalid operation each
// helper prints the exact one-line message the interpreter prints and
// exits with code 1, so interp/native parity extends to failing
// programs. Array layout is the usual [len, cap, elems...]; strings
// are NUL-terminated, so the string check pays a strlen.
fn emit_trap_helpers() {
    emit("@.rt.oob = private constant [47 x i8] c\"Error: Index %lld out of bounds (length %lld)\\0A\\00\"");
    emit("@.rt.div0 = private constant [25 x i8] c\"Error: Division by zero\\0A\\00\"");
    emit("@.rt.mod0 = private constant [23 x i8] c\"Error: Modulo by zero\\0A\\00\"");
    emit("define i64 @arrow_index_get(i64 %arr.i, i64 %idx) {");
    emit("entry:");
    emit("  %arr = inttoptr i64 %arr.i to ptr");
    emit("  %len = load i64, ptr %arr");
    emit("  %neg = icmp slt i64 %idx, 0");
    emit("  %big = icmp sge i64 %idx, %len");
    emit("  %bad = or i1 %neg, %big");
    emit("  br i1 %bad, label %trap, label %ok");
    emit("trap:");
    emit("  call i32 (ptr, ...) @printf(ptr @.rt.oob, i64 %idx, i64 %len)");
    emit("  call void @exit(i32 1)");
    emit("  unreachable");
    emit("ok:");
    emit("  %off = add i64 %idx, 2");
    emit("  %ep = getelementptr i64, ptr %arr, i64 %off");
    emit("  %v = load i64, ptr %ep");
    emit("  ret i64 %v");
    emit("}");
    emit("");
    emit("define void @arrow_index_set(i64 %arr.i, i64 %idx, i64 %val) {");
    emit("entry:");
    emit("  %arr = inttoptr i64 %arr.i to ptr");
    emit("  %len = load i64, ptr %arr");
    emit("  %neg = icmp slt i64 %idx, 0");
    emit("  %big = icmp sge i64 %idx, %len");
    emit("  %bad = or i1 %neg, %big");
    emit("  br i1 %bad, label %trap, label %ok");
    emit("trap:");
    emit("  call i32 (ptr, ...) @printf(ptr @.rt.oob, i64 %idx, i64 %len)");
    emit("  call void @exit(i32 1)");
    emit("  unreachable");
    emit("ok:");
    emit("  %off = add i64 %idx, 2");
    emit("  %ep = getelementptr i64, ptr %arr, i64 %off");
    emit("  store i64 %val, ptr %ep");
    emit("  ret void");
    emit("}");
    emit("");
    emit("define i64 @arrow_char_at(i64 %s.i, i64 %idx) {");
    emit("entry:");
    emit("  %sp = inttoptr i64 %s.i to ptr");
    emit("  %len = call i64 @strlen(ptr %sp)");
    emit("  %neg = icmp slt i64 %idx, 0");
    emit("  %big = icmp sge i64 %idx, %len");
    emit("  %bad = or i1 %neg, %big");
    emit("  br i1 %bad, label %trap, label %ok");
    emit("trap:");
    emit("  call i32 (ptr, ...) @printf(ptr @.rt.oob, i64 %idx, i64 %len)");
    emit("  call void @exit(i32 1)");
    emit("  unreachable");
    emit("ok:");
    emit("  %ep = getelementptr i8, ptr %sp, i64 %idx");
    emit("  %ch = load i8, ptr %ep");
    emit("  %buf = call ptr @arena_alloc(i64 2)");
    emit("  store i8 %ch, ptr %buf");
    emit("  %np = getelementptr i8, ptr %buf, i64 1");
    emit("  store i8 0, ptr %np");
    emit("  %r = ptrtoint ptr %buf to i64");
    emit("  ret i64 %r");
    emit("}");
    emit("");
    emit("define i64 @arrow_div(i64 %a, i64 %b) {");
    emit("entry:");
    emit("  %z = icmp eq i64 %b, 0");
    emit("  br i1 %z, label %trap, label %ok");
    emit("trap:");
    emit("  call i32 @printf(ptr @.rt.div0)");
    emit("  call void @exit(i32 1)");
    emit("  unreachable");
    emit("ok:");
    emit("  %q = sdiv i64 %a, %b");
    emit("  ret i64 %q");
    emit("}");
    emit("");
    emit("define i64 @arrow_rem(i64 %a, i64 %b) {");
    emit("entry:");
    emit("  %z = icmp eq i64 %b, 0");
    emit("  br i1 %z, label %trap, label %ok");
    emit("trap:");
    emit("  call i32 @printf(ptr @.rt.mod0)");
    emit("  call void @exit(i32 1)");
    emit("  unreachable");
    emit("ok:");
    emit("  %q = srem i64 %a, %b");
    emit("  ret i64 %q");
    emit("}");
    emit("");
    // Checked any-cell unwrap: verifies the cell tag against the
    // expected kind (want; 8 = the indexable sentinel accepting str or
    // array), promotes int/bool payloads to double bits when a float is
    // expected (mirrors the static fsi promote), passes opaque (7)
    // unconditionally, and otherwise prints the exact interpreter trap
    // and exits 1. Emission side: ir_unwrap_any_checked.
    emit("@.rt.anyexp = private constant [35 x i8] c\"Error: expected %s in any, got %s\\0A\\00\"");
    emit("@.rt.kint = private constant [4 x i8] c\"int\\00\"");
    emit("@.rt.kfloat = private constant [6 x i8] c\"float\\00\"");
    emit("@.rt.kbool = private constant [5 x i8] c\"bool\\00\"");
    emit("@.rt.kstr = private constant [4 x i8] c\"str\\00\"");
    emit("@.rt.karr = private constant [6 x i8] c\"array\\00\"");
    emit("@.rt.kstruct = private constant [7 x i8] c\"struct\\00\"");
    emit("@.rt.kfn = private constant [3 x i8] c\"fn\\00\"");
    emit("@.rt.kopq = private constant [7 x i8] c\"opaque\\00\"");
    emit("@.rt.knames = private constant [8 x ptr] [ptr @.rt.kint, ptr @.rt.kfloat, ptr @.rt.kbool, ptr @.rt.kstr, ptr @.rt.karr, ptr @.rt.kstruct, ptr @.rt.kfn, ptr @.rt.kopq]");
    emit("define i64 @arrow_any_unwrap(i64 %cell.i, i64 %want) {");
    emit("entry:");
    emit("  %p = inttoptr i64 %cell.i to ptr");
    emit("  %tag = load i64, ptr %p");
    emit("  %pp = getelementptr i64, ptr %p, i64 1");
    emit("  %pay = load i64, ptr %pp");
    emit("  %eq = icmp eq i64 %tag, %want");
    emit("  br i1 %eq, label %ok, label %ck7");
    emit("ck7:");
    emit("  %is7 = icmp eq i64 %tag, 7");
    emit("  br i1 %is7, label %ok, label %ck8");
    emit("ck8:");
    emit("  %w8 = icmp eq i64 %want, 8");
    emit("  br i1 %w8, label %idx, label %cknum");
    emit("idx:");
    emit("  %t3 = icmp eq i64 %tag, 3");
    emit("  %t4 = icmp eq i64 %tag, 4");
    emit("  %tidx = or i1 %t3, %t4");
    emit("  br i1 %tidx, label %ok, label %trap");
    emit("cknum:");
    emit("  %wn = icmp sle i64 %want, 2");
    emit("  %tn = icmp sle i64 %tag, 2");
    emit("  %bn = and i1 %wn, %tn");
    emit("  br i1 %bn, label %num, label %trap");
    emit("num:");
    emit("  %wf = icmp eq i64 %want, 1");
    emit("  br i1 %wf, label %prom, label %ok");
    emit("prom:");
    emit("  %d = sitofp i64 %pay to double");
    emit("  %pb = bitcast double %d to i64");
    emit("  ret i64 %pb");
    emit("ok:");
    emit("  ret i64 %pay");
    emit("trap:");
    emit("  %wi = select i1 %w8, i64 4, i64 %want");
    emit("  %gw = getelementptr ptr, ptr @.rt.knames, i64 %wi");
    emit("  %wname = load ptr, ptr %gw");
    emit("  %gt = getelementptr ptr, ptr @.rt.knames, i64 %tag");
    emit("  %tname = load ptr, ptr %gt");
    emit("  call i32 (ptr, ...) @printf(ptr @.rt.anyexp, ptr %wname, ptr %tname)");
    emit("  call void @exit(i32 1)");
    emit("  unreachable");
    emit("}");
    emit("");
}

// ── Emit tagged-any runtime helpers ─────
//
// Dispatchers for tagged any-cells: exact printing/formatting, a 3-way
// dynamic compare (same-kind compares by kind, different kinds order by
// tag, opaque falls back to the magnitude heuristic), and a to-string
// used by concatenation. Cells share the union layout; tags are the
// universal namespace from any_tag_of.
fn emit_dyn_helpers() {
    emit("@.dyn.arr = private constant [8 x i8] c\"<array>\\00\"");
    emit("@.dyn.struct = private constant [9 x i8] c\"<struct>\\00\"");
    emit("@.dyn.fnv = private constant [5 x i8] c\"<fn>\\00\"");
    emit("@.dyn.true = private constant [5 x i8] c\"true\\00\"");
    emit("@.dyn.false = private constant [6 x i8] c\"false\\00\"");
    emit("@.dyn.fmtg = private constant [3 x i8] c\"%g\\00\"");
    emit("define void @arrow_print_dyn(i64 %cell) {");
    emit("entry:");
    emit("  %cp = inttoptr i64 %cell to ptr");
    emit("  %tag = load i64, ptr %cp");
    emit("  %pp = getelementptr i64, ptr %cp, i64 1");
    emit("  %pay = load i64, ptr %pp");
    emit("  switch i64 %tag, label %opq [ i64 0, label %ti");
    emit("    i64 1, label %tf");
    emit("    i64 2, label %tb");
    emit("    i64 3, label %ts");
    emit("    i64 4, label %ta");
    emit("    i64 5, label %tt");
    emit("    i64 6, label %tn ]");
    emit("ti:");
    emit("  call i32 (ptr, ...) @printf(ptr @fmt_int, i64 %pay)");
    emit("  call i32 @fflush(ptr null)");
    emit("  ret void");
    emit("tf:");
    emit("  call void @arrow_print_float(i64 %pay)");
    emit("  ret void");
    emit("tb:");
    emit("  call void @arrow_print_bool(i64 %pay)");
    emit("  ret void");
    emit("ts:");
    emit("  %sp = inttoptr i64 %pay to ptr");
    emit("  call i32 @puts(ptr %sp)");
    emit("  call i32 @fflush(ptr null)");
    emit("  ret void");
    emit("ta:");
    emit("  call i32 @puts(ptr @.dyn.arr)");
    emit("  call i32 @fflush(ptr null)");
    emit("  ret void");
    emit("tt:");
    emit("  call i32 @puts(ptr @.dyn.struct)");
    emit("  call i32 @fflush(ptr null)");
    emit("  ret void");
    emit("tn:");
    emit("  call i32 @puts(ptr @.dyn.fnv)");
    emit("  call i32 @fflush(ptr null)");
    emit("  ret void");
    emit("opq:");
    emit("  call void @arrow_print_any(i64 %pay)");
    emit("  ret void");
    emit("}");
    emit("");
    emit("define void @arrow_format_dyn(i64 %cell) {");
    emit("entry:");
    emit("  %cp = inttoptr i64 %cell to ptr");
    emit("  %tag = load i64, ptr %cp");
    emit("  %pp = getelementptr i64, ptr %cp, i64 1");
    emit("  %pay = load i64, ptr %pp");
    emit("  switch i64 %tag, label %opq [ i64 0, label %ti");
    emit("    i64 1, label %tf");
    emit("    i64 2, label %tb");
    emit("    i64 3, label %ts");
    emit("    i64 4, label %ta");
    emit("    i64 5, label %tt");
    emit("    i64 6, label %tn ]");
    emit("ti:");
    emit("  call void @arrow_format_int(i64 %pay)");
    emit("  ret void");
    emit("tf:");
    emit("  call void @arrow_format_float(i64 %pay)");
    emit("  ret void");
    emit("tb:");
    emit("  call void @arrow_format_bool(i64 %pay)");
    emit("  ret void");
    emit("ts:");
    emit("  call void @arrow_format_str_q(i64 %pay)");
    emit("  ret void");
    emit("ta:");
    emit("  call i32 (ptr, ...) @printf(ptr @.dyn.arr)");
    emit("  ret void");
    emit("tt:");
    emit("  call i32 (ptr, ...) @printf(ptr @.dyn.struct)");
    emit("  ret void");
    emit("tn:");
    emit("  call i32 (ptr, ...) @printf(ptr @.dyn.fnv)");
    emit("  ret void");
    emit("opq:");
    emit("  call void @arrow_format_any(i64 %pay)");
    emit("  ret void");
    emit("}");
    emit("");
    emit("define i32 @arrow_dyn_cmp(i64 %t1, i64 %p1, i64 %t2, i64 %p2) {");
    emit("entry:");
    emit("  %o1 = icmp eq i64 %t1, 7");
    emit("  %o2 = icmp eq i64 %t2, 7");
    emit("  %opq = or i1 %o1, %o2");
    emit("  br i1 %opq, label %heur, label %tags");
    emit("heur:");
    emit("  %hp1 = inttoptr i64 %p1 to ptr");
    emit("  %hp2 = inttoptr i64 %p2 to ptr");
    emit("  %hr = call i32 @arrow_safe_strcmp(ptr %hp1, ptr %hp2)");
    emit("  ret i32 %hr");
    emit("tags:");
    emit("  %same = icmp eq i64 %t1, %t2");
    emit("  br i1 %same, label %kind, label %tcmp");
    emit("tcmp:");
    emit("  %tlt = icmp slt i64 %t1, %t2");
    emit("  %tr1 = select i1 %tlt, i32 -1, i32 1");
    emit("  ret i32 %tr1");
    emit("kind:");
    emit("  %isstr = icmp eq i64 %t1, 3");
    emit("  br i1 %isstr, label %scmp, label %kf");
    emit("scmp:");
    emit("  %sp1 = inttoptr i64 %p1 to ptr");
    emit("  %sp2 = inttoptr i64 %p2 to ptr");
    emit("  %sr = call i32 @strcmp(ptr %sp1, ptr %sp2)");
    emit("  ret i32 %sr");
    emit("kf:");
    emit("  %isf = icmp eq i64 %t1, 1");
    emit("  br i1 %isf, label %fcmp3, label %icmp3");
    emit("fcmp3:");
    emit("  %d1 = bitcast i64 %p1 to double");
    emit("  %d2 = bitcast i64 %p2 to double");
    emit("  %flt = fcmp olt double %d1, %d2");
    emit("  %fgt = fcmp ogt double %d1, %d2");
    emit("  %fr1 = select i1 %flt, i32 -1, i32 0");
    emit("  %fr = select i1 %fgt, i32 1, i32 %fr1");
    emit("  ret i32 %fr");
    emit("icmp3:");
    emit("  %lt = icmp slt i64 %p1, %p2");
    emit("  %gt = icmp sgt i64 %p1, %p2");
    emit("  %r1 = select i1 %lt, i32 -1, i32 0");
    emit("  %ir = select i1 %gt, i32 1, i32 %r1");
    emit("  ret i32 %ir");
    emit("}");
    emit("");
    emit("define i64 @arrow_dyn_str(i64 %tag, i64 %pay) {");
    emit("entry:");
    emit("  switch i64 %tag, label %opq [ i64 0, label %ti");
    emit("    i64 1, label %tf");
    emit("    i64 2, label %tb");
    emit("    i64 3, label %ts");
    emit("    i64 4, label %ta");
    emit("    i64 5, label %tt");
    emit("    i64 6, label %tn ]");
    emit("ti:");
    emit("  %is = call ptr @arrow_itoa(i64 %pay)");
    emit("  %ii = ptrtoint ptr %is to i64");
    emit("  ret i64 %ii");
    emit("tf:");
    emit("  %fb = call ptr @arena_alloc(i64 32)");
    emit("  %d = bitcast i64 %pay to double");
    emit("  call i32 (ptr, i64, ptr, ...) @snprintf(ptr %fb, i64 32, ptr @.dyn.fmtg, double %d)");
    emit("  %fi = ptrtoint ptr %fb to i64");
    emit("  ret i64 %fi");
    emit("tb:");
    emit("  %bz = icmp eq i64 %pay, 0");
    emit("  %bp = select i1 %bz, ptr @.dyn.false, ptr @.dyn.true");
    emit("  %bi = ptrtoint ptr %bp to i64");
    emit("  ret i64 %bi");
    emit("ts:");
    emit("  ret i64 %pay");
    emit("ta:");
    emit("  %ai = ptrtoint ptr @.dyn.arr to i64");
    emit("  ret i64 %ai");
    emit("tt:");
    emit("  %ti2 = ptrtoint ptr @.dyn.struct to i64");
    emit("  ret i64 %ti2");
    emit("tn:");
    emit("  %ni = ptrtoint ptr @.dyn.fnv to i64");
    emit("  ret i64 %ni");
    emit("opq:");
    emit("  %op = call ptr @arrow_to_str(i64 %pay)");
    emit("  %oi = ptrtoint ptr %op to i64");
    emit("  ret i64 %oi");
    emit("}");
    emit("");
}

// ── Emit keys helper ────────────────────
//
// arrow_keys(struct_ptr) returns a new [str] of the struct's field names.
// Struct layout (see emit_struct_lit):
//   slot 0      : count n
//   slots 1..n  : values
//   slots n+1.. : name pointers (as i64)
// Output array layout (see emit_array_lit):
//   slot 0      : len
//   slot 1      : cap
//   slots 2..   : elements
fn emit_keys_helper() {
    emit("define i64 @arrow_keys(i64 %s.i) {");
    emit("entry:");
    emit("  %s = inttoptr i64 %s.i to ptr");
    emit("  %np = getelementptr i64, ptr %s, i64 0");
    emit("  %n = load i64, ptr %np");
    // Allocate the result array. Same sizing rule as emit_array_lit: cap=max(n,4096).
    emit("  %cap1 = icmp slt i64 %n, 4096");
    emit("  %cap = select i1 %cap1, i64 4096, i64 %n");
    emit("  %total = add i64 %cap, 2");
    emit("  %bytes = mul i64 %total, 8");
    emit("  %arr = call ptr @malloc(i64 %bytes)");
    emit("  store i64 %n, ptr %arr");
    emit("  %capp = getelementptr i64, ptr %arr, i64 1");
    emit("  store i64 %cap, ptr %capp");
    // Copy name pointers from struct slots [n+1 .. 2n] into array slots [2 .. n+1].
    emit("  br label %loop_cond");
    emit("loop_cond:");
    emit("  %i = phi i64 [0, %entry], [%i_next, %loop_body]");
    emit("  %done = icmp sge i64 %i, %n");
    emit("  br i1 %done, label %exit, label %loop_body");
    emit("loop_body:");
    emit("  %src_off = add i64 %i, %n");
    emit("  %src_off1 = add i64 %src_off, 1");
    emit("  %src_p = getelementptr i64, ptr %s, i64 %src_off1");
    emit("  %name = load i64, ptr %src_p");
    emit("  %dst_off = add i64 %i, 2");
    emit("  %dst_p = getelementptr i64, ptr %arr, i64 %dst_off");
    emit("  store i64 %name, ptr %dst_p");
    emit("  %i_next = add i64 %i, 1");
    emit("  br label %loop_cond");
    emit("exit:");
    emit("  %ri = ptrtoint ptr %arr to i64");
    emit("  ret i64 %ri");
    emit("}");
    emit("");
}

// ── Emit substring helper ───────────────
// Used by the IR-emitter's `substring` op so that the rendered IR stays
// linear (no copy loop inlined per call site). Same semantics as the
// existing inlined version: arena-allocate end-start+1 bytes, byte-copy
// from src+start..src+end, null-terminate, return the new string ptr.
//
// Signature: i64 @arrow_substring(i64 %s, i64 %start, i64 %end)
fn emit_substring_helper() {
    emit("define i64 @arrow_substring(i64 %si, i64 %start, i64 %end) {");
    emit("entry:");
    emit("  %sp = inttoptr i64 %si to ptr");
    emit("  %sl = sub i64 %end, %start");
    emit("  %bs = add i64 %sl, 1");
    emit("  %buf = call ptr @arena_alloc(i64 %bs)");
    emit("  %src = getelementptr i8, ptr %sp, i64 %start");
    emit("  %idx = alloca i64");
    emit("  store i64 0, ptr %idx");
    emit("  br label %cond");
    emit("cond:");
    emit("  %i = load i64, ptr %idx");
    emit("  %cmp = icmp slt i64 %i, %sl");
    emit("  br i1 %cmp, label %body, label %done");
    emit("body:");
    emit("  %i2 = load i64, ptr %idx");
    emit("  %sep = getelementptr i8, ptr %src, i64 %i2");
    emit("  %sch = load i8, ptr %sep");
    emit("  %dep = getelementptr i8, ptr %buf, i64 %i2");
    emit("  store i8 %sch, ptr %dep");
    emit("  %inc = add i64 %i2, 1");
    emit("  store i64 %inc, ptr %idx");
    emit("  br label %cond");
    emit("done:");
    emit("  %ntp = getelementptr i8, ptr %buf, i64 %sl");
    emit("  store i8 0, ptr %ntp");
    emit("  %ri = ptrtoint ptr %buf to i64");
    emit("  ret i64 %ri");
    emit("}");
    emit("");
}

// ── Emit strcat helper ─────────────────
// Used by the IR translator's `+` of strings (op = "strcat" in the IR).
// Each operand is run through @arrow_to_str first, so this works for any
// combination of str / int / any operands without compile-time dispatch.
//
// Signature: i64 @arrow_strcat(i64 %li, i64 %ri)
fn emit_strcat_helper() {
    // Note: @strcpy / @strcat are declared in the module preamble, not here.
    emit("define i64 @arrow_strcat(i64 %li, i64 %ri) {");
    emit("entry:");
    emit("  %lp = call ptr @arrow_to_str(i64 %li)");
    emit("  %rp = call ptr @arrow_to_str(i64 %ri)");
    emit("  %ll = call i64 @strlen(ptr %lp)");
    emit("  %rl = call i64 @strlen(ptr %rp)");
    emit("  %tl = add i64 %ll, %rl");
    emit("  %bs = add i64 %tl, 1");
    emit("  %buf = call ptr @arena_alloc(i64 %bs)");
    emit("  call ptr @strcpy(ptr %buf, ptr %lp)");
    emit("  call ptr @strcat(ptr %buf, ptr %rp)");
    emit("  %res = ptrtoint ptr %buf to i64");
    emit("  ret i64 %res");
    emit("}");
    emit("");
}

// ── Emit read_file helper ───────────────

fn emit_read_file_helper() {
    emit("define ptr @arrow_read_file(ptr %path) {");
    emit("entry:");
    emit("  %fp = call ptr @fopen(ptr %path, ptr @.str.rb)");
    emit("  %fpv = ptrtoint ptr %fp to i64");
    emit("  %is_null = icmp eq i64 %fpv, 0");
    emit("  br i1 %is_null, label %fail, label %ok");
    emit("fail:");
    emit("  %empty = call ptr @arena_alloc(i64 1)");
    emit("  store i8 0, ptr %empty");
    emit("  ret ptr %empty");
    emit("ok:");
    emit("  call i32 @fseek(ptr %fp, i64 0, i32 2)");
    emit("  %size = call i64 @ftell(ptr %fp)");
    emit("  call i32 @fseek(ptr %fp, i64 0, i32 0)");
    emit("  %bufsz = add i64 %size, 1");
    emit("  %buf = call ptr @malloc(i64 %bufsz)");
    emit("  call i64 @fread(ptr %buf, i64 1, i64 %size, ptr %fp)");
    emit("  %endp = getelementptr i8, ptr %buf, i64 %size");
    emit("  store i8 0, ptr %endp");
    emit("  call i32 @fclose(ptr %fp)");
    emit("  ret ptr %buf");
    emit("}");
    emit("");
}

// ── Emit write_file helper ──────────────

fn emit_write_file_helper() {
    emit("define i64 @arrow_write_file(ptr %path, ptr %content) {");
    emit("entry:");
    emit("  %fp = call ptr @fopen(ptr %path, ptr @.str.wb)");
    emit("  %fpv = ptrtoint ptr %fp to i64");
    emit("  %is_null = icmp eq i64 %fpv, 0");
    emit("  br i1 %is_null, label %fail, label %ok");
    emit("fail:");
    emit("  ret i64 0");
    emit("ok:");
    emit("  %slen = call i64 @strlen(ptr %content)");
    emit("  %written = call i64 @fwrite(ptr %content, i64 1, i64 %slen, ptr %fp)");
    emit("  call i32 @fclose(ptr %fp)");
    emit("  ret i64 %written");
    emit("}");
    emit("");
}

fn emit_append_file_helper() {
    emit("define i64 @arrow_append_file(ptr %path, ptr %content) {");
    emit("entry:");
    emit("  %fp = call ptr @fopen(ptr %path, ptr @.str.ab)");
    emit("  %fpv = ptrtoint ptr %fp to i64");
    emit("  %is_null = icmp eq i64 %fpv, 0");
    emit("  br i1 %is_null, label %fail, label %ok");
    emit("fail:");
    emit("  ret i64 0");
    emit("ok:");
    emit("  %slen = call i64 @strlen(ptr %content)");
    emit("  %written = call i64 @fwrite(ptr %content, i64 1, i64 %slen, ptr %fp)");
    emit("  call i32 @fclose(ptr %fp)");
    emit("  ret i64 %written");
    emit("}");
    emit("");
}

// ── Emit print helpers ──────────────────
//
// A small family of helpers used by typed printing. The IR emitter walks the
// static type of a `print(x)` argument and composes calls to these for
// composite types (arrays, structs). Primitives have a dedicated outer helper
// (newline-terminated) and a "format" variant used inside collections (no
// newline, strings get quoted).
//
// Constants:
//   @.s.t       "true"
//   @.s.f       "false"
//   @.s.tnl     "true\n"
//   @.s.fnl     "false\n"
//   @.fmt.d     "%lld"
//   @.fmt.s_    "%s"
//   @.fmt.qs_   "\"%s\""

fn emit_print_helpers() {
    // Constants
    emit("@.s.t = private constant [5 x i8] c\"true\\00\"");
    emit("@.s.f = private constant [6 x i8] c\"false\\00\"");
    emit("@.s.tnl = private constant [6 x i8] c\"true\\0A\\00\"");
    emit("@.s.fnl = private constant [7 x i8] c\"false\\0A\\00\"");
    emit("@.fmt.d = private constant [5 x i8] c\"%lld\\00\"");
    emit("@.fmt.s_ = private constant [3 x i8] c\"%s\\00\"");
    emit("@.fmt.qs_ = private constant [5 x i8] c\"\\22%s\\22\\00\"");
    emit("");

    // arrow_print_bool — outer: prints "true\n" or "false\n" + fflush.
    emit("define void @arrow_print_bool(i64 %v) {");
    emit("entry:");
    emit("  %nz = icmp ne i64 %v, 0");
    emit("  %s = select i1 %nz, ptr @.s.tnl, ptr @.s.fnl");
    emit("  call i32 (ptr, ...) @printf(ptr @.fmt.s_, ptr %s)");
    emit("  call i32 @fflush(ptr null)");
    emit("  ret void");
    emit("}");
    emit("");

    // arrow_format_int — inner: prints "%lld" (no newline).
    emit("define void @arrow_format_int(i64 %v) {");
    emit("entry:");
    emit("  call i32 (ptr, ...) @printf(ptr @.fmt.d, i64 %v)");
    emit("  ret void");
    emit("}");
    emit("");

    // arrow_format_str_q — inner: prints "\"%s\"" with surrounding quotes.
    // Takes an i64 holding a string pointer; casts to ptr then printfs.
    emit("define void @arrow_format_str_q(i64 %vi) {");
    emit("entry:");
    emit("  %v = inttoptr i64 %vi to ptr");
    emit("  call i32 (ptr, ...) @printf(ptr @.fmt.qs_, ptr %v)");
    emit("  ret void");
    emit("}");
    emit("");

    // arrow_format_bool — inner: prints "true" or "false" (no newline).
    emit("define void @arrow_format_bool(i64 %v) {");
    emit("entry:");
    emit("  %nz = icmp ne i64 %v, 0");
    emit("  %s = select i1 %nz, ptr @.s.t, ptr @.s.f");
    emit("  call i32 (ptr, ...) @printf(ptr @.fmt.s_, ptr %s)");
    emit("  ret void");
    emit("}");
    emit("");

    // arrow_print_lit — prints an i64-as-cstr-ptr without newline. Used for
    // brackets, separators, and field names when formatting arrays/structs.
    emit("define void @arrow_print_lit(i64 %vi) {");
    emit("entry:");
    emit("  %v = inttoptr i64 %vi to ptr");
    emit("  call i32 (ptr, ...) @printf(ptr @.fmt.s_, ptr %v)");
    emit("  ret void");
    emit("}");
    emit("");

    // arrow_print_newline — emit \n + fflush. Used as the trailing newline
    // for top-level print of composite values, where we've already written
    // the opening/closing brackets piecemeal.
    emit("define void @arrow_print_newline() {");
    emit("entry:");
    emit("  call i32 @putchar(i32 10)");
    emit("  call i32 @fflush(ptr null)");
    emit("  ret void");
    emit("}");
    emit("");

    // ── Float formatting (Python-repr-compatible) ─────────────
    //
    // The goal: produce the shortest decimal string that round-trips to the
    // same double, matching what Python's repr(float) and str(float) do.
    // This is exactly what Grisu / Steele-White solve, but we don't need
    // their speed — only their output. So we do the dumb version:
    //
    //   for precision = 1..17:
    //       snprintf(buf, "%.*g", precision, v)
    //       if strtod(buf) == v: break
    //
    // The first precision that round-trips is, by construction, the shortest
    // round-trippable representation. If we reach 17 (always sufficient for
    // doubles), we stop there. Then, if the result looks like an integer
    // (no '.', no 'e', no 'inf'/'nan' markers), append ".0" to match Python's
    // "always show a decimal point" rule for floats.
    //
    // Constants used:
    //   @.fmt.pg        "%.*g"     for snprintf with width-precision arg
    //   @.fmt.sn        "%s\n"     for printing the formatted buffer + newline
    //   @.special_chars ".enN"     chars that mean "don't append .0"
    emit("@.fmt.pg = private constant [5 x i8] c\"%.*g\\00\"");
    emit("@.fmt.sn = private constant [4 x i8] c\"%s\\0A\\00\"");
    emit("@.special_chars = private constant [5 x i8] c\".enN\\00\"");
    emit("declare i32 @snprintf(ptr, i64, ptr, ...)");
    emit("declare double @strtod(ptr, ptr)");
    emit("declare ptr @strpbrk(ptr, ptr)");
    emit("");

    // Fill `buf` with the formatted text. Caller provides ≥40-byte buffer.
    //
    // We exhaustively try every precision 1..17 with snprintf("%.*g") and keep
    // the SHORTEST output that round-trips through strtod. This matters
    // because, for example, "%.1g" of 10.0 yields "1e+01" (5 chars, parses
    // back to 10.0) while "%.2g" yields "10" (2 chars, also round-trips).
    // Picking the shortest matches Python's repr(float) on every value we've
    // tried, at the cost of a handful of snprintf calls per print.
    emit("define void @arrow_fmt_float_to(double %v, ptr %buf) {");
    emit("entry:");
    emit("  %tmp = alloca [40 x i8]");
    emit("  %best_len = alloca i64");
    emit("  store i64 9999, ptr %best_len");
    emit("  store i8 0, ptr %buf");
    emit("  %prec_slot = alloca i32");
    emit("  store i32 1, ptr %prec_slot");
    emit("  br label %loop");
    emit("loop:");
    emit("  %prec = load i32, ptr %prec_slot");
    emit("  call i32 (ptr, i64, ptr, ...) @snprintf(ptr %tmp, i64 40, ptr @.fmt.pg, i32 %prec, double %v)");
    emit("  %parsed = call double @strtod(ptr %tmp, ptr null)");
    emit("  %eq = fcmp oeq double %parsed, %v");
    emit("  br i1 %eq, label %check_len, label %inc");
    emit("check_len:");
    emit("  %tmplen = call i64 @strlen(ptr %tmp)");
    emit("  %best = load i64, ptr %best_len");
    emit("  %shorter = icmp slt i64 %tmplen, %best");
    emit("  br i1 %shorter, label %update, label %inc");
    emit("update:");
    emit("  store i64 %tmplen, ptr %best_len");
    emit("  call ptr @strcpy(ptr %buf, ptr %tmp)");
    emit("  br label %inc");
    emit("inc:");
    emit("  %p1 = add i32 %prec, 1");
    emit("  store i32 %p1, ptr %prec_slot");
    emit("  %toomany = icmp sgt i32 %p1, 17");
    emit("  br i1 %toomany, label %done_fmt, label %loop");
    emit("done_fmt:");
    emit("  %special = call ptr @strpbrk(ptr %buf, ptr @.special_chars)");
    emit("  %has_special = icmp ne ptr %special, null");
    emit("  br i1 %has_special, label %retv, label %appdot");
    emit("appdot:");
    emit("  %len = call i64 @strlen(ptr %buf)");
    emit("  %end1 = getelementptr i8, ptr %buf, i64 %len");
    emit("  store i8 46, ptr %end1");
    emit("  %len1 = add i64 %len, 1");
    emit("  %end2 = getelementptr i8, ptr %buf, i64 %len1");
    emit("  store i8 48, ptr %end2");
    emit("  %len2 = add i64 %len, 2");
    emit("  %end3 = getelementptr i8, ptr %buf, i64 %len2");
    emit("  store i8 0, ptr %end3");
    emit("  br label %retv");
    emit("retv:");
    emit("  ret void");
    emit("}");
    emit("");

    // arrow_print_float — outer (top-level print): formats + newline + fflush.
    emit("define void @arrow_print_float(i64 %vi) {");
    emit("entry:");
    emit("  %v = bitcast i64 %vi to double");
    emit("  %buf = alloca [40 x i8]");
    emit("  call void @arrow_fmt_float_to(double %v, ptr %buf)");
    emit("  call i32 (ptr, ...) @printf(ptr @.fmt.sn, ptr %buf)");
    emit("  call i32 @fflush(ptr null)");
    emit("  ret void");
    emit("}");
    emit("");

    // arrow_format_float — inner (inside arrays / structs): no newline.
    emit("define void @arrow_format_float(i64 %vi) {");
    emit("entry:");
    emit("  %v = bitcast i64 %vi to double");
    emit("  %buf = alloca [40 x i8]");
    emit("  call void @arrow_fmt_float_to(double %v, ptr %buf)");
    emit("  call i32 (ptr, ...) @printf(ptr @.fmt.s_, ptr %buf)");
    emit("  ret void");
    emit("}");
    emit("");

    // ── Runtime fallback for `any` ────────────
    //
    // When a value's static type was lost to `any` (e.g. an unannotated
    // function return, or a field whose type joined across mixed-shape
    // literals), we don't know at compile time whether to print it as int
    // or string. The heuristic — same one used by arrow_safe_strcmp —
    // checks the value's magnitude:
    //
    //   < 1 MiB    → treat as int (real ints rarely reach 2^20)
    //   ≥ 1 MiB    → treat as a pointer to a C string
    //
    // It's not bulletproof (floats stored in `any` slots have bit patterns
    // above the threshold, large counters can land below pointer space)
    // but it correctly handles the common cases: small ints, all string
    // pointers in our arena. We accept the trade-off because the alternative
    // is no output at all for these values.
    emit("define void @arrow_print_any(i64 %v) {");
    emit("entry:");
    emit("  %small = icmp ult i64 %v, 1048576");
    emit("  br i1 %small, label %as_int, label %as_str");
    emit("as_int:");
    emit("  call i32 (ptr, ...) @printf(ptr @fmt_int, i64 %v)");
    emit("  call i32 @fflush(ptr null)");
    emit("  ret void");
    emit("as_str:");
    emit("  %sp = inttoptr i64 %v to ptr");
    emit("  call i32 @puts(ptr %sp)");
    emit("  call i32 @fflush(ptr null)");
    emit("  ret void");
    emit("}");
    emit("");

    // arrow_format_any — same dispatch, but no trailing newline; strings get
    // quoted (matching the in-collection formatting of all other primitives).
    emit("define void @arrow_format_any(i64 %v) {");
    emit("entry:");
    emit("  %small = icmp ult i64 %v, 1048576");
    emit("  br i1 %small, label %as_int, label %as_str");
    emit("as_int:");
    emit("  call void @arrow_format_int(i64 %v)");
    emit("  ret void");
    emit("as_str:");
    emit("  call void @arrow_format_str_q(i64 %v)");
    emit("  ret void");
    emit("}");
    emit("");
}

// ── Emit input helper ───────────────────

fn emit_input_helper() {
    emit("define ptr @arrow_input() {");
    emit("entry:");
    emit("  %buf = call ptr @malloc(i64 4096)");
    if (is_win[0] = 1) {
        emit("  %stdin = call ptr @__acrt_iob_func(i32 0)");
    } else if (is_mac[0] = 1) {
        // macOS exposes stdio as __stdinp / __stdoutp / __stderrp.
        emit("  %stdin = load ptr, ptr @__stdinp");
    } else {
        emit("  %stdin = load ptr, ptr @stdin");
    }
    emit("  %result = call ptr @fgets(ptr %buf, i32 4096, ptr %stdin)");
    emit("  %slen = call i64 @strlen(ptr %buf)");
    emit("  %has = icmp sgt i64 %slen, 0");
    emit("  br i1 %has, label %strip, label %done");
    emit("strip:");
    emit("  %li = sub i64 %slen, 1");
    emit("  %lp = getelementptr i8, ptr %buf, i64 %li");
    emit("  %lc = load i8, ptr %lp");
    emit("  %is_nl = icmp eq i8 %lc, 10");
    emit("  %nv = select i1 %is_nl, i8 0, i8 %lc");
    emit("  store i8 %nv, ptr %lp");
    emit("  br label %done");
    emit("done:");
    emit("  ret ptr %buf");
    emit("}");
    emit("");
}

// ═══════════════════════════════════════════
//  MAIN — Read, lex, parse, compile, write, run clang
// ═══════════════════════════════════════════

// Detect platform: try "cmd /c exit 0" which only works on Windows; otherwise
// check whether `uname -s` reports Darwin to identify macOS (which has its own
// stdio symbol naming — __stdinp instead of stdin).
is_win[0] <- 0;
is_mac[0] <- 0;
var rc_detect <- exec_cmd("cmd /c exit 0 2>nul");
if (rc_detect = 0) {
    is_win[0] <- 1;
} else {
    // Clean up "nul" file created by redirect on Unix
    exec_cmd("rm -f nul 2>/dev/null");
    // Probe for macOS via uname; redirect output to a temp file so we don't
    // pollute stdout, then read it back.
    exec_cmd("uname -s > /tmp/.arrow_uname 2>/dev/null");
    var uname_out <- read_file("/tmp/.arrow_uname");
    if (str_len(uname_out) >= 6) {
        if (substring(uname_out, 0, 6) = "Darwin") {
            is_mac[0] <- 1;
        }
    }
    exec_cmd("rm -f /tmp/.arrow_uname 2>/dev/null");
}

// ═══════════════════════════════════════════
//  ARROW IR — data structures & renderer
//
//  The compiler's intermediate representation. User functions and the
//  synthetic __main_logic wrapper are translated through this layer; an
//  LLVM text renderer at the bottom of the section produces the final
//  `.ll` file. The shapes are designed to allow a second backend (e.g.
//  Cranelift, a hand-rolled x86_64 emitter) to consume the same IR
//  module without touching the AST.
//
//  Shapes (all are plain Arrow structs):
//
//    Value =
//      { kind: "reg",        name: str,  type: Type }   // %name
//      { kind: "const_int",  val: int,   type: Type }   // literal integer
//      { kind: "const_str",  id: str,    type: Type }   // @strN (pooled)
//      { kind: "label",      name: str,                 }  // basic-block label
//      { kind: "global",     name: str,  type: Type }   // @g_name
//
//    Instruction =
//      { op: str,            // "add", "strcat", "call", ...
//        dst: str,           // result register name, or "" when void
//        dst_type: Type,     // T.mk_none() when void
//        operands: [Value],  // inputs
//        extra: <any> }      // op-specific (call target, field name, etc.)
//
//    BasicBlock =
//      { label: str,
//        insts: [Instruction],     // non-terminator instructions
//        terminator: Instruction | false }   // br/cond_br/ret/ret_void
//
//    Function =
//      { name: str,
//        params: [{name: str, type: Type}],
//        ret_type: Type,
//        blocks: [BasicBlock],
//        // used during construction:
//        next_reg: [int],          // fresh-register counter (boxed)
//        next_label: [int] }       // fresh-label counter (boxed)
//
//    Module =
//      { functions: [Function],
//        str_table: [{id: str, text: str}],
//        globals:   [{name: str, type: Type}],
//        externs:   [{name: str, params: [Type], ret_type: Type, is_variadic: int}] }
//
//  Terminator discipline: every BasicBlock in a well-formed Function has a
//  non-false terminator at render time. During construction the field can be
//  false; set_terminator(bb, ...) fills it.
//
//  Opcode set (each backend implements its own lowering):
//    Arithmetic (int):   add sub mul sdiv srem neg
//    Compare (int):      icmp_eq icmp_ne icmp_slt icmp_sle icmp_sgt icmp_sge
//    String-aware cmp:   strcmp_eq strcmp_ne  (higher-level than icmp)
//    Logical:            land lor lnot
//    Memory (stack):     alloca load store
//    Memory (heap):      malloc  (treated as extern call by some backends)
//    String ops:         strcat strlen char_code char_at substring from_char_code int_to_str
//    Array ops:          array_new array_len array_get array_set array_push array_pop array_keys
//    Struct ops:         struct_new struct_get struct_set
//    Calls:              call indirect_call
//    Control flow:       br cond_br ret ret_void unreachable
//    Misc:               print io_read_file io_write_file io_append_file io_exec io_input io_args
//                        ptrtoint inttoptr  (only used by the low-level slice of the IR)
//
//  The io_* and ptr*/* ops are placeholders: they may become regular `call`s
//  to externs when the runtime-vs-IR split is fully settled. For now they're
//  first-class so each backend can decide.
// ═══════════════════════════════════════════

// ── Value constructors ──────────────────────────────

fn ir_reg(name: str, t) {
    return {kind: "reg", name: name, type: t};
}

// NOTE: `n` is deliberately unannotated (raw tier), matching
// ir_const_float — NumberLit and match-arm literal tokens carry their
// digits as lexer strings and flow here unconverted; rendering
// concatenates them into IR text, where a digit string and an int are
// indistinguishable. An int annotation here is a lie the interpreter's
// runtime kind checks catch (a none-sourced str at an int-annotated edge).
fn ir_const_int(n) {
    return {kind: "const_int", val: n, type: T.mk_int()};
}

// Float constant: `val` is the source-level text ("1.5", "3.14159", "0.1").
// Rendered as the bare text — LLVM accepts decimal float literals in any
// position that takes a `double` operand (e.g. `fadd double 1.5, %x`).
fn ir_const_float(val) {
    return {kind: "const_float", val: val, type: T.mk_float()};
}

fn ir_const_str(id: str) {
    // id is a string-table id like "str7" (produced by add_string-style API)
    return {kind: "const_str", id: id, type: T.mk_str()};
}

// Variant that takes a custom id (e.g. "fmt") rather than the auto-generated
// "strN". Used by hand-built IR code that wants specific global names.
fn ir_const_str_raw(id: str) {
    return {kind: "const_str", id: id, type: T.mk_str()};
}

fn ir_label(name: str) {
    return {kind: "label", name: name};
}

fn ir_global(name: str, t) {
    return {kind: "global", name: name, type: t};
}

// ── Instruction constructor ─────────────────────────

fn ir_inst(op: str, dst: str, dst_type, operands, extra) {
    return {op: op, dst: dst, dst_type: dst_type, operands: operands, extra: extra};
}

// Convenience: a void instruction (no result).
fn ir_void_inst(op: str, operands, extra) {
    return {op: op, dst: "", dst_type: T.mk_none(), operands: operands, extra: extra};
}

// ── BasicBlock ──────────────────────────────────────

fn ir_block(label: str) {
    return {label: label, insts: [], terminator: false};
}

fn ir_push_inst(bb, inst) {
    push(bb.insts, inst);
    return 0;
}

fn ir_set_terminator(bb, term) {
    bb.terminator <- term;
    return 0;
}

// ── Function ────────────────────────────────────────
//
// Fresh-name counters are boxed (length-1 arrays) so helper fns can mutate them.
fn ir_function(name: str, params, ret_type) {
    return {
        name: name,
        params: params,
        ret_type: ret_type,
        blocks: [],
        next_reg: [0],
        next_label: [0]
    };
}

fn ir_fn_fresh_reg(f, prefix: str): str {
    f.next_reg[0] <- f.next_reg[0] + 1;
    return "%" + prefix + f.next_reg[0];
}

fn ir_fn_fresh_label(f, prefix: str): str {
    f.next_label[0] <- f.next_label[0] + 1;
    return prefix + f.next_label[0];
}

fn ir_fn_add_block(f, bb) {
    push(f.blocks, bb);
    return 0;
}

// ── Module ──────────────────────────────────────────

fn ir_module() {
    return {
        functions: [],
        str_table: [],
        globals: [],
        externs: [],
        // Counter for unique str ids. Using a separate boxed counter (not
        // len(str_table)) sidesteps any quirk in len() called on a struct
        // field after intervening allocations.
        next_str_id: [0],
        // Track which FnDecls have had a "_shim" wrapper emitted, so that
        // higher-order references to the same fn share one shim. Needed for
        // passing regular FnDecls as values (e.g. apply(add, 10, 20)) where
        // the call-site expects a closure pair calling convention.
        shimmed_fns: []
    };
}

fn ir_mod_add_function(m, f) {
    push(m.functions, f);
    return 0;
}

fn ir_mod_add_str(m, text: str): str {
    // Return the id used to refer to this string via ir_const_str. We use
    // a separate next_str_id counter rather than len(m.str_table) for the
    // id generation — the latter was historically fragile under realloc.
    var next_id <- m.next_str_id[0];
    var id <- "str" + next_id;
    m.next_str_id[0] <- next_id + 1;
    push(m.str_table, {id: id, text: text});
    return id;
}

// Variant that takes an explicit id (e.g. "fmt"). Useful for hand-built
// IR test code that wants specific names. Caller is responsible for
// uniqueness.
fn ir_mod_add_str_raw(m, id: str, text: str) {
    push(m.str_table, {id: id, text: text});
    return 0;
}

fn ir_mod_add_global(m, name: str, t) {
    push(m.globals, {name: name, type: t});
    return 0;
}

fn ir_mod_add_extern(m, name: str, params, ret_type, is_variadic: int) {
    push(m.externs, {name: name, params: params, ret_type: ret_type, is_variadic: is_variadic});
    return 0;
}

// ── Convenience instruction builders ────────────────
//
// Each wraps ir_inst with the right operand ordering. Extra field carries
// op-specific data (the callee name for `call`, field name for struct_get, etc.).

fn ii_add(dst: str, l, r)       { return ir_inst("add",     dst, T.mk_int(), [l, r], false); }
fn ii_sub(dst: str, l, r)       { return ir_inst("sub",     dst, T.mk_int(), [l, r], false); }
fn ii_mul(dst: str, l, r)       { return ir_inst("mul",     dst, T.mk_int(), [l, r], false); }
fn ii_sdiv(dst: str, l, r)      { return ir_inst("sdiv",    dst, T.mk_int(), [l, r], false); }
fn ii_srem(dst: str, l, r)      { return ir_inst("srem",    dst, T.mk_int(), [l, r], false); }
fn ii_neg(dst: str, v)          { return ir_inst("neg",     dst, T.mk_int(), [v],    false); }

// ── Float arithmetic ──────────────────
//
// Arrow stores floats in i64 slots via `bitcast double … to i64` so the whole
// ABI (vars, params, arrays, structs, closure envs) stays uniformly i64.
// Each arithmetic site has to:
//   1. Cast each operand from i64 to double (bitcast for floats, sitofp for ints).
//   2. Run the float op in double space.
//   3. Bitcast the double result back to i64 for storage.
//
// Helpers below render exactly one cast or one float op per inst — the binop
// emitter orchestrates the sequence. Operands marked "double-typed" are
// register names that the renderer trusts to already be doubles; mixing them
// with i64 registers will produce LLVM type errors at clang time, which is a
// loud failure mode and helpful for catching codegen bugs.

fn ii_fadd(dst: str, l, r)      { return ir_inst("fadd",    dst, T.mk_float(), [l, r], false); }
fn ii_fsub(dst: str, l, r)      { return ir_inst("fsub",    dst, T.mk_float(), [l, r], false); }
fn ii_fmul(dst: str, l, r)      { return ir_inst("fmul",    dst, T.mk_float(), [l, r], false); }
fn ii_fdiv(dst: str, l, r)      { return ir_inst("fdiv",    dst, T.mk_float(), [l, r], false); }
fn ii_fneg(dst: str, v)         { return ir_inst("fneg",    dst, T.mk_float(), [v],    false); }
// LLVM fcmp predicates: oeq, one, olt, ole, ogt, oge. The "o" variants are
// "ordered" — they return false if either operand is NaN. We use them so
// `nan = nan` is false, matching Python/IEEE.
fn ii_fcmp(dst: str, op: str, l, r) {
    return ir_inst("fcmp", dst, T.mk_int(), [l, r], op);
}

// Cast i64 (storage form of a float) ↔ double.
fn ii_bc_i_to_d(dst: str, v)    { return ir_inst("bc_i_to_d", dst, T.mk_float(), [v], false); }
fn ii_bc_d_to_i(dst: str, v)    { return ir_inst("bc_d_to_i", dst, T.mk_int(),   [v], false); }
// allocate an 8-byte heap cell for a captured local. The
// instruction's dst register holds the cell's address (as i64, the IR's
// universal integer/pointer). Reads/writes against a boxed slot go through
// load/store on this pointer, so closures and the outer function share
// the same memory and see each other's writes.
fn ii_box_alloc(dst: str)       { return ir_inst("box_alloc", dst, T.mk_int(),   [],  false); }
// load through a box pointer. operand is the box ptr held as i64
// (e.g. loaded from a slot, or received as a captured env value); we
// inttoptr it to ptr before the i64 load so LLVM accepts the type.
fn ii_box_load(dst: str, p)     { return ir_inst("box_load",  dst, T.mk_int(),   [p], false); }
// store through a box pointer. operands = [value, box_ptr_i64].
// dst is a scratch register name for the inttoptr — caller passes a
// fresh tmp via ir_fresh_tmp(b, "bsp").
fn ii_box_store(dst: str, v, p)  { return ir_inst("box_store", dst, T.mk_int(), [v, p], false); }
// Cast i64 (an int value) to double via signed int-to-fp.
fn ii_sitofp(dst: str, v)       { return ir_inst("sitofp",    dst, T.mk_float(), [v], false); }
// Cast double back to a signed i64 (truncate-toward-zero).
fn ii_fptosi(dst: str, v)       { return ir_inst("fptosi",    dst, T.mk_int(),   [v], false); }
// Zero-extend i1 → i64. Used after fcmp to get a bool-as-int.
fn ii_zext_i1(dst: str, v)      { return ir_inst("zext_i1",   dst, T.mk_int(),   [v], false); }

fn ii_icmp(dst: str, op: str, l, r) {
    // op is "eq","ne","slt","sle","sgt","sge"
    return ir_inst("icmp", dst, T.mk_int(), [l, r], op);
}

fn ii_strcmp(dst: str, op: str, l, r) {
    return ir_inst("strcmp", dst, T.mk_int(), [l, r], op);
}

fn ii_alloca(dst: str, t)       { return ir_inst("alloca",  dst, t,        [],     false); }
fn ii_load(dst: str, t, ptr)    { return ir_inst("load",    dst, t,        [ptr],  false); }
fn ii_store(val, ptr)           { return ir_void_inst("store",              [val, ptr], false); }

fn ii_strcat(dst: str, l, r)    { return ir_inst("strcat",  dst, T.mk_str(), [l, r], false); }
fn ii_strlen(dst: str, s)       { return ir_inst("strlen",  dst, T.mk_int(), [s],    false); }
fn ii_int_to_str(dst: str, n)   { return ir_inst("int_to_str", dst, T.mk_str(), [n], false); }

// String ops. Each one is lowered inline by the LLVM renderer to match
// what the runtime expects.
fn ii_char_code(dst: str, s)        { return ir_inst("char_code", dst, T.mk_int(), [s], false); }
fn ii_char_at(dst: str, s, idx)     { return ir_inst("char_at",   dst, T.mk_str(), [s, idx], false); }
fn ii_from_char_code(dst: str, n)   { return ir_inst("from_char_code", dst, T.mk_str(), [n], false); }
// substring is delegated to a runtime helper @arrow_substring — keeps the
// IR linear instead of generating a copy loop.
fn ii_substring(dst: str, s, st, ed) { return ir_inst("substring", dst, T.mk_str(), [s, st, ed], false); }

// IO ops — each calls into the corresponding arrow_* runtime helper.
fn ii_read_file(dst: str, path)     { return ir_inst("read_file",   dst, T.mk_str(), [path], false); }
fn ii_write_file(dst: str, p, c)    { return ir_inst("write_file",  dst, T.mk_int(), [p, c], false); }
fn ii_append_file(dst: str, p, c)   { return ir_inst("append_file", dst, T.mk_int(), [p, c], false); }
fn ii_exec_cmd(dst: str, c)         { return ir_inst("exec_cmd",    dst, T.mk_int(), [c], false); }
fn ii_input(dst: str)               { return ir_inst("input",       dst, T.mk_str(), [],   false); }
fn ii_input_with_prompt(dst: str, p) { return ir_inst("input",       dst, T.mk_str(), [p],  false); }

fn ii_array_new(dst: str, elem_type, elems) {
    // elems is [Value]; elem_type is a Type (element kind)
    return ir_inst("array_new", dst, T.mk_array(elem_type), elems, elem_type);
}
fn ii_array_len(dst: str, arr) { return ir_inst("array_len", dst, T.mk_int(), [arr], false); }
fn ii_array_get(dst: str, elem_type, arr, idx) {
    return ir_inst("array_get", dst, elem_type, [arr, idx], false);
}
fn ii_array_set(prefix: str, arr, idx, val) {
    // prefix is a fresh register-name root used by the renderer to synthesize
    // the intermediate cast/GEP/store registers. Caller's responsibility to
    // make it unique within the function (e.g. ir_fresh_tmp(b, "aset")).
    return ir_inst("array_set", prefix, T.mk_none(), [arr, idx, val], false);
}
fn ii_array_push(dst: str, arr, val) {
    // Returns updated array pointer (realloc may move it)
    return ir_inst("array_push", dst, arr.type, [arr, val], false);
}
fn ii_array_concat(dst: str, a, b) {
    // Returns freshly-allocated array containing a's elems followed by b's.
    return ir_inst("array_concat", dst, a.type, [a, b], false);
}
fn ii_array_pop(dst: str, elem_type, arr) {
    return ir_inst("array_pop", dst, elem_type, [arr], false);
}

fn ii_union_new(dst: str, tag, payload) { return ir_inst("union_new", dst, T.mk_int(), [tag, payload], false); }
fn ii_union_tag(dst: str, cell)            { return ir_inst("union_tag", dst, T.mk_int(), [cell], false); }
fn ii_union_payload(dst: str, cell)        { return ir_inst("union_payload", dst, T.mk_int(), [cell], false); }
fn ii_struct_new(dst: str, fields) {
    // fields: [{name: str, val: Value}]
    return ir_inst("struct_new", dst, T.mk_struct(), [], fields);
}
fn ii_struct_get(dst: str, field_type, s, field: str) {
    return ir_inst("struct_get", dst, field_type, [s], field);
}
fn ii_struct_set(prefix: str, s, field: str, val) {
    return ir_inst("struct_set", prefix, T.mk_none(), [s, val], field);
}
fn ii_struct_keys(dst: str, s) {
    return ir_inst("struct_keys", dst, T.mk_array(T.mk_str()), [s], false);
}

fn ii_call(dst: str, ret_type, callee: str, args) {
    return ir_inst("call", dst, ret_type, args, callee);
}
fn ii_indirect_call(dst: str, ret_type, fn_ptr, args) {
    var ops <- [fn_ptr];
    var i <- 0;
    while (i < len(args)) { push(ops, args[i]); i <- i + 1; }
    return ir_inst("indirect_call", dst, ret_type, ops, false);
}

// Closure ops. A closure is represented as a 2-slot heap pair [fn_ptr, env_ptr].
// `closure_make`: build the pair. operands = captured Values; extra = fn_name.
// Returns the pair pointer as i64.
// `closure_call`: load fn_ptr + env_ptr from a pair, indirect-call with env
// prepended to the user args. operands = [pair_ptr, arg0, arg1, ...].
fn ii_closure_make(dst: str, fn_name: str, captures) {
    return ir_inst("closure_make", dst, T.mk_int(), captures, fn_name);
}
fn ii_closure_call(dst: str, ret_type, pair_val, args) {
    var ops <- [pair_val];
    var i <- 0;
    while (i < len(args)) { push(ops, args[i]); i <- i + 1; }
    return ir_inst("closure_call", dst, ret_type, ops, false);
}

fn ii_br(label: str)            { return ir_void_inst("br", [ir_label(label)], false); }
fn ii_cond_br(i1_reg: str, cond, then_lbl: str, else_lbl: str) {
    // i1_reg is the name for the intermediate icmp-ne result (e.g. "%br1").
    // Must be unique within the function — caller's responsibility.
    return ir_inst("cond_br", i1_reg, T.mk_none(), [cond, ir_label(then_lbl), ir_label(else_lbl)], false);
}
fn ii_ret(val)                  { return ir_void_inst("ret", [val], false); }
fn ii_ret_void()                { return ir_void_inst("ret_void", [], false); }
fn ii_unreachable()             { return ir_void_inst("unreachable", [], false); }

// Print: separate ops for int and str so the lowering can use printf / puts
// without re-deriving the value's type from operand metadata. The AST→IR
// translator picks which one to emit using typeof_expr on the source node.
fn ii_print_int(val)            { return ir_void_inst("print_int", [val], false); }
fn ii_print_str(ptr_reg: str, val) {
    // ptr_reg is the name for the intermediate inttoptr cast (e.g. "%pp1").
    // Caller's responsibility to make it unique within the function.
    return ir_inst("print_str", ptr_reg, T.mk_none(), [val], false);
}
fn ii_print_bool(val)           { return ir_void_inst("print_bool", [val], false); }
fn ii_print_float(val)          { return ir_void_inst("print_float", [val], false); }

// Format helpers — used to compose printed output for composite values.
// These don't add a trailing newline; the translator emits ii_print_newline
// at the end of a top-level composite print.
fn ii_format_int(val)           { return ir_void_inst("format_int", [val], false); }
fn ii_format_str_q(val)         { return ir_void_inst("format_str_q", [val], false); }
fn ii_format_bool(val)          { return ir_void_inst("format_bool", [val], false); }
fn ii_format_float(val)         { return ir_void_inst("format_float", [val], false); }
// Runtime-dispatching variants used when the static type is `any` — they
// use the int-vs-pointer size heuristic to guess whether to format as int
// or as a (quoted) string.
fn ii_print_any(val)            { return ir_void_inst("print_any", [val], false); }
fn ii_format_any(val)           { return ir_void_inst("format_any", [val], false); }
fn ii_print_dyn(val)            { return ir_void_inst("print_dyn", [val], false); }
fn ii_format_dyn(val)           { return ir_void_inst("format_dyn", [val], false); }
fn ii_dyn_cmp(dst: str, t1, p1, t2, p2) { return ir_inst("dyncmp", dst, T.mk_int(), [t1, p1, t2, p2], false); }
fn ii_dyn_str(dst: str, t, p)   { return ir_inst("dyn_str", dst, T.mk_str(), [t, p], false); }
fn ii_print_lit(val)            { return ir_void_inst("print_lit", [val], false); }
fn ii_print_newline()           { return ir_void_inst("print_newline", [], false); }
// Generic print op — translator code prefers the typed variants
// (ii_print_int, ii_print_str), but ii_print stays around as a single hook
// for backends that want one entry point.
fn ii_print(val)                { return ir_void_inst("print", [val], false); }

// Logical NOT: dst = (operand == 0) ? 1 : 0, i64. Used by UnaryOp("!").
fn ii_lnot(dst: str, v)         { return ir_inst("lnot", dst, T.mk_int(), [v], false); }

// Low-level escape hatches for the current runtime:
fn ii_ptrtoint(dst: str, v)     { return ir_inst("ptrtoint", dst, T.mk_int(), [v], false); }
fn ii_inttoptr(dst: str, v)     { return ir_inst("inttoptr", dst, T.mk_any(), [v], false); }

// Render a Module by pushing line-by-line into ir_lines. Avoids the O(N²)
// string-concat blowup that ir_render_module hits for large modules like
// compiler.arrow itself. Output is functionally identical — just streamed
// through ir_lines instead of returned as one big string.
fn ir_render_module_to_lines(m) {
    // Externs
    var i <- 0;
    while (i < len(m.externs)) {
        var ex <- m.externs[i];
        ps <- "";
        var j <- 0;
        while (j < len(ex.params)) {
            if (j > 0) { ps <- ps + ", "; }
            ps <- ps + irr.ir_llvm_type(ex.params[j]);
            j <- j + 1;
        }
        if (ex.is_variadic = 1) {
            if (len(ex.params) > 0) { ps <- ps + ", "; }
            ps <- ps + "...";
        }
        emit("declare " + irr.ir_llvm_type(ex.ret_type) + " @" + ex.name + "(" + ps + ")");
        i <- i + 1;
    }
    // String table
    i <- 0;
    while (i < len(m.str_table)) {
        var ste <- m.str_table[i];
        var bytelen <- irr.ir_str_len(ste.text);
        emit("@" + ste.id + " = private constant [" + bytelen + " x i8] c\"" + irr.ir_escape(ste.text) + "\\00\"");
        i <- i + 1;
    }
    // Globals
    i <- 0;
    while (i < len(m.globals)) {
        emit("@g_" + m.globals[i].name + " = global i64 0");
        i <- i + 1;
    }
    if (len(m.externs) + len(m.str_table) + len(m.globals) > 0) { emit(""); }
    // Functions — render each function's body line-by-line.
    i <- 0;
    while (i < len(m.functions)) {
        ir_render_function_to_lines(m.functions[i]);
        emit("");
        i <- i + 1;
    }
}

fn ir_render_function_to_lines(f) {
    var params_s <- "";
    var i <- 0;
    while (i < len(f.params)) {
        if (i > 0) { params_s <- params_s + ", "; }
        params_s <- params_s + "i64 %" + f.params[i].name + ".arg";
        i <- i + 1;
    }
    emit("define " + irr.ir_llvm_type(f.ret_type) + " @" + f.name + "(" + params_s + ") {");
    i <- 0;
    while (i < len(f.blocks)) {
        ir_render_block_to_lines(f.blocks[i]);
        i <- i + 1;
    }
    emit("}");
}

fn ir_render_block_to_lines(bb) {
    emit(bb.label + ":");
    var i <- 0;
    while (i < len(bb.insts)) {
        emit("  " + irr.ir_render_inst(bb.insts[i]));
        i <- i + 1;
    }
    if (bb.terminator != false) {
        emit("  " + irr.ir_render_inst(bb.terminator));
    }
}

// ═══════════════════════════════════════════
//  ARROW IR — AST → IR translator
//
//  A Builder struct carries state across an in-progress function build:
//    fn           — the IR Function being populated
//    cur_block    — the basic block currently receiving instructions
//    locals       — list of {name, reg} mapping source var → alloca slot
//    tmp_counter  — boxed int for fresh temporary register names
//    block_counter— boxed int for fresh basic-block labels
//
//  The translator covers every AST node the language produces; each
//  ir_emit_stmt / ir_emit_expr branch maps one source-level construct
//  onto a sequence of IR instructions appended to the current block.
// ═══════════════════════════════════════════

fn ir_builder_new(f, entry_bb, mod) {
    return {
        func: f,
        cur_block: entry_bb,
        locals: [],
        tmp_counter: [0],
        block_counter: [0],
        for_idx_counter: [0],
        // The owning module — needed by emitters that allocate string
        // constants or externs (e.g. StringLit, PrintStmt).
        mod: mod,
        // Per-builder map: variable name → {fn_name, param_count} for variables
        // that hold a closure value. Set by Assignment when rhs is an ArrowFn,
        // consulted by CallExpr to emit an indirect call instead of a direct one.
        closure_vars: []
    };
}

// Look up whether a variable holds a closure (was assigned an ArrowFn).
// Returns the {fn_name, param_count} record, or false if not a closure.
fn ir_get_closure(b, name: str) {
    var i <- 0;
    while (i < len(b.closure_vars)) {
        if (b.closure_vars[i].name = name) { return b.closure_vars[i]; }
        i <- i + 1;
    }
    return false;
}

fn ir_set_closure(b, name: str, fn_name: str, param_count: int) {
    push(b.closure_vars, {name: name, fn_name: fn_name, param_count: param_count});
    return 0;
}

fn ir_fresh_tmp(b, prefix: str): str {
    b.tmp_counter[0] <- b.tmp_counter[0] + 1;
    return "%" + prefix + b.tmp_counter[0];
}

fn ir_fresh_block_lbl(b, prefix: str): str {
    b.block_counter[0] <- b.block_counter[0] + 1;
    return prefix + b.block_counter[0];
}

// Look up a local by name, allocating it (with an alloca in the entry block)
// if this is the first reference. Returns the slot register name (e.g. "%c").
fn ir_get_local_slot(b, name: str): str {
    var i <- 0;
    while (i < len(b.locals)) {
        if (b.locals[i].name = name) { return b.locals[i].reg; }
        i <- i + 1;
    }
    var reg <- "%" + name;
    push(b.locals, {name: name, reg: reg, boxed: false, box_owned: false});
    // Always emit allocas in the entry block (first block of the function).
    // LLVM convention; also keeps alloca out of loops where it would reset each iter.
    ir_push_inst(b.func.blocks[0], ii_alloca(reg, T.mk_int()));
    return reg;
}

// Mark an existing local slot as `boxed` — the slot stores a heap-cell
// pointer rather than the value itself. All reads/writes of this name
// go through the indirection. The `owned` flag distinguishes the two
// callers of this function:
//   owned=true   the outer-fn captured-locals pass that allocated the
//                box itself. `var x <- ...` for such a slot writes the
//                initial value through the box pointer — the box IS x's
//                real storage.
//   owned=false  the closure body's capture prologue, receiving a box
//                pointer from env. `var x <- ...` for such a slot
//                shadows the captured binding with a fresh local, so
//                we un-box at the var-decl site instead of writing
//                through.
fn ir_mark_boxed(b, name: str, owned: int) {
    var i <- 0;
    while (i < len(b.locals)) {
        if (b.locals[i].name = name) {
            b.locals[i].boxed <- true;
            b.locals[i].box_owned <- owned;
            return false;
        }
        i <- i + 1;
    }
    return false;
}

// Inverse of ir_mark_boxed: used when `var x` shadows a captured (boxed)
// slot inside a closure body. The slot stays the same alloca, but reads
// and writes after this point treat it as a regular i64 (no deref). The
// previously-captured box is dropped from this closure's view but still
// exists on the heap and is still seen by the outer function — only this
// closure's local binding shadows.
fn ir_unmark_boxed(b, name: str) {
    var i <- 0;
    while (i < len(b.locals)) {
        if (b.locals[i].name = name) {
            b.locals[i].boxed <- false;
            b.locals[i].box_owned <- false;
            return false;
        }
        i <- i + 1;
    }
    return false;
}

fn ir_is_boxed(b, name: str): int {
    var i <- 0;
    while (i < len(b.locals)) {
        if (b.locals[i].name = name) { return b.locals[i].boxed; }
        i <- i + 1;
    }
    return false;
}

// True only when the slot is boxed AND we own that box (allocated it
// ourselves at fn entry). Used to decide whether `var x <- ...` writes
// through the box (we own it → it's x's real storage) or shadows the
// captured binding with a fresh unboxed local (we don't own it).
fn ir_is_box_owned(b, name: str): int {
    var i <- 0;
    while (i < len(b.locals)) {
        if (b.locals[i].name = name) {
            if (b.locals[i].boxed) { return b.locals[i].box_owned; }
            return false;
        }
        i <- i + 1;
    }
    return false;
}

// Box-aware store. If `name`'s slot is boxed, the slot value is a pointer
// (held as i64) to a heap cell; we load that pointer and box_store the
// value through it (box_store handles the inttoptr). Otherwise it's a
// regular alloca and we store the value directly. Used by every
// Assignment write site so boxing stays transparent at the callsites.
fn ir_emit_store_to_slot(b, slot: str, name: str, v) {
    if (ir_is_boxed(b, name)) {
        var ptr_tmp <- ir_fresh_tmp(b, "bxp");
        ir_push_inst(b.cur_block, ii_load(ptr_tmp, T.mk_int(), ir_reg(slot, T.mk_int())));
        var bs_tmp <- ir_fresh_tmp(b, "bsp");
        ir_push_inst(b.cur_block, ii_box_store(bs_tmp, v, ir_reg(ptr_tmp, T.mk_int())));
    } else {
        ir_push_inst(b.cur_block, ii_store(v, ir_reg(slot, T.mk_int())));
    }
    return false;
}

// Non-vivifying lookup: returns true iff the current function already has
// an alloca for `name`. Distinguishes "first write reaches a global" from
// "write to an existing local" without accidentally creating a fresh local
// slot just to ask the question — important for routing in the
// Assignment codegen below.
fn ir_has_local_slot(b, name: str): int {
    var i <- 0;
    while (i < len(b.locals)) {
        if (b.locals[i].name = name) { return true; }
        i <- i + 1;
    }
    return false;
}

// Map an Arrow BinOp comparison op to the LLVM icmp predicate suffix.
fn ir_cmp_op(op: str): str {
    if (op = "=")  { return "eq"; }
    if (op = "!=") { return "ne"; }
    if (op = "<")  { return "slt"; }
    if (op = "<=") { return "sle"; }
    if (op = ">")  { return "sgt"; }
    if (op = ">=") { return "sge"; }
    return "";
}

// fcmp predicates use the "ordered" family (o*) so NaN comparisons return
// false on both sides, matching IEEE semantics and what Python does.
fn ir_fcmp_op(op: str): str {
    if (op = "=")  { return "oeq"; }
    if (op = "!=") { return "one"; }
    if (op = "<")  { return "olt"; }
    if (op = "<=") { return "ole"; }
    if (op = ">")  { return "ogt"; }
    if (op = ">=") { return "oge"; }
    return "";
}

fn ir_is_cmp_op(op: str): int {
    return op = "=" || op = "!=" || op = "<" || op = "<=" || op = ">" || op = ">=";
}

// Cast a Value of i64 storage type to a double-typed register. Used to
// prepare operands for float arithmetic / comparison sites. Returns the
// register name (a string like "%fbc7"); callers wrap it in ir_reg(...).
//
//   float operand  → bitcast i64 → double  (no value change, just reinterpret)
//   int   operand  → sitofp i64 → double    (real numeric promotion)
//   bool / any     → sitofp too — bool is just an int at runtime, and any
//                     gets a numeric promotion which is the most useful default
fn ir_to_double_reg(b, val, t): str {
    if (t.kind = "float") {
        var d <- ir_fresh_tmp(b, "fbc");
        ir_push_inst(b.cur_block, ii_bc_i_to_d(d, val));
        return d;
    }
    var d <- ir_fresh_tmp(b, "fsi");
    ir_push_inst(b.cur_block, ii_sitofp(d, val));
    return d;
}

// Build a "_shim" wrapper around a regular FnDecl so it can be passed as a
// value to higher-order functions, which expect a closure-call convention
// (i64 env first, then user args). The shim simply discards env and forwards
// to the real fn. Idempotent: a second call for the same name is a no-op.
//
//     fn add(a, b)  =>  define i64 @add_shim(i64 %env, i64 %a, i64 %b) {
//                         %r = call i64 @add(i64 %a, i64 %b)
//                         ret i64 %r
//                       }
fn ir_ensure_fn_shim(m, fn_name: str, param_count: int): str {
    var shim_name <- fn_name + "_shim";
    // Skip if already emitted.
    var i <- 0;
    while (i < len(m.shimmed_fns)) {
        if (m.shimmed_fns[i] = fn_name) { return shim_name; }
        i <- i + 1;
    }
    push(m.shimmed_fns, fn_name);

    // Build the shim function: env param + user params, all i64.
    var shim_params <- [];
    push(shim_params, {name: "env", type: T.mk_int()});
    i <- 0;
    while (i < param_count) {
        push(shim_params, {name: "p" + i, type: T.mk_int()});
        i <- i + 1;
    }
    var shim <- ir_function(shim_name, shim_params, T.mk_int());
    var bb <- ir_block("entry");
    ir_fn_add_block(shim, bb);

    // Forward call: load each user param and call the real fn.
    var fwd_args <- [];
    i <- 0;
    while (i < param_count) {
        push(fwd_args, ir_reg("%p" + i + ".arg", T.mk_int()));
        i <- i + 1;
    }
    var rtmp <- "%shim_r";
    ir_push_inst(bb, ii_call(rtmp, T.mk_int(), fn_name, fwd_args));
    ir_set_terminator(bb, ii_ret(ir_reg(rtmp, T.mk_int())));

    ir_mod_add_function(m, shim);
    return shim_name;
}

fn ir_emit_expr(b, nd) {
    if (nd.node = "NumberLit") {
        return ir_const_int(nd.value);
    }
    if (nd.node = "FloatLit") {
        // Build the double constant and bitcast it to i64 for our uniform
        // i64-everywhere storage. The literal text is passed through to LLVM
        // verbatim — LLVM rounds decimal floats to nearest double using IEEE
        // round-to-nearest, matching the interpreter's Python conversion.
        var d_tmp <- ir_fresh_tmp(b, "fconst");
        ir_push_inst(b.cur_block, ii_bc_d_to_i(d_tmp, ir_const_float(nd.value)));
        return ir_reg(d_tmp, T.mk_float());
    }
    if (nd.node = "StringLit") {
        // Pool the string in the module table. Return a const_str value
        // whose id refers to the pooled entry; render sites inttoptr or use
        // ptr directly depending on context.
        var sid <- ir_mod_add_str(b.mod, nd.value);
        // The const_str renders as `@<id>` — for use inside expression positions
        // we need it as an i64 (the IR's universal integer for pointers). Emit
        // a ptrtoint into a fresh register.
        var tmp <- ir_fresh_tmp(b, "s");
        ir_push_inst(b.cur_block, ii_ptrtoint(tmp, ir_const_str(sid)));
        return ir_reg(tmp, T.mk_str());
    }
    if (nd.node = "BoolLit") {
        if (nd.value = "true") { return ir_const_int(1); }
        return ir_const_int(0);
    }
    if (nd.node = "Identifier") {
        // Locals shadow globals: scan the builder's locals first; only fall
        // back to a global @g_<n> load if the name isn't found locally.
        var is_loc <- false;
        var j <- 0;
        while (j < len(b.locals)) {
            if (b.locals[j].name = nd.name) { is_loc <- true; }
            j <- j + 1;
        }
        if (!is_loc && is_global(nd.name)) {
            var tmp <- ir_fresh_tmp(b, "ld");
            ir_push_inst(b.cur_block, ii_load(tmp, T.mk_int(), ir_reg("@g_" + nd.name, T.mk_int())));
            return ir_reg(tmp, T.mk_int());
        }
        // Reference to a regular FnDecl as a value (e.g. apply(add, 10, 20)).
        // Wrap in a closure pair so the call-site's closure-call convention
        // works. Skip arrow vars — those are already closure pairs assigned
        // to globals/locals and handled by the cases above.
        if (!is_loc) {
            var fi_ref <- find_fn(nd.name);
            if (fi_ref != false && !fi_ref.is_arrow_var) {
                var shim_name <- ir_ensure_fn_shim(b.mod, nd.name, fi_ref.param_count);
                var cm_tmp <- ir_fresh_tmp(b, "fnref");
                ir_push_inst(b.cur_block, ii_closure_make(cm_tmp, shim_name, []));
                return ir_reg(cm_tmp, T.mk_int());
            }
        }
        var slot <- ir_get_local_slot(b, nd.name);
        var tmp <- ir_fresh_tmp(b, "ld");
        ir_push_inst(b.cur_block, ii_load(tmp, T.mk_int(), ir_reg(slot, T.mk_int())));
        if (ir_is_boxed(b, nd.name)) {
            // boxed slot holds a heap-cell pointer (as i64); the
            // actual value lives one indirection further. box_load handles
            // the inttoptr + load.
            var deref <- ir_fresh_tmp(b, "bx");
            ir_push_inst(b.cur_block, ii_box_load(deref, ir_reg(tmp, T.mk_int())));
            return ir_reg(deref, T.mk_int());
        }
        return ir_reg(tmp, T.mk_int());
    }
    if (nd.node = "MatchExpr") {
        var cell <- ir_emit_expr(b, nd.scrutinee);
        var ut <- typeof_expr(nd.scrutinee);
        var R <- match_expr_result_type(nd);
        var r_is_union <- false;
        if (R.kind = "union") { r_is_union <- true; }
        var res_slot <- ir_fresh_tmp(b, "mres");
        ir_push_inst(b.func.blocks[0], ii_alloca(res_slot, T.mk_int()));
        var tag <- ir_fresh_tmp(b, "mtag");
        ir_push_inst(b.cur_block, ii_union_tag(tag, cell));
        var join_lbl <- ir_fresh_block_lbl(b, "mxjoin");
        var mi <- 0;
        while (mi < len(nd.arms)) {
            var arm <- nd.arms[mi];
            if (arm.wild) {
                // Coerce the arm value into the result type (3c).
                var wv <- ir_coerce_slot_value(b, arm.value, R);
                ir_push_inst(b.cur_block, ii_store(wv, ir_reg(res_slot, T.mk_int())));
                if (b.cur_block.terminator = false) { ir_set_terminator(b.cur_block, ii_br(join_lbl)); }
            } else {
            var idx <- union_member_index(ut, arm.ptype);
            var do_lbl <- ir_fresh_block_lbl(b, "mxarm");
            var next_lbl <- join_lbl;
            if (mi + 1 < len(nd.arms)) { next_lbl <- ir_fresh_block_lbl(b, "mxnext"); }
            var cmp <- ir_fresh_tmp(b, "mxcmp");
            ir_push_inst(b.cur_block, ii_icmp(cmp, "eq", ir_reg(tag, T.mk_int()), ir_const_int(idx)));
            if (arm.is_lit) {
                var vchk_lbl <- ir_fresh_block_lbl(b, "mxval");
                var brt <- ir_fresh_tmp(b, "br");
                ir_set_terminator(b.cur_block, ii_cond_br(brt, ir_reg(cmp, T.mk_int()), vchk_lbl, next_lbl));
                var vchk_bb <- ir_block(vchk_lbl);
                ir_fn_add_block(b.func, vchk_bb);
                b.cur_block <- vchk_bb;
                var lpay <- ir_fresh_tmp(b, "mxlpay");
                ir_push_inst(b.cur_block, ii_union_payload(lpay, cell));
                var veq <- ir_fresh_tmp(b, "mxveq");
                if (arm.lit_kind = "str") {
                    var sid <- ir_mod_add_str(b.mod, arm.lit);
                    var lptr <- ir_fresh_tmp(b, "mxls");
                    ir_push_inst(b.cur_block, ii_ptrtoint(lptr, ir_const_str(sid)));
                    ir_push_inst(b.cur_block, ii_strcmp(veq, "eq", ir_reg(lpay, T.mk_str()), ir_reg(lptr, T.mk_str())));
                } else {
                    var kconst <- ir_const_int(0);
                    if (arm.lit_kind = "bool") {
                        if (arm.lit = "true") { kconst <- ir_const_int(1); }
                    } else {
                        kconst <- ir_const_int(arm.lit);
                    }
                    ir_push_inst(b.cur_block, ii_icmp(veq, "eq", ir_reg(lpay, T.mk_int()), kconst));
                }
                var brv <- ir_fresh_tmp(b, "br");
                ir_set_terminator(b.cur_block, ii_cond_br(brv, ir_reg(veq, T.mk_int()), do_lbl, next_lbl));
            } else {
                var brc <- ir_fresh_tmp(b, "br");
                ir_set_terminator(b.cur_block, ii_cond_br(brc, ir_reg(cmp, T.mk_int()), do_lbl, next_lbl));
            }
            var do_bb <- ir_block(do_lbl);
            ir_fn_add_block(b.func, do_bb);
            b.cur_block <- do_bb;
            var bn <- match_bind_name(arm, nd.scrutinee);
            var swapped <- false;
            var swap_i <- -1;
            var add_idx <- -1;
            var saved_reg <- "";
            var saved_boxed <- false;
            var saved_vt <- T.mk_none();
            var fld_rec <- {saves: [], pre: 0};
            if (bn != "") {
                var payload <- ir_fresh_tmp(b, "mxpay");
                ir_push_inst(b.cur_block, ii_union_payload(payload, cell));
                var slot <- ir_fresh_tmp(b, "mxbind");
                ir_push_inst(b.func.blocks[0], ii_alloca(slot, T.mk_int()));
                ir_push_inst(b.cur_block, ii_store(ir_reg(payload, arm.ptype), ir_reg(slot, T.mk_int())));
                var li <- 0;
                var found <- false;
                while (li < len(b.locals)) {
                    if (b.locals[li].name = bn) { found <- true; swap_i <- li; }
                    li <- li + 1;
                }
                if (found) {
                    saved_reg <- b.locals[swap_i].reg;
                    saved_boxed <- b.locals[swap_i].boxed;
                    b.locals[swap_i].reg <- slot;
                    b.locals[swap_i].boxed <- false;
                    swapped <- true;
                } else {
                    add_idx <- len(b.locals);
                    push(b.locals, {name: bn, reg: slot, boxed: false, box_owned: false});
                }
                saved_vt <- get_var_type(bn);
                set_var_type(bn, arm.ptype);
                fld_rec <- arm_destructure_emit_bind(b, bn, arm.ptype);
            }
            // Coerce the arm value into the result type (3c).
            var av <- ir_coerce_slot_value(b, arm.value, R);
            ir_push_inst(b.cur_block, ii_store(av, ir_reg(res_slot, T.mk_int())));
            if (bn != "") {
                arm_destructure_emit_restore(b, fld_rec);
                set_var_type(bn, saved_vt);
                if (swapped) {
                    b.locals[swap_i].reg <- saved_reg;
                    b.locals[swap_i].boxed <- saved_boxed;
                } else {
                    var nl <- [];
                    var ri <- 0;
                    while (ri < len(b.locals)) { if (ri != add_idx) { push(nl, b.locals[ri]); } ri <- ri + 1; }
                    b.locals <- nl;
                }
            }
            if (b.cur_block.terminator = false) { ir_set_terminator(b.cur_block, ii_br(join_lbl)); }
            if (mi + 1 < len(nd.arms)) {
                var next_bb <- ir_block(next_lbl);
                ir_fn_add_block(b.func, next_bb);
                b.cur_block <- next_bb;
            }
            }
            mi <- mi + 1;
        }
        var join_bb <- ir_block(join_lbl);
        ir_fn_add_block(b.func, join_bb);
        b.cur_block <- join_bb;
        var result <- ir_fresh_tmp(b, "mxresv");
        ir_push_inst(b.cur_block, ii_load(result, T.mk_int(), ir_reg(res_slot, T.mk_int())));
        return ir_reg(result, R);
    }
    if (nd.node = "BinOp") {
        return ir_emit_binop(b, nd);
    }
    if (nd.node = "UnaryOp") {
        var operand <- ir_emit_expr(b, nd.operand);
        if (nd.op = "-") {
            // Float-aware: if the operand is float, bitcast to double, fneg,
            // bitcast back. Otherwise integer `sub i64 0, x`.
            var ot <- typeof_expr(nd.operand);
            if (ot.kind = "float") {
                var dd <- ir_to_double_reg(b, operand, ot);
                var fr <- ir_fresh_tmp(b, "fr");
                ir_push_inst(b.cur_block, ii_fneg(fr, ir_reg(dd, T.mk_float())));
                var i64r <- ir_fresh_tmp(b, "fi");
                ir_push_inst(b.cur_block, ii_bc_d_to_i(i64r, ir_reg(fr, T.mk_float())));
                return ir_reg(i64r, T.mk_float());
            }
            var tmp <- ir_fresh_tmp(b, "neg");
            ir_push_inst(b.cur_block, ii_neg(tmp, operand));
            return ir_reg(tmp, T.mk_int());
        }
        if (nd.op = "!") {
            var tmp <- ir_fresh_tmp(b, "not");
            ir_push_inst(b.cur_block, ii_lnot(tmp, operand));
            return ir_reg(tmp, T.mk_int());
        }
        print("ir_emit_expr UnaryOp: unsupported op " + nd.op);
        return ir_const_int(0);
    }
    if (nd.node = "CallExpr") {
        // Indirect call: when the callee isn't a plain identifier it's some
        // expression that produces a closure pair (e.g. `make_inc()(5)`,
        // `arr[0](x)`, `obj.field(x)`). Evaluate the callee as an i64 pair
        // pointer and route through closure_call, which already handles
        // unpacking [fn_ptr, env_ptr] and prepending env to the args.
        if (nd.callee.node != "Identifier") {
            var callee_val <- ir_emit_expr(b, nd.callee);
            var args <- [];
            var i <- 0;
            while (i < len(nd.args)) {
                push(args, ir_emit_arg(b, nd.args[i]));
                i <- i + 1;
            }
            var tmp <- ir_fresh_tmp(b, "icc");
            ir_push_inst(b.cur_block, ii_closure_call(tmp, T.mk_int(), callee_val, args));
            return ir_reg(tmp, T.mk_int());
        }
        var nm <- nd.callee.name;

        // Built-ins that map to dedicated IR ops.
        if (nm = "len") {
            var arg <- ir_emit_arg(b, nd.args[0]);
            // Strings: strlen via existing helper (renderer handles strlen op).
            // Arrays: array_len op (loads slot 0 of the array layout).
            var argt <- typeof_expr(nd.args[0]);
            var tmp <- ir_fresh_tmp(b, "len");
            if (argt.kind = "str") {
                ir_push_inst(b.cur_block, ii_strlen(tmp, arg));
            } else {
                ir_push_inst(b.cur_block, ii_array_len(tmp, arg));
            }
            return ir_reg(tmp, T.mk_int());
        }
        if (nm = "push") {
            var arr <- ir_emit_arg(b, nd.args[0]);
            var parrt <- typeof_expr(nd.args[0]);
            // Coerce the pushed value into the array element type so a
            // struct-with-union-field (and a union element's own tag) is
            // stored as a real cell, not a raw value (3c).
            // Element slot unknown (none-typed array param, etc.): raw
            // tier — wrapping here would poison raw-tier readers of the
            // same array in other scopes.
            var pelem <- T.mk_none();
            if (parrt.kind = "array") { pelem <- parrt.elem; }
            var val <- ir_coerce_slot_value(b, nd.args[1], pelem);
            var tmp <- ir_fresh_tmp(b, "push");
            ir_push_inst(b.cur_block, ii_array_push(tmp, arr, val));
            // push mutates and returns the (possibly relocated) array pointer;
            // store it back into wherever the source array lives. Without
            // this, the source variable still holds the old pointer after a
            // realloc — which silently shrinks the array next time it's read.
            if (nd.args[0].node = "Identifier") {
                if (is_global(nd.args[0].name)) {
                    ir_push_inst(b.cur_block, ii_store(ir_reg(tmp, T.mk_int()), ir_reg("@g_" + nd.args[0].name, T.mk_int())));
                } else {
                    var slot <- ir_get_local_slot(b, nd.args[0].name);
                    ir_push_inst(b.cur_block, ii_store(ir_reg(tmp, T.mk_int()), ir_reg(slot, T.mk_int())));
                }
            } else if (nd.args[0].node = "DotExpr") {
                // Re-evaluate the obj. Reusing the earlier-evaluated `arr`
                // would point at the *old* pointer; we need the obj struct.
                var obj_v <- ir_emit_arg(b, nd.args[0].obj);
                var fid <- ir_mod_add_str(b.mod, nd.args[0].field);
                var prefix <- ir_fresh_tmp(b, "pset");
                ir_push_inst(b.cur_block, ii_struct_set(prefix, obj_v, fid, ir_reg(tmp, T.mk_int())));
            } else if (nd.args[0].node = "IndexExpr") {
                var obj_v <- ir_emit_arg(b, nd.args[0].obj);
                var idx_v <- ir_emit_arg(b, nd.args[0].index);
                var prefix <- ir_fresh_tmp(b, "paset");
                ir_push_inst(b.cur_block, ii_array_set(prefix, obj_v, idx_v, ir_reg(tmp, T.mk_int())));
            }
            return ir_reg(tmp, T.mk_int());
        }
        if (nm = "pop") {
            var arr <- ir_emit_arg(b, nd.args[0]);
            var tmp <- ir_fresh_tmp(b, "pop");
            ir_push_inst(b.cur_block, ii_array_pop(tmp, T.mk_int(), arr));
            return ir_reg(tmp, T.mk_int());
        }
        if (nm = "keys") {
            var s <- ir_emit_arg(b, nd.args[0]);
            var tmp <- ir_fresh_tmp(b, "keys");
            ir_push_inst(b.cur_block, ii_struct_keys(tmp, s));
            return ir_reg(tmp, T.mk_array(T.mk_str()));
        }

        // Cluster-3 string + IO builtins.
        if (nm = "str_len") {
            var arg <- ir_emit_arg(b, nd.args[0]);
            var tmp <- ir_fresh_tmp(b, "sl");
            ir_push_inst(b.cur_block, ii_strlen(tmp, arg));
            return ir_reg(tmp, T.mk_int());
        }
        if (nm = "char_code") {
            var arg <- ir_emit_arg(b, nd.args[0]);
            var tmp <- ir_fresh_tmp(b, "cc");
            ir_push_inst(b.cur_block, ii_char_code(tmp, arg));
            return ir_reg(tmp, T.mk_int());
        }
        if (nm = "char_at") {
            var sarg <- ir_emit_arg(b, nd.args[0]);
            var iarg <- ir_emit_arg(b, nd.args[1]);
            var tmp <- ir_fresh_tmp(b, "ca");
            ir_push_inst(b.cur_block, ii_char_at(tmp, sarg, iarg));
            return ir_reg(tmp, T.mk_str());
        }
        if (nm = "from_char_code") {
            var arg <- ir_emit_arg(b, nd.args[0]);
            var tmp <- ir_fresh_tmp(b, "fcc");
            ir_push_inst(b.cur_block, ii_from_char_code(tmp, arg));
            return ir_reg(tmp, T.mk_str());
        }
        if (nm = "substring") {
            var sarg <- ir_emit_arg(b, nd.args[0]);
            var stargv <- ir_emit_arg(b, nd.args[1]);
            var edarg <- ir_emit_arg(b, nd.args[2]);
            var tmp <- ir_fresh_tmp(b, "sub");
            ir_push_inst(b.cur_block, ii_substring(tmp, sarg, stargv, edarg));
            return ir_reg(tmp, T.mk_str());
        }
        if (nm = "read_file") {
            var arg <- ir_emit_arg(b, nd.args[0]);
            var tmp <- ir_fresh_tmp(b, "rf");
            ir_push_inst(b.cur_block, ii_read_file(tmp, arg));
            return ir_reg(tmp, T.mk_str());
        }
        if (nm = "write_file") {
            var parg <- ir_emit_arg(b, nd.args[0]);
            var carg <- ir_emit_arg(b, nd.args[1]);
            var tmp <- ir_fresh_tmp(b, "wf");
            ir_push_inst(b.cur_block, ii_write_file(tmp, parg, carg));
            return ir_reg(tmp, T.mk_int());
        }
        if (nm = "append_file") {
            var parg <- ir_emit_arg(b, nd.args[0]);
            var carg <- ir_emit_arg(b, nd.args[1]);
            var tmp <- ir_fresh_tmp(b, "af");
            ir_push_inst(b.cur_block, ii_append_file(tmp, parg, carg));
            return ir_reg(tmp, T.mk_int());
        }
        if (nm = "exec_cmd") {
            var arg <- ir_emit_arg(b, nd.args[0]);
            var tmp <- ir_fresh_tmp(b, "ec");
            ir_push_inst(b.cur_block, ii_exec_cmd(tmp, arg));
            return ir_reg(tmp, T.mk_int());
        }
        if (nm = "input") {
            var tmp <- ir_fresh_tmp(b, "in");
            if (len(nd.args) >= 1) {
                var parg <- ir_emit_arg(b, nd.args[0]);
                ir_push_inst(b.cur_block, ii_input_with_prompt(tmp, parg));
            } else {
                ir_push_inst(b.cur_block, ii_input(tmp));
            }
            return ir_reg(tmp, T.mk_str());
        }
        if (nm = "args") {
            // Two forms: args() returns argc-1 (script arg count, excluding
            // program name); args(N) returns argv[N+1] as a string. Both use
            // the @g_argc / @g_argv globals populated by main.
            var tmp <- ir_fresh_tmp(b, "args");
            if (len(nd.args) = 0) {
                ir_push_inst(b.cur_block, ir_inst("args_count", tmp, T.mk_int(), [], false));
                return ir_reg(tmp, T.mk_int());
            }
            var iarg <- ir_emit_arg(b, nd.args[0]);
            ir_push_inst(b.cur_block, ir_inst("args_get", tmp, T.mk_str(), [iarg], false));
            return ir_reg(tmp, T.mk_str());
        }

        // Closure invocation: if `nm` was assigned an ArrowFn earlier in this
        // function, it holds a closure pair. Load the pair, unpack [fn_ptr,
        // env_ptr], and indirect-call with env prepended to args.
        var cinfo <- ir_get_closure(b, nm);
        if (cinfo != false) {
            // Load the closure pair pointer from wherever the variable lives.
            // Locals shadow globals: if the name is in this builder's locals,
            // use the local slot even when a global of the same name exists.
            var is_loc <- false;
            var j <- 0;
            while (j < len(b.locals)) {
                if (b.locals[j].name = nm) { is_loc <- true; }
                j <- j + 1;
            }
            var pair_tmp <- ir_fresh_tmp(b, "pair");
            if (is_loc) {
                var slot <- ir_get_local_slot(b, nm);
                ir_push_inst(b.cur_block, ii_load(pair_tmp, T.mk_int(), ir_reg(slot, T.mk_int())));
                if (ir_is_boxed(b, nm)) {
                    // slot holds a box pointer; the closure pair
                    // value lives one indirection further.
                    var deref <- ir_fresh_tmp(b, "bxpair");
                    ir_push_inst(b.cur_block, ii_box_load(deref, ir_reg(pair_tmp, T.mk_int())));
                    pair_tmp <- deref;
                }
            } else {
                ir_push_inst(b.cur_block, ii_load(pair_tmp, T.mk_int(), ir_reg("@g_" + nm, T.mk_int())));
            }
            // A callee variable DECLARED any holds a tagged cell (tag 6
            // when the pair wrapped as a fn value): verify the tag and
            // unwrap to the raw closure pair before the indirect call.
            if (get_decl_type(nm).kind = "any") {
                var cuw <- ir_fresh_tmp(b, "cuw");
                ir_push_inst(b.cur_block, ii_call(cuw, T.mk_int(), "arrow_any_unwrap", [ir_reg(pair_tmp, T.mk_int()), ir_const_int(6)]));
                pair_tmp <- cuw;
            }
            // Evaluate user args. If the underlying arrow fn carries
            // annotations, coerce per-annotation: an any-annotated param
            // receives a tagged cell, a union param wraps, and unannotated
            // params stay raw (blanket any-unwrap via ir_emit_arg).
            var cl_fi <- find_fn(cinfo.fn_name);
            var args <- [];
            var i <- 0;
            while (i < len(nd.args)) {
                var cl_pann <- T.mk_none();
                if (cl_fi != false && i < len(cl_fi.param_types_ann)) { cl_pann <- cl_fi.param_types_ann[i]; }
                if (cl_pann.kind = "none") {
                    push(args, ir_emit_arg(b, nd.args[i]));
                } else {
                    push(args, ir_coerce_slot_value(b, nd.args[i], cl_pann));
                }
                i <- i + 1;
            }
            var tmp <- ir_fresh_tmp(b, "cc");
            ir_push_inst(b.cur_block, ii_closure_call(tmp, T.mk_int(), ir_reg(pair_tmp, T.mk_int()), args));
            return ir_reg(tmp, T.mk_int());
        }

        // Indirect call via variable: if `nm` isn't a known top-level fn but
        // matches a local var or a global, treat it as holding a closure pair
        // value (e.g. assigned from another fn that returns a closure).
        var fi_lookup <- find_fn(nm);
        var is_known_fn <- false;
        if (fi_lookup != false) {
            // is_arrow_var entries are top-level arrow-fn assignments; they
            // ARE callable via closure_call too, so still go through the
            // indirect path. Plain FnDecls are direct calls.
            if (!fi_lookup.is_arrow_var) { is_known_fn <- true; }
        }
        if (!is_known_fn) {
            // Find where the closure pair lives — local slot or global.
            // Locals SHADOW globals. Otherwise a captured parameter that
            // happens to share a name with a top-level var (like `g` being
            // captured in compose's body while another `g` exists at top
            // level) would silently load the wrong value.
            var is_loc <- false;
            var j <- 0;
            while (j < len(b.locals)) {
                if (b.locals[j].name = nm) { is_loc <- true; }
                j <- j + 1;
            }
            if (is_loc || is_global(nm)) {
                var pair_tmp <- ir_fresh_tmp(b, "pair");
                if (is_loc) {
                    var slot <- ir_get_local_slot(b, nm);
                    ir_push_inst(b.cur_block, ii_load(pair_tmp, T.mk_int(), ir_reg(slot, T.mk_int())));
                    if (ir_is_boxed(b, nm)) {
                        var deref <- ir_fresh_tmp(b, "bxpair");
                        ir_push_inst(b.cur_block, ii_box_load(deref, ir_reg(pair_tmp, T.mk_int())));
                        pair_tmp <- deref;
                    }
                } else {
                    ir_push_inst(b.cur_block, ii_load(pair_tmp, T.mk_int(), ir_reg("@g_" + nm, T.mk_int())));
                }
                // A callee variable DECLARED any holds a tagged cell:
                // verify the tag and unwrap to the raw closure pair.
                if (get_decl_type(nm).kind = "any") {
                    var cuw <- ir_fresh_tmp(b, "cuw");
                    ir_push_inst(b.cur_block, ii_call(cuw, T.mk_int(), "arrow_any_unwrap", [ir_reg(pair_tmp, T.mk_int()), ir_const_int(6)]));
                    pair_tmp <- cuw;
                }
                var args <- [];
                var i <- 0;
                while (i < len(nd.args)) {
                    var iv_pann <- T.mk_none();
                    if (fi_lookup != false && i < len(fi_lookup.param_types_ann)) { iv_pann <- fi_lookup.param_types_ann[i]; }
                    if (iv_pann.kind = "none") {
                        push(args, ir_emit_arg(b, nd.args[i]));
                    } else {
                        push(args, ir_coerce_slot_value(b, nd.args[i], iv_pann));
                    }
                    i <- i + 1;
                }
                var tmp <- ir_fresh_tmp(b, "cc");
                ir_push_inst(b.cur_block, ii_closure_call(tmp, T.mk_int(), ir_reg(pair_tmp, T.mk_int()), args));
                return ir_reg(tmp, T.mk_int());
            }
        }

        // Generic user-function call. Arguments are evaluated left-to-right.
        // A member argument passed to a union-typed parameter is wrapped in a
        // {tag, payload} cell so the callee (where the param is a union) reads
        // a real union value.
        var cfi <- find_fn(nm);
        var args <- [];
        var i <- 0;
        while (i < len(nd.args)) {
            var pann <- T.mk_none();
            if (cfi != false && i < len(cfi.param_types_ann)) { pann <- cfi.param_types_ann[i]; }
            // ir_coerce_slot_value owns every slot-keyed coercion: union
            // params wrap member values, any-annotated params receive a
            // tagged cell (wrap by the arg's static type; statically-any
            // args pass through as cells), and its raw/none tail unwraps
            // tagged values bound for concrete or unannotated params.
            var av <- ir_coerce_slot_value(b, nd.args[i], pann);
            push(args, av);
            i <- i + 1;
        }
        var tmp <- ir_fresh_tmp(b, "call");
        ir_push_inst(b.cur_block, ii_call(tmp, T.mk_int(), nm, args));
        return ir_reg(tmp, T.mk_int());
    }
    if (nd.node = "ArrayLit") {
        // A mixed literal types as [any]; its elements are tagged cells,
        // each wrapped by its own static type.
        var alit <- typeof_expr(nd);
        var mixed <- false;
        if (alit.kind = "array") { if (alit.elem.kind = "any") { mixed <- true; } }
        var elems <- [];
        var i <- 0;
        while (i < len(nd.elements)) {
            var ev2 <- ir_emit_expr(b, nd.elements[i]);
            var et2 <- typeof_expr(nd.elements[i]);
            if (mixed) { ev2 <- ir_wrap_any(b, ev2, et2); }
            // A tagged value entering a raw/concrete-elem literal is
            // unwrapped: the literal's type declares its elements' tier.
            if (!mixed) { ev2 <- ir_unwrap_any(b, ev2, et2); }
            push(elems, ev2);
            i <- i + 1;
        }
        var tmp <- ir_fresh_tmp(b, "arr");
        ir_push_inst(b.cur_block, ii_array_new(tmp, T.mk_int(), elems));
        return ir_reg(tmp, T.mk_array(T.mk_int()));
    }
    if (nd.node = "IndexExpr") {
        // Dispatch on the object's static type (via typeof_expr — populated
        // by infer_body and friends in the prep dance). Strings get char_at
        // semantics, arrays get array_get. Anything else falls back to array
        // since `any`-typed values are most commonly arrays in practice.
        // A statically-any object must be indexable — tag 3 (str)
        // or 4 (array); want 8 is the indexable sentinel. The index
        // operand stays raw-tier. A cell-held str passing the check
        // still routes through array_get (static dispatch), matching
        // the raw regime for that edge.
        var obj <- ir_unwrap_any_checked(b, ir_emit_expr(b, nd.obj), typeof_expr(nd.obj), 8);
        var idx <- ir_unwrap_any(b, ir_emit_expr(b, nd.index), typeof_expr(nd.index));
        var ot <- typeof_expr(nd.obj);
        if (ot.kind = "str") {
            var tmp <- ir_fresh_tmp(b, "ca");
            ir_push_inst(b.cur_block, ii_char_at(tmp, obj, idx));
            return ir_reg(tmp, T.mk_str());
        }
        var tmp <- ir_fresh_tmp(b, "idx");
        ir_push_inst(b.cur_block, ii_array_get(tmp, T.mk_int(), obj, idx));
        return ir_reg(tmp, T.mk_int());
    }
    if (nd.node = "DotExpr") {
        // A statically-any object must hold a struct (tag 5).
        var obj <- ir_unwrap_any_checked(b, ir_emit_expr(b, nd.obj), typeof_expr(nd.obj), any_tag_of("struct"));
        // Pool the field name in the module's string table.
        var fid <- ir_mod_add_str(b.mod, nd.field);
        var tmp <- ir_fresh_tmp(b, "dot");
        ir_push_inst(b.cur_block, ii_struct_get(tmp, T.mk_int(), obj, fid));
        return ir_reg(tmp, T.mk_int());
    }
    if (nd.node = "StructLit") {
        // Pool field names; build the struct_new instruction with {key_id, val} entries.
        var fields <- [];
        var i <- 0;
        while (i < len(nd.fields)) {
            // Each AST field is {key: <str>, val: <expr>}; pool the name and
            // emit the value expression.
            var key_id <- ir_mod_add_str(b.mod, nd.fields[i].key);
            // Bare literals are raw tier: an any-typed field value is
            // unwrapped so the record stays readable in raw-tier scopes.
            // (Annotated struct slots wrap through the coercion path.)
            var val <- ir_unwrap_any(b, ir_emit_expr(b, nd.fields[i].val), typeof_expr(nd.fields[i].val));
            push(fields, {key_id: key_id, val: val});
            i <- i + 1;
        }
        var tmp <- ir_fresh_tmp(b, "sl");
        // Replace the operands list with [] since the renderer reads from extra.
        var inst <- ir_inst("struct_new", tmp, T.mk_struct(), [], fields);
        ir_push_inst(b.cur_block, inst);
        return ir_reg(tmp, T.mk_struct());
    }
    if (nd.node = "ArrowFn") {
        // 1) Find captures in the body.
        // 2) Build a new IR Function with `env` as first param + user params.
        //    The Function body loads each capture from env into a local, then
        //    runs the body via ir_emit_stmt.
        // 3) In the current block, emit a closure_make instruction that
        //    allocates the env array (storing the captures' current values)
        //    and the [fn_ptr, env_ptr] pair. Returns the pair pointer.
        var captures <- ir_find_captures(b, nd.body, nd.params, nd.is_expr);

        // Mint a unique name for the closure's IR function.
        arrow_fn_counter[0] <- arrow_fn_counter[0] + 1;
        var afn_name <- "__arrow_" + arrow_fn_counter[0];

        // When the arrow carries a return annotation,
        // register the mangled entry BEFORE the body emits, so block-body
        // ReturnStmts (which key on find_fn of the mangled name) see the
        // annotation as rslot and wrap/unwrap accordingly. Callers already
        // type the call annotation-first (typeof_expr returns ret_type_ann
        // when set), so this aligns the body half with the caller half.
        // set_fn_ret_type skips annotated entries, so the later
        // inferred-type mirror becomes a no-op rather than a conflict.
        if (nd.ret_type_ann.kind != "none") {
            if (find_fn(afn_name) = false) {
                push(declared_fns, {
                    name: afn_name,
                    param_count: len(nd.params),
                    ret_type: nd.ret_type_ann,
                    ret_fields: false,
                    param_types: [],
                    param_types_ann: nd.param_types_ann,
                    ret_type_ann: nd.ret_type_ann,
                    is_arrow_var: false
                });
            }
        }

        // Build the IR Function. Param list = [env, user params...].
        var ir_params <- [{name: "env", type: T.mk_int()}];
        var i <- 0;
        while (i < len(nd.params)) {
            push(ir_params, {name: nd.params[i], type: T.mk_int()});
            i <- i + 1;
        }
        var afn <- ir_function(afn_name, ir_params, T.mk_int());
        var afn_entry <- ir_block("entry");
        ir_fn_add_block(afn, afn_entry);

        // Sub-builder for the closure body. Reuses the outer module so
        // string constants pool together.
        var sub <- ir_builder_new(afn, afn_entry, b.mod);

        // Save the outer var-types so we can restore later. We need fresh
        // var_types for the closure scope (params + captures + locals).
        // Captures keep their outer types so subsequent typeof_expr in body
        // sees them correctly.
        var old_vars <- alloc_vars[0];
        var old_types <- var_types[0];
        var old_layouts <- struct_layouts[0];
        var old_arr_types <- array_elem_types[0];
        var old_decl_types <- decl_types[0];
        var cap_outer_types <- [];
        i <- 0;
        while (i < len(captures)) {
            push(cap_outer_types, get_var_type(captures[i]));
            i <- i + 1;
        }
        alloc_vars[0] <- [];
        var_types[0] <- [];
        struct_layouts[0] <- [];
        array_elem_types[0] <- [];
        decl_types[0] <- [];
        shadow_decls[0] <- [];

        // Preserve type info for top-level globals into the arrow fn scope.
        // Inside a closure, references to top-level vars resolve to @g_<n>
        // loads; typeof_expr needs to see their types so that e.g. `prefix +
        // msg` (string global + any param) typechecks as str-concat instead of
        // int-add.
        var gi <- 0;
        while (gi < len(old_types)) {
            if (is_global(old_types[gi].name)) {
                push(var_types[0], old_types[gi]);
            }
            gi <- gi + 1;
        }
        gi <- 0;
        while (gi < len(old_decl_types)) {
            if (is_global(old_decl_types[gi].name)) {
                push(decl_types[0], old_decl_types[gi]);
            }
            gi <- gi + 1;
        }

        // Param prologue: allocate a slot for each user param and copy the arg in.
        i <- 0;
        while (i < len(nd.params)) {
            var pname <- nd.params[i];
            var pslot <- ir_get_local_slot(sub, pname);
            ir_push_inst(sub.cur_block, ii_store(ir_reg("%" + pname + ".arg", T.mk_int()), ir_reg(pslot, T.mk_int())));
            // Annotation-first: an annotated closure param uses its
            // annotation, and an explicitly-any param joins the tagged
            // tier (call sites wrap arguments into cells) — enrolled as
            // declared-any for typeof's tier gate. Unannotated stays raw.
            var pann3 <- T.mk_none();
            if (i < len(nd.param_types_ann)) { pann3 <- nd.param_types_ann[i]; }
            if (pann3.kind = "any") { set_decl_type(pname, pann3); }
            if (pann3.kind != "none") {
                set_var_type(pname, pann3);
            } else {
                set_var_type(pname, T.mk_none());
            }
            shadow_declare(pname, pann3, 0, 0);
            i <- i + 1;
        }

        // Capture prologue: load each capture from env into a local slot.
        // the env stores box POINTERS (not values). Loading them
        // into the local slot gives the slot a box pointer; we mark the
        // slot as boxed so reads dereference and writes store through.
        // This is what makes inner-fn `n <- n + 1` propagate back to the
        // outer fn's `n` — they share the same heap cell.
        if (len(captures) > 0) {
            i <- 0;
            while (i < len(captures)) {
                var cname <- captures[i];
                var cslot <- ir_get_local_slot(sub, cname);
                var load_reg <- ir_fresh_tmp(sub, "cval");
                ir_push_inst(sub.cur_block, ir_inst("closure_load_cap", load_reg, T.mk_int(), [ir_reg("%env.arg", T.mk_int()), ir_const_int(i)], false));
                ir_push_inst(sub.cur_block, ii_store(ir_reg(load_reg, T.mk_int()), ir_reg(cslot, T.mk_int())));
                // Box came in via env: we don't own it. A later `var cname`
                // in this closure body should shadow, not write through.
                ir_mark_boxed(sub, cname, false);
                set_var_type(cname, cap_outer_types[i]);
                i <- i + 1;
            }
        }

        // Body. ArrowFn bodies can be either a list of statements (block form)
        // or a single expression (expression form).
        var ret_type_inferred <- T.mk_any();

        // For block-body forms, pre-populate sub.locals with every name
        // assigned to in the body BEFORE the boxing pass runs. Mirrors
        // emit_function_via_ir for regular FnDecls. We also need infer_body
        // to run first so var_types is populated for typeof_expr lookups
        // during emission. Expression-body forms have no declarations, so
        // they skip this step.
        if (!nd.is_expr) {
            var old_cur <- current_fn[0];
            current_fn[0] <- afn_name;
            infer_body(nd.body);
            current_fn[0] <- old_cur;

            var body_vars <- [];
            collect_vars(nd.body, body_vars);
            i <- 0;
            while (i < len(body_vars)) {
                ir_get_local_slot(sub, body_vars[i]);
                i <- i + 1;
            }
            ir_get_local_slot(sub, "_for_idx");
        }

        // if our body contains nested closures that capture our
        // locals (including our params or our own captures), box those
        // locals so the nested closures share writable state with us.
        // This pass runs BEFORE body emission so reads/writes throughout
        // the body see the boxed slot. We do it here uniformly for both
        // expr-body and block-body ArrowFns — otherwise expression-body
        // forms like `(a) => (b) => (c) => a + b + c` would skip boxing
        // for `a` and the inner closures would receive raw values
        // instead of box pointers, then inttoptr them into bogus
        // pointers and segfault.
        var inner_body_list <- nd.body;
        if (nd.is_expr) {
            inner_body_list <- [nd.body];
        }
        var inner_box <- ir_find_my_captured_locals(sub, inner_body_list);
        var ibi <- 0;
        while (ibi < len(inner_box)) {
            var ibname <- inner_box[ibi];
            if (!ir_is_boxed(sub, ibname)) {
                var ibslot <- ir_get_local_slot(sub, ibname);
                var ibox_tmp <- ir_fresh_tmp(sub, "box");
                ir_push_inst(sub.cur_block, ii_box_alloc(ibox_tmp));
                ir_push_inst(sub.cur_block, ii_store(ir_reg(ibox_tmp, T.mk_int()), ir_reg(ibslot, T.mk_int())));
                // We allocated this box ourselves — own it. A future
                // `var ibname` in this body is the original declaration
                // and should write the initial value through the box.
                ir_mark_boxed(sub, ibname, true);
            }
            ibi <- ibi + 1;
        }
        // Re-init any boxed params (same reason as in the regular fn
        // path: the earlier %x.arg → slot store wrote a value where a
        // box ptr is now required).
        var ipi <- 0;
        while (ipi < len(nd.params)) {
            var ipname <- nd.params[ipi];
            if (ir_is_boxed(sub, ipname)) {
                ir_emit_store_to_slot(sub, ir_get_local_slot(sub, ipname), ipname, ir_reg("%" + ipname + ".arg", T.mk_int()));
            }
            ipi <- ipi + 1;
        }

        if (nd.is_expr) {
            if (nd.ret_type_ann.kind != "none") {
                // An annotated expression body returns
                // through the same slot machinery as a ReturnStmt —
                // the value is built for the annotation, wrapped for an
                // any return, checked-unwrapped for a concrete one, and
                // union members are wrapped.
                var rv <- ir_emit_value_for_slot(sub, nd.body, nd.ret_type_ann);
                var rvt3 <- typeof_expr(nd.body);
                if (nd.ret_type_ann.kind = "union") {
                    if (rvt3.kind != "union") { rv <- ir_union_wrap(sub, rv, rvt3, nd.ret_type_ann); }
                }
                if (nd.ret_type_ann.kind = "any") { rv <- ir_wrap_any(sub, rv, rvt3); }
                ir_set_terminator(sub.cur_block, ii_ret(rv));
                ret_type_inferred <- nd.ret_type_ann;
            } else {
                var v <- ir_emit_expr(sub, nd.body);
                ir_set_terminator(sub.cur_block, ii_ret(v));
                // Observe the expression's static type for the body's return type.
                // typeof_expr consults var_types populated during emission.
                ret_type_inferred <- typeof_expr(nd.body);
            }
        } else {
            i <- 0;
            while (i < len(nd.body)) {
                ir_emit_stmt(sub, nd.body[i]);
                i <- i + 1;
            }
            if (sub.cur_block.terminator = false) {
                ir_set_terminator(sub.cur_block, ii_ret(ir_const_int(0)));
            }
            // After infer_body, declared_fns[afn_name].ret_type holds the
            // inferred return type (or any if inference couldn't decide).
            var fi_after <- find_fn(afn_name);
            if (fi_after != false) { ret_type_inferred <- fi_after.ret_type; }
        }

        // Restore outer compilation state.
        alloc_vars[0] <- old_vars;
        var_types[0] <- old_types;
        struct_layouts[0] <- old_layouts;
        array_elem_types[0] <- old_arr_types;
        decl_types[0] <- old_decl_types;

        // Add the new function to the module.
        ir_mod_add_function(b.mod, afn);

        // Now emit closure_make in the OUTER (current) block. Captures' values
        // are loaded from outer locals.
        var cap_vals <- [];
        i <- 0;
        while (i < len(captures)) {
            var cap_slot <- ir_get_local_slot(b, captures[i]);
            var cap_tmp <- ir_fresh_tmp(b, "cap");
            ir_push_inst(b.cur_block, ii_load(cap_tmp, T.mk_int(), ir_reg(cap_slot, T.mk_int())));
            push(cap_vals, ir_reg(cap_tmp, T.mk_int()));
            i <- i + 1;
        }
        var cm_tmp <- ir_fresh_tmp(b, "cm");
        ir_push_inst(b.cur_block, ii_closure_make(cm_tmp, afn_name, cap_vals));

        // Register the arrow fn's mangled name in declared_fns with the
        // inferred return type. This lets typeof_expr resolve the correct
        // return type when the call is made via the var the closure is
        // assigned to (the surrounding Assignment will mirror this onto the
        // var's entry too).
        if (find_fn(afn_name) = false) {
            push(declared_fns, {
                name: afn_name,
                param_count: len(nd.params),
                ret_type: ret_type_inferred,
                ret_fields: false,
                param_types: [],
                param_types_ann: nd.param_types_ann,
                ret_type_ann: T.mk_none(),
                is_arrow_var: false
            });
        } else {
            set_fn_ret_type(afn_name, ret_type_inferred, false);
        }

        // Stash {pair_value, fn_name, param_count, ret_type} in a side struct
        // so the surrounding Assignment can record it as a closure variable
        // and mirror the ret_type onto the var's declared_fns entry.
        return {
            kind: "reg",
            name: cm_tmp,
            type: T.mk_int(),
            // Marker so ir_emit_stmt's Assignment branch recognizes this came
            // from an ArrowFn and registers a closure_var entry.
            arrow_fn_name: afn_name,
            arrow_param_count: len(nd.params),
            arrow_ret_type: ret_type_inferred
        };
    }

    // Fallback — unsupported node. Return a sentinel const_int(0) so that
    // we at least produce valid (but semantically wrong) IR for any node the
    // emitter doesn't explicitly handle, rather than crashing.
    print("ir_emit_expr: unsupported node " + nd.node);
    return ir_const_int(0);
}

fn ir_emit_binop(b, nd) {
    var op <- nd.op;

    if (op = "&&") {
        // Short-circuit: allocate a result slot (entry-block alloca), store 0,
        // eval LHS, branch on truthiness; true path evaluates RHS and stores;
        // join block loads the result.
        var res_slot_name <- ir_fresh_tmp(b, "and_res");
        ir_push_inst(b.func.blocks[0], ii_alloca(res_slot_name, T.mk_int()));
        ir_push_inst(b.cur_block, ii_store(ir_const_int(0), ir_reg(res_slot_name, T.mk_int())));

        var lhs <- ir_emit_expr(b, nd.left);

        var rhs_lbl <- ir_fresh_block_lbl(b, "and_r");
        var end_lbl <- ir_fresh_block_lbl(b, "and_e");
        var br_tmp  <- ir_fresh_tmp(b, "br");
        ir_set_terminator(b.cur_block, ii_cond_br(br_tmp, lhs, rhs_lbl, end_lbl));

        var rhs_bb <- ir_block(rhs_lbl);
        ir_fn_add_block(b.func, rhs_bb);
        b.cur_block <- rhs_bb;
        var rhs <- ir_emit_expr(b, nd.right);
        ir_push_inst(b.cur_block, ii_store(rhs, ir_reg(res_slot_name, T.mk_int())));
        ir_set_terminator(b.cur_block, ii_br(end_lbl));

        var end_bb <- ir_block(end_lbl);
        ir_fn_add_block(b.func, end_bb);
        b.cur_block <- end_bb;

        var result_tmp <- ir_fresh_tmp(b, "andres");
        ir_push_inst(b.cur_block, ii_load(result_tmp, T.mk_int(), ir_reg(res_slot_name, T.mk_int())));
        return ir_reg(result_tmp, T.mk_int());
    }

    if (op = "||") {
        // Mirror of && with the default set to 1; LHS true short-circuits to end.
        var res_slot_name <- ir_fresh_tmp(b, "or_res");
        ir_push_inst(b.func.blocks[0], ii_alloca(res_slot_name, T.mk_int()));
        ir_push_inst(b.cur_block, ii_store(ir_const_int(1), ir_reg(res_slot_name, T.mk_int())));

        var lhs <- ir_emit_expr(b, nd.left);

        var rhs_lbl <- ir_fresh_block_lbl(b, "or_r");
        var end_lbl <- ir_fresh_block_lbl(b, "or_e");
        var br_tmp  <- ir_fresh_tmp(b, "br");
        // LHS true → skip to end; LHS false → compute RHS.
        ir_set_terminator(b.cur_block, ii_cond_br(br_tmp, lhs, end_lbl, rhs_lbl));

        var rhs_bb <- ir_block(rhs_lbl);
        ir_fn_add_block(b.func, rhs_bb);
        b.cur_block <- rhs_bb;
        var rhs <- ir_emit_expr(b, nd.right);
        ir_push_inst(b.cur_block, ii_store(rhs, ir_reg(res_slot_name, T.mk_int())));
        ir_set_terminator(b.cur_block, ii_br(end_lbl));

        var end_bb <- ir_block(end_lbl);
        ir_fn_add_block(b.func, end_bb);
        b.cur_block <- end_bb;

        var result_tmp <- ir_fresh_tmp(b, "orres");
        ir_push_inst(b.cur_block, ii_load(result_tmp, T.mk_int(), ir_reg(res_slot_name, T.mk_int())));
        return ir_reg(result_tmp, T.mk_int());
    }

    // Arithmetic and comparison — both operands are eagerly evaluated.
    var lhs <- ir_emit_expr(b, nd.left);
    var rhs <- ir_emit_expr(b, nd.right);

    if (ir_is_cmp_op(op)) {
        // Use @arrow_safe_strcmp when either side is statically a str —
        // otherwise integer icmp. For "any vs any" we also route through
        // strcmp because the safe variant tolerates either pointer or int
        // operands.
        var lt <- typeof_expr(nd.left);
        var rt <- typeof_expr(nd.right);
        // Tagged-any comparison: split each side into (tag, payload) —
        // concrete sides ride with constant tags, none rides as opaque —
        // and 3-way compare in the runtime, then icmp the result vs 0.
        // Two raw-tier (`none`) sides also route here: their opaque lane
        // is the magnitude heuristic, which is what dynamic-vs-dynamic
        // comparison always meant (string content, not pointer identity).
        if (lt.kind = "any" || rt.kind = "any"
            || (lt.kind = "none" && rt.kind = "none")) {
            var ls <- ir_dyn_side(b, lhs, lt);
            var rs <- ir_dyn_side(b, rhs, rt);
            var dc <- ir_fresh_tmp(b, "dcmp");
            ir_push_inst(b.cur_block, ii_dyn_cmp(dc, ls.t, ls.p, rs.t, rs.p));
            var dtmp <- ir_fresh_tmp(b, "scmp");
            ir_push_inst(b.cur_block, ii_icmp(dtmp, ir_cmp_op(op), ir_reg(dc, T.mk_int()), ir_const_int(0)));
            return ir_reg(dtmp, T.mk_int());
        }
        if (lt.kind = "str" || rt.kind = "str") {
            var tmp <- ir_fresh_tmp(b, "scmp");
            ir_push_inst(b.cur_block, ii_strcmp(tmp, ir_cmp_op(op), lhs, rhs));
            return ir_reg(tmp, T.mk_int());
        }
        // Float comparison: if either side is statically float, promote both
        // to double and use fcmp. The other-side promotion handles mixed
        // int/float comparisons like `2 < 1.5`.
        if (lt.kind = "float" || rt.kind = "float") {
            var ld <- ir_to_double_reg(b, lhs, lt);
            var rd <- ir_to_double_reg(b, rhs, rt);
            var tmp <- ir_fresh_tmp(b, "fc");
            ir_push_inst(b.cur_block, ii_fcmp(tmp, ir_fcmp_op(op), ir_reg(ld, T.mk_float()), ir_reg(rd, T.mk_float())));
            return ir_reg(tmp, T.mk_bool());
        }
        var tmp <- ir_fresh_tmp(b, "cmp");
        ir_push_inst(b.cur_block, ii_icmp(tmp, ir_cmp_op(op), lhs, rhs));
        return ir_reg(tmp, T.mk_int());
    }
    if (op = "+") {
        // Distinguish string concat from integer add via static typing.
        // typeof_expr knows `+` of any-strings returns str; for the IR layer
        // this means emitting a strcat (call to @arrow_strcat) rather than
        // an integer add. Mixed str+int is supported by converting the int
        // operand to a string via int_to_str.
        var lt <- typeof_expr(nd.left);
        var rt <- typeof_expr(nd.right);
        if (lt.kind = "str" || rt.kind = "str") {
            var lhs_s: any <- lhs;
            var rhs_s: any <- rhs;
            if (lt.kind = "int") {
                var t <- ir_fresh_tmp(b, "i2s");
                ir_push_inst(b.cur_block, ii_int_to_str(t, lhs));
                lhs_s <- ir_reg(t, T.mk_str());
            }
            if (rt.kind = "int") {
                var t <- ir_fresh_tmp(b, "i2s");
                ir_push_inst(b.cur_block, ii_int_to_str(t, rhs));
                rhs_s <- ir_reg(t, T.mk_str());
            }
            // Tagged-any sides convert to a string by tag before the concat.
            if (lt.kind = "any") {
                var lds <- ir_dyn_side(b, lhs, lt);
                var lt2 <- ir_fresh_tmp(b, "dstr");
                ir_push_inst(b.cur_block, ii_dyn_str(lt2, lds.t, lds.p));
                lhs_s <- ir_reg(lt2, T.mk_str());
            }
            if (rt.kind = "any") {
                var rds <- ir_dyn_side(b, rhs, rt);
                var rt2 <- ir_fresh_tmp(b, "dstr");
                ir_push_inst(b.cur_block, ii_dyn_str(rt2, rds.t, rds.p));
                rhs_s <- ir_reg(rt2, T.mk_str());
            }
            var tmp <- ir_fresh_tmp(b, "scat");
            ir_push_inst(b.cur_block, ii_strcat(tmp, lhs_s, rhs_s));
            return ir_reg(tmp, T.mk_str());
        }
        // Tagged-any operands in numeric `+` are unwrapped to their payload
        // word — raw-tier semantics: operand positions are not checked edges.
        lhs <- ir_unwrap_any(b, lhs, lt);
        rhs <- ir_unwrap_any(b, rhs, rt);
        // Array concatenation — both sides are arrays, lower to a runtime
        // helper that allocates a fresh array and copies elements. The result
        // carries the joined element type from typeof_expr so prints format
        // correctly.
        if (lt.kind = "array" && rt.kind = "array") {
            var tmp <- ir_fresh_tmp(b, "acat");
            ir_push_inst(b.cur_block, ii_array_concat(tmp, lhs, rhs));
            return ir_reg(tmp, T.mk_array(T.types_join(lt.elem, rt.elem)));
        }
        if (lt.kind = "float" || rt.kind = "float") {
            return ir_emit_fbinop(b, "fadd", lhs, lt, rhs, rt);
        }
        var tmp <- ir_fresh_tmp(b, "add");
        ir_push_inst(b.cur_block, ii_add(tmp, lhs, rhs));
        return ir_reg(tmp, T.mk_int());
    }

    // Numeric arithmetic — route through float if either side is float.
    var lt <- typeof_expr(nd.left);
    var rt <- typeof_expr(nd.right);
    var use_float <- (lt.kind = "float" || rt.kind = "float");
    // Tagged-any operands unwrap to their payload word (raw-tier semantics).
    lhs <- ir_unwrap_any(b, lhs, lt);
    rhs <- ir_unwrap_any(b, rhs, rt);

    if (op = "-") {
        if (use_float) { return ir_emit_fbinop(b, "fsub", lhs, lt, rhs, rt); }
        var tmp <- ir_fresh_tmp(b, "sub"); ir_push_inst(b.cur_block, ii_sub(tmp, lhs, rhs)); return ir_reg(tmp, T.mk_int());
    }
    if (op = "*") {
        if (use_float) { return ir_emit_fbinop(b, "fmul", lhs, lt, rhs, rt); }
        var tmp <- ir_fresh_tmp(b, "mul"); ir_push_inst(b.cur_block, ii_mul(tmp, lhs, rhs)); return ir_reg(tmp, T.mk_int());
    }
    if (op = "/") {
        if (use_float) { return ir_emit_fbinop(b, "fdiv", lhs, lt, rhs, rt); }
        var tmp <- ir_fresh_tmp(b, "div"); ir_push_inst(b.cur_block, ii_sdiv(tmp, lhs, rhs)); return ir_reg(tmp, T.mk_int());
    }
    if (op = "%") {
        // `%` on floats is unusual but defined (frem) — kept as int-only here
        // to match Python semantics where `1.5 % 1.0` doesn't usually appear
        // in Arrow programs. If we want it later, add fmod via libc.
        var tmp <- ir_fresh_tmp(b, "rem"); ir_push_inst(b.cur_block, ii_srem(tmp, lhs, rhs)); return ir_reg(tmp, T.mk_int());
    }

    print("ir_emit_binop: unsupported op " + op);
    return ir_const_int(0);
}

// Helper for arithmetic when at least one side is float. Promotes both sides
// to double, emits the named float op, then bitcasts the result back to i64
// for storage. Returns an ir_reg holding the i64-storage form of the result.
fn ir_emit_fbinop(b, fop: str, lhs, lt, rhs, rt) {
    var ld <- ir_to_double_reg(b, lhs, lt);
    var rd <- ir_to_double_reg(b, rhs, rt);
    var fr <- ir_fresh_tmp(b, "fr");
    if (fop = "fadd") { ir_push_inst(b.cur_block, ii_fadd(fr, ir_reg(ld, T.mk_float()), ir_reg(rd, T.mk_float()))); }
    else if (fop = "fsub") { ir_push_inst(b.cur_block, ii_fsub(fr, ir_reg(ld, T.mk_float()), ir_reg(rd, T.mk_float()))); }
    else if (fop = "fmul") { ir_push_inst(b.cur_block, ii_fmul(fr, ir_reg(ld, T.mk_float()), ir_reg(rd, T.mk_float()))); }
    else if (fop = "fdiv") { ir_push_inst(b.cur_block, ii_fdiv(fr, ir_reg(ld, T.mk_float()), ir_reg(rd, T.mk_float()))); }
    var i64r <- ir_fresh_tmp(b, "fi");
    ir_push_inst(b.cur_block, ii_bc_d_to_i(i64r, ir_reg(fr, T.mk_float())));
    return ir_reg(i64r, T.mk_float());
}

// ── Typed printing of composite values ──────────────
//
// Walks the static type at each `print(x)` call site and emits IR that
// composes the formatted output. Primitives use the dedicated runtime
// helpers (arrow_print_int / _str / _bool); arrays emit an inline runtime
// loop that calls back into ir_emit_format_value with top_level=false for
// each element; struct_lits unroll their fields at compile time. Nested
// composites recurse the codegen — there's no runtime type tag.
//
// top_level=true:  trailing newline; scalar strings printed without quotes.
// top_level=false: no newline; scalar strings printed with surrounding quotes.

// Pool a literal string in the module string table, then emit code that calls
// arrow_print_lit on it. Used for all the static glue between formatted parts:
// "[", "]", ", ", "{", "}", and field-name labels like "name: ".
fn ir_emit_lit(b, text: str) {
    var sid <- ir_mod_add_str(b.mod, text);
    var tmp <- ir_fresh_tmp(b, "lit");
    ir_push_inst(b.cur_block, ii_ptrtoint(tmp, ir_const_str(sid)));
    ir_push_inst(b.cur_block, ii_print_lit(ir_reg(tmp, T.mk_int())));
    return 0;
}

fn ir_emit_format_value(b, val, t, top_level: int) {
    if (t.kind = "int") {
        if (top_level) { ir_push_inst(b.cur_block, ii_print_int(val)); }
        else { ir_push_inst(b.cur_block, ii_format_int(val)); }
        return 0;
    }
    if (t.kind = "str") {
        if (top_level) {
            var cast_reg <- ir_fresh_tmp(b, "pp");
            ir_push_inst(b.cur_block, ii_print_str(cast_reg, val));
        } else {
            ir_push_inst(b.cur_block, ii_format_str_q(val));
        }
        return 0;
    }
    if (t.kind = "bool") {
        if (top_level) { ir_push_inst(b.cur_block, ii_print_bool(val)); }
        else { ir_push_inst(b.cur_block, ii_format_bool(val)); }
        return 0;
    }
    if (t.kind = "float") {
        if (top_level) { ir_push_inst(b.cur_block, ii_print_float(val)); }
        else { ir_push_inst(b.cur_block, ii_format_float(val)); }
        return 0;
    }
    if (t.kind = "array") {
        ir_emit_format_array(b, val, t.elem);
        if (top_level) { ir_push_inst(b.cur_block, ii_print_newline()); }
        return 0;
    }
    if (t.kind = "struct_lit") {
        ir_emit_format_struct(b, val, t.fields);
        if (top_level) { ir_push_inst(b.cur_block, ii_print_newline()); }
        return 0;
    }
    if (t.kind = "any") {
        // Tagged cell: exact runtime dispatch. Raw-tier none keeps the
        // heuristic fallback below.
        if (top_level) { ir_push_inst(b.cur_block, ii_print_dyn(val)); }
        else { ir_push_inst(b.cur_block, ii_format_dyn(val)); }
        return 0;
    }
    if (t.kind = "union") {
        ir_emit_format_union(b, val, t.members, top_level);
        return 0;
    }
    // Fallback for any/struct/unknown — use the runtime any-dispatcher,
    // which heuristically picks int vs string based on the value's
    // magnitude. Catches cases where static inference couldn't recover an
    // element type, like an unannotated function return or a field whose
    // type joined across mixed-shape literals to `any`. For untyped structs
    // (the `struct` kind, distinct from `struct_lit`) we still fall back to
    // int — there's no general way to walk an opaque struct at runtime.
    if (t.kind = "any" || t.kind = "none") {
        if (top_level) { ir_push_inst(b.cur_block, ii_print_any(val)); }
        else { ir_push_inst(b.cur_block, ii_format_any(val)); }
        return 0;
    }
    if (top_level) { ir_push_inst(b.cur_block, ii_print_int(val)); }
    else { ir_push_inst(b.cur_block, ii_format_int(val)); }
    return 0;
}

// Emit `[a, b, c]` for an array value. No newline — the caller adds one if
// this is a top-level print. Walks the array via a runtime loop driven by
// an alloca'd index counter (the existing while-stmt pattern).
fn ir_emit_format_array(b, arr_val, elem_type) {
    ir_emit_lit(b, "[");

    // len_reg = array_len(arr_val)
    var len_reg <- ir_fresh_tmp(b, "alen");
    ir_push_inst(b.cur_block, ii_array_len(len_reg, arr_val));

    // Index counter slot — allocated in the entry block (LLVM convention,
    // and avoids re-allocating on each loop iteration).
    var idx_slot <- ir_fresh_tmp(b, "fidx");
    ir_push_inst(b.func.blocks[0], ii_alloca(idx_slot, T.mk_int()));
    ir_push_inst(b.cur_block, ii_store(ir_const_int(0), ir_reg(idx_slot, T.mk_int())));

    var cond_lbl <- ir_fresh_block_lbl(b, "fac");
    var body_lbl <- ir_fresh_block_lbl(b, "fab");
    var sep_lbl  <- ir_fresh_block_lbl(b, "fas");
    var elem_lbl <- ir_fresh_block_lbl(b, "fae");
    var end_lbl  <- ir_fresh_block_lbl(b, "faE");

    ir_set_terminator(b.cur_block, ii_br(cond_lbl));

    // cond: i < len → body, else end
    var cond_bb <- ir_block(cond_lbl);
    ir_fn_add_block(b.func, cond_bb);
    b.cur_block <- cond_bb;
    var i_c <- ir_fresh_tmp(b, "fi");
    ir_push_inst(b.cur_block, ii_load(i_c, T.mk_int(), ir_reg(idx_slot, T.mk_int())));
    var cmp <- ir_fresh_tmp(b, "fcmp");
    ir_push_inst(b.cur_block, ii_icmp(cmp, "slt", ir_reg(i_c, T.mk_int()), ir_reg(len_reg, T.mk_int())));
    var br_t1 <- ir_fresh_tmp(b, "br");
    ir_set_terminator(b.cur_block, ii_cond_br(br_t1, ir_reg(cmp, T.mk_int()), body_lbl, end_lbl));

    // body: if i = 0 → elem (skip separator), else → sep block
    var body_bb <- ir_block(body_lbl);
    ir_fn_add_block(b.func, body_bb);
    b.cur_block <- body_bb;
    var i_b <- ir_fresh_tmp(b, "fi");
    ir_push_inst(b.cur_block, ii_load(i_b, T.mk_int(), ir_reg(idx_slot, T.mk_int())));
    var is_first <- ir_fresh_tmp(b, "ffirst");
    ir_push_inst(b.cur_block, ii_icmp(is_first, "eq", ir_reg(i_b, T.mk_int()), ir_const_int(0)));
    var br_t2 <- ir_fresh_tmp(b, "br");
    ir_set_terminator(b.cur_block, ii_cond_br(br_t2, ir_reg(is_first, T.mk_int()), elem_lbl, sep_lbl));

    // sep: print ", " then fall through to elem
    var sep_bb <- ir_block(sep_lbl);
    ir_fn_add_block(b.func, sep_bb);
    b.cur_block <- sep_bb;
    ir_emit_lit(b, ", ");
    ir_set_terminator(b.cur_block, ii_br(elem_lbl));

    // elem: load arr[i], format it, then i = i+1, jump to cond
    var elem_bb <- ir_block(elem_lbl);
    ir_fn_add_block(b.func, elem_bb);
    b.cur_block <- elem_bb;
    var i_e <- ir_fresh_tmp(b, "fi");
    ir_push_inst(b.cur_block, ii_load(i_e, T.mk_int(), ir_reg(idx_slot, T.mk_int())));
    var elem_reg <- ir_fresh_tmp(b, "felem");
    ir_push_inst(b.cur_block, ii_array_get(elem_reg, T.mk_int(), arr_val, ir_reg(i_e, T.mk_int())));
    ir_emit_format_value(b, ir_reg(elem_reg, T.mk_int()), elem_type, false);
    // increment counter
    var i_n <- ir_fresh_tmp(b, "fi");
    ir_push_inst(b.cur_block, ii_load(i_n, T.mk_int(), ir_reg(idx_slot, T.mk_int())));
    var nx <- ir_fresh_tmp(b, "fnext");
    ir_push_inst(b.cur_block, ii_add(nx, ir_reg(i_n, T.mk_int()), ir_const_int(1)));
    ir_push_inst(b.cur_block, ii_store(ir_reg(nx, T.mk_int()), ir_reg(idx_slot, T.mk_int())));
    ir_set_terminator(b.cur_block, ii_br(cond_lbl));

    // end: print "]"
    var end_bb <- ir_block(end_lbl);
    ir_fn_add_block(b.func, end_bb);
    b.cur_block <- end_bb;
    ir_emit_lit(b, "]");
    return 0;
}

// Emit `{name: val, ...}` for a struct value. No newline (caller handles top
// level). Fields are unrolled at compile time using the static struct_lit
// type — we know names and per-field types up front.
fn ir_emit_format_struct(b, struct_val, fields) {
    ir_emit_lit(b, "{");
    var i <- 0;
    while (i < len(fields)) {
        var f <- fields[i];
        if (i > 0) { ir_emit_lit(b, ", "); }
        ir_emit_lit(b, f.name + ": ");
        // Fetch the field's value via struct_get. The runtime returns i64
        // regardless; format_value re-interprets it through f.type.
        var fid <- ir_mod_add_str(b.mod, f.name);
        var fld_reg <- ir_fresh_tmp(b, "fld");
        ir_push_inst(b.cur_block, ii_struct_get(fld_reg, T.mk_int(), struct_val, fid));
        ir_emit_format_value(b, ir_reg(fld_reg, T.mk_int()), f.type, false);
        i <- i + 1;
    }
    ir_emit_lit(b, "}");
    return 0;
}

// Wrap a member value in a {tag, payload} union cell. tag = the member's
// index in the normalized union (exact type match, or a struct value whose
// field types are narrower than the member's — see union_member_index).
// Universal tags for tagged `any` cells (see spec-tagged-any). Cells share
// the union {tag, payload} layout but use this fixed namespace, because
// `any`'s member set is open. 7 = opaque: the value crossed a none -> any
// edge, so its kind is statically unknown; opaque payloads keep the old
// magnitude-heuristic semantics.
fn any_tag_of(k: str): int {
    if (k = "int") { return 0; }
    if (k = "float") { return 1; }
    if (k = "bool") { return 2; }
    if (k = "str") { return 3; }
    if (k = "array") { return 4; }
    if (k = "struct_lit") { return 5; }
    if (k = "struct") { return 5; }
    if (k = "fn") { return 6; }
    return 7;
}

// Wrap a value into a tagged any-cell, keyed by its static type. Already-
// any values pass through (they are cells); unions cannot be stored into
// any (their positional tags are meaningless outside their member list).
fn ir_wrap_any(b, vreg, st) {
    if (st.kind = "any") { return vreg; }
    if (st.kind = "union") {
        report_error(0, 0, "cannot store a union value into any; match it and store the member");
        return vreg;
    }
    var dst <- ir_fresh_tmp(b, "aw");
    ir_push_inst(b.cur_block, ii_union_new(dst, ir_const_int(any_tag_of(st.kind)), vreg));
    return ir_reg(dst, T.mk_any());
}

// Unwrap a statically-any value to its raw payload word, keyed by the
// STATIC type (many emitters stamp approximate types on registers, so the
// register type cannot be trusted). The invariant "static any implies
// tagged cell" makes the payload load unconditional under the gate.
fn ir_unwrap_any(b, vreg, st) {
    if (st.kind != "any") { return vreg; }
    var p <- ir_fresh_tmp(b, "auw");
    ir_push_inst(b.cur_block, ii_union_payload(p, vreg));
    // The payload is a raw i64 word; stamp int so downstream call/store
    // rendering treats it as a value (none would render as void).
    return ir_reg(p, T.mk_int());
}

// Checked unwrap: like ir_unwrap_any, but verifies the cell tag
// against `want` at runtime — a universal tag from any_tag_of, or 8 =
// "indexable" (str or array). Tag 7 (opaque) passes any expectation;
// int/bool/float (tags 0..2) accept each other, with an expected float
// promoting an int/bool payload to double bits inside the helper (the
// reverse raw-bits edge is deliberate — spec-tagged-any). A mismatch
// prints `Error: expected <kind> in any, got <kind>` and exits 1.
fn ir_unwrap_any_checked(b, vreg, st, want: int) {
    if (st.kind != "any") { return vreg; }
    var c <- ir_fresh_tmp(b, "auc");
    ir_push_inst(b.cur_block, ii_call(c, T.mk_int(), "arrow_any_unwrap", [vreg, ir_const_int(want)]));
    return ir_reg(c, T.mk_int());
}

// Split a value into (tag, payload) operands for the dyn runtime helpers.
// A static any is a cell (load both words); a concrete side rides with a
// constant universal tag; none rides as opaque, keeping the raw tier's
// heuristic semantics inside the helper.
fn ir_dyn_side(b, vreg, st) {
    if (st.kind = "any") {
        var t <- ir_fresh_tmp(b, "dt");
        ir_push_inst(b.cur_block, ii_union_tag(t, vreg));
        var p <- ir_fresh_tmp(b, "dp");
        ir_push_inst(b.cur_block, ii_union_payload(p, vreg));
        return {t: ir_reg(t, T.mk_int()), p: ir_reg(p, T.mk_int())};
    }
    return {t: ir_const_int(any_tag_of(st.kind)), p: vreg};
}

// Does this container type hold an `any` position at any depth? Mirrors
// union_in_container for the tagged tier: such slots route through the
// coercion path so every any position wraps its value.
fn contains_dyn(t): int {
    if (t.kind = "any") { return true; }
    if (t.kind = "array") { return contains_dyn(t.elem); }
    if (t.kind = "struct_lit") {
        var i <- 0;
        while (i < len(t.fields)) {
            if (contains_dyn(t.fields[i].type)) { return true; }
            i <- i + 1;
        }
    }
    return false;
}

// Emit a call argument bound for a RAW-TIER target: builtins and
// unannotated params. A statically-any argument is unwrapped to its
// payload here. Annotation-aware call paths route through
// ir_coerce_slot_value instead and never reach this for tagged targets.
fn ir_emit_arg(b, e) {
    return ir_unwrap_any(b, ir_emit_expr(b, e), typeof_expr(e));
}

fn ir_union_wrap(b, val, member_type, union_type) {
    if (member_type.kind = "any") {
        report_error(0, 0, "cannot widen a value of unknown type (any) into union " + T.type_str(union_type) + "; give the source a concrete member type");
    }
    var tag <- union_member_index(union_type, member_type);
    var dst <- ir_fresh_tmp(b, "umk");
    ir_push_inst(b.cur_block, ii_union_new(dst, ir_const_int(tag), val));
    return ir_reg(dst, union_type);
}

// Format a union value: load its tag, then an if-chain selecting the member
// formatter on the reinterpreted payload. top_level flows through so scalar
// members use the print* path (with newline) and nested ones use format*.
fn ir_emit_format_union(b, cell_val, members, top_level: int) {
    var ms <- T.union_normalize(members);
    var tag <- ir_fresh_tmp(b, "utag");
    ir_push_inst(b.cur_block, ii_union_tag(tag, cell_val));
    var payload <- ir_fresh_tmp(b, "upay");
    ir_push_inst(b.cur_block, ii_union_payload(payload, cell_val));
    var join_lbl <- ir_fresh_block_lbl(b, "ujoin");
    var i <- 0;
    while (i < len(ms)) {
        var do_lbl <- ir_fresh_block_lbl(b, "udo");
        var next_lbl <- join_lbl;
        if (i + 1 < len(ms)) { next_lbl <- ir_fresh_block_lbl(b, "utest"); }
        var cmp <- ir_fresh_tmp(b, "ucmp");
        ir_push_inst(b.cur_block, ii_icmp(cmp, "eq", ir_reg(tag, T.mk_int()), ir_const_int(i)));
        var brc <- ir_fresh_tmp(b, "br");
        ir_set_terminator(b.cur_block, ii_cond_br(brc, ir_reg(cmp, T.mk_int()), do_lbl, next_lbl));
        var do_bb <- ir_block(do_lbl);
        ir_fn_add_block(b.func, do_bb);
        b.cur_block <- do_bb;
        ir_emit_format_value(b, ir_reg(payload, ms[i]), ms[i], top_level);
        ir_set_terminator(b.cur_block, ii_br(join_lbl));
        if (i + 1 < len(ms)) {
            var next_bb <- ir_block(next_lbl);
            ir_fn_add_block(b.func, next_bb);
            b.cur_block <- next_bb;
        }
        i <- i + 1;
    }
    var join_bb <- ir_block(join_lbl);
    ir_fn_add_block(b.func, join_bb);
    b.cur_block <- join_bb;
    return 0;
}

// Build `expr` as a value for a slot of type `slot_t`. If the slot is itself a
// union, a member value is wrapped into a {tag, payload} cell here; container
// slots (arrays/structs holding unions) are built by ir_emit_value_for_slot.
fn ir_coerce_slot_value(b, expr, slot_t) {
    // A slot declared `any` stores a tagged cell: wrap the value by its
    // static type (already-any values pass through as cells).
    if (slot_t.kind = "any") {
        var avt <- typeof_expr(expr);
        var araw <- ir_emit_expr(b, expr);
        return ir_wrap_any(b, araw, avt);
    }
    // A union *leaf* (this position is itself a union member): wrap the value
    // into a {tag, payload} cell. Otherwise descend through any container.
    if (slot_t.kind = "union") {
        var vt <- typeof_expr(expr);
        if (vt.kind != "union") {
            // Resolve which member the value inhabits, then build the value
            // *for that member type* so a struct member's union-typed fields
            // get wrapped (a literal {tag: 42} stored into a {tag: int | str}
            // member needs its tag field wrapped into an int|str cell) before
            // the whole value is tagged as that member.
            var midx <- union_member_index(slot_t, vt);
            var mem <- vt;
            if (midx >= 0) {
                var ms2 <- T.union_normalize(slot_t.members);
                mem <- ms2[midx];
            }
            var raw <- ir_emit_value_for_slot(b, expr, mem);
            return ir_union_wrap(b, raw, mem, slot_t);
        }
        return ir_emit_expr(b, expr);
    }
    return ir_emit_value_for_slot(b, expr, slot_t);
}

// Recursively build `expr` as a value for `slot_t`, wrapping every union-typed
// position that sits *inside* a container (a struct field or array element, at
// any depth) into a {tag, payload} cell. A whole-value (top-level) union is not
// wrapped here — the var-decl/return/arg sites wrap that themselves — but the
// value IS built for the specific member type it inhabits, so a struct member's
// own union fields get coerced before the caller tags it. Slots with no nested
// union emit through the normal expression path unchanged.
fn ir_emit_value_for_slot(b, expr, slot_t) {
    if (slot_t.kind = "array" && expr.node = "ArrayLit" && (T.union_in_container(slot_t) || contains_dyn(slot_t))) {
        var welems <- [];
        var wi <- 0;
        while (wi < len(expr.elements)) {
            push(welems, ir_coerce_slot_value(b, expr.elements[wi], slot_t.elem));
            wi <- wi + 1;
        }
        var atmp <- ir_fresh_tmp(b, "uarr");
        ir_push_inst(b.cur_block, ii_array_new(atmp, T.mk_int(), welems));
        return ir_reg(atmp, slot_t);
    }
    if (slot_t.kind = "struct_lit" && expr.node = "StructLit" && (T.union_in_container(slot_t) || contains_dyn(slot_t))) {
        var fields <- [];
        var fi <- 0;
        while (fi < len(expr.fields)) {
            var fkey <- expr.fields[fi].key;
            var fslot <- T.struct_field_type(slot_t.fields, fkey);
            var fval <- ir_coerce_slot_value(b, expr.fields[fi].val, fslot);
            var fkid <- ir_mod_add_str(b.mod, fkey);
            push(fields, {key_id: fkid, val: fval});
            fi <- fi + 1;
        }
        var stmp <- ir_fresh_tmp(b, "sl");
        ir_push_inst(b.cur_block, ir_inst("struct_new", stmp, T.mk_struct(), [], fields));
        return ir_reg(stmp, T.mk_struct());
    }
    if (slot_t.kind = "union") {
        var uvt <- typeof_expr(expr);
        if (uvt.kind != "union") {
            var umidx <- union_member_index(slot_t, uvt);
            if (umidx >= 0) {
                var ums <- T.union_normalize(slot_t.members);
                return ir_emit_value_for_slot(b, expr, ums[umidx]);
            }
        }
    }
    // A tagged value landing in any non-any slot (concrete or raw) unwraps
    // to its payload word. This tail owns the unwrap for every slot route
    // (assignments, returns, element/field stores), so the callers only add
    // the wrap direction.
    var dvt <- typeof_expr(expr);
    if (dvt.kind = "any" && slot_t.kind != "any") {
        // Raw (none) slots take the unchecked payload — "none is not
        // type checked, not even at runtime". Union slots are
        // unreachable here (any -> union is rejected statically) and
        // stay raw defensively. Every concrete slot verifies the tag
        // here — this tail owns the checked unwrap for assignments,
        // returns, element/field stores and annotated call arguments.
        if (slot_t.kind = "none" || slot_t.kind = "union") {
            return ir_unwrap_any(b, ir_emit_expr(b, expr), dvt);
        }
        return ir_unwrap_any_checked(b, ir_emit_expr(b, expr), dvt, any_tag_of(slot_t.kind));
    }
    return ir_emit_expr(b, expr);
}
fn ir_emit_stmt(b, stmt) {
    if (stmt.node = "ReturnStmt") {
        if (stmt.expr = false) {
            // bare `return;` — still require a terminator for well-formed IR.
            ir_set_terminator(b.cur_block, ii_ret(ir_const_int(0)));
        } else {
            var rfn <- find_fn(b.func.name);
            var rslot <- T.mk_none();
            if (rfn != false) { rslot <- rfn.ret_type_ann; }
            var v: any <- ir_emit_value_for_slot(b, stmt.expr, rslot);
            // Return coercion: a member value returned from a union-typed
            // function is wrapped in a {tag, payload} cell, so callers (which
            // type the call as the union) receive a real union value. A struct
            // or array return whose fields hold unions is wrapped field-wise by
            // ir_emit_value_for_slot above; values already of union type pass
            // through unchanged.
            var rvt <- typeof_expr(stmt.expr);
            if (rslot.kind = "union") {
                if (rvt.kind != "union") {
                    v <- ir_union_wrap(b, v, rvt, rslot);
                }
            }
            // Tagged-any return edges: an any-returning function wraps a
            // concrete value; a concrete/raw-returning function unwraps a
            // tagged one.
            if (rslot.kind = "any") { v <- ir_wrap_any(b, v, rvt); }
            ir_set_terminator(b.cur_block, ii_ret(v));
        }
        return 0;
    }
    if (stmt.node = "Assignment") {
        var slot_t <- T.mk_none();
        if (stmt.type_ann.kind != "none") {
            slot_t <- stmt.type_ann;
        } else {
            // Look up existing var type — same name may have been declared earlier.
            slot_t <- get_var_type(stmt.name);
            // The tier key is the declaration: a lookup that reads `any`
            // only means a tagged slot when the name is DECLARED any.
            // (A miss also reads as any — synthetic desugar temps like
            // for-in counters must stay raw.)
            if (slot_t.kind = "any" && get_decl_type(stmt.name).kind != "any") {
                slot_t <- T.mk_none();
            }
        }
        // An array-of-union literal wraps each element into the union at
        // construction (ir_emit_value_for_slot); all other RHS forms emit
        // normally. The float promotion below still applies for float slots:
        // storing raw int bits into a float slot would bitcast to a denormal.
        var v: any <- ir_emit_value_for_slot(b, stmt.expr, slot_t);
        var rhs_t <- typeof_expr(stmt.expr);
        // If the RHS was an ArrowFn (returned a value carrying arrow_fn_name),
        // record this var as holding a closure so future CallExpr on this name
        // emit closure_call instead of a direct call, and mirror the inferred
        // return type onto the var's declared_fns entry so typeof_expr at call
        // sites returns the right kind. This runs BEFORE the slot coercions
        // below: the tagged-any wrap replaces `v` with a plain cell register,
        // which would lose the arrow_* marker fields this block reads.
        if (stmt.expr.node = "ArrowFn") {
            ir_set_closure(b, stmt.name, v.arrow_fn_name, v.arrow_param_count);
            set_fn_ret_type(stmt.name, v.arrow_ret_type, false);
            set_arrow_fn_var(stmt.name, v.arrow_fn_name);
        }
        if (slot_t.kind = "float" && (rhs_t.kind = "int" || rhs_t.kind = "bool")) {
            // Promote: sitofp i64 → double, then bitcast double → i64 storage.
            var dr <- ir_fresh_tmp(b, "fsi");
            ir_push_inst(b.cur_block, ii_sitofp(dr, v));
            var i64r <- ir_fresh_tmp(b, "fi");
            ir_push_inst(b.cur_block, ii_bc_d_to_i(i64r, ir_reg(dr, T.mk_float())));
            v <- ir_reg(i64r, T.mk_float());
        }
        // Union coercion: a member value stored into a union-typed slot is
        // wrapped in a {tag, payload} cell. Values already of union type
        // (e.g. from a union-returning call) pass through unchanged.
        if (slot_t.kind = "union" && rhs_t.kind != "union") {
            v <- ir_union_wrap(b, v, rhs_t, slot_t);
        }
        // Tagged-any coercion: a concrete value stored into a slot declared
        // any is wrapped into a tagged cell. (The reverse edge — a tagged
        // value into a non-any slot — is unwrapped inside
        // ir_emit_value_for_slot, which built `v` above.)
        if (slot_t.kind = "any" && rhs_t.kind != "any") {
            v <- ir_wrap_any(b, v, rhs_t);
        }
        // Route the store based on declaration intent.
        //
        //   var x <- expr;   (is_decl=true)   always writes to a fresh
        //                                     local alloca in this function
        //                                     — even if a global of the
        //                                     same name exists, this is a
        //                                     deliberate shadow.
        //
        //   x <- expr;       (is_decl=false)  walks up: if there's already
        //                                     a local in this function, use
        //                                     it; otherwise, if `x` is a
        //                                     global, store to @g_x; else
        //                                     fall back to local. (The
        //                                     scope checker rejects the
        //                                     last case ahead of time, so
        //                                     it shouldn't happen here.)
        //
        // At the top-level synthetic frame (__main_logic), top-level vars
        // ARE the globals, so both forms route to @g_x.
        //
        // Closure shadowing: if `var x` shadows a captured (boxed) slot
        // — which happens in closure bodies like `var n <- n + 1;` — we
        // un-box the slot at the var-decl site. The RHS evaluation
        // already happened above (reading through the box, getting the
        // captured value); now we want this `var` to introduce a fresh
        // local shadow, so subsequent reads find the new value directly
        // and writes don't propagate back to the outer's box.
        var is_top_level <- (b.func.name = "__main_logic");
        if (is_top_level && is_global(stmt.name)) {
            ir_push_inst(b.cur_block, ii_store(v, ir_reg("@g_" + stmt.name, T.mk_int())));
        } else {
            if (stmt.is_decl) {
                var slot <- ir_get_local_slot(b, stmt.name);
                // If this `var` is shadowing a captured (not-owned) box,
                // un-box now so subsequent reads/writes go to the local
                // slot directly. If we OWN the box (it's the original
                // declaration in the outer fn that allocated it), keep
                // the box — the store-to-slot below will write through.
                if (ir_is_boxed(b, stmt.name) && !ir_is_box_owned(b, stmt.name)) {
                    ir_unmark_boxed(b, stmt.name);
                }
                ir_emit_store_to_slot(b, slot, stmt.name, v);
            } else {
                if (ir_has_local_slot(b, stmt.name)) {
                    var slot2 <- ir_get_local_slot(b, stmt.name);
                    ir_emit_store_to_slot(b, slot2, stmt.name, v);
                } else {
                    if (is_global(stmt.name)) {
                        ir_push_inst(b.cur_block, ii_store(v, ir_reg("@g_" + stmt.name, T.mk_int())));
                    } else {
                        // Defensive fall-through. The scope checker should
                        // have rejected this; if we reach here, behave as
                        // the old auto-declare did and emit a local.
                        var slot3 <- ir_get_local_slot(b, stmt.name);
                        ir_emit_store_to_slot(b, slot3, stmt.name, v);
                    }
                }
            }
        }
        return 0;
    }
    if (stmt.node = "IndexAssign") {
        // Element writes are array-only — expected tag 4 strictly.
        var obj <- ir_unwrap_any_checked(b, ir_emit_expr(b, stmt.obj), typeof_expr(stmt.obj), any_tag_of("array"));
        var idx <- ir_unwrap_any(b, ir_emit_expr(b, stmt.index), typeof_expr(stmt.index));
        // Coerce the new value to the array's element type: a union
        // element stores a {tag,payload} cell, so a member value is
        // wrapped (and a nested container has its own unions wrapped,
        // recursively) instead of landing as a raw word.
        var at <- typeof_expr(stmt.obj);
        var eslot <- T.mk_none();
        if (at.kind = "array") { eslot <- at.elem; }
        var val <- ir_coerce_slot_value(b, stmt.value, eslot);
        var prefix <- ir_fresh_tmp(b, "aset");
        ir_push_inst(b.cur_block, ii_array_set(prefix, obj, idx, val));
        return 0;
    }
    if (stmt.node = "DotAssign") {
        // A statically-any object must hold a struct (tag 5).
        var obj <- ir_unwrap_any_checked(b, ir_emit_expr(b, stmt.obj), typeof_expr(stmt.obj), any_tag_of("struct"));
        // Coerce the new value to the field's declared type: a union-typed
        // field stores a {tag,payload} cell, so a member value is wrapped
        // (and a nested container has its own unions wrapped, recursively).
        var ot <- typeof_expr(stmt.obj);
        var fslot <- T.mk_none();
        if (ot.kind = "struct_lit") { fslot <- T.struct_field_type(ot.fields, stmt.field); }
        var val <- ir_coerce_slot_value(b, stmt.value, fslot);
        var fid <- ir_mod_add_str(b.mod, stmt.field);
        var prefix <- ir_fresh_tmp(b, "sset");
        ir_push_inst(b.cur_block, ii_struct_set(prefix, obj, fid, val));
        return 0;
    }
    if (stmt.node = "PrintStmt") {
        var pv <- ir_emit_expr(b, stmt.expr);
        // Decide formatting based on the expression's static type. typeof_expr
        // consults var_types (set by scan_call_sites + infer_body in our prep
        // pass) so identifiers / params / fields with inferred types are
        // recognized, not just surface literals. For composite types
        // (array, struct_lit) ir_emit_format_value emits an inline runtime
        // walk; for scalars it dispatches to print_int / print_str / print_bool.
        var et <- typeof_expr(stmt.expr);
        ir_emit_format_value(b, pv, et, true);
        return 0;
    }
    if (stmt.node = "MatchStmt") {
        var cell <- ir_emit_expr(b, stmt.scrutinee);
        var ut <- typeof_expr(stmt.scrutinee);
        if (ut.kind != "union") { return 0; }
        var tag <- ir_fresh_tmp(b, "mtag");
        ir_push_inst(b.cur_block, ii_union_tag(tag, cell));
        var join_lbl <- ir_fresh_block_lbl(b, "mjoin");
        var mi <- 0;
        while (mi < len(stmt.arms)) {
            var arm <- stmt.arms[mi];
            if (arm.wild) {
                var wbi <- 0;
                while (wbi < len(arm.body)) { ir_emit_stmt(b, arm.body[wbi]); wbi <- wbi + 1; }
                if (b.cur_block.terminator = false) { ir_set_terminator(b.cur_block, ii_br(join_lbl)); }
            } else {
            var midx <- union_member_index(ut, arm.ptype);
            var do_lbl <- ir_fresh_block_lbl(b, "marm");
            var next_lbl <- join_lbl;
            if (mi + 1 < len(stmt.arms)) { next_lbl <- ir_fresh_block_lbl(b, "mnext"); }
            var cmp <- ir_fresh_tmp(b, "mcmp");
            ir_push_inst(b.cur_block, ii_icmp(cmp, "eq", ir_reg(tag, T.mk_int()), ir_const_int(midx)));
            if (arm.is_lit) {
                var vchk_lbl <- ir_fresh_block_lbl(b, "mval");
                var brt <- ir_fresh_tmp(b, "br");
                ir_set_terminator(b.cur_block, ii_cond_br(brt, ir_reg(cmp, T.mk_int()), vchk_lbl, next_lbl));
                var vchk_bb <- ir_block(vchk_lbl);
                ir_fn_add_block(b.func, vchk_bb);
                b.cur_block <- vchk_bb;
                var lpay <- ir_fresh_tmp(b, "mlpay");
                ir_push_inst(b.cur_block, ii_union_payload(lpay, cell));
                var veq <- ir_fresh_tmp(b, "mveq");
                if (arm.lit_kind = "str") {
                    var sid <- ir_mod_add_str(b.mod, arm.lit);
                    var lptr <- ir_fresh_tmp(b, "mls");
                    ir_push_inst(b.cur_block, ii_ptrtoint(lptr, ir_const_str(sid)));
                    ir_push_inst(b.cur_block, ii_strcmp(veq, "eq", ir_reg(lpay, T.mk_str()), ir_reg(lptr, T.mk_str())));
                } else {
                    var kconst <- ir_const_int(0);
                    if (arm.lit_kind = "bool") {
                        if (arm.lit = "true") { kconst <- ir_const_int(1); }
                    } else {
                        kconst <- ir_const_int(arm.lit);
                    }
                    ir_push_inst(b.cur_block, ii_icmp(veq, "eq", ir_reg(lpay, T.mk_int()), kconst));
                }
                var brv <- ir_fresh_tmp(b, "br");
                ir_set_terminator(b.cur_block, ii_cond_br(brv, ir_reg(veq, T.mk_int()), do_lbl, next_lbl));
            } else {
                var brc <- ir_fresh_tmp(b, "br");
                ir_set_terminator(b.cur_block, ii_cond_br(brc, ir_reg(cmp, T.mk_int()), do_lbl, next_lbl));
            }
            var do_bb <- ir_block(do_lbl);
            ir_fn_add_block(b.func, do_bb);
            b.cur_block <- do_bb;
            var bn <- match_bind_name(arm, stmt.scrutinee);
            var swapped <- false;
            var swap_i <- -1;
            var add_idx <- -1;
            var saved_reg <- "";
            var saved_boxed <- false;
            var saved_vt <- T.mk_none();
            if (bn != "") {
                var payload <- ir_fresh_tmp(b, "mpay");
                ir_push_inst(b.cur_block, ii_union_payload(payload, cell));
                var slot <- ir_fresh_tmp(b, "mbind");
                ir_push_inst(b.func.blocks[0], ii_alloca(slot, T.mk_int()));
                ir_push_inst(b.cur_block, ii_store(ir_reg(payload, arm.ptype), ir_reg(slot, T.mk_int())));
                var li <- 0;
                var found <- false;
                while (li < len(b.locals)) {
                    if (b.locals[li].name = bn) { found <- true; swap_i <- li; }
                    li <- li + 1;
                }
                if (found) {
                    saved_reg <- b.locals[swap_i].reg;
                    saved_boxed <- b.locals[swap_i].boxed;
                    b.locals[swap_i].reg <- slot;
                    b.locals[swap_i].boxed <- false;
                    swapped <- true;
                } else {
                    add_idx <- len(b.locals);
                    push(b.locals, {name: bn, reg: slot, boxed: false, box_owned: false});
                }
                saved_vt <- get_var_type(bn);
                set_var_type(bn, arm.ptype);
            }
            var bi <- 0;
            while (bi < len(arm.body)) { ir_emit_stmt(b, arm.body[bi]); bi <- bi + 1; }
            if (bn != "") {
                set_var_type(bn, saved_vt);
                if (swapped) {
                    b.locals[swap_i].reg <- saved_reg;
                    b.locals[swap_i].boxed <- saved_boxed;
                } else {
                    var nl <- [];
                    var ri <- 0;
                    while (ri < len(b.locals)) { if (ri != add_idx) { push(nl, b.locals[ri]); } ri <- ri + 1; }
                    b.locals <- nl;
                }
            }
            if (b.cur_block.terminator = false) { ir_set_terminator(b.cur_block, ii_br(join_lbl)); }
            if (mi + 1 < len(stmt.arms)) {
                var next_bb <- ir_block(next_lbl);
                ir_fn_add_block(b.func, next_bb);
                b.cur_block <- next_bb;
            }
            }
            mi <- mi + 1;
        }
        var join_bb <- ir_block(join_lbl);
        ir_fn_add_block(b.func, join_bb);
        b.cur_block <- join_bb;
        return 0;
    }
    if (stmt.node = "IfStmt") {
        var cond <- ir_unwrap_any(b, ir_emit_expr(b, stmt.cond), typeof_expr(stmt.cond));
        var then_lbl <- ir_fresh_block_lbl(b, "then");
        var end_lbl  <- ir_fresh_block_lbl(b, "ifend");
        var has_else <- len(stmt.else_body) > 0;
        var else_lbl <- end_lbl;
        if (has_else) { else_lbl <- ir_fresh_block_lbl(b, "else"); }
        var br_tmp <- ir_fresh_tmp(b, "br");
        ir_set_terminator(b.cur_block, ii_cond_br(br_tmp, cond, then_lbl, else_lbl));

        // then branch
        var then_bb <- ir_block(then_lbl);
        ir_fn_add_block(b.func, then_bb);
        b.cur_block <- then_bb;
        var i <- 0;
        while (i < len(stmt.then_body)) {
            ir_emit_stmt(b, stmt.then_body[i]);
            i <- i + 1;
        }
        // If the then-body didn't terminate (e.g. ended with a return), branch
        // to end. Otherwise the existing terminator stays. ir_set_terminator
        // overwrites — protect with a check.
        if (b.cur_block.terminator = false) {
            ir_set_terminator(b.cur_block, ii_br(end_lbl));
        }

        // else branch (if any)
        if (has_else) {
            var else_bb <- ir_block(else_lbl);
            ir_fn_add_block(b.func, else_bb);
            b.cur_block <- else_bb;
            i <- 0;
            while (i < len(stmt.else_body)) {
                ir_emit_stmt(b, stmt.else_body[i]);
                i <- i + 1;
            }
            if (b.cur_block.terminator = false) {
                ir_set_terminator(b.cur_block, ii_br(end_lbl));
            }
        }

        // join
        var end_bb <- ir_block(end_lbl);
        ir_fn_add_block(b.func, end_bb);
        b.cur_block <- end_bb;
        return 0;
    }
    if (stmt.node = "WhileStmt") {
        var cond_lbl <- ir_fresh_block_lbl(b, "wc");
        var body_lbl <- ir_fresh_block_lbl(b, "wb");
        var end_lbl  <- ir_fresh_block_lbl(b, "we");

        // jump from current block into the cond block
        ir_set_terminator(b.cur_block, ii_br(cond_lbl));

        // cond
        var cond_bb <- ir_block(cond_lbl);
        ir_fn_add_block(b.func, cond_bb);
        b.cur_block <- cond_bb;
        var cond <- ir_unwrap_any(b, ir_emit_expr(b, stmt.cond), typeof_expr(stmt.cond));
        var br_tmp <- ir_fresh_tmp(b, "br");
        ir_set_terminator(b.cur_block, ii_cond_br(br_tmp, cond, body_lbl, end_lbl));

        // body
        var body_bb <- ir_block(body_lbl);
        ir_fn_add_block(b.func, body_bb);
        b.cur_block <- body_bb;
        var i <- 0;
        while (i < len(stmt.body)) {
            ir_emit_stmt(b, stmt.body[i]);
            i <- i + 1;
        }
        if (b.cur_block.terminator = false) {
            ir_set_terminator(b.cur_block, ii_br(cond_lbl));
        }

        // end
        var end_bb <- ir_block(end_lbl);
        ir_fn_add_block(b.func, end_bb);
        b.cur_block <- end_bb;
        return 0;
    }
    if (stmt.node = "Block") {
        var i <- 0;
        while (i < len(stmt.stmts)) {
            ir_emit_stmt(b, stmt.stmts[i]);
            i <- i + 1;
        }
        return 0;
    }
    if (stmt.node = "ForInStmt") {
        // Desugar `for (x in coll) { body }` into:
        //
        //     _for_idx_N <- 0;
        //     while (_for_idx_N < len(coll)) {
        //         x <- coll[_for_idx_N];
        //         body...
        //         _for_idx_N <- _for_idx_N + 1;
        //     }
        //
        // We construct synthetic AST nodes and recurse through ir_emit_stmt /
        // ir_emit_expr. Length, indexing, and inc/cmp all reuse the existing
        // emitter paths, so str-vs-array dispatch comes for free.
        //
        // The counter is named uniquely per loop so nested for-ins don't
        // clobber each other's index. Without this, an inner loop's final
        // counter value leaks into the outer loop's increment, breaking the
        // outer loop's continuation check after a single iteration.
        b.for_idx_counter[0] <- b.for_idx_counter[0] + 1;
        var idx_name <- "_for_idx_" + b.for_idx_counter[0];

        var idx_init <- {node: "Assignment", name: idx_name, expr: {node: "NumberLit", value: 0}, type_ann: T.mk_none(), is_decl: true};
        ir_emit_stmt(b, idx_init);

        // condition: idx_name < len(coll)
        var cond_ast <- {
            node: "BinOp",
            op: "<",
            left: {node: "Identifier", name: idx_name},
            right: {node: "CallExpr", callee: {node: "Identifier", name: "len"}, args: [stmt.iterable]}
        };

        // body: x <- coll[idx_name]; <user body>; idx_name <- idx_name + 1;
        var bind_x <- {
            node: "Assignment",
            name: stmt.var_name,
            expr: {node: "IndexExpr", obj: stmt.iterable, index: {node: "Identifier", name: idx_name}},
            type_ann: T.mk_none(),
            is_decl: true
        };
        var inc_idx <- {
            node: "Assignment",
            name: idx_name,
            expr: {node: "BinOp", op: "+", left: {node: "Identifier", name: idx_name}, right: {node: "NumberLit", value: 1}},
            type_ann: T.mk_none(),
            is_decl: false
        };
        // Statement nodes of mixed shapes go in here, so the element
        // type must be the explicit escape hatch.
        var new_body: [any] <- [bind_x];
        var i <- 0;
        while (i < len(stmt.body)) {
            push(new_body, stmt.body[i]);
            i <- i + 1;
        }
        push(new_body, inc_idx);

        var while_stmt <- {node: "WhileStmt", cond: cond_ast, body: new_body};
        ir_emit_stmt(b, while_stmt);
        return 0;
    }
    if (stmt.node = "ExprStmt") {
        // Evaluate for side effects; discard result.
        ir_emit_expr(b, stmt.expr);
        return 0;
    }
    // Bare expressions used as statements (the parser doesn't wrap them in
    // ExprStmt — calls and similar appear directly). Reuse ir_emit_expr for
    // anything that looks like an expression node.
    if (stmt.node = "CallExpr"
            || stmt.node = "BinOp"
            || stmt.node = "UnaryOp"
            || stmt.node = "NumberLit"
            || stmt.node = "FloatLit"
            || stmt.node = "StringLit"
            || stmt.node = "BoolLit"
            || stmt.node = "Identifier") {
        ir_emit_expr(b, stmt);
        return 0;
    }
    print("ir_emit_stmt: unsupported node " + stmt.node);
    return 0;
}

// Translate an AST FnDecl into an IR Function. The owning Module is passed
// so emitters that need to register string constants or externs can do so.
// The caller is responsible for adding the returned Function to the Module.
//
// This function mirrors the prep dance done by the existing emit_function:
// save the caller's type-tracking state, populate param types from the
// call-site-analysis info, run infer_body to populate var_types for this
// function's locals, then emit. State is restored on the way out.
fn emit_function_via_ir(nd, mod) {
    var params <- [];
    var i <- 0;
    while (i < len(nd.params)) {
        push(params, {name: nd.params[i], type: T.mk_int()});
        i <- i + 1;
    }
    var f <- ir_function(nd.name, params, T.mk_int());

    var ent_bb <- ir_block("entry");
    ir_fn_add_block(f, ent_bb);
    var b <- ir_builder_new(f, ent_bb, mod);

    // Save type-tracking state and start fresh for this function's body.
    var old_vars <- alloc_vars[0];
    var old_types <- var_types[0];
    var old_layouts <- struct_layouts[0];
    var old_arr_types <- array_elem_types[0];
    var old_decl_types <- decl_types[0];
    alloc_vars[0] <- [];
    var_types[0] <- [];
    struct_layouts[0] <- [];
    array_elem_types[0] <- [];
    decl_types[0] <- [];
    shadow_decls[0] <- [];
    var old_fn <- current_fn[0];
    current_fn[0] <- nd.name;

    // Preserve type info for top-level globals into this function's scope.
    // Mirrors what the existing compile() does implicitly via shared state —
    // typeof_expr inside the body needs to see e.g. tmp_counter as an int
    // array global, not as `any`, so `prefix + tmp_counter[0]` correctly
    // routes to strcat-with-int-conversion rather than int-add.
    var gi <- 0;
    while (gi < len(old_types)) {
        if (is_global(old_types[gi].name)) {
            push(var_types[0], old_types[gi]);
        }
        gi <- gi + 1;
    }
    // Same for array element types and struct layouts of globals.
    gi <- 0;
    while (gi < len(old_arr_types)) {
        if (is_global(old_arr_types[gi].var_name)) {
            push(array_elem_types[0], old_arr_types[gi]);
        }
        gi <- gi + 1;
    }
    gi <- 0;
    while (gi < len(old_layouts)) {
        if (is_global(old_layouts[gi].var_name)) {
            push(struct_layouts[0], old_layouts[gi]);
        }
        gi <- gi + 1;
    }
    gi <- 0;
    while (gi < len(old_decl_types)) {
        if (is_global(old_decl_types[gi].name)) {
            push(decl_types[0], old_decl_types[gi]);
        }
        gi <- gi + 1;
    }

    // Populate param types from call-site analysis (already run by caller).
    var fi_info <- find_fn(nd.name);
    i <- 0;
    while (i < len(nd.params)) {
        // Annotation-first param typing: an explicit annotation is the
        // param's type, and an explicitly-any param joins the tagged tier
        // — call sites wrap its arguments into cells — so it keeps `any`
        // and is enrolled as declared-any for typeof's tier gate. Without
        // an annotation, a call-site join landing on `any` still maps to
        // `none`: nothing wraps those arguments (raw tier).
        var pt2 <- T.mk_any();
        var pann2 <- T.mk_none();
        if (fi_info != false && i < len(fi_info.param_types)) {
            pt2 <- fi_info.param_types[i];
        }
        if (fi_info != false && i < len(fi_info.param_types_ann)) {
            pann2 <- fi_info.param_types_ann[i];
        }
        if (pann2.kind != "none") { pt2 <- pann2; }
        if (pt2.kind = "any" && pann2.kind != "any") { pt2 <- T.mk_none(); }
        if (pann2.kind = "any") { set_decl_type(nd.params[i], pann2); }
        set_var_type(nd.params[i], pt2);
        shadow_declare(nd.params[i], pann2, 0, 0);
            i <- i + 1;
    }

    // Run type inference on body to populate var_types before emission.
    infer_body(nd.body);

    // Type-check the body against any user annotations.
    check_body(nd.body);

    // Type errors detected (here or in an earlier function): skip codegen of
    // this body. Emitting IR for ill-typed code can feed malformed values into
    // the IR builders (e.g. a push whose value matches no union member) and
    // crash the native compiler. The driver suppresses the IR write and link
    // when type_errors is non-empty, so this stub body is never used; it just
    // keeps the in-memory module well-formed while the errors are reported.
    if (len(type_errors) > 0) {
        ir_set_terminator(b.cur_block, ii_ret(ir_const_int(0)));
        alloc_vars[0] <- old_vars;
        var_types[0] <- old_types;
        struct_layouts[0] <- old_layouts;
        array_elem_types[0] <- old_arr_types;
        decl_types[0] <- old_decl_types;
        current_fn[0] <- old_fn;
        return f;
    }

    // Prologue: allocate each param's local slot and store the arg into it.
    i <- 0;
    while (i < len(nd.params)) {
        var pname <- nd.params[i];
        var slot <- ir_get_local_slot(b, pname);
        ir_push_inst(b.cur_block, ii_store(ir_reg("%" + pname + ".arg", T.mk_int()), ir_reg(slot, T.mk_int())));
        i <- i + 1;
    }

    // For non-main functions, pre-populate b.locals with every name assigned
    // to in the body (including for-in loop vars). This ensures that any
    // shadowed-by-name globals resolve to the local slot when read, not the
    // global — without this, a body that reads `i` before assigning it would
    // load from @g_i even if a later Assignment creates the local. (In
    // __main_logic, top-level global names should resolve to globals, so we
    // skip this step there.)
    if (nd.name != "__main_logic") {
        var body_vars <- [];
        collect_vars(nd.body, body_vars);
        i <- 0;
        while (i < len(body_vars)) {
            ir_get_local_slot(b, body_vars[i]);
            i <- i + 1;
        }
        // for-in loops use a synthetic _for_idx counter — pre-allocate that too.
        ir_get_local_slot(b, "_for_idx");

        // any local (or param) captured by a nested ArrowFn gets
        // heap-boxed so reads/writes from either side share storage. The
        // slot now holds the box pointer; ir_emit_store_to_slot and the
        // Identifier read path dereference automatically. Boxes are
        // allocated once per fn entry, so each call gets a fresh cell.
        var to_box <- ir_find_my_captured_locals(b, nd.body);
        var bi <- 0;
        while (bi < len(to_box)) {
            var bname <- to_box[bi];
            var bslot <- ir_get_local_slot(b, bname);
            var box_tmp <- ir_fresh_tmp(b, "box");
            ir_push_inst(b.cur_block, ii_box_alloc(box_tmp));
            ir_push_inst(b.cur_block, ii_store(ir_reg(box_tmp, T.mk_int()), ir_reg(bslot, T.mk_int())));
            // We own the box. `var bname` later in the body is the
            // original declaration and should write through.
            ir_mark_boxed(b, bname, true);
            bi <- bi + 1;
        }
        // If a param is boxed, the param-store earlier put the raw arg
        // value into the slot — but the slot is supposed to hold a box
        // pointer. Restore: box was just allocated above; load the arg
        // back from the (now-bogus) location? No — simpler to redo the
        // param init for boxed params: load the arg directly from the
        // %x.arg register and store it through the box pointer.
        var pi <- 0;
        while (pi < len(nd.params)) {
            var pname <- nd.params[pi];
            if (ir_is_boxed(b, pname)) {
                ir_emit_store_to_slot(b, ir_get_local_slot(b, pname), pname, ir_reg("%" + pname + ".arg", T.mk_int()));
            }
            pi <- pi + 1;
        }
    }

    // Body
    i <- 0;
    while (i < len(nd.body)) {
        ir_emit_stmt(b, nd.body[i]);
        i <- i + 1;
    }

    // If the source function fell off the end without an explicit return,
    // close the final block with `ret i64 0` for IR well-formedness.
    if (b.cur_block.terminator = false) {
        ir_set_terminator(b.cur_block, ii_ret(ir_const_int(0)));
    }

    // Restore caller's type-tracking state.
    alloc_vars[0] <- old_vars;
    var_types[0] <- old_types;
    struct_layouts[0] <- old_layouts;
    array_elem_types[0] <- old_arr_types;
    decl_types[0] <- old_decl_types;
    current_fn[0] <- old_fn;

    return f;
}

// ═══════════════════════════════════════════
//  Backend abstraction
//
//  A Backend is a small struct holding a kind tag plus a couple of
//  identification fields. The backend_* dispatch functions below
//  inspect b.kind and route to the corresponding backend-specific
//  implementation (currently llvm_*; future: cranelift_*, etc.).
//
//  This split isolates everything that emits target-specific IR text
//  or calls a target-specific toolchain. The translator (AST → Arrow
//  IR) is shared across backends; only the rendering of the Arrow IR
//  module and the runtime/wrapper emission are backend-private.
//
//  Adding a new backend means: implement the same stages as llvm_*
//  (preamble, globals, module, runtime, main wrapper, link), then add
//  a constructor + a kind branch to each backend_* dispatcher. The
//  rest of the compiler stays untouched.
// ═══════════════════════════════════════════

fn make_llvm_backend() {
    return {
        kind: "llvm",
        name: "LLVM",
        // File extension for the intermediate text format this backend
        // produces. The CLI uses this to derive the intermediate filename
        // from the user-requested output name.
        intermediate_ext: ".ll"
    };
}

// Emit any target-specific preamble: extern declarations, target triple,
// data layout, etc.
fn backend_emit_preamble(b) {
    if (b.kind = "llvm") {
        llvm_emit_preamble();
    }
}

// Emit declarations for the program's global variables. The list of names
// comes from scan_globals; each backend chooses how to lay them out.
fn backend_emit_globals(b, global_names) {
    if (b.kind = "llvm") {
        llvm_emit_globals(global_names);
    }
}

// Render the Arrow IR module (functions + string table) into the line
// buffer, in the backend's own text format.
fn backend_emit_module(b, m) {
    if (b.kind = "llvm") {
        ir_render_module_to_lines(m);
    }
}

// Emit the runtime helpers (arena allocator, strcat, push, pop, etc.).
// These are linked alongside user code and called by the rendered module.
fn backend_emit_runtime(b) {
    if (b.kind = "llvm") {
        llvm_emit_runtime();
    }
}

// Emit the program entry point (C-ABI main wrapping __main_logic) and any
// trailing constants the runtime needs.
fn backend_emit_main_wrapper(b) {
    if (b.kind = "llvm") {
        llvm_emit_main_wrapper();
    }
}

// Invoke the backend's toolchain to turn the intermediate file into a
// native executable. Returns the toolchain's exit code (0 = success).
fn backend_link(b, ir_file: str, exe_file: str): int {
    if (b.kind = "llvm") {
        return llvm_link(ir_file, exe_file);
    }
    return 1;
}

// ── LLVM backend: target-specific implementations ────────

fn llvm_emit_preamble() {
    emit("; Arrow Lang -- compiled by self-hosted compiler");
    emit("");

    emit("declare i32 @printf(ptr, ...)");
    emit("declare i32 @puts(ptr)");
    emit("declare i32 @putchar(i32)");
    emit("declare i32 @fflush(ptr)");
    emit("declare ptr @malloc(i64)");
    emit("declare ptr @realloc(ptr, i64)");
    emit("declare void @free(ptr)");
    emit("declare i64 @strlen(ptr)");
    emit("declare ptr @strcpy(ptr, ptr)");
    emit("declare ptr @strcat(ptr, ptr)");
    emit("declare i32 @strcmp(ptr, ptr)");
    emit("declare void @exit(i32)");
    emit("declare i32 @system(ptr)");
    emit("declare ptr @fopen(ptr, ptr)");
    emit("declare i32 @fclose(ptr)");
    emit("declare i64 @fread(ptr, i64, i64, ptr)");
    emit("declare i64 @fwrite(ptr, i64, i64, ptr)");
    emit("declare i32 @fseek(ptr, i64, i32)");
    emit("declare i64 @ftell(ptr)");
    emit("declare ptr @fgets(ptr, i32, ptr)");
    if (is_win[0] = 1) {
        emit("declare ptr @__acrt_iob_func(i32)");
    } else if (is_mac[0] = 1) {
        emit("@__stdinp = external global ptr");
    } else {
        emit("@stdin = external global ptr");
    }
    emit("");
}

fn llvm_emit_globals(global_names) {
    var i <- 0;
    while (i < len(global_names)) {
        emit("@g_" + global_names[i] + " = global i64 0");
        i <- i + 1;
    }
    emit("@g_argc = global i64 0");
    emit("@g_argv = global i64 0");
    emit("");
}

fn llvm_emit_runtime() {
    emit_arena_helper();
    emit_safe_strcmp_helper();
    emit_push_helper();
    emit_array_concat_helper();
    emit_pop_helper();
    emit_trap_helpers();
    emit_dyn_helpers();
    emit_keys_helper();
    emit_struct_find_helper();
    emit_itoa_helper();
    emit_substring_helper();
    emit_strcat_helper();
    emit_read_file_helper();
    emit_write_file_helper();
    emit_append_file_helper();
    emit_input_helper();
    emit_print_helpers();
}

fn llvm_emit_main_wrapper() {
    // C main: arena init, capture argc/argv, call __main_logic, return 0.
    emit("define i64 @main(i32 %argc, ptr %argv) {");
    emit("entry:");
    emit("  %argc64 = sext i32 %argc to i64");
    emit("  store i64 %argc64, ptr @g_argc");
    emit("  %argv64 = ptrtoint ptr %argv to i64");
    emit("  store i64 %argv64, ptr @g_argv");
    emit("  call void @arena_init(i64 268435456)");
    emit("  %ml = call i64 @__main_logic()");
    emit("  ret i64 0");
    emit("}");
    emit("");

    // Constants the runtime uses. The IR module's string table already
    // pools any user-supplied StringLits, but a few labels are referenced
    // directly by hand-written runtime IR.
    emit("@fmt_int = private constant [6 x i8] c\"%lld\\0A\\00\"");
    emit("@.str.rb = private constant [3 x i8] c\"rb\\00\"");
    emit("@.str.wb = private constant [3 x i8] c\"wb\\00\"");
    emit("@.str.ab = private constant [3 x i8] c\"ab\\00\"");
}

fn llvm_link(ll_file: str, exe_file: str): int {
    var clang_cmd <- "";
    if (is_win[0] = 1) {
        clang_cmd <- "clang " + ll_file + " -o " + exe_file + " -O2 -Wno-override-module -Xlinker /STACK:67108864";
    } else {
        clang_cmd <- "clang " + ll_file + " -o " + exe_file + " -O2 -Wno-override-module";
    }
    return exec_cmd(clang_cmd);
}

// ═══════════════════════════════════════════
//  compile_via_ir — the codegen entry point
//
//  Walks the AST: every user FnDecl is translated into the IR module via
//  emit_function_via_ir, then rendered to LLVM IR text in ir_lines. Top-
//  level statements are wrapped into a synthetic __main_logic FnDecl and
//  translated through the same path. Runtime helpers, globals, and the
//  C main wrapper are appended directly as IR text (they don't need to
//  be retargeted).
// ═══════════════════════════════════════════

fn compile_via_ir(stmts, backend) {
    backend_emit_preamble(backend);

    // Pre-passes: function table, call-site type inference, globals.
    scan_fns(stmts);
    scan_call_sites(stmts);
    scan_fn_param_returns(stmts);

    var i <- 0;
    while (i < len(stmts)) {
        if (stmts[i].node != "FnDecl") {
            scan_globals(stmts[i]);
        }
        i <- i + 1;
    }

    backend_emit_globals(backend, global_vars);

    // Build an Arrow IR module and translate every user FnDecl into it.
    var m <- ir_module();
    i <- 0;
    while (i < len(stmts)) {
        if (stmts[i].node = "FnDecl") {
            ir_mod_add_function(m, emit_function_via_ir(stmts[i], m));
        }
        i <- i + 1;
    }

    // Wrap top-level non-FnDecl stmts into a synthetic __main_logic fn so the
    // same IR translator handles them. The fn returns int; ret 0 is appended
    // by emit_function_via_ir if the body falls off the end without one.
    var top_stmts <- [];
    i <- 0;
    while (i < len(stmts)) {
        if (stmts[i].node != "FnDecl") {
            push(top_stmts, stmts[i]);
        }
        i <- i + 1;
    }
    var main_logic_fn <- {
        node: "FnDecl",
        name: "__main_logic",
        params: [],
        param_types_ann: [],
        ret_type: T.mk_int(),
        body: top_stmts
    };
    // Register __main_logic in the function table so calls / lookups resolve.
    push(declared_fns, {
        name: "__main_logic",
        param_count: 0,
        ret_type: T.mk_int(),
        ret_fields: [],
        param_types: [],
        param_types_ann: [],
        ret_type_ann: T.mk_none(),
        is_arrow_var: false
    });
    ir_mod_add_function(m, emit_function_via_ir(main_logic_fn, m));

    backend_emit_module(backend, m);
    backend_emit_runtime(backend);
    backend_emit_main_wrapper(backend);
}


// ═══════════════════════════════════════════
//  CLI dispatch
// ═══════════════════════════════════════════

if (args() < 1) {
    print("Usage: arrow <file.arrow> [-o output] [--keep-ll]");
    print("  Compiles Arrow Lang source to a native executable.");
}

if (args() > 0) {
    var input_file <- args(0);

    // Parse arguments after the input file (args(0)). Both flags are scanned
    // position-independently, so -o and --keep-ll may appear in any order:
    //   -o <output>  set the output path
    //   --keep-ll    keep the generated .ll instead of deleting it after the
    //               link step (useful for inspecting IR, or for the self-host
    //               fixed-point check without a no-op rm shim)
    var out_name <- "";
    var keep_ll <- false;
    var ka <- 1;
    while (ka < args()) {
        if (args(ka) = "-o" && ka + 1 < args()) {
            out_name <- args(ka + 1);
            ka <- ka + 2;
        } else if (args(ka) = "--keep-ll") {
            keep_ll <- true;
            ka <- ka + 1;
        } else {
            ka <- ka + 1;
        }
    }

    // Construct the backend. Today there's only one; future flags would
    // pick a different one (e.g. --backend=cranelift).
    var backend <- make_llvm_backend();

    // Derive base name from input: foo.arrow -> foo
    var base_name <- input_file;
    if (str_len(input_file) > 6) {
        var suffix <- substring(input_file, str_len(input_file) - 6, str_len(input_file));
        if (suffix = ".arrow") {
            base_name <- substring(input_file, 0, str_len(input_file) - 6);
        }
    }

    // Set output filenames (platform-dependent extension). All three names
    // are declared in the outer scope first so block-scope rules don't make
    // them die at the end of the branch.
    var exe_file <- "";
    var ll_base <- "";
    var ir_file <- "";
    if (out_name != "") {
        exe_file <- out_name;
        ll_base <- out_name;
        // Strip .exe if present
        if (str_len(out_name) > 4) {
            var ext <- substring(out_name, str_len(out_name) - 4, str_len(out_name));
            if (ext = ".exe") {
                ll_base <- substring(out_name, 0, str_len(out_name) - 4);
            }
        }
        ir_file <- ll_base + backend.intermediate_ext;
    } else {
        ir_file <- base_name + backend.intermediate_ext;
        if (is_win[0] = 1) {
            exe_file <- base_name + ".exe";
        } else {
            exe_file <- base_name;
        }
    }

    var source <- read_file(input_file);

    toks <- lex.tokenize(source);
    pos[0] <- 0;
    parse_src_file[0] <- input_file;
    var main_ast <- pp();
    src_filename[0] <- input_file;

    // Module resolution runs here in __main_logic where writes to the
    // global `toks` actually update the global (functions can't — their
    // assignments would land in locals). Iterative work-list rather than
    // recursion: pop a (path, name), parse, validate, collect that file's
    // imports onto the same work list, rename its decls, accumulate. Repeat
    // until the list drains.
    import_errors <- [];
    var all_paths <- [];                    // dedup of files already loaded
    var all_mod_names <- [];                // namespaces seen anywhere
    var path_canonical <- [];               // [{path, name}] — first name wins per path
    canonical_for <- [];                // alias-name → canonical mapping
    var work_paths <- [];                   // pending {path, name, line, col}
    var work_dirs <- [];                    // parallel: dir to resolve from
    var all_imported_stmts <- [];           // accumulated, renamed

    // Seed from the main file's own imports, then filter them out.
    main_ast <- extract_imports(main_ast, dirname(input_file), work_paths, work_dirs, all_mod_names);

    while (len(work_paths) > 0) {
        // Pop end of list (LIFO ordering — load order matters less than dedup).
        var item <- work_paths[len(work_paths) - 1];
        var item_dir <- work_dirs[len(work_dirs) - 1];
        pop(work_paths);
        pop(work_dirs);

        // Resolve the path: try relative to importer first; if not found,
        // try the search-path fallback (the directory containing the arrow
        // executable, where std/ lives). Read the file content once, here,
        // so we can settle on a path before doing any dedup or bookkeeping.
        var resolved_path <- item.path;
        var sub_src <- read_file(resolved_path);
        if (len(sub_src) = 0) {
            var exe_dir <- dirname(args(-1));
            var fb_path <- exe_dir + item.raw_path + ".arrow";
            var fb_src <- read_file(fb_path);
            if (len(fb_src) > 0) {
                resolved_path <- fb_path;
                sub_src <- fb_src;
            }
        }

        // Dedup: only load each file once. Uses the resolved path so a
        // fallback hit dedups against any future relative-path resolution
        // that lands on the same file.
        var already <- false;
        var existing_canonical <- "";
        var ii <- 0;
        while (ii < len(all_paths)) {
            if (all_paths[ii] = resolved_path) {
                already <- true;
                var jj <- 0;
                while (jj < len(path_canonical)) {
                    if (path_canonical[jj].path = resolved_path) {
                        existing_canonical <- path_canonical[jj].name;
                    }
                    jj <- jj + 1;
                }
            }
            ii <- ii + 1;
        }
        if (already) {
            // Same file, possibly different alias. If this import uses a
            // different `as` name from the first one, record the alias so
            // `<this_name>.sym` resolves to `__mod_<canonical>__sym`.
            if (item.name != existing_canonical) {
                push(canonical_for, {name: item.name, canonical: existing_canonical});
            }
        } else {
            push(all_paths, resolved_path);
            push(path_canonical, {path: resolved_path, name: item.name});
            push(canonical_for, {name: item.name, canonical: item.name});
            if (len(sub_src) = 0) {
                push(import_errors, "import: cannot read file (missing or empty): " + item.path);
            } else {
                toks <- lex.tokenize(sub_src);
                pos[0] <- 0;
                parse_src_file[0] <- resolved_path;
                var sub_stmts <- pp();
                validate_module(sub_stmts, resolved_path);
                // Sub-imports resolve relative to THIS file's directory.
                var sub_dir <- dirname(resolved_path);
                sub_stmts <- extract_imports(sub_stmts, sub_dir, work_paths, work_dirs, all_mod_names);
                var renamed <- rename_module(sub_stmts, item.name);
                var kk <- 0;
                while (kk < len(renamed)) {
                    push(all_imported_stmts, renamed[kk]);
                    kk <- kk + 1;
                }
            }
        }
    }

    // Imported decls go first so scan_fns / scan_globals see them when
    // processing the main module's bodies.
    var combined <- [];
    var ii <- 0;
    while (ii < len(all_imported_stmts)) { push(combined, all_imported_stmts[ii]); ii <- ii + 1; }
    ii <- 0;
    while (ii < len(main_ast)) { push(combined, main_ast[ii]); ii <- ii + 1; }

    // Final pass: rewrite `mod.sym` DotExpr uses to mangled identifiers
    // throughout. Runs after splicing so it sees both imported and main
    // module bodies (the latter may have nested calls to `mod.sym`).
    main_rewrite_stmts(combined, all_mod_names);

    // Run the static scope check before type-checking and codegen. Scope
    // errors are reported with their own priority — between import errors
    // and type errors. They typically signal a leaked variable from a
    // block (e.g. declared in an if branch, used outside).
    //
    // Skip if the parse already failed: an Assignment with no name, or an
    // if with no condition, can drop scope_check into states (empty arrays,
    // unexpected node shapes) that crash before parse errors get reported.
    // Parse errors take priority anyway and are surfaced next.
    if (len(parse_errors) = 0) {
        scope_check_program(combined);
    }

    if (len(parse_errors) > 0) {
        // Parse errors take priority — type errors and import errors are
        // unreliable when the AST is malformed, so report parse problems and
        // stop here.
        var jj <- 0;
        while (jj < len(parse_errors)) {
            var e <- parse_errors[jj];
            print(e.file + ":" + e.line + ":" + e.col + ": parse error: " + e.msg);
            jj <- jj + 1;
        }
        print("--");
        print(len(parse_errors) + " parse error(s). Compilation aborted.");
    } else if (len(import_errors) > 0) {
        var jj <- 0;
        while (jj < len(import_errors)) {
            print(import_errors[jj]);
            jj <- jj + 1;
        }
        print("--");
        print(len(import_errors) + " import error(s). Compilation aborted.");
    } else if (len(scope_errors) > 0) {
        var jj <- 0;
        while (jj < len(scope_errors)) {
            var e <- scope_errors[jj];
            print(input_file + ":" + e.line + ":" + e.col + ": scope error: " + e.msg);
            jj <- jj + 1;
        }
        print("--");
        print(len(scope_errors) + " scope error(s). Compilation aborted.");
    } else if (len(type_errors) > 0) {
        print_type_errors();
    } else {
        compile_via_ir(combined, backend);
        if (len(type_errors) > 0) {
            print_type_errors();
        } else {
            write_ir_lines(ir_file);

            var rc <- backend_link(backend, ir_file, exe_file);
            if (rc = 0) {
                print("Compiled " + exe_file + " successfully!");
                // Remove the intermediate .ll unless asked to keep it
                // (platform-dependent delete command).
                if (keep_ll) {
                    print("IR kept at " + ir_file);
                } else if (is_win[0] = 1) {
                    exec_cmd("del " + ir_file);
                } else {
                    exec_cmd("rm " + ir_file);
                }
            } else {
                print(backend.name + " toolchain failed with exit code " + rc);
                print("IR written to " + ir_file);
            }
        }
    }
}
