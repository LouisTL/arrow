// ═══════════════════════════════════════════
//  Arrow Lang -- Self-Hosted Compiler
//  Emits LLVM IR text (.ll), then shells out
//  to clang for AOT compilation.
//
//  Usage: python lang.py compiler.arrow <file.arrow>
//  Or:    compiler.exe <file.arrow>
//  Compiles <file.arrow> to <file>.ll and <file>.exe
//
//  Type tracking: emit_expr returns {reg, type}
//  where type is "int" or "str".
// ═══════════════════════════════════════════

// ── Lexer ───────────────────────────────
fn is_digit(c: int): int{return c>=48&&c<=57;}
fn is_alpha(c: int): int{return(c>=65&&c<=90)||(c>=97&&c<=122)||c=95;}
fn is_alnum(c: int): int{return is_digit(c)||is_alpha(c);}
fn is_ws(c: int): int{return c=32||c=9||c=10||c=13;}
fn mktok(t: str,v: str,l: int,c: int){return{type:t,value:v,line:l,col:c};}
fn is_kw(w: str): int{if(w="if"){return true;}if(w="else"){return true;}if(w="while"){return true;}if(w="for"){return true;}if(w="in"){return true;}if(w="print"){return true;}if(w="fn"){return true;}if(w="return"){return true;}if(w="true"){return true;}if(w="false"){return true;}return false;}

fn tokenize(src: str){
    ts<-[];p<-0;ln<-1;cl<-1;sl<-str_len(src);
    while(p<sl){ch<-char_code(char_at(src,p));
        if(is_ws(ch)){if(ch=10){ln<-ln+1;cl<-1;}else{cl<-cl+1;}p<-p+1;}
        else if(ch=47&&p+1<sl&&char_code(char_at(src,p+1))=47){while(p<sl&&char_code(char_at(src,p))!=10){p<-p+1;}}
        else if(is_digit(ch)){s<-p;sc<-cl;while(p<sl&&is_digit(char_code(char_at(src,p)))){p<-p+1;cl<-cl+1;}push(ts,mktok("NUMBER",substring(src,s,p),ln,sc));}
        else if(ch=34){sc<-cl;p<-p+1;cl<-cl+1;sv<-"";while(p<sl&&char_code(char_at(src,p))!=34){c<-char_at(src,p);if(c="\\"){p<-p+1;cl<-cl+1;nx<-char_at(src,p);if(nx="n"){sv<-sv+from_char_code(10);}else if(nx="t"){sv<-sv+from_char_code(9);}else if(nx="\\"){sv<-sv+"\\";}else{sv<-sv+nx;}}else{sv<-sv+c;}p<-p+1;cl<-cl+1;}p<-p+1;cl<-cl+1;push(ts,mktok("STRING",sv,ln,sc));}
        else if(is_alpha(ch)){s<-p;sc<-cl;while(p<sl&&is_alnum(char_code(char_at(src,p)))){p<-p+1;cl<-cl+1;}w<-substring(src,s,p);if(w="true"||w="false"){push(ts,mktok("BOOL",w,ln,sc));}else if(is_kw(w)){push(ts,mktok(w,w,ln,sc));}else{push(ts,mktok("IDENT",w,ln,sc));}  }
        else if(ch=60&&p+1<sl&&char_code(char_at(src,p+1))=45){push(ts,mktok("ARROW","<-",ln,cl));p<-p+2;cl<-cl+2;}
        else if(ch=61&&p+1<sl&&char_code(char_at(src,p+1))=62){push(ts,mktok("FAT_ARROW","=>",ln,cl));p<-p+2;cl<-cl+2;}
        else if(ch=60&&p+1<sl&&char_code(char_at(src,p+1))=61){push(ts,mktok("LTE","<=",ln,cl));p<-p+2;cl<-cl+2;}
        else if(ch=62&&p+1<sl&&char_code(char_at(src,p+1))=61){push(ts,mktok("GTE",">=",ln,cl));p<-p+2;cl<-cl+2;}
        else if(ch=33&&p+1<sl&&char_code(char_at(src,p+1))=61){push(ts,mktok("NEQ","!=",ln,cl));p<-p+2;cl<-cl+2;}
        else if(ch=38&&p+1<sl&&char_code(char_at(src,p+1))=38){push(ts,mktok("AND","&&",ln,cl));p<-p+2;cl<-cl+2;}
        else if(ch=124&&p+1<sl&&char_code(char_at(src,p+1))=124){push(ts,mktok("OR","||",ln,cl));p<-p+2;cl<-cl+2;}
        else if(ch=43){push(ts,mktok("PLUS","+",ln,cl));p<-p+1;cl<-cl+1;}
        else if(ch=45){push(ts,mktok("MINUS","-",ln,cl));p<-p+1;cl<-cl+1;}
        else if(ch=42){push(ts,mktok("STAR","*",ln,cl));p<-p+1;cl<-cl+1;}
        else if(ch=47){push(ts,mktok("SLASH","/",ln,cl));p<-p+1;cl<-cl+1;}
        else if(ch=37){push(ts,mktok("PERCENT","%",ln,cl));p<-p+1;cl<-cl+1;}
        else if(ch=60){push(ts,mktok("LT","<",ln,cl));p<-p+1;cl<-cl+1;}
        else if(ch=62){push(ts,mktok("GT",">",ln,cl));p<-p+1;cl<-cl+1;}
        else if(ch=33){push(ts,mktok("NOT","!",ln,cl));p<-p+1;cl<-cl+1;}
        else if(ch=61){push(ts,mktok("EQ","=",ln,cl));p<-p+1;cl<-cl+1;}
        else if(ch=46){push(ts,mktok("DOT",".",ln,cl));p<-p+1;cl<-cl+1;}
        else if(ch=58){push(ts,mktok("COLON",":",ln,cl));p<-p+1;cl<-cl+1;}
        else if(ch=40){push(ts,mktok("LPAREN","(",ln,cl));p<-p+1;cl<-cl+1;}
        else if(ch=41){push(ts,mktok("RPAREN",")",ln,cl));p<-p+1;cl<-cl+1;}
        else if(ch=123){push(ts,mktok("LBRACE","{",ln,cl));p<-p+1;cl<-cl+1;}
        else if(ch=125){push(ts,mktok("RBRACE","}",ln,cl));p<-p+1;cl<-cl+1;}
        else if(ch=91){push(ts,mktok("LBRACKET","[",ln,cl));p<-p+1;cl<-cl+1;}
        else if(ch=93){push(ts,mktok("RBRACKET","]",ln,cl));p<-p+1;cl<-cl+1;}
        else if(ch=59){push(ts,mktok("SEMI",";",ln,cl));p<-p+1;cl<-cl+1;}
        else if(ch=44){push(ts,mktok("COMMA",",",ln,cl));p<-p+1;cl<-cl+1;}
        else{p<-p+1;cl<-cl+1;}
    }
    push(ts,mktok("EOF","",ln,cl));return ts;
}

// ── Parser ──────────────────────────────
toks<-[];pos<-[0];
fn ci(e: str): int{return toks[pos[0]].type=e;}
fn pi(o: int,e: str): int{x<-pos[0]+o;if(x<len(toks)){return toks[x].type=e;}return false;}
fn adv(){pos[0]<-pos[0]+1;}
fn cv(): str{return toks[pos[0]].value;}
fn eat(e: str){t<-toks[pos[0]];if(t.type!=e){print("Parse error: expected "+e+" got "+t.type+" at "+t.line+":"+t.col);}pos[0]<-pos[0]+1;return t;}
fn ev(e: str): str{t<-toks[pos[0]];pos[0]<-pos[0]+1;return t.value;}
fn pp(){ss<-[];while(!ci("EOF")){push(ss,ps());}return ss;}
fn ps(){
    if(ci("fn")){return pfd();}if(ci("return")){return prt();}
    if(ci("if")){return pif();}if(ci("while")){return pwh();}
    if(ci("for")){return pfi();}if(ci("print")){return ppr();}
    if(ci("LBRACE")){if(isl()){e<-pe();eat("SEMI");return e;}return{node:"Block",stmts:pb()};}
    if(ci("IDENT")){if(pi(1,"ARROW")){return pas();}if(pi(1,"COLON")){return ptd();}if(pi(1,"LBRACKET")||pi(1,"DOT")){return ppa();}}
    e<-pe();eat("SEMI");return e;
}
fn isl(): int{if(pi(1,"RBRACE")){return true;}if(pi(1,"IDENT")&&pi(2,"COLON")){return true;}return false;}
fn pb(){eat("LBRACE");ss<-[];while(!ci("RBRACE")){push(ss,ps());}eat("RBRACE");return ss;}
fn pty(){if(ci("LBRACKET")){eat("LBRACKET");et<-pty();eat("RBRACKET");return{kind:"array",elem:et};}if(ci("LBRACE")){eat("LBRACE");fs<-[];if(!ci("RBRACE")){fn1<-ev("IDENT");eat("COLON");ft<-pty();push(fs,{name:fn1,type:ft});while(ci("COMMA")){eat("COMMA");if(ci("RBRACE")){eat("RBRACE");return{kind:"struct_lit",fields:fs};}fn2<-ev("IDENT");eat("COLON");ft2<-pty();push(fs,{name:fn2,type:ft2});}}eat("RBRACE");return{kind:"struct_lit",fields:fs};}n<-ev("IDENT");if(n="int"){return{kind:"int"};}if(n="str"){return{kind:"str"};}if(n="any"){return{kind:"any"};}if(n="struct"){return{kind:"struct"};}if(n="fn"){return{kind:"fn"};}return{kind:"any"};}
fn pas(){ln<-toks[pos[0]].line;n<-ev("IDENT");eat("ARROW");e<-pe();eat("SEMI");return{node:"Assignment",name:n,expr:e,type_ann:{kind:"none"},line:ln};}
fn ptd(){ln<-toks[pos[0]].line;n<-ev("IDENT");eat("COLON");ta<-pty();eat("ARROW");e<-pe();eat("SEMI");return{node:"Assignment",name:n,expr:e,type_ann:ta,line:ln};}
fn ppa(){e<-pe();if(ci("ARROW")){eat("ARROW");v<-pe();eat("SEMI");if(e.node="IndexExpr"){return{node:"IndexAssign",obj:e.obj,index:e.index,value:v};}if(e.node="DotExpr"){return{node:"DotAssign",obj:e.obj,field:e.field,value:v};}}eat("SEMI");return e;}
fn ppr(){eat("print");eat("LPAREN");e<-pe();eat("RPAREN");eat("SEMI");return{node:"PrintStmt",expr:e};}
fn prt(){ln<-toks[pos[0]].line;eat("return");if(ci("SEMI")){eat("SEMI");return{node:"ReturnStmt",expr:false,line:ln};}e<-pe();eat("SEMI");return{node:"ReturnStmt",expr:e,line:ln};}
fn pfd(){ln<-toks[pos[0]].line;eat("fn");n<-ev("IDENT");eat("LPAREN");p<-[];pt<-[];if(!ci("RPAREN")){pn<-ev("IDENT");push(p,pn);if(ci("COLON")){eat("COLON");push(pt,pty());}else{push(pt,{kind:"none"});}while(ci("COMMA")){eat("COMMA");pn<-ev("IDENT");push(p,pn);if(ci("COLON")){eat("COLON");push(pt,pty());}else{push(pt,{kind:"none"});}}}eat("RPAREN");rt<-{kind:"none"};if(ci("COLON")){eat("COLON");rt<-pty();}b<-pb();return{node:"FnDecl",name:n,params:p,param_types_ann:pt,ret_type_ann:rt,body:b,line:ln};}
fn ppl(){eat("LPAREN");p<-[];pt<-[];if(!ci("RPAREN")){push(p,ev("IDENT"));if(ci("COLON")){eat("COLON");push(pt,pty());}else{push(pt,{kind:"none"});}while(ci("COMMA")){eat("COMMA");push(p,ev("IDENT"));if(ci("COLON")){eat("COLON");push(pt,pty());}else{push(pt,{kind:"none"});}}}eat("RPAREN");return{params:p,param_types_ann:pt};}
fn pif(){eat("if");eat("LPAREN");c<-pe();eat("RPAREN");tb<-pb();eb<-[];if(ci("else")){eat("else");if(ci("if")){eb<-[pif()];}else{eb<-pb();}}return{node:"IfStmt",cond:c,then_body:tb,else_body:eb};}
fn pwh(){eat("while");eat("LPAREN");c<-pe();eat("RPAREN");b<-pb();return{node:"WhileStmt",cond:c,body:b};}
fn pfi(){eat("for");eat("LPAREN");v<-ev("IDENT");eat("in");it<-pe();eat("RPAREN");b<-pb();return{node:"ForInStmt",var_name:v,iterable:it,body:b};}
fn pe(){if(ci("LPAREN")&&iaf()){return paf();}return por();}
fn iaf(): int{d<-0;i<-pos[0];while(i<len(toks)){t<-toks[i].type;if(t="LPAREN"){d<-d+1;}else if(t="RPAREN"){d<-d-1;if(d=0){j<-i+1;if(j<len(toks)&&toks[j].type="COLON"){j<-j+1;while(j<len(toks)&&toks[j].type!="FAT_ARROW"&&toks[j].type!="LBRACE"&&toks[j].type!="SEMI"){j<-j+1;}}if(j<len(toks)){return toks[j].type="FAT_ARROW";}return false;}}i<-i+1;}return false;}
fn paf(){pl<-ppl();rt<-{kind:"none"};if(ci("COLON")){eat("COLON");rt<-pty();}eat("FAT_ARROW");if(ci("LBRACE")&&!isl()){b<-pb();return{node:"ArrowFn",params:pl.params,param_types_ann:pl.param_types_ann,ret_type_ann:rt,body:b,is_expr:false};}e<-pe();return{node:"ArrowFn",params:pl.params,param_types_ann:pl.param_types_ann,ret_type_ann:rt,body:e,is_expr:true};}
fn por(){l<-pan();while(ci("OR")){eat("OR");l<-{node:"BinOp",op:"||",left:l,right:pan()};}return l;}
fn pan(){l<-peq();while(ci("AND")){eat("AND");l<-{node:"BinOp",op:"&&",left:l,right:peq()};}return l;}
fn peq(){l<-pcm();while(ci("EQ")||ci("NEQ")){o<-cv();adv();l<-{node:"BinOp",op:o,left:l,right:pcm()};}return l;}
fn pcm(){l<-ppad();while(ci("LT")||ci("GT")||ci("LTE")||ci("GTE")){o<-cv();adv();l<-{node:"BinOp",op:o,left:l,right:ppad()};}return l;}
fn ppad(){l<-pmu();while(ci("PLUS")||ci("MINUS")){o<-cv();adv();l<-{node:"BinOp",op:o,left:l,right:pmu()};}return l;}
fn pmu(){l<-pun();while(ci("STAR")||ci("SLASH")||ci("PERCENT")){o<-cv();adv();l<-{node:"BinOp",op:o,left:l,right:pun()};}return l;}
fn pun(){if(ci("MINUS")){adv();return{node:"UnaryOp",op:"-",operand:pun()};}if(ci("NOT")){adv();return{node:"UnaryOp",op:"!",operand:pun()};}return ppf();}
fn ppf(){e<-ppm();dn<-false;while(!dn){if(ci("LPAREN")){cln<-toks[pos[0]].line;eat("LPAREN");a<-[];if(!ci("RPAREN")){push(a,pe());while(ci("COMMA")){eat("COMMA");push(a,pe());}}eat("RPAREN");e<-{node:"CallExpr",callee:e,args:a,line:cln};}
    else if(ci("LBRACKET")){eat("LBRACKET");x<-pe();eat("RBRACKET");e<-{node:"IndexExpr",obj:e,index:x};}
    else if(ci("DOT")){eat("DOT");f<-ev("IDENT");e<-{node:"DotExpr",obj:e,field:f};}
    else{dn<-true;}}return e;}
fn ppm(){
    if(ci("NUMBER")){v<-cv();adv();return{node:"NumberLit",value:v};}
    if(ci("STRING")){v<-cv();adv();return{node:"StringLit",value:v};}
    if(ci("BOOL")){v<-cv();adv();return{node:"BoolLit",value:v};}
    if(ci("IDENT")){v<-cv();adv();return{node:"Identifier",name:v};}
    if(ci("LBRACKET")){eat("LBRACKET");el<-[];if(!ci("RBRACKET")){push(el,pe());while(ci("COMMA")){eat("COMMA");push(el,pe());}}eat("RBRACKET");return{node:"ArrayLit",elements:el};}
    if(ci("LBRACE")){eat("LBRACE");fs<-[];if(!ci("RBRACE")){k<-ev("IDENT");eat("COLON");v<-pe();push(fs,{key:k,val:v});while(ci("COMMA")){eat("COMMA");if(ci("RBRACE")){eat("RBRACE");return{node:"StructLit",fields:fs};}k<-ev("IDENT");eat("COLON");v<-pe();push(fs,{key:k,val:v});}}eat("RBRACE");return{node:"StructLit",fields:fs};}
    if(ci("LPAREN")){eat("LPAREN");e<-pe();eat("RPAREN");return e;}
    print("Parse error");adv();return{node:"NumberLit",value:"0"};
}


// ═══════════════════════════════════════════
//  LLVM IR EMITTER
//  Strategy: everything is i64. Strings are
//  i8* cast to i64. Simple and uniform.
//
//  Type tracking: emit_expr returns {reg, type}
//  where type is "int" or "str".
// ═══════════════════════════════════════════

// Output buffer: array of lines
ir_lines <- [""];  // init with "" so global type tracking knows it holds strings
deferred_ir <- [""];  // buffer for arrow function definitions
emit_target <- [0];  // 0 = ir_lines, 1 = deferred_ir

// Platform detection. is_win = 1 on Windows; is_mac = 1 on macOS; both 0 on Linux.
// is_mac matters because macOS doesn't expose `stdin` as a real symbol — the
// underlying name is __stdinp.
is_win <- [1]; // default Windows, overridden at startup
is_mac <- [0];

fn emit(s: str) {
    if (emit_target[0] = 0) {
        push(ir_lines, s);
    } else {
        push(deferred_ir, s);
    }
}

fn write_ir_lines(path: str) {
    // Write IR directly to file in chunks without building one huge string
    // First write truncates (wb), subsequent writes append (ab)
    chunk <- "";
    count <- 0;
    first <- 1;
    i <- 0;
    while (i < len(ir_lines)) {
        if (str_len(ir_lines[i]) > 0) {
            chunk <- chunk + ir_lines[i] + from_char_code(10);
            count <- count + 1;
        }
        if (count >= 200) {
            if (first = 1) {
                write_file(path, chunk);
                first <- 0;
            } else {
                append_file(path, chunk);
            }
            chunk <- "";
            count <- 0;
        }
        i <- i + 1;
    }
    if (str_len(chunk) > 0) {
        if (first = 1) {
            write_file(path, chunk);
        } else {
            append_file(path, chunk);
        }
    }
}

// Counter for unique names
tmp_counter <- [0];
fn fresh(prefix: str): str {
    tmp_counter[0] <- tmp_counter[0] + 1;
    return prefix + tmp_counter[0];
}

// Label counter
lbl_counter <- [0];
fn fresh_lbl(prefix: str): str {
    lbl_counter[0] <- lbl_counter[0] + 1;
    return prefix + lbl_counter[0];
}

// Track which variables have been allocated in current function
fn_vars <- []; // list of {name, depth}  — we'll simplify to just names in scope
current_fn <- [""]; // name of function being compiled

// Arrow function counter
arrow_fn_counter <- [0];

// Map variable names to arrow function names for return type lookup
arrow_fn_map <- []; // [{var_name, fn_name}]

fn set_arrow_fn_var(var_name: str, fn_name: str) {
    push(arrow_fn_map, {var_name: var_name, fn_name: fn_name});
}

fn get_arrow_fn_name(var_name: str): str {
    i <- len(arrow_fn_map) - 1;
    while (i >= 0) {
        if (arrow_fn_map[i].var_name = var_name) { return arrow_fn_map[i].fn_name; }
        i <- i - 1;
    }
    return "";
}

// String constants
str_constants <- []; // [{id, text}]
str_counter <- [0];

fn add_string(text: str): str {
    str_counter[0] <- str_counter[0] + 1;
    id <- "str" + str_counter[0];
    push(str_constants, {id: id, text: text});
    return id;
}

// Escape string for LLVM IR constant
fn ir_escape(s: str): str {
    result <- "";
    i <- 0;
    total_len <- 0;
    while (i < str_len(s)) {
        ch <- char_code(char_at(s, i));
        if (ch = 10) { result <- result + "\\0A"; }
        else if (ch = 9) { result <- result + "\\09"; }
        else if (ch = 34) { result <- result + "\\22"; }
        else if (ch = 92) { result <- result + "\\5C"; }
        else if (ch = 0) { result <- result + "\\00"; }
        else { result <- result + char_at(s, i); }
        total_len <- total_len + 1;
        i <- i + 1;
    }
    return result;
}

fn ir_str_len(s: str): int {
    // Count actual bytes in the escaped string
    // Each \XX escape = 1 byte, each regular char = check byte length
    // Simple approach: iterate and count char_code > 127 as multi-byte
    count <- 0;
    i <- 0;
    while (i < str_len(s)) {
        ch <- char_code(char_at(s, i));
        if (ch >= 128) {
            // Multi-byte UTF-8: determine byte count from leading byte
            if (ch >= 240) { count <- count + 4; }
            else if (ch >= 224) { count <- count + 3; }
            else if (ch >= 192) { count <- count + 2; }
            else { count <- count + 1; } // continuation byte (shouldn't happen at start)
        } else {
            count <- count + 1;
        }
        i <- i + 1;
    }
    return count + 1; // +1 for null terminator
}

// Track allocated variables per function — boxed in array
alloc_vars <- [[]]; // alloc_vars[0] is the current var list [{name, reg}]

// Track variable types: var_name -> "int" or "str"
var_types <- [[]]; // var_types[0] is list of [{name, vtype}]

// Track global variables (top-level)
global_vars <- []; // list of variable name strings

fn is_global(name: str): int {
    i <- 0;
    while (i < len(global_vars)) {
        if (global_vars[i] = name) { return true; }
        i <- i + 1;
    }
    return false;
}

fn find_var(name: str): str {
    vars <- alloc_vars[0];
    i <- len(vars) - 1;
    while (i >= 0) {
        if (vars[i].name = name) { return vars[i].reg; }
        i <- i - 1;
    }
    // Fall back to global
    if (is_global(name)) { return "@g_" + name; }
    return "";
}

fn add_var(name: str): str {
    reg <- "%" + name;
    if (find_var(name) != "") { return find_var(name); }
    push(alloc_vars[0], {name: name, reg: reg});
    return reg;
}

fn set_var_type(name: str, vtype) {
    types <- var_types[0];
    i <- 0;
    while (i < len(types)) {
        if (types[i].name = name) {
            types[i] <- {name: name, vtype: vtype};
            return false;
        }
        i <- i + 1;
    }
    push(var_types[0], {name: name, vtype: vtype});
    return false;
}

fn get_var_type(name: str) {
    types <- var_types[0];
    i <- len(types) - 1;
    while (i >= 0) {
        if (types[i].name = name) { return types[i].vtype; }
        i <- i - 1;
    }
    return mk_any();
}

// Track struct field layouts: var_name -> [{fname, ftype}]
struct_layouts <- [[]]; // struct_layouts[0] is list of [{var_name, fields}]

fn set_struct_layout(var_name: str, fields) {
    layouts <- struct_layouts[0];
    i <- 0;
    while (i < len(layouts)) {
        if (layouts[i].var_name = var_name) {
            layouts[i] <- {var_name: var_name, fields: fields};
            return false;
        }
        i <- i + 1;
    }
    push(struct_layouts[0], {var_name: var_name, fields: fields});
    return false;
}

fn get_struct_layout(var_name: str) {
    layouts <- struct_layouts[0];
    i <- len(layouts) - 1;
    while (i >= 0) {
        if (layouts[i].var_name = var_name) { return layouts[i].fields; }
        i <- i - 1;
    }
    return false;
}

fn get_field_type(fields, fname: str) {
    i <- 0;
    while (i < len(fields)) {
        if (fields[i].fname = fname) {
            ft <- fields[i].ftype;
            if (ft = "int") { return mk_int(); }
            if (ft = "str") { return mk_str(); }
            if (ft = "struct") { return mk_struct(); }
            if (ft = "fn") { return mk_fn(); }
            return mk_any();
        }
        i <- i + 1;
    }
    return mk_any();
}

// Track array element types: var_name -> elem_type ("int" or "str")
array_elem_types <- [[]]; // array_elem_types[0] is list of [{var_name, elem_type}]
global_array_types <- []; // persistent list for globals [{var_name, elem_type}]

fn set_array_elem_type(var_name: str, etype: str) {
    types <- array_elem_types[0];
    i <- 0;
    while (i < len(types)) {
        if (types[i].var_name = var_name) {
            if (etype = "str") {
                types[i] <- {var_name: var_name, elem_type: etype};
            }
            return false;
        }
        i <- i + 1;
    }
    push(array_elem_types[0], {var_name: var_name, elem_type: etype});
    return false;
}

fn set_global_array_type(var_name: str, etype: str) {
    i <- 0;
    while (i < len(global_array_types)) {
        if (global_array_types[i].var_name = var_name) {
            if (etype = "str") {
                global_array_types[i] <- {var_name: var_name, elem_type: etype};
            }
            return false;
        }
        i <- i + 1;
    }
    push(global_array_types, {var_name: var_name, elem_type: etype});
    return false;
}

fn get_array_elem_type(var_name: str) {
    // Check local scope first
    types <- array_elem_types[0];
    i <- len(types) - 1;
    while (i >= 0) {
        if (types[i].var_name = var_name) {
            if (types[i].elem_type = "str") { return mk_str(); }
            return mk_int();
        }
        i <- i - 1;
    }
    // Fall back to global array types
    i <- 0;
    while (i < len(global_array_types)) {
        if (global_array_types[i].var_name = var_name) {
            if (global_array_types[i].elem_type = "str") { return mk_str(); }
            return mk_int();
        }
        i <- i + 1;
    }
    return mk_any();
}

// Function declarations we need to track
declared_fns <- []; // [{name, param_count, ret_type, ret_fields, param_types}]

fn find_fn(name: str) {
    i <- 0;
    while (i < len(declared_fns)) {
        if (declared_fns[i].name = name) { return declared_fns[i]; }
        i <- i + 1;
    }
    return false;
}

fn set_fn_ret_type(name: str, rtype, rfields) {
    i <- 0;
    while (i < len(declared_fns)) {
        if (declared_fns[i].name = name) {
            // Don't override explicit user annotations — let the checker complain instead
            if (declared_fns[i].ret_type_ann.kind != "none") {
                return false;
            }
            declared_fns[i] <- {name: name, param_count: declared_fns[i].param_count, ret_type: rtype, ret_fields: rfields, param_types: declared_fns[i].param_types, param_types_ann: declared_fns[i].param_types_ann, ret_type_ann: declared_fns[i].ret_type_ann, is_arrow_var: declared_fns[i].is_arrow_var};
            return false;
        }
        i <- i + 1;
    }
    return false;
}

// Set a parameter type for a function (from call-site analysis)
fn set_fn_param_type(fn_name: str, param_idx: int, ptype) {
    fi <- find_fn(fn_name);
    if (fi = false) { return false; }
    if (param_idx < len(fi.param_types)) {
        // Don't override explicit user annotations — let the checker complain instead
        if (param_idx < len(fi.param_types_ann)) {
            if (fi.param_types_ann[param_idx].kind != "none") {
                return false;
            }
        }
        // Upgrade from "any" or "int" to a more specific type, never downgrade from "str"
        if (fi.param_types[param_idx].kind != "str") {
            fi.param_types[param_idx] <- ptype;
        }
    }
    return false;
}

// Scan all statements for call sites to infer parameter types
fn scan_call_sites(stmts) {
    work <- [];
    i <- 0;
    while (i < len(stmts)) {
        push(work, stmts[i]);
        i <- i + 1;
    }
    wi <- 0;
    while (wi < len(work)) {
        nd <- work[wi];
        wi <- wi + 1;
        work <- scs_handle(nd, work);
    }
}

fn scs_handle(nd, work) {
    work <- scs_stmt(nd, work);
    work <- scs_expr(nd, work);
    return work;
}

fn scs_stmt(nd, work) {
    if (nd.node = "Assignment") { push(work, nd.expr); }
    if (nd.node = "PrintStmt") { push(work, nd.expr); }
    if (nd.node = "ReturnStmt") { if (nd.expr != false) { push(work, nd.expr); } }
    if (nd.node = "IfStmt") {
        push(work, nd.cond);
        i <- 0;
        while (i < len(nd.then_body)) { push(work, nd.then_body[i]); i <- i + 1; }
        i <- 0;
        while (i < len(nd.else_body)) { push(work, nd.else_body[i]); i <- i + 1; }
    }
    if (nd.node = "WhileStmt") {
        push(work, nd.cond);
        i <- 0;
        while (i < len(nd.body)) { push(work, nd.body[i]); i <- i + 1; }
    }
    if (nd.node = "ForInStmt") {
        push(work, nd.iterable);
        i <- 0;
        while (i < len(nd.body)) { push(work, nd.body[i]); i <- i + 1; }
    }
    if (nd.node = "IndexAssign") {
        push(work, nd.obj);
        push(work, nd.index);
        push(work, nd.value);
    }
    if (nd.node = "DotAssign") {
        push(work, nd.obj);
        push(work, nd.value);
    }
    if (nd.node = "Block") {
        i <- 0;
        while (i < len(nd.stmts)) { push(work, nd.stmts[i]); i <- i + 1; }
    }
    if (nd.node = "FnDecl") {
        i <- 0;
        while (i < len(nd.body)) { push(work, nd.body[i]); i <- i + 1; }
    }
    return work;
}

fn scs_expr(nd, work) {
    if (nd.node = "CallExpr") {
        if (nd.callee.node = "Identifier") {
            fi <- find_fn(nd.callee.name);
            if (fi != false) {
                j <- 0;
                while (j < len(nd.args)) {
                    if (j < fi.param_count) {
                        if (is_str_expr(nd.args[j])) {
                            set_fn_param_type(fi.name, j, mk_str());
                        }
                    }
                    j <- j + 1;
                }
            }
        }
        j <- 0;
        while (j < len(nd.args)) { push(work, nd.args[j]); j <- j + 1; }
    }
    if (nd.node = "BinOp") { push(work, nd.left); push(work, nd.right); }
    if (nd.node = "UnaryOp") { push(work, nd.operand); }
    if (nd.node = "ArrayLit") {
        j <- 0;
        while (j < len(nd.elements)) { push(work, nd.elements[j]); j <- j + 1; }
    }
    if (nd.node = "IndexExpr") { push(work, nd.obj); push(work, nd.index); }
    if (nd.node = "DotExpr") { push(work, nd.obj); }
    if (nd.node = "StructLit") {
        j <- 0;
        while (j < len(nd.fields)) { push(work, nd.fields[j].val); j <- j + 1; }
    }
    if (nd.node = "ArrowFn") {
        // Scan arrow function body for call sites
        if (nd.is_expr = false) {
            j <- 0;
            while (j < len(nd.body)) { push(work, nd.body[j]); j <- j + 1; }
        } else {
            push(work, nd.body);
        }
    }
    return work;
}

// ═══════════════════════════════════════════
//  TYPE REPRESENTATION (universe 1)
//  A Type is a struct {kind: str, ...}.
//  Kinds:
//    "int", "str", "any", "struct", "fn"     — primitive
//    "array" with field `elem: Type`           — [T]
//    "struct_lit" with field `fields: [...]`   — {name: T, ...}
//    "none"                                    — sentinel: no annotation
//  Stored in var_types and declared_fns; returned by typeof_expr.
//  Distinct from the .type string field on typed values (universe 2)
//  used by the IR emitter for codegen decisions.
// ═══════════════════════════════════════════

fn mk_int() { return {kind: "int"}; }
fn mk_str() { return {kind: "str"}; }
fn mk_any() { return {kind: "any"}; }
fn mk_struct() { return {kind: "struct"}; }
fn mk_fn() { return {kind: "fn"}; }
fn mk_none() { return {kind: "none"}; }
fn mk_array(elem) { return {kind: "array", elem: elem}; }
fn mk_struct_lit(fields) { return {kind: "struct_lit", fields: fields}; }

// Render a Type as surface syntax for error messages.
fn type_str(t): str {
    if (t.kind = "array") { return "[" + type_str(t.elem) + "]"; }
    if (t.kind = "struct_lit") {
        s <- "{";
        i <- 0;
        while (i < len(t.fields)) {
            if (i > 0) { s <- s + ", "; }
            s <- s + t.fields[i].name + ": " + type_str(t.fields[i].type);
            i <- i + 1;
        }
        return s + "}";
    }
    return t.kind;
}

// Convert a kind string (from typed-value .type strings) to a Type.
// Used at the codegen → type-system boundary. Does NOT handle composite
// types — those come from the parser, not from value tags.
fn parse_type_ann(s: str) {
    if (s = "int") { return mk_int(); }
    if (s = "str") { return mk_str(); }
    if (s = "any") { return mk_any(); }
    if (s = "struct") { return mk_struct(); }
    if (s = "fn") { return mk_fn(); }
    return mk_any();
}

// Look up a field's type in a struct_lit's fields list. Returns mk_none() if absent.
fn struct_field_type(fields, name: str) {
    i <- 0;
    while (i < len(fields)) {
        if (fields[i].name = name) { return fields[i].type; }
        i <- i + 1;
    }
    return mk_none();
}

// Recursive structural equality on Types.
fn type_eq(a, b): int {
    if (a.kind != b.kind) { return false; }
    if (a.kind = "array") { return type_eq(a.elem, b.elem); }
    if (a.kind = "struct_lit") {
        if (len(a.fields) != len(b.fields)) { return false; }
        // Order-independent: every field in a must exist with matching type in b
        i <- 0;
        while (i < len(a.fields)) {
            bt <- struct_field_type(b.fields, a.fields[i].name);
            if (bt.kind = "none") { return false; }
            if (!type_eq(a.fields[i].type, bt)) { return false; }
            i <- i + 1;
        }
        return true;
    }
    return true;
}

// ── Typed result helpers (universe 2) ────
fn tv(reg: str, vtype: str) { return {reg: reg, type: vtype, fields: false}; }
fn tv_int(reg: str) { return {reg: reg, type: "int", fields: false}; }
fn tv_str(reg: str) { return {reg: reg, type: "str", fields: false}; }

// Convert a typed value to i64 (for storing, passing as arg, etc.)
// Strings are already i8*-as-i64 via ptrtoint, so no conversion needed.
// This just returns the reg — all values are i64 in our IR.
fn to_i64(t): str { return t.reg; }

// Convert an i64 value to a string (for string concat with non-strings)
// Calls our own arrow_itoa helper (no sprintf dependency)
fn int_to_str(reg: str): str {
    r <- fresh("%i2s");
    rp <- fresh("%i2sp");
    emit("  " + r + " = call ptr @arrow_itoa(i64 " + reg + ")");
    emit("  " + rp + " = ptrtoint ptr " + r + " to i64");
    return rp;
}

// Ensure a typed value is a string (i8* as i64)
// If it's already a string, return as-is; if int, convert via itoa
fn ensure_str(t): str {
    if (t.type = "str") { return t.reg; }
    return int_to_str(t.reg);
}

// Like ensure_str, but when we know the context is string-heavy,
// treat "int" as a string pointer (don't itoa it)
fn as_str_ptr(t): str {
    return t.reg; // i64 is already the right value — just use it as-is
}

// ── Pre-scan: collect all fn declarations ──
fn scan_fns(stmts) {
    i <- 0;
    while (i < len(stmts)) {
        if (stmts[i].node = "FnDecl") {
            // param_types_ann from AST is already a list of Type values (mk_none() if absent)
            // param_types is the working type used for inference (starts at any, widens via call sites)
            pt <- [];
            j <- 0;
            while (j < len(stmts[i].params)) {
                ann <- mk_none();
                if (j < len(stmts[i].param_types_ann)) {
                    ann <- stmts[i].param_types_ann[j];
                }
                if (ann.kind != "none") {
                    push(pt, ann);
                } else {
                    push(pt, mk_any());
                }
                j <- j + 1;
            }
            // Use return type annotation if present (a Type value)
            rt <- mk_any();
            if (stmts[i].ret_type_ann.kind != "none") {
                rt <- stmts[i].ret_type_ann;
            }
            push(declared_fns, {name: stmts[i].name, param_count: len(stmts[i].params), ret_type: rt, ret_fields: false, param_types: pt, param_types_ann: stmts[i].param_types_ann, ret_type_ann: stmts[i].ret_type_ann, is_arrow_var: false});
        }
        // Also register top-level arrow-fn assignments under the variable name.
        // This lets the type checker resolve `myVar(args)` calls where myVar holds
        // an ArrowFn. Uses the variable name directly (not the mangled "__arrow_N"
        // name chosen later at emit time) because the checker runs before emit.
        if (stmts[i].node = "Assignment") {
            if (stmts[i].expr.node = "ArrowFn") {
                afn <- stmts[i].expr;
                apt <- [];
                apt_ann <- [];
                k <- 0;
                while (k < len(afn.params)) {
                    ann <- mk_none();
                    if (k < len(afn.param_types_ann)) {
                        ann <- afn.param_types_ann[k];
                    }
                    push(apt_ann, ann);
                    if (ann.kind != "none") {
                        push(apt, ann);
                    } else {
                        push(apt, mk_any());
                    }
                    k <- k + 1;
                }
                art <- mk_any();
                if (afn.ret_type_ann.kind != "none") { art <- afn.ret_type_ann; }
                push(declared_fns, {name: stmts[i].name, param_count: len(afn.params), ret_type: art, ret_fields: false, param_types: apt, param_types_ann: apt_ann, ret_type_ann: afn.ret_type_ann, is_arrow_var: true});
            }
        }
        i <- i + 1;
    }
}

// ── Pre-scan: collect top-level variable names as globals ──
fn scan_globals(nd) {
    if (nd.node = "Assignment") {
        if (!var_exists(global_vars, nd.name)) {
            push(global_vars, nd.name);
        }
        // Detect string arrays: x <- ["..."]
        if (nd.expr.node = "ArrayLit") {
            i <- 0;
            while (i < len(nd.expr.elements)) {
                if (is_str_expr(nd.expr.elements[i])) {
                    set_global_array_type(nd.name, "str");
                }
                i <- i + 1;
            }
        }
    }
    else if (nd.node = "IfStmt") {
        scan_globals_list(nd.then_body);
        scan_globals_list(nd.else_body);
    }
    else if (nd.node = "WhileStmt") {
        scan_globals_list(nd.body);
    }
    else if (nd.node = "ForInStmt") {
        if (!var_exists(global_vars, nd.var_name)) {
            push(global_vars, nd.var_name);
        }
        scan_globals_list(nd.body);
    }
    else if (nd.node = "Block") {
        scan_globals_list(nd.stmts);
    }
}

fn scan_globals_list(stmts) {
    i <- 0;
    while (i < len(stmts)) {
        scan_globals(stmts[i]);
        i <- i + 1;
    }
}

fn var_exists(vars, name: str): int {
    i <- 0;
    while (i < len(vars)) {
        if (vars[i] = name) { return true; }
        i <- i + 1;
    }
    return false;
}

// ── Collect all variables used in a function body ──
// Split into small handler functions to avoid large-function crashes
fn collect_vars(stmts, vars) {
    work <- [];
    i <- 0;
    while (i < len(stmts)) {
        push(work, stmts[i]);
        i <- i + 1;
    }
    wi <- 0;
    while (wi < len(work)) {
        nd <- work[wi];
        wi <- wi + 1;
        cv_handle(nd, work, vars);
    }
}

fn cv_handle(nd, work, vars) {
    cv_stmt(nd, work, vars);
    cv_expr(nd, work, vars);
}

fn cv_stmt(nd, work, vars) {
    if (nd.node = "Assignment") {
        if (!var_exists(vars, nd.name)) { push(vars, nd.name); }
        push(work, nd.expr);
    }
    if (nd.node = "PrintStmt") { push(work, nd.expr); }
    if (nd.node = "ReturnStmt") {
        if (nd.expr != false) { push(work, nd.expr); }
    }
    if (nd.node = "IfStmt") {
        push(work, nd.cond);
        i <- 0;
        while (i < len(nd.then_body)) { push(work, nd.then_body[i]); i <- i + 1; }
        i <- 0;
        while (i < len(nd.else_body)) { push(work, nd.else_body[i]); i <- i + 1; }
    }
    if (nd.node = "WhileStmt") {
        push(work, nd.cond);
        i <- 0;
        while (i < len(nd.body)) { push(work, nd.body[i]); i <- i + 1; }
    }
    if (nd.node = "ForInStmt") {
        if (!var_exists(vars, nd.var_name)) { push(vars, nd.var_name); }
        push(work, nd.iterable);
        i <- 0;
        while (i < len(nd.body)) { push(work, nd.body[i]); i <- i + 1; }
    }
    if (nd.node = "Block") {
        i <- 0;
        while (i < len(nd.stmts)) { push(work, nd.stmts[i]); i <- i + 1; }
    }
    if (nd.node = "IndexAssign") {
        push(work, nd.obj);
        push(work, nd.index);
        push(work, nd.value);
    }
    if (nd.node = "DotAssign") {
        push(work, nd.obj);
        push(work, nd.value);
    }
}

fn cv_expr(nd, work, vars) {
    if (nd.node = "BinOp") { push(work, nd.left); push(work, nd.right); }
    if (nd.node = "UnaryOp") { push(work, nd.operand); }
    if (nd.node = "CallExpr") {
        push(work, nd.callee);
        i <- 0;
        while (i < len(nd.args)) { push(work, nd.args[i]); i <- i + 1; }
    }
    if (nd.node = "ArrayLit") {
        i <- 0;
        while (i < len(nd.elements)) { push(work, nd.elements[i]); i <- i + 1; }
    }
    if (nd.node = "IndexExpr") { push(work, nd.obj); push(work, nd.index); }
    if (nd.node = "DotExpr") { push(work, nd.obj); }
    if (nd.node = "StructLit") {
        i <- 0;
        while (i < len(nd.fields)) { push(work, nd.fields[i].val); i <- i + 1; }
    }
}

// ── Emit LLVM IR for expression ─────────
// Returns {reg, type} where type is "int" or "str"

fn emit_expr(nd) {
    if (nd.node = "NumberLit") {
        return tv_int(nd.value); // literal integer
    }
    if (nd.node = "StringLit") {
        id <- add_string(nd.value);
        r <- fresh("%s");
        emit("  " + r + " = ptrtoint ptr @" + id + " to i64");
        return tv_str(r);
    }
    if (nd.node = "BoolLit") {
        if (nd.value = "true") { return tv_int("1"); }
        return tv_int("0");
    }
    if (nd.node = "Identifier") {
        reg <- find_var(nd.name);
        if (reg = "") {
            // Might be a function reference
            fi <- find_fn(nd.name);
            if (fi != false) {
                r <- fresh("%fref");
                emit("  " + r + " = ptrtoint ptr @" + nd.name + " to i64");
                return tv_int(r);
            }
            print("Error: undefined var " + nd.name);
            return tv_int("0");
        }
        r <- fresh("%ld");
        emit("  " + r + " = load i64, ptr " + reg);
        return tv(r, get_var_type(nd.name).kind);
    }
    if (nd.node = "BinOp") {
        return emit_binop(nd);
    }
    if (nd.node = "UnaryOp") {
        vt <- emit_expr(nd.operand);
        if (nd.op = "-") {
            r <- fresh("%neg");
            emit("  " + r + " = sub i64 0, " + vt.reg);
            return tv_int(r);
        }
        if (nd.op = "!") {
            r1 <- fresh("%cmp");
            r2 <- fresh("%not");
            emit("  " + r1 + " = icmp eq i64 " + vt.reg + ", 0");
            emit("  " + r2 + " = zext i1 " + r1 + " to i64");
            return tv_int(r2);
        }
        return tv_int("0");
    }
    if (nd.node = "CallExpr") {
        return emit_call(nd);
    }
    if (nd.node = "ArrayLit") {
        return tv_int(emit_array_lit(nd));
    }
    if (nd.node = "IndexExpr") {
        return emit_index(nd);
    }
    if (nd.node = "StructLit") {
        return emit_struct_lit(nd);
    }
    if (nd.node = "DotExpr") {
        return emit_dot_expr(nd);
    }
    if (nd.node = "ArrowFn") {
        return emit_arrow_fn(nd);
    }
    print("Emit error: unsupported expr " + nd.node);
    return tv_int("0");
}

fn emit_binop(nd) {
    if (nd.op = "&&") {
        return emit_and(nd);
    }
    if (nd.op = "||") {
        return emit_or(nd);
    }

    // Emit both sides and use tracked types for decisions
    l <- emit_expr(nd.left);
    r <- emit_expr(nd.right);

    if (nd.op = "+") {
        // String concatenation when either side is tracked as "str"
        if (l.type = "str" || r.type = "str") {
            return emit_strcat(l, r);
        }
        res <- fresh("%add");
        emit("  " + res + " = add i64 " + l.reg + ", " + r.reg);
        return tv_int(res);
    }
    if (nd.op = "-") { res <- fresh("%sub"); emit("  " + res + " = sub i64 " + l.reg + ", " + r.reg); return tv_int(res); }
    if (nd.op = "*") { res <- fresh("%mul"); emit("  " + res + " = mul i64 " + l.reg + ", " + r.reg); return tv_int(res); }
    if (nd.op = "/") { res <- fresh("%div"); emit("  " + res + " = sdiv i64 " + l.reg + ", " + r.reg); return tv_int(res); }
    if (nd.op = "%") { res <- fresh("%rem"); emit("  " + res + " = srem i64 " + l.reg + ", " + r.reg); return tv_int(res); }

    // Comparisons — always return int (0 or 1)
    cmp_op <- "";
    if (nd.op = "=") { cmp_op <- "eq"; }
    else if (nd.op = "!=") { cmp_op <- "ne"; }
    else if (nd.op = "<") { cmp_op <- "slt"; }
    else if (nd.op = ">") { cmp_op <- "sgt"; }
    else if (nd.op = "<=") { cmp_op <- "sle"; }
    else if (nd.op = ">=") { cmp_op <- "sge"; }

    if (cmp_op != "") {
        // Use strcmp when either side is "str", or both are "any"
        // arrow_safe_strcmp handles the case where values might be integers
        if (l.type = "str" || r.type = "str" || (l.type = "any" && r.type = "any")) {
            return emit_strcmp(l, r, cmp_op);
        }
        r1 <- fresh("%cmp");
        r2 <- fresh("%ext");
        emit("  " + r1 + " = icmp " + cmp_op + " i64 " + l.reg + ", " + r.reg);
        emit("  " + r2 + " = zext i1 " + r1 + " to i64");
        return tv_int(r2);
    }
    return tv_int("0");
}

// Check if an AST expression node is known to be a string
fn is_str_expr(nd): int {
    if (nd.node = "StringLit") { return true; }
    // Note: DotExpr used to return true here as a blanket heuristic ("struct fields
    // are usually strings in Arrow") but that's a lie for the majority of fields
    // (body, args, params, etc. are arrays). The lie was latent because len() and
    // other code paths defaulted to array ops regardless of the tag. Removing the
    // heuristic means some DotExpr-returning-str cases (field lookups that really
    // do return strings) fall through to mk_any() — which is fine for correctness,
    // just slightly less precise.
    if (nd.node = "BinOp") {
        if (nd.op = "+") {
            return is_str_expr(nd.left) || is_str_expr(nd.right);
        }
    }
    if (nd.node = "CallExpr") {
        if (nd.callee.node = "Identifier") {
            nm <- nd.callee.name;
            if (nm = "char_at") { return true; }
            if (nm = "from_char_code") { return true; }
            if (nm = "substring") { return true; }
            if (nm = "input") { return true; }
            if (nm = "read_file") { return true; }
        }
    }
    return false;
}

// ── String concatenation ────────────────
fn emit_strcat(l, r) {
    // "str" → use as string pointer directly
    // "any" → runtime check via arrow_to_str (itoa if small int, use as ptr otherwise)
    // "int" → convert via itoa at compile time
    if (l.type = "str") {
        lp <- fresh("%scl");
        emit("  " + lp + " = inttoptr i64 " + l.reg + " to ptr");
    } else if (l.type = "any") {
        lp <- fresh("%scl");
        emit("  " + lp + " = call ptr @arrow_to_str(i64 " + l.reg + ")");
    } else {
        ls <- ensure_str(l);
        lp <- fresh("%scl");
        emit("  " + lp + " = inttoptr i64 " + ls + " to ptr");
    }
    if (r.type = "str") {
        rp <- fresh("%scr");
        emit("  " + rp + " = inttoptr i64 " + r.reg + " to ptr");
    } else if (r.type = "any") {
        rp <- fresh("%scr");
        emit("  " + rp + " = call ptr @arrow_to_str(i64 " + r.reg + ")");
    } else {
        rs <- ensure_str(r);
        rp <- fresh("%scr");
        emit("  " + rp + " = inttoptr i64 " + rs + " to ptr");
    }

    // Get lengths
    ll <- fresh("%sll");
    rl <- fresh("%srl");
    emit("  " + ll + " = call i64 @strlen(ptr " + lp + ")");
    emit("  " + rl + " = call i64 @strlen(ptr " + rp + ")");

    // Allocate buffer: len_l + len_r + 1
    tl <- fresh("%stl");
    bs <- fresh("%sbs");
    buf <- fresh("%sbuf");
    emit("  " + tl + " = add i64 " + ll + ", " + rl);
    emit("  " + bs + " = add i64 " + tl + ", 1");
    emit("  " + buf + " = call ptr @arena_alloc(i64 " + bs + ")");

    // strcpy + strcat
    emit("  call ptr @strcpy(ptr " + buf + ", ptr " + lp + ")");
    emit("  call ptr @strcat(ptr " + buf + ", ptr " + rp + ")");

    // Return as i64
    res <- fresh("%scres");
    emit("  " + res + " = ptrtoint ptr " + buf + " to i64");
    return tv_str(res);
}

// ── String comparison ───────────────────
fn emit_strcmp(l, r, cmp_op: str) {
    // In strcmp context, both values must be string pointers
    ls <- as_str_ptr(l);
    rs <- as_str_ptr(r);

    lp <- fresh("%csl");
    rp <- fresh("%csr");
    emit("  " + lp + " = inttoptr i64 " + ls + " to ptr");
    emit("  " + rp + " = inttoptr i64 " + rs + " to ptr");

    sc <- fresh("%scmp");
    emit("  " + sc + " = call i32 @arrow_safe_strcmp(ptr " + lp + ", ptr " + rp + ")");

    // strcmp returns <0, 0, >0 — compare against 0
    r1 <- fresh("%scr");
    r2 <- fresh("%sce");
    // Use if/else to avoid cmp_op string concat (param type not tracked as str)
    if (cmp_op = "eq") {
        emit("  " + r1 + " = icmp eq i32 " + sc + ", 0");
    }
    if (cmp_op = "ne") {
        emit("  " + r1 + " = icmp ne i32 " + sc + ", 0");
    }
    if (cmp_op = "slt") {
        emit("  " + r1 + " = icmp slt i32 " + sc + ", 0");
    }
    if (cmp_op = "sgt") {
        emit("  " + r1 + " = icmp sgt i32 " + sc + ", 0");
    }
    if (cmp_op = "sle") {
        emit("  " + r1 + " = icmp sle i32 " + sc + ", 0");
    }
    if (cmp_op = "sge") {
        emit("  " + r1 + " = icmp sge i32 " + sc + ", 0");
    }
    emit("  " + r2 + " = zext i1 " + r1 + " to i64");
    return tv_int(r2);
}

fn emit_and(nd) {
    // Use alloca approach to avoid phi block tracking issues
    res_ptr <- fresh("%and_res");
    emit("  " + res_ptr + " = alloca i64");
    emit("  store i64 0, ptr " + res_ptr);
    l <- emit_expr(nd.left);
    lbl_right <- fresh_lbl("and_r");
    lbl_end <- fresh_lbl("and_e");
    lc <- fresh("%ac");
    emit("  " + lc + " = icmp ne i64 " + l.reg + ", 0");
    emit("  br i1 " + lc + ", label %" + lbl_right + ", label %" + lbl_end);
    emit(lbl_right + ":");
    r <- emit_expr(nd.right);
    rc <- fresh("%arc");
    emit("  " + rc + " = icmp ne i64 " + r.reg + ", 0");
    rext <- fresh("%arext");
    emit("  " + rext + " = zext i1 " + rc + " to i64");
    emit("  store i64 " + rext + ", ptr " + res_ptr);
    emit("  br label %" + lbl_end);
    emit(lbl_end + ":");
    res <- fresh("%aphi");
    emit("  " + res + " = load i64, ptr " + res_ptr);
    return tv_int(res);
}

fn emit_or(nd) {
    // Use alloca approach to avoid phi block tracking issues
    res_ptr <- fresh("%or_res");
    emit("  " + res_ptr + " = alloca i64");
    emit("  store i64 1, ptr " + res_ptr); // default true
    l <- emit_expr(nd.left);
    lbl_right <- fresh_lbl("or_r");
    lbl_end <- fresh_lbl("or_e");
    lc <- fresh("%oc");
    emit("  " + lc + " = icmp ne i64 " + l.reg + ", 0");
    emit("  br i1 " + lc + ", label %" + lbl_end + ", label %" + lbl_right);
    emit(lbl_right + ":");
    r <- emit_expr(nd.right);
    rc <- fresh("%orc");
    emit("  " + rc + " = icmp ne i64 " + r.reg + ", 0");
    rext <- fresh("%orext");
    emit("  " + rext + " = zext i1 " + rc + " to i64");
    emit("  store i64 " + rext + ", ptr " + res_ptr);
    emit("  br label %" + lbl_end);
    emit(lbl_end + ":");
    res <- fresh("%ophi");
    emit("  " + res + " = load i64, ptr " + res_ptr);
    return tv_int(res);
}

fn emit_call(nd) {
    // Builtins
    if (nd.callee.node = "Identifier") {
        nm <- nd.callee.name;

        if (nm = "print") {
            // Should not get here — print is a statement
            return tv_int("0");
        }

        // User function call
        // Note: find_fn may return an entry registered for an arrow-fn variable
        // (from scan_fns's pre-pass, used by the type checker). Those entries
        // have `is_arrow_var: true` — skip them so we fall through to the
        // indirect-call branch which actually knows how to invoke closures.
        fi <- find_fn(nm);
        if (fi != false && fi.is_arrow_var = true) { fi <- false; }
        if (fi != false) {
            args_str <- "";
            i <- 0;
            while (i < len(nd.args)) {
                if (i > 0) { args_str <- args_str + ", "; }
                vt <- emit_expr(nd.args[i]);
                args_str <- args_str + "i64 " + vt.reg;
                // Emit-time param type propagation: use actual tracked types
                // This catches cases scan_call_sites misses (Identifiers with type "str")
                if (i < fi.param_count) {
                    if (vt.type = "str") {
                        set_fn_param_type(fi.name, i, mk_str());
                    }
                }
                i <- i + 1;
            }
            r <- fresh("%call");
            emit("  " + r + " = call i64 @" + nm + "(" + args_str + ")");
            if (fi.ret_type.kind = "struct") {
                return {reg: r, type: "struct", fields: fi.ret_fields};
            }
            return tv(r, fi.ret_type.kind);
        }

        // Builtin len
        if (nm = "len") {
            vt <- emit_expr(nd.args[0]);
            // Dispatch on static type: strings use strlen, arrays/any read the
            // length word at offset 0. Defaulting non-str to the array path
            // preserves existing behavior for arrays whose variable was typed
            // as "any" (happens when arrays flow through generic helpers).
            if (vt.type = "str") {
                sp <- fresh("%lsp");
                sl <- fresh("%lsr");
                emit("  " + sp + " = inttoptr i64 " + vt.reg + " to ptr");
                emit("  " + sl + " = call i64 @strlen(ptr " + sp + ")");
                return tv_int(sl);
            }
            ap <- fresh("%ap");
            lp <- fresh("%lp");
            lv <- fresh("%lv");
            emit("  " + ap + " = inttoptr i64 " + vt.reg + " to ptr");
            emit("  " + lp + " = getelementptr i64, ptr " + ap + ", i64 0");
            emit("  " + lv + " = load i64, ptr " + lp);
            return tv_int(lv);
        }

        // Builtin push
        if (nm = "push") {
            vt_arr <- emit_expr(nd.args[0]);
            vt_val <- emit_expr(nd.args[1]);
            rp <- fresh("%push_r");
            emit("  " + rp + " = call i64 @arrow_push(i64 " + vt_arr.reg + ", i64 " + vt_val.reg + ")");
            // Store the (possibly reallocated) array pointer back
            if (nd.args[0].node = "Identifier") {
                arr_reg <- find_var(nd.args[0].name);
                if (arr_reg != "") {
                    emit("  store i64 " + rp + ", ptr " + arr_reg);
                }
            }
            return tv(vt_val.reg, vt_val.type);
        }

        // Builtin pop — returns last element, decrements array len in place.
        // No pointer store-back needed: arrow_pop shrinks in place and never reallocs.
        if (nm = "pop") {
            vt_arr <- emit_expr(nd.args[0]);
            rp <- fresh("%pop_r");
            emit("  " + rp + " = call i64 @arrow_pop(i64 " + vt_arr.reg + ")");
            // Element type from the full typeof_expr pipeline (which reads var_types
            // populated by infer_body). Avoids dropping structural types that
            // emit-time codegen doesn't carry on typed values.
            at <- typeof_expr(nd.args[0]);
            et_kind <- "any";
            if (at.kind = "array") { et_kind <- at.elem.kind; }
            return tv(rp, et_kind);
        }

        // Builtin keys — returns [str] of a struct's field names.
        if (nm = "keys") {
            vt_s <- emit_expr(nd.args[0]);
            rp <- fresh("%keys_r");
            emit("  " + rp + " = call i64 @arrow_keys(i64 " + vt_s.reg + ")");
            // Result is a [str]. Tag the value as "int" (pointer) — the structural
            // type info lives in var_types once assigned (preserved by the
            // infer_body/emit_stmt harmony fix from the pop work).
            return tv_int(rp);
        }

        // Builtin str_len
        if (nm = "str_len") {
            vt <- emit_expr(nd.args[0]);
            sp <- fresh("%slp");
            sl <- fresh("%slr");
            emit("  " + sp + " = inttoptr i64 " + vt.reg + " to ptr");
            emit("  " + sl + " = call i64 @strlen(ptr " + sp + ")");
            return tv_int(sl);
        }

        // Builtin char_code
        if (nm = "char_code") {
            vt <- emit_expr(nd.args[0]);
            sp <- fresh("%ccp");
            ch <- fresh("%ccv");
            r <- fresh("%ccr");
            emit("  " + sp + " = inttoptr i64 " + vt.reg + " to ptr");
            emit("  " + ch + " = load i8, ptr " + sp);
            emit("  " + r + " = zext i8 " + ch + " to i64");
            return tv_int(r);
        }

        // Builtin from_char_code
        if (nm = "from_char_code") {
            vt <- emit_expr(nd.args[0]);
            buf <- fresh("%fcc");
            ch <- fresh("%fcch");
            r <- fresh("%fccr");
            np <- fresh("%fccn");
            emit("  " + buf + " = call ptr @arena_alloc(i64 2)");
            emit("  " + ch + " = trunc i64 " + vt.reg + " to i8");
            emit("  store i8 " + ch + ", ptr " + buf);
            emit("  " + np + " = getelementptr i8, ptr " + buf + ", i64 1");
            emit("  store i8 0, ptr " + np);
            emit("  " + r + " = ptrtoint ptr " + buf + " to i64");
            return tv_str(r);
        }

        // Builtin char_at
        if (nm = "char_at") {
            vt_s <- emit_expr(nd.args[0]);
            vt_i <- emit_expr(nd.args[1]);
            sp <- fresh("%cap");
            ep <- fresh("%caep");
            ch <- fresh("%cach");
            buf <- fresh("%cabuf");
            np <- fresh("%canp");
            r <- fresh("%car");
            emit("  " + sp + " = inttoptr i64 " + vt_s.reg + " to ptr");
            emit("  " + ep + " = getelementptr i8, ptr " + sp + ", i64 " + vt_i.reg);
            emit("  " + ch + " = load i8, ptr " + ep);
            emit("  " + buf + " = call ptr @arena_alloc(i64 2)");
            emit("  store i8 " + ch + ", ptr " + buf);
            emit("  " + np + " = getelementptr i8, ptr " + buf + ", i64 1");
            emit("  store i8 0, ptr " + np);
            emit("  " + r + " = ptrtoint ptr " + buf + " to i64");
            return tv_str(r);
        }

        // Builtin substring
        if (nm = "substring") {
            vt_s <- emit_expr(nd.args[0]);
            vt_start <- emit_expr(nd.args[1]);
            vt_end <- emit_expr(nd.args[2]);
            sp <- fresh("%ssp");
            sl <- fresh("%ssl");
            bs <- fresh("%sbs");
            buf <- fresh("%sbf");
            src <- fresh("%ssrc");
            emit("  " + sp + " = inttoptr i64 " + vt_s.reg + " to ptr");
            emit("  " + sl + " = sub i64 " + vt_end.reg + ", " + vt_start.reg);
            emit("  " + bs + " = add i64 " + sl + ", 1");
            emit("  " + buf + " = call ptr @arena_alloc(i64 " + bs + ")");
            emit("  " + src + " = getelementptr i8, ptr " + sp + ", i64 " + vt_start.reg);
            // Copy loop
            idx_r <- fresh("%ssi");
            emit("  " + idx_r + " = alloca i64");
            emit("  store i64 0, ptr " + idx_r);
            lbl_c <- fresh_lbl("ssc");
            lbl_b <- fresh_lbl("ssb");
            lbl_e <- fresh_lbl("sse");
            emit("  br label %" + lbl_c);
            emit(lbl_c + ":");
            ci2 <- fresh("%ssci");
            cmp <- fresh("%sscmp");
            emit("  " + ci2 + " = load i64, ptr " + idx_r);
            emit("  " + cmp + " = icmp slt i64 " + ci2 + ", " + sl);
            emit("  br i1 " + cmp + ", label %" + lbl_b + ", label %" + lbl_e);
            emit(lbl_b + ":");
            ci3 <- fresh("%ssci2");
            sep2 <- fresh("%ssep");
            sch <- fresh("%ssch");
            dep <- fresh("%ssdep");
            emit("  " + ci3 + " = load i64, ptr " + idx_r);
            emit("  " + sep2 + " = getelementptr i8, ptr " + src + ", i64 " + ci3);
            emit("  " + sch + " = load i8, ptr " + sep2);
            emit("  " + dep + " = getelementptr i8, ptr " + buf + ", i64 " + ci3);
            emit("  store i8 " + sch + ", ptr " + dep);
            ci4 <- fresh("%ssinc");
            emit("  " + ci4 + " = add i64 " + ci3 + ", 1");
            emit("  store i64 " + ci4 + ", ptr " + idx_r);
            emit("  br label %" + lbl_c);
            emit(lbl_e + ":");
            // Null terminate
            ntp <- fresh("%ssnt");
            emit("  " + ntp + " = getelementptr i8, ptr " + buf + ", i64 " + sl);
            emit("  store i8 0, ptr " + ntp);
            r <- fresh("%ssr");
            emit("  " + r + " = ptrtoint ptr " + buf + " to i64");
            return tv_str(r);
        }

        // Builtin read_file
        if (nm = "read_file") {
            vt <- emit_expr(nd.args[0]);
            sp <- fresh("%rfp");
            r <- fresh("%rfr");
            ri <- fresh("%rfi");
            emit("  " + sp + " = inttoptr i64 " + vt.reg + " to ptr");
            emit("  " + r + " = call ptr @arrow_read_file(ptr " + sp + ")");
            emit("  " + ri + " = ptrtoint ptr " + r + " to i64");
            return tv_str(ri);
        }

        // Builtin write_file
        if (nm = "write_file") {
            vt_path <- emit_expr(nd.args[0]);
            vt_content <- emit_expr(nd.args[1]);
            pp <- fresh("%wfp");
            cp <- fresh("%wfc");
            r <- fresh("%wfr");
            emit("  " + pp + " = inttoptr i64 " + vt_path.reg + " to ptr");
            emit("  " + cp + " = inttoptr i64 " + vt_content.reg + " to ptr");
            emit("  " + r + " = call i64 @arrow_write_file(ptr " + pp + ", ptr " + cp + ")");
            return tv_int(r);
        }

        // Builtin append_file
        if (nm = "append_file") {
            vt_path <- emit_expr(nd.args[0]);
            vt_content <- emit_expr(nd.args[1]);
            pp <- fresh("%afp");
            cp <- fresh("%afc");
            r <- fresh("%afr");
            emit("  " + pp + " = inttoptr i64 " + vt_path.reg + " to ptr");
            emit("  " + cp + " = inttoptr i64 " + vt_content.reg + " to ptr");
            emit("  " + r + " = call i64 @arrow_append_file(ptr " + pp + ", ptr " + cp + ")");
            return tv_int(r);
        }

        // Builtin exec_cmd
        if (nm = "exec_cmd") {
            vt <- emit_expr(nd.args[0]);
            sp <- fresh("%ecp");
            r <- fresh("%ecr");
            emit("  " + sp + " = inttoptr i64 " + vt.reg + " to ptr");
            emit("  " + r + " = call i32 @system(ptr " + sp + ")");
            ri <- fresh("%ecri");
            emit("  " + ri + " = sext i32 " + r + " to i64");
            return tv_int(ri);
        }

        // Builtin input
        if (nm = "input") {
            if (len(nd.args) >= 1) {
                vt <- emit_expr(nd.args[0]);
                sp <- fresh("%inp");
                emit("  " + sp + " = inttoptr i64 " + vt.reg + " to ptr");
                emit("  call i32 (ptr, ...) @printf(ptr " + sp + ")");
            }
            r <- fresh("%inr");
            ri <- fresh("%inri");
            emit("  " + r + " = call ptr @arrow_input()");
            emit("  " + ri + " = ptrtoint ptr " + r + " to i64");
            return tv_str(ri);
        }

        // Builtin args — access command line arguments
        if (nm = "args") {
            if (len(nd.args) = 0) {
                // args() with no arguments — return argc - 1 (number of script args)
                ac <- fresh("%argc");
                ar <- fresh("%argr");
                emit("  " + ac + " = load i64, ptr @g_argc");
                emit("  " + ar + " = sub i64 " + ac + ", 1");
                return tv_int(ar);
            }
            // args(N) — return argv[N+1] as string
            vt <- emit_expr(nd.args[0]);
            ai <- fresh("%argi");
            emit("  " + ai + " = add i64 " + vt.reg + ", 1"); // skip program name
            av <- fresh("%argv");
            emit("  " + av + " = load i64, ptr @g_argv");
            avp <- fresh("%argvp");
            emit("  " + avp + " = inttoptr i64 " + av + " to ptr");
            ep <- fresh("%argep");
            emit("  " + ep + " = getelementptr ptr, ptr " + avp + ", i64 " + ai);
            sp <- fresh("%argsp");
            emit("  " + sp + " = load ptr, ptr " + ep);
            ri <- fresh("%argri");
            emit("  " + ri + " = ptrtoint ptr " + sp + " to i64");
            return tv_str(ri);
        }

        // Indirect call via variable (arrow function stored in variable)
        fn_reg <- find_var(nm);
        if (fn_reg != "") {
            // Look up arrow function info for param type propagation
            afn_name <- get_arrow_fn_name(nm);
            afn_info <- false;
            if (afn_name != "") {
                afn_info <- find_fn(afn_name);
            }

            // Load closure pair [fn_ptr, env_ptr]
            pair_val <- fresh("%pld");
            emit("  " + pair_val + " = load i64, ptr " + fn_reg);
            pair_ptr <- fresh("%pptr");
            emit("  " + pair_ptr + " = inttoptr i64 " + pair_val + " to ptr");
            // Extract fn_ptr (slot 0)
            fn_i64 <- fresh("%fni");
            emit("  " + fn_i64 + " = load i64, ptr " + pair_ptr);
            fn_ptr <- fresh("%fnp");
            emit("  " + fn_ptr + " = inttoptr i64 " + fn_i64 + " to ptr");
            // Extract env_ptr (slot 1)
            env_slot <- fresh("%esl");
            env_i64 <- fresh("%eni");
            emit("  " + env_slot + " = getelementptr i64, ptr " + pair_ptr + ", i64 1");
            emit("  " + env_i64 + " = load i64, ptr " + env_slot);

            // Build args: env first, then user args
            args_str <- "i64 " + env_i64;
            i <- 0;
            while (i < len(nd.args)) {
                args_str <- args_str + ", ";
                vt <- emit_expr(nd.args[i]);
                args_str <- args_str + "i64 " + vt.reg;
                if (afn_info != false && i < afn_info.param_count) {
                    if (vt.type = "str") {
                        set_fn_param_type(afn_info.name, i, mk_str());
                    }
                }
                i <- i + 1;
            }
            r <- fresh("%icall");
            emit("  " + r + " = call i64 " + fn_ptr + "(" + args_str + ")");
            if (afn_info != false) {
                return tv(r, afn_info.ret_type.kind);
            }
            return tv(r, "any");
        }

        print("Error: unknown function " + nm);
        return tv_int("0");
    }

    // Indirect call via expression (e.g. make_fn()(args))
    fn_vt <- emit_expr(nd.callee);
    // Unpack closure pair [fn_ptr, env_ptr]
    pair_ptr <- fresh("%pptr");
    emit("  " + pair_ptr + " = inttoptr i64 " + fn_vt.reg + " to ptr");
    fn_i64 <- fresh("%fni");
    emit("  " + fn_i64 + " = load i64, ptr " + pair_ptr);
    fn_ptr <- fresh("%fnp");
    emit("  " + fn_ptr + " = inttoptr i64 " + fn_i64 + " to ptr");
    env_slot <- fresh("%esl");
    env_i64 <- fresh("%eni");
    emit("  " + env_slot + " = getelementptr i64, ptr " + pair_ptr + ", i64 1");
    emit("  " + env_i64 + " = load i64, ptr " + env_slot);

    args_str <- "i64 " + env_i64;
    i <- 0;
    while (i < len(nd.args)) {
        args_str <- args_str + ", ";
        vt <- emit_expr(nd.args[i]);
        args_str <- args_str + "i64 " + vt.reg;
        i <- i + 1;
    }
    r <- fresh("%icall");
    emit("  " + r + " = call i64 " + fn_ptr + "(" + args_str + ")");
    return tv(r, "any");
}

fn emit_array_lit(nd) {
    // Allocate: [len, cap, elem0, elem1, ...]
    // Layout: i64* with [length, capacity, elements...]
    n <- len(nd.elements);
    cap <- n;
    if (cap < 4096) { cap <- 4096; }
    total <- 2 + cap; // len + cap + elements
    sz <- fresh("%asz");
    ap <- fresh("%aptr");
    ai <- fresh("%aint");
    emit("  " + sz + " = mul i64 " + total + ", 8");
    emit("  " + ap + " = call ptr @malloc(i64 " + sz + ")");

    // Store length
    emit("  store i64 " + n + ", ptr " + ap);
    // Store capacity
    cp <- fresh("%cp");
    emit("  " + cp + " = getelementptr i64, ptr " + ap + ", i64 1");
    emit("  store i64 " + cap + ", ptr " + cp);

    // Store elements
    i <- 0;
    while (i < n) {
        vt <- emit_expr(nd.elements[i]);
        ep <- fresh("%ep");
        idx <- i + 2;
        emit("  " + ep + " = getelementptr i64, ptr " + ap + ", i64 " + idx);
        emit("  store i64 " + vt.reg + ", ptr " + ep);
        i <- i + 1;
    }

    emit("  " + ai + " = ptrtoint ptr " + ap + " to i64");
    return ai;
}

fn emit_index(nd) {
    vt_obj <- emit_expr(nd.obj);
    vt_idx <- emit_expr(nd.index);

    // Dispatch: if the object is statically a string, index by byte and build
    // a 2-byte allocated string (same semantics as char_at). If it's an array
    // or we don't know, fall through to the array-indexing path.
    //
    // We could also check vt_obj.type = "str" here, but that field only reflects
    // the immediate emit_expr return tag — which is "int" for a string literal
    // loaded from a global. The richer source of truth is the var_types table
    // populated by infer_body/scan_call_sites.
    is_str <- false;
    if (nd.obj.node = "Identifier") {
        ot <- get_var_type(nd.obj.name);
        if (ot.kind = "str") { is_str <- true; }
    }
    if (vt_obj.type = "str") { is_str <- true; }

    if (is_str) {
        sp <- fresh("%sip");
        ep <- fresh("%sibp");
        ch <- fresh("%sich");
        buf <- fresh("%sibuf");
        np <- fresh("%sinp");
        r <- fresh("%sir");
        emit("  " + sp + " = inttoptr i64 " + vt_obj.reg + " to ptr");
        emit("  " + ep + " = getelementptr i8, ptr " + sp + ", i64 " + vt_idx.reg);
        emit("  " + ch + " = load i8, ptr " + ep);
        emit("  " + buf + " = call ptr @arena_alloc(i64 2)");
        emit("  store i8 " + ch + ", ptr " + buf);
        emit("  " + np + " = getelementptr i8, ptr " + buf + ", i64 1");
        emit("  store i8 0, ptr " + np);
        emit("  " + r + " = ptrtoint ptr " + buf + " to i64");
        return tv_str(r);
    }

    // Array path
    ap <- fresh("%ip");
    off <- fresh("%ioff");
    ep <- fresh("%iep");
    ev <- fresh("%iev");
    emit("  " + ap + " = inttoptr i64 " + vt_obj.reg + " to ptr");
    emit("  " + off + " = add i64 " + vt_idx.reg + ", 2"); // skip len+cap
    emit("  " + ep + " = getelementptr i64, ptr " + ap + ", i64 " + off);
    emit("  " + ev + " = load i64, ptr " + ep);
    // Element type: prefer structural info from var_types (set by infer_body for
    // all [T]-typed variables), fall back to the legacy side table.
    // When the object isn't a direct Identifier (e.g. nested `m.functions[0]`
    // or `arr[i][j]`), recurse through typeof_expr to walk structural types.
    etype <- mk_any();
    if (nd.obj.node = "Identifier") {
        ot <- get_var_type(nd.obj.name);
        if (ot.kind = "array") {
            etype <- ot.elem;
        } else {
            etype <- get_array_elem_type(nd.obj.name);
        }
    } else {
        ot <- typeof_expr(nd.obj);
        if (ot.kind = "array") { etype <- ot.elem; }
    }
    return tv(ev, etype.kind);
}

// ── Emit statement ──────────────────────

fn emit_stmt(nd) {
    if (nd.node = "Assignment") {
        vt <- emit_expr(nd.expr);
        reg <- find_var(nd.name);
        if (reg = "") { reg <- add_var(nd.name); }
        emit("  store i64 " + vt.reg + ", ptr " + reg);
        // Track type — use explicit annotation if present (already a Type)
        if (nd.type_ann.kind != "none") {
            set_var_type(nd.name, nd.type_ann);
        } else if (vt.type = "struct") {
            set_var_type(nd.name, mk_int());
            if (vt.fields != false) {
                set_struct_layout(nd.name, vt.fields);
            }
        } else if (vt.type = "fn") {
            // Arrow function assignment — track var → fn name mapping
            set_var_type(nd.name, mk_fn());
            if (vt.fields != false) {
                set_arrow_fn_var(nd.name, vt.fields);
            }
        } else {
            // Don't clobber a richer inferred type from infer_body.
            // emit_expr returns a value-tag kind string — e.g. ArrayLit returns
            // "int" because its value is a pointer. If infer_body already set
            // a structural Type (array, struct_lit), keep it. For primitives,
            // accept the update — a var reassigned from str to int truly is int.
            existing <- get_var_type(nd.name);
            if (existing.kind = "array" || existing.kind = "struct_lit") {
                // keep structural type
            } else {
                set_var_type(nd.name, parse_type_ann(vt.type));
            }
        }
        // Track array element types from ArrayLit initializers
        if (nd.expr.node = "ArrayLit") {
            i <- 0;
            while (i < len(nd.expr.elements)) {
                if (is_str_expr(nd.expr.elements[i])) {
                    set_array_elem_type(nd.name, "str");
                }
                i <- i + 1;
            }
        }
        return false;
    }
    if (nd.node = "PrintStmt") {
        return emit_print(nd.expr);
    }
    if (nd.node = "IfStmt") {
        return emit_if(nd);
    }
    if (nd.node = "WhileStmt") {
        return emit_while(nd);
    }
    if (nd.node = "ForInStmt") {
        return emit_for_in(nd);
    }
    if (nd.node = "ReturnStmt") {
        if (nd.expr = false) {
            emit("  ret i64 0");
        } else {
            vt <- emit_expr(nd.expr);
            emit("  ret i64 " + vt.reg);
            // Track return type and struct fields for function
            fn_name <- current_fn[0];
            if (fn_name != "") {
                set_fn_ret_type(fn_name, parse_type_ann(vt.type), vt.fields);
            }
        }
        return false;
    }
    if (nd.node = "IndexAssign") {
        vt_obj <- emit_expr(nd.obj);
        vt_idx <- emit_expr(nd.index);
        vt_val <- emit_expr(nd.value);
        ap <- fresh("%iap");
        off <- fresh("%iaoff");
        ep <- fresh("%iaep");
        emit("  " + ap + " = inttoptr i64 " + vt_obj.reg + " to ptr");
        emit("  " + off + " = add i64 " + vt_idx.reg + ", 2");
        emit("  " + ep + " = getelementptr i64, ptr " + ap + ", i64 " + off);
        emit("  store i64 " + vt_val.reg + ", ptr " + ep);
        // Track element type for this array
        if (nd.obj.node = "Identifier") {
            if (vt_val.type = "str") {
                set_array_elem_type(nd.obj.name, "str");
            }
        }
        return false;
    }
    if (nd.node = "DotAssign") {
        return emit_dot_assign(nd);
    }
    if (nd.node = "Block") {
        emit_block(nd.stmts);
        return false;
    }
    // Expression statement
    emit_expr(nd);
    return false;
}

fn emit_block(stmts) {
    i <- 0;
    while (i < len(stmts)) {
        emit_stmt(stmts[i]);
        i <- i + 1;
    }
}

fn emit_print(expr) {
    // Use type info to decide format
    vt <- emit_expr(expr);
    if (vt.type = "str") {
        // Print as string with puts-style: printf("%s\n", ptr)
        sp <- fresh("%pp");
        emit("  " + sp + " = inttoptr i64 " + vt.reg + " to ptr");
        emit("  call i32 @puts(ptr " + sp + ")");
    } else {
        // Default: print as integer (includes "any" — use concat to force string)
        emit("  call i32 (ptr, ...) @printf(ptr @fmt_int, i64 " + vt.reg + ")");
    }
    // Flush stdout
    emit("  call i32 @fflush(ptr null)");
    return false;
}

fn emit_if(nd) {
    vt <- emit_expr(nd.cond);
    cmp <- fresh("%ifc");
    lbl_then <- fresh_lbl("then");
    lbl_else <- fresh_lbl("else");
    lbl_end <- fresh_lbl("ifend");

    emit("  " + cmp + " = icmp ne i64 " + vt.reg + ", 0");

    if (len(nd.else_body) > 0) {
        emit("  br i1 " + cmp + ", label %" + lbl_then + ", label %" + lbl_else);
    } else {
        emit("  br i1 " + cmp + ", label %" + lbl_then + ", label %" + lbl_end);
    }

    emit(lbl_then + ":");
    emit_block(nd.then_body);
    emit("  br label %" + lbl_end);

    if (len(nd.else_body) > 0) {
        emit(lbl_else + ":");
        emit_block(nd.else_body);
        emit("  br label %" + lbl_end);
    }

    emit(lbl_end + ":");
    return false;
}

fn emit_while(nd) {
    lbl_cond <- fresh_lbl("wc");
    lbl_body <- fresh_lbl("wb");
    lbl_end <- fresh_lbl("we");

    emit("  br label %" + lbl_cond);
    emit(lbl_cond + ":");
    vt <- emit_expr(nd.cond);
    cmp <- fresh("%wcc");
    emit("  " + cmp + " = icmp ne i64 " + vt.reg + ", 0");
    emit("  br i1 " + cmp + ", label %" + lbl_body + ", label %" + lbl_end);

    emit(lbl_body + ":");
    emit_block(nd.body);
    emit("  br label %" + lbl_cond);

    emit(lbl_end + ":");
    return false;
}

// ── Struct support ──────────────────────

// Struct layout: [count, val0, val1, ..., name_ptr0, name_ptr1, ...]
// Total slots = 1 + 2*N.  All i64.

fn emit_struct_lit(nd) {
    n <- len(nd.fields);
    total <- 1 + n * 2; // count + N values + N name ptrs
    sz <- fresh("%ssz");
    sp <- fresh("%sptr");
    emit("  " + sz + " = mul i64 " + total + ", 8");
    emit("  " + sp + " = call ptr @arena_alloc(i64 " + sz + ")");

    // Store count
    emit("  store i64 " + n + ", ptr " + sp);

    // Store values at slots [1..N] and track field types
    field_info <- [];
    i <- 0;
    while (i < n) {
        vt <- emit_expr(nd.fields[i].val);
        slot <- i + 1;
        vp <- fresh("%svp");
        emit("  " + vp + " = getelementptr i64, ptr " + sp + ", i64 " + slot);
        emit("  store i64 " + vt.reg + ", ptr " + vp);
        push(field_info, {fname: nd.fields[i].key, ftype: vt.type});
        i <- i + 1;
    }

    // Store name pointers at slots [N+1..2N]
    i <- 0;
    while (i < n) {
        fname <- nd.fields[i].key;
        fid <- add_string(fname);
        np <- fresh("%snp");
        ni <- fresh("%sni");
        slot <- 1 + n + i;
        emit("  " + ni + " = ptrtoint ptr @" + fid + " to i64");
        emit("  " + np + " = getelementptr i64, ptr " + sp + ", i64 " + slot);
        emit("  store i64 " + ni + ", ptr " + np);
        i <- i + 1;
    }

    // Return struct pointer as i64, with field info attached
    ri <- fresh("%sri");
    emit("  " + ri + " = ptrtoint ptr " + sp + " to i64");
    return {reg: ri, type: "struct", fields: field_info};
}

fn emit_dot_expr(nd) {
    vt_obj <- emit_expr(nd.obj);

    // Field name as string constant
    fid <- add_string(nd.field);

    // Object pointer
    op <- fresh("%dop");
    emit("  " + op + " = inttoptr i64 " + vt_obj.reg + " to ptr");

    // Call struct_find helper to get field index
    idx <- fresh("%didx");
    emit("  " + idx + " = call i64 @arrow_struct_find(ptr " + op + ", ptr @" + fid + ")");

    // Load value at slot [1 + idx]
    slot <- fresh("%dslot");
    vp <- fresh("%dvp");
    val <- fresh("%dval");
    emit("  " + slot + " = add i64 " + idx + ", 1");
    emit("  " + vp + " = getelementptr i64, ptr " + op + ", i64 " + slot);
    emit("  " + val + " = load i64, ptr " + vp);

    // Try to determine field type from struct layout
    ftype <- mk_any(); // unknown type — could be string, int, or struct pointer
    if (nd.obj.node = "Identifier") {
        layout <- get_struct_layout(nd.obj.name);
        if (layout != false) {
            ftype <- get_field_type(layout, nd.field);
        }
    }
    return tv(val, ftype.kind);
}

fn emit_dot_assign(nd) {
    vt_obj <- emit_expr(nd.obj);
    vt_val <- emit_expr(nd.value);

    // Field name as string constant
    fid <- add_string(nd.field);

    // Object pointer
    op <- fresh("%daop");
    emit("  " + op + " = inttoptr i64 " + vt_obj.reg + " to ptr");

    // Find field index
    idx <- fresh("%daidx");
    emit("  " + idx + " = call i64 @arrow_struct_find(ptr " + op + ", ptr @" + fid + ")");

    slot <- fresh("%daslot");
    vp <- fresh("%davp");
    emit("  " + slot + " = add i64 " + idx + ", 1");
    emit("  " + vp + " = getelementptr i64, ptr " + op + ", i64 " + slot);
    emit("  store i64 " + vt_val.reg + ", ptr " + vp);
    return false;
}

// Emit the struct_find helper function
// arrow_struct_find(ptr %sptr, ptr %name) -> i64 index (or -1)
fn emit_struct_find_helper() {
    emit("define i64 @arrow_struct_find(ptr %sptr, ptr %name) {");
    emit("entry:");
    emit("  %count = load i64, ptr %sptr");
    emit("  %idx = alloca i64");
    emit("  store i64 0, ptr %idx");
    emit("  br label %cond");
    emit("cond:");
    emit("  %i = load i64, ptr %idx");
    emit("  %done = icmp slt i64 %i, %count");
    emit("  br i1 %done, label %body, label %notfound");
    emit("body:");
    emit("  %i2 = load i64, ptr %idx");
    // name slot = 1 + count + i
    emit("  %ns1 = add i64 1, %count");
    emit("  %ns2 = add i64 %ns1, %i2");
    emit("  %nsp = getelementptr i64, ptr %sptr, i64 %ns2");
    emit("  %ni = load i64, ptr %nsp");
    emit("  %np = inttoptr i64 %ni to ptr");
    emit("  %cmp = call i32 @strcmp(ptr %np, ptr %name)");
    emit("  %eq = icmp eq i32 %cmp, 0");
    emit("  br i1 %eq, label %found, label %next");
    emit("found:");
    emit("  %fi = load i64, ptr %idx");
    emit("  ret i64 %fi");
    emit("next:");
    emit("  %i3 = load i64, ptr %idx");
    emit("  %i4 = add i64 %i3, 1");
    emit("  store i64 %i4, ptr %idx");
    emit("  br label %cond");
    emit("notfound:");
    emit("  ret i64 -1");
    emit("}");
    emit("");
}

// Emit integer-to-string helper (no sprintf dependency)
// arrow_itoa(i64 %val) -> ptr
fn emit_itoa_helper() {
    emit("define ptr @arrow_itoa(i64 %val) {");
    emit("entry:");
    emit("  %buf = call ptr @arena_alloc(i64 24)");
    emit("  %tmp = call ptr @arena_alloc(i64 24)");
    emit("  %pos = alloca i64");
    emit("  %cur = alloca i64");
    emit("  %wp = alloca i64");
    emit("  store i64 0, ptr %wp");
    // Handle zero
    emit("  %is_zero = icmp eq i64 %val, 0");
    emit("  br i1 %is_zero, label %zero, label %check_neg");
    emit("zero:");
    emit("  store i8 48, ptr %buf");
    emit("  %zp = getelementptr i8, ptr %buf, i64 1");
    emit("  store i8 0, ptr %zp");
    emit("  ret ptr %buf");
    // Handle negative
    emit("check_neg:");
    emit("  %is_neg = icmp slt i64 %val, 0");
    emit("  br i1 %is_neg, label %neg, label %start");
    emit("neg:");
    emit("  store i8 45, ptr %buf");
    emit("  store i64 1, ptr %wp");
    emit("  %abs = sub i64 0, %val");
    emit("  store i64 %abs, ptr %cur");
    emit("  store i64 0, ptr %pos");
    emit("  br label %dloop");
    emit("start:");
    emit("  store i64 %val, ptr %cur");
    emit("  store i64 0, ptr %pos");
    emit("  br label %dloop");
    // Extract digits into tmp (reversed)
    emit("dloop:");
    emit("  %c = load i64, ptr %cur");
    emit("  %d = srem i64 %c, 10");
    emit("  %ch = add i64 %d, 48");
    emit("  %ch8 = trunc i64 %ch to i8");
    emit("  %p = load i64, ptr %pos");
    emit("  %tp = getelementptr i8, ptr %tmp, i64 %p");
    emit("  store i8 %ch8, ptr %tp");
    emit("  %p1 = add i64 %p, 1");
    emit("  store i64 %p1, ptr %pos");
    emit("  %nc = sdiv i64 %c, 10");
    emit("  store i64 %nc, ptr %cur");
    emit("  %more = icmp sgt i64 %nc, 0");
    emit("  br i1 %more, label %dloop, label %rev");
    // Reverse copy from tmp into buf (after optional '-')
    emit("rev:");
    emit("  %len = load i64, ptr %pos");
    emit("  %ri = alloca i64");
    emit("  store i64 0, ptr %ri");
    emit("  br label %rcond");
    emit("rcond:");
    emit("  %r = load i64, ptr %ri");
    emit("  %rdone = icmp slt i64 %r, %len");
    emit("  br i1 %rdone, label %rbody, label %rend");
    emit("rbody:");
    emit("  %r2 = load i64, ptr %ri");
    emit("  %src_idx = sub i64 %len, %r2");
    emit("  %src_idx2 = sub i64 %src_idx, 1");
    emit("  %sp = getelementptr i8, ptr %tmp, i64 %src_idx2");
    emit("  %sc = load i8, ptr %sp");
    emit("  %w = load i64, ptr %wp");
    emit("  %dst_idx = add i64 %w, %r2");
    emit("  %dp = getelementptr i8, ptr %buf, i64 %dst_idx");
    emit("  store i8 %sc, ptr %dp");
    emit("  %r3 = add i64 %r2, 1");
    emit("  store i64 %r3, ptr %ri");
    emit("  br label %rcond");
    emit("rend:");
    // Null terminate
    emit("  %w2 = load i64, ptr %wp");
    emit("  %total = add i64 %w2, %len");
    emit("  %ep = getelementptr i8, ptr %buf, i64 %total");
    emit("  store i8 0, ptr %ep");
    emit("  ret ptr %buf");
    emit("}");
    emit("");
}

fn emit_for_in(nd) {
    // Compile iterable
    vt_coll <- emit_expr(nd.iterable);

    // Index variable
    idx_reg <- find_var("_for_idx");
    if (idx_reg = "") { idx_reg <- add_var("_for_idx"); }
    emit("  store i64 0, ptr " + idx_reg);

    // Loop var
    var_reg <- find_var(nd.var_name);
    if (var_reg = "") { var_reg <- add_var(nd.var_name); }

    if (vt_coll.type = "str") {
        // String iteration: iterate over characters
        sp <- fresh("%fsp");
        emit("  " + sp + " = inttoptr i64 " + vt_coll.reg + " to ptr");
        flen <- fresh("%flen");
        emit("  " + flen + " = call i64 @strlen(ptr " + sp + ")");

        lbl_cond <- fresh_lbl("fc");
        lbl_body <- fresh_lbl("fb");
        lbl_end <- fresh_lbl("fe");

        emit("  br label %" + lbl_cond);
        emit(lbl_cond + ":");
        ci2 <- fresh("%fi");
        emit("  " + ci2 + " = load i64, ptr " + idx_reg);
        cmp <- fresh("%fcmp");
        emit("  " + cmp + " = icmp slt i64 " + ci2 + ", " + flen);
        emit("  br i1 " + cmp + ", label %" + lbl_body + ", label %" + lbl_end);

        emit(lbl_body + ":");
        ci3 <- fresh("%fi2");
        emit("  " + ci3 + " = load i64, ptr " + idx_reg);

        // Extract single char as a 2-byte string [ch, 0]
        chp <- fresh("%fchp");
        chv <- fresh("%fchv");
        buf <- fresh("%fbuf");
        np <- fresh("%fnp");
        ri <- fresh("%fri");
        emit("  " + chp + " = getelementptr i8, ptr " + sp + ", i64 " + ci3);
        emit("  " + chv + " = load i8, ptr " + chp);
        emit("  " + buf + " = call ptr @arena_alloc(i64 2)");
        emit("  store i8 " + chv + ", ptr " + buf);
        emit("  " + np + " = getelementptr i8, ptr " + buf + ", i64 1");
        emit("  store i8 0, ptr " + np);
        emit("  " + ri + " = ptrtoint ptr " + buf + " to i64");
        emit("  store i64 " + ri + ", ptr " + var_reg);

        // Set loop var type to string
        set_var_type(nd.var_name, mk_str());

        emit_block(nd.body);

        // Increment
        ci4 <- fresh("%fi3");
        ci5 <- fresh("%fi4");
        emit("  " + ci4 + " = load i64, ptr " + idx_reg);
        emit("  " + ci5 + " = add i64 " + ci4 + ", 1");
        emit("  store i64 " + ci5 + ", ptr " + idx_reg);
        emit("  br label %" + lbl_cond);

        emit(lbl_end + ":");
    } else {
        // Array iteration (existing logic)
        ap <- fresh("%fap");
        flen <- fresh("%flen");
        emit("  " + ap + " = inttoptr i64 " + vt_coll.reg + " to ptr");
        emit("  " + flen + " = load i64, ptr " + ap);

        lbl_cond <- fresh_lbl("fc");
        lbl_body <- fresh_lbl("fb");
        lbl_end <- fresh_lbl("fe");

        emit("  br label %" + lbl_cond);
        emit(lbl_cond + ":");
        ci2 <- fresh("%fi");
        emit("  " + ci2 + " = load i64, ptr " + idx_reg);
        cmp <- fresh("%fcmp");
        emit("  " + cmp + " = icmp slt i64 " + ci2 + ", " + flen);
        emit("  br i1 " + cmp + ", label %" + lbl_body + ", label %" + lbl_end);

        emit(lbl_body + ":");
        ci3 <- fresh("%fi2");
        emit("  " + ci3 + " = load i64, ptr " + idx_reg);
        off <- fresh("%foff");
        ep <- fresh("%fep");
        ev <- fresh("%fev");
        emit("  " + off + " = add i64 " + ci3 + ", 2");
        emit("  " + ep + " = getelementptr i64, ptr " + ap + ", i64 " + off);
        emit("  " + ev + " = load i64, ptr " + ep);
        emit("  store i64 " + ev + ", ptr " + var_reg);

        emit_block(nd.body);

        // Increment
        ci4 <- fresh("%fi3");
        ci5 <- fresh("%fi4");
        emit("  " + ci4 + " = load i64, ptr " + idx_reg);
        emit("  " + ci5 + " = add i64 " + ci4 + ", 1");
        emit("  store i64 " + ci5 + ", ptr " + idx_reg);
        emit("  br label %" + lbl_cond);

        emit(lbl_end + ":");
    }
    return false;
}

// ── Capture detection ──────────────────
// Find variables referenced in an arrow fn body that aren't params or locally defined
// ── Type inference pass ────────────────
// Pure type computation — no IR emission. Used to populate var_types
// before emit_function runs its body, so emit_expr returns concrete
// types instead of "any" for local variables.

fn typeof_expr(nd) {
    if (nd.node = "NumberLit") { return mk_int(); }
    if (nd.node = "StringLit") { return mk_str(); }
    if (nd.node = "BoolLit") { return mk_int(); }
    if (nd.node = "Identifier") {
        return get_var_type(nd.name);
    }
    if (nd.node = "BinOp") {
        op <- nd.op;
        if (op = "&&" || op = "||") { return mk_int(); }
        lt <- typeof_expr(nd.left);
        rt <- typeof_expr(nd.right);
        if (op = "+") {
            if (lt.kind = "str" || rt.kind = "str") { return mk_str(); }
            return mk_int();
        }
        // Arithmetic or comparison — all return int
        return mk_int();
    }
    if (nd.node = "UnaryOp") { return mk_int(); }
    if (nd.node = "CallExpr") {
        if (nd.callee.node = "Identifier") {
            nm <- nd.callee.name;
            if (nm = "len") { return mk_int(); }
            if (nm = "str_len") { return mk_int(); }
            if (nm = "char_code") { return mk_int(); }
            if (nm = "char_at") { return mk_str(); }
            if (nm = "from_char_code") { return mk_str(); }
            if (nm = "substring") { return mk_str(); }
            if (nm = "input") { return mk_str(); }
            if (nm = "read_file") { return mk_str(); }
            if (nm = "write_file") { return mk_int(); }
            if (nm = "append_file") { return mk_int(); }
            if (nm = "exec_cmd") { return mk_int(); }
            if (nm = "push") { return mk_int(); }
            if (nm = "pop") {
                // Element type if known, else any
                if (len(nd.args) > 0) {
                    at <- typeof_expr(nd.args[0]);
                    if (at.kind = "array") { return at.elem; }
                }
                return mk_any();
            }
            if (nm = "keys") { return mk_array(mk_str()); }
            if (nm = "print") { return mk_int(); }
            if (nm = "args") {
                if (len(nd.args) = 0) { return mk_int(); }
                return mk_str();
            }
            fi <- find_fn(nm);
            if (fi != false) { return fi.ret_type; }
        }
        return mk_any();
    }
    if (nd.node = "ArrayLit") {
        // Empty array → unknown element type
        if (len(nd.elements) = 0) { return mk_array(mk_any()); }
        // Use the first element's type as the array's element type.
        // (No unification across mixed-type literals yet — that's a future refinement.)
        et <- typeof_expr(nd.elements[0]);
        return mk_array(et);
    }
    if (nd.node = "IndexExpr") {
        // Prefer the array's Type if we know it
        if (nd.obj.node = "Identifier") {
            ot <- get_var_type(nd.obj.name);
            if (ot.kind = "array") { return ot.elem; }
            // Fall back to the side table for arrays we set up before var_types existed
            return get_array_elem_type(nd.obj.name);
        }
        // Index into a non-Identifier (e.g. nested [[int]] subscript)
        ot <- typeof_expr(nd.obj);
        if (ot.kind = "array") { return ot.elem; }
        return mk_any();
    }
    if (nd.node = "DotExpr") {
        if (nd.obj.node = "Identifier") {
            // Prefer the struct_lit Type from var_types if present
            ot <- get_var_type(nd.obj.name);
            if (ot.kind = "struct_lit") {
                ft <- struct_field_type(ot.fields, nd.field);
                if (ft.kind != "none") { return ft; }
            }
            // Fall back to legacy struct_layouts side table
            layout <- get_struct_layout(nd.obj.name);
            if (layout != false) {
                return get_field_type(layout, nd.field);
            }
        }
        // Index into a non-Identifier (e.g. arr[0].field where arr is [{...}])
        ot <- typeof_expr(nd.obj);
        if (ot.kind = "struct_lit") {
            ft <- struct_field_type(ot.fields, nd.field);
            if (ft.kind != "none") { return ft; }
        }
        return mk_any();
    }
    if (nd.node = "StructLit") {
        // Build a struct_lit type from the literal's fields
        fs <- [];
        i <- 0;
        while (i < len(nd.fields)) {
            f <- nd.fields[i];
            push(fs, {name: f.key, type: typeof_expr(f.val)});
            i <- i + 1;
        }
        return mk_struct_lit(fs);
    }
    if (nd.node = "ArrowFn") { return mk_fn(); }
    return mk_any();
}

// Walk a body of statements, updating var_types for each assignment
fn infer_body(stmts) {
    i <- 0;
    while (i < len(stmts)) {
        s <- stmts[i];
        if (s.node = "Assignment") {
            // Use explicit type annotation if present (already a Type), otherwise infer
            if (s.type_ann.kind != "none") {
                set_var_type(s.name, s.type_ann);
            } else {
                ty <- typeof_expr(s.expr);
                set_var_type(s.name, ty);
            }
            // Track struct layouts from struct literals — store ftype as kind string
            if (s.expr.node = "StructLit") {
                layout <- [];
                j <- 0;
                while (j < len(s.expr.fields)) {
                    f <- s.expr.fields[j];
                    fty <- typeof_expr(f.val);
                    push(layout, {fname: f.key, ftype: fty.kind});
                    j <- j + 1;
                }
                set_struct_layout(s.name, layout);
            }
            // Track array element types from array literals
            if (s.expr.node = "ArrayLit") {
                j <- 0;
                while (j < len(s.expr.elements)) {
                    ety <- typeof_expr(s.expr.elements[j]);
                    if (ety.kind = "str") {
                        set_array_elem_type(s.name, "str");
                    }
                    j <- j + 1;
                }
            }
        }
        if (s.node = "IfStmt") {
            infer_body(s.then_body);
            infer_body(s.else_body);
        }
        if (s.node = "WhileStmt") { infer_body(s.body); }
        if (s.node = "ForInStmt") {
            // Loop variable: if iterable is a string, element is str char (a string)
            it_ty <- typeof_expr(s.iterable);
            if (it_ty.kind = "str") {
                set_var_type(s.var_name, mk_str());
            } else {
                // Array iteration: elem type from array
                et <- mk_any();
                if (s.iterable.node = "Identifier") {
                    et <- get_array_elem_type(s.iterable.name);
                }
                set_var_type(s.var_name, et);
            }
            infer_body(s.body);
        }
        if (s.node = "ReturnStmt") {
            if (s.expr != false) {
                rt <- typeof_expr(s.expr);
                if (current_fn[0] != "") {
                    set_fn_ret_type(current_fn[0], rt, false);
                }
            }
        }
        if (s.node = "Block") { infer_body(s.stmts); }
        i <- i + 1;
    }
}

// ═══════════════════════════════════════════
//  TYPE CHECKER
//  Compares user-written annotations against
//  inferred types. Errors are accumulated and
//  printed at the end; compilation aborts if any.
// ═══════════════════════════════════════════

type_errors <- [];
src_filename <- ["<unknown>"];

fn report_error(line: int, msg: str) {
    push(type_errors, {line: line, msg: msg});
}

// Two types are compatible when they're equal, when either is "any" or "none",
// or when either is a structural type we can't yet model precisely.
// For arrays, recurse into element types. For struct_lits, recurse into fields.
// Note: "struct" (no field info) is permissive against "struct_lit" — preserves
// backward compat with code annotated `: struct` before struct_lit existed.
fn types_compat(annot, actual): int {
    if (annot.kind = "none") { return true; }   // no annotation = no check
    if (actual.kind = "none") { return true; }
    if (annot.kind = "any") { return true; }
    if (actual.kind = "any") { return true; }
    if (annot.kind = "struct") { return true; }
    if (actual.kind = "struct") { return true; }
    if (annot.kind = "fn") { return true; }
    if (actual.kind = "fn") { return true; }
    if (annot.kind = "array" && actual.kind = "array") {
        return types_compat(annot.elem, actual.elem);
    }
    if (annot.kind = "struct_lit" && actual.kind = "struct_lit") {
        // Every field in annot must be present in actual with a compatible type.
        // (Width subtyping: actual may have extra fields. This matches typical structural
        //  typing and lets you pass a richer struct where a smaller shape is expected.)
        i <- 0;
        while (i < len(annot.fields)) {
            af <- annot.fields[i];
            bt <- struct_field_type(actual.fields, af.name);
            if (bt.kind = "none") { return false; }
            if (!types_compat(af.type, bt)) { return false; }
            i <- i + 1;
        }
        return true;
    }
    return annot.kind = actual.kind;
}

fn check_body(stmts) {
    i <- 0;
    while (i < len(stmts)) {
        check_stmt(stmts[i]);
        i <- i + 1;
    }
}

fn check_stmt(s) {
    if (s.node = "Assignment") {
        if (s.type_ann.kind != "none") {
            actual <- typeof_expr(s.expr);
            if (!types_compat(s.type_ann, actual)) {
                report_error(s.line, "type mismatch: '" + s.name + "' annotated as " + type_str(s.type_ann) + " but assigned " + type_str(actual));
            }
        }
        check_expr(s.expr);
    }
    if (s.node = "PrintStmt") { check_expr(s.expr); }
    if (s.node = "ReturnStmt") {
        if (s.expr != false) {
            check_expr(s.expr);
            if (current_fn[0] != "") {
                fi <- find_fn(current_fn[0]);
                if (fi != false) {
                    if (fi.ret_type_ann.kind != "none") {
                        actual <- typeof_expr(s.expr);
                        if (!types_compat(fi.ret_type_ann, actual)) {
                            report_error(s.line, "return type mismatch in '" + current_fn[0] + "': declared " + type_str(fi.ret_type_ann) + " but returning " + type_str(actual));
                        }
                    }
                }
            }
        }
    }
    if (s.node = "IfStmt") {
        check_expr(s.cond);
        check_body(s.then_body);
        check_body(s.else_body);
    }
    if (s.node = "WhileStmt") {
        check_expr(s.cond);
        check_body(s.body);
    }
    if (s.node = "ForInStmt") {
        check_expr(s.iterable);
        check_body(s.body);
    }
    if (s.node = "Block") { check_body(s.stmts); }
    if (s.node = "IndexAssign") {
        check_expr(s.obj);
        check_expr(s.index);
        check_expr(s.value);
    }
    if (s.node = "DotAssign") {
        check_expr(s.obj);
        check_expr(s.value);
    }
}

fn check_expr(e) {
    if (e.node = "BinOp") { check_expr(e.left); check_expr(e.right); }
    if (e.node = "UnaryOp") { check_expr(e.operand); }
    if (e.node = "CallExpr") {
        if (e.callee.node = "Identifier") {
            fi <- find_fn(e.callee.name);
            // If the direct lookup failed, the callee may be a variable holding
            // an arrow function — look up via the var-name → fn-name mapping.
            if (fi = false) {
                afn_name <- get_arrow_fn_name(e.callee.name);
                if (afn_name != "") { fi <- find_fn(afn_name); }
            }
            if (fi != false) {
                j <- 0;
                while (j < len(e.args)) {
                    if (j < fi.param_count) {
                        ann <- fi.param_types_ann[j];
                        // Only check args against EXPLICIT annotations
                        if (ann.kind != "none") {
                            actual <- typeof_expr(e.args[j]);
                            if (!types_compat(ann, actual)) {
                                report_error(e.line, "call to '" + e.callee.name + "': argument " + (j + 1) + " expected " + type_str(ann) + " but got " + type_str(actual));
                            }
                        }
                    }
                    j <- j + 1;
                }
            }
        }
        j <- 0;
        while (j < len(e.args)) { check_expr(e.args[j]); j <- j + 1; }
    }
    if (e.node = "ArrayLit") {
        j <- 0;
        while (j < len(e.elements)) { check_expr(e.elements[j]); j <- j + 1; }
    }
    if (e.node = "IndexExpr") { check_expr(e.obj); check_expr(e.index); }
    if (e.node = "DotExpr") { check_expr(e.obj); }
    if (e.node = "StructLit") {
        j <- 0;
        while (j < len(e.fields)) { check_expr(e.fields[j].val); j <- j + 1; }
    }
}

fn print_type_errors() {
    // Insertion sort by line for stable, source-order output.
    // Note: type_errors[j].line returns "any" via DotExpr, which would make
    // ">" emit strcmp. Pulling each side into a typed int local forces icmp.
    i <- 1;
    while (i < len(type_errors)) {
        j <- i;
        keep_going <- 1;
        while (j > 0 && keep_going = 1) {
            a: int <- type_errors[j - 1].line;
            b: int <- type_errors[j].line;
            if (a > b) {
                tmp <- type_errors[j - 1];
                type_errors[j - 1] <- type_errors[j];
                type_errors[j] <- tmp;
                j <- j - 1;
            } else {
                keep_going <- 0;
            }
        }
        i <- i + 1;
    }
    i <- 0;
    while (i < len(type_errors)) {
        e <- type_errors[i];
        print(src_filename[0] + ":" + e.line + ": " + e.msg);
        i <- i + 1;
    }
    if (len(type_errors) > 0) {
        print("--");
        print(len(type_errors) + " type error(s). Compilation aborted.");
    }
}


fn find_captures(body, params, is_expr: int) {
    refs <- [];
    // Collect all Identifier references via worklist
    work <- [];
    if (is_expr = false) {
        i <- 0;
        while (i < len(body)) { push(work, body[i]); i <- i + 1; }
    } else {
        push(work, body);
    }
    wi <- 0;
    while (wi < len(work)) {
        nd <- work[wi];
        wi <- wi + 1;
        if (nd.node = "Identifier") {
            if (!var_exists(refs, nd.name)) { push(refs, nd.name); }
        }
        // Walk children
        if (nd.node = "Assignment") { push(work, nd.expr); }
        if (nd.node = "PrintStmt") { push(work, nd.expr); }
        if (nd.node = "ReturnStmt") { if (nd.expr != false) { push(work, nd.expr); } }
        if (nd.node = "IfStmt") {
            push(work, nd.cond);
            i <- 0;
            while (i < len(nd.then_body)) { push(work, nd.then_body[i]); i <- i + 1; }
            i <- 0;
            while (i < len(nd.else_body)) { push(work, nd.else_body[i]); i <- i + 1; }
        }
        if (nd.node = "WhileStmt") {
            push(work, nd.cond);
            i <- 0;
            while (i < len(nd.body)) { push(work, nd.body[i]); i <- i + 1; }
        }
        if (nd.node = "ForInStmt") {
            push(work, nd.iterable);
            i <- 0;
            while (i < len(nd.body)) { push(work, nd.body[i]); i <- i + 1; }
        }
        if (nd.node = "BinOp") { push(work, nd.left); push(work, nd.right); }
        if (nd.node = "UnaryOp") { push(work, nd.operand); }
        if (nd.node = "CallExpr") {
            push(work, nd.callee);
            i <- 0;
            while (i < len(nd.args)) { push(work, nd.args[i]); i <- i + 1; }
        }
        if (nd.node = "ArrayLit") {
            i <- 0;
            while (i < len(nd.elements)) { push(work, nd.elements[i]); i <- i + 1; }
        }
        if (nd.node = "IndexExpr") { push(work, nd.obj); push(work, nd.index); }
        if (nd.node = "IndexAssign") { push(work, nd.obj); push(work, nd.index); push(work, nd.value); }
        if (nd.node = "DotExpr") { push(work, nd.obj); }
        if (nd.node = "DotAssign") { push(work, nd.obj); push(work, nd.value); }
        if (nd.node = "StructLit") {
            i <- 0;
            while (i < len(nd.fields)) { push(work, nd.fields[i].val); i <- i + 1; }
        }
    }
    // Filter: keep refs that are NOT params and ARE in current enclosing scope
    caps <- [];
    i <- 0;
    while (i < len(refs)) {
        if (!var_exists(params, refs[i])) {
            if (find_var(refs[i]) != "") {
                push(caps, refs[i]);
            }
        }
        i <- i + 1;
    }
    return caps;
}

// ── Emit arrow function ────────────────
fn emit_arrow_fn(nd) {
    // Generate unique name
    arrow_fn_counter[0] <- arrow_fn_counter[0] + 1;
    fn_name <- "__arrow_" + arrow_fn_counter[0];

    // Detect captures (before switching scope)
    captures <- find_captures(nd.body, nd.params, nd.is_expr);

    // Register as a known function (param_count does NOT include env param).
    // Pull user annotations from the AST (param_types_ann, ret_type_ann are
    // present on ArrowFn as of the parser update; each defaults to mk_none()
    // if absent). The `param_types` list tracks the working inferred type; it
    // starts from the annotation when present, else mk_any().
    pt <- [];
    pt_ann <- [];
    j <- 0;
    while (j < len(nd.params)) {
        ann <- mk_none();
        if (j < len(nd.param_types_ann)) {
            ann <- nd.param_types_ann[j];
        }
        push(pt_ann, ann);
        if (ann.kind != "none") {
            push(pt, ann);
        } else {
            push(pt, mk_any());
        }
        j <- j + 1;
    }
    rt_ann <- mk_none();
    if (nd.ret_type_ann.kind != "none") { rt_ann <- nd.ret_type_ann; }
    rt <- mk_any();
    if (rt_ann.kind != "none") { rt <- rt_ann; }
    push(declared_fns, {name: fn_name, param_count: len(nd.params), ret_type: rt, ret_fields: false, param_types: pt, param_types_ann: pt_ann, ret_type_ann: rt_ann, is_arrow_var: false});

    // Build env struct for captures (before switching emit target).
    // Also snapshot each capture's type from the outer scope so we can
    // restore it inside the closure scope (otherwise they default to "any"
    // and strings-from-capture get printed as pointers).
    env_reg <- fresh("%env");
    capture_types <- [];
    if (len(captures) > 0) {
        env_sz <- fresh("%esz");
        emit("  " + env_sz + " = mul i64 " + len(captures) + ", 8");
        emit("  " + env_reg + " = call ptr @arena_alloc(i64 " + env_sz + ")");
        // Store captured values into env
        i <- 0;
        while (i < len(captures)) {
            push(capture_types, get_var_type(captures[i]));
            cap_reg <- find_var(captures[i]);
            cv <- fresh("%ecv");
            ep <- fresh("%eep");
            emit("  " + cv + " = load i64, ptr " + cap_reg);
            emit("  " + ep + " = getelementptr i64, ptr " + env_reg + ", i64 " + i);
            emit("  store i64 " + cv + ", ptr " + ep);
            i <- i + 1;
        }
    }

    // Switch to deferred emit buffer
    emit_target[0] <- 1;

    // Save compilation state
    old_vars <- alloc_vars[0];
    old_types <- var_types[0];
    old_layouts <- struct_layouts[0];
    old_arr_types <- array_elem_types[0];
    old_fn <- current_fn[0];
    alloc_vars[0] <- [];
    var_types[0] <- [];
    struct_layouts[0] <- [];
    array_elem_types[0] <- [];
    current_fn[0] <- fn_name;

    // Build param list (env is first param, then user params)
    params_str <- "i64 %env.arg";
    i <- 0;
    while (i < len(nd.params)) {
        params_str <- params_str + ", i64 %" + nd.params[i] + ".arg";
        i <- i + 1;
    }

    emit("define i64 @" + fn_name + "(" + params_str + ") {");
    emit("entry:");

    // Collect and alloca variables
    if (nd.is_expr = false) {
        vars <- [];
        collect_vars(nd.body, vars);
        i <- 0;
        while (i < len(nd.params)) {
            if (!var_exists(vars, nd.params[i])) { push(vars, nd.params[i]); }
            i <- i + 1;
        }
        // Add captured vars as local allocas too
        i <- 0;
        while (i < len(captures)) {
            if (!var_exists(vars, captures[i])) { push(vars, captures[i]); }
            i <- i + 1;
        }
        i <- 0;
        while (i < len(vars)) {
            reg <- "%" + vars[i];
            push(alloc_vars[0], {name: vars[i], reg: reg});
            emit("  " + reg + " = alloca i64");
            i <- i + 1;
        }
    } else {
        // Expression body — alloca params + captures
        i <- 0;
        while (i < len(nd.params)) {
            reg <- "%" + nd.params[i];
            push(alloc_vars[0], {name: nd.params[i], reg: reg});
            emit("  " + reg + " = alloca i64");
            i <- i + 1;
        }
        i <- 0;
        while (i < len(captures)) {
            reg <- "%" + captures[i];
            push(alloc_vars[0], {name: captures[i], reg: reg});
            emit("  " + reg + " = alloca i64");
            i <- i + 1;
        }
    }
    push(alloc_vars[0], {name: "_for_idx", reg: "%_for_idx"});
    emit("  %_for_idx = alloca i64");

    // Store params into allocas
    i <- 0;
    while (i < len(nd.params)) {
        emit("  store i64 %" + nd.params[i] + ".arg, ptr %" + nd.params[i]);
        set_var_type(nd.params[i], mk_any());
        i <- i + 1;
    }

    // Load captured variables from env
    if (len(captures) > 0) {
        emit("  %env_ptr = inttoptr i64 %env.arg to ptr");
        i <- 0;
        while (i < len(captures)) {
            cep <- fresh("%cep");
            cval <- fresh("%cval");
            emit("  " + cep + " = getelementptr i64, ptr %env_ptr, i64 " + i);
            emit("  " + cval + " = load i64, ptr " + cep);
            emit("  store i64 " + cval + ", ptr %" + captures[i]);
            // Preserve type from enclosing scope (snapshotted before the scope
            // switch). Falls back to mk_any() when the outer scope didn't have
            // a type for the var (shouldn't normally happen for a valid capture).
            ct <- mk_any();
            if (i < len(capture_types)) { ct <- capture_types[i]; }
            if (ct.kind = "none") { ct <- mk_any(); }
            set_var_type(captures[i], ct);
            i <- i + 1;
        }
    }

    // Emit body
    if (nd.is_expr = false) {
        // Run type inference on body to populate var_types
        infer_body(nd.body);
        emit_block(nd.body);
        emit("  ret i64 0");
    } else {
        vt <- emit_expr(nd.body);
        emit("  ret i64 " + vt.reg);
        set_fn_ret_type(fn_name, parse_type_ann(vt.type), vt.fields);
    }

    emit("}");
    emit("");

    // Restore state
    alloc_vars[0] <- old_vars;
    var_types[0] <- old_types;
    struct_layouts[0] <- old_layouts;
    array_elem_types[0] <- old_arr_types;
    current_fn[0] <- old_fn;

    // Switch back to normal emit
    emit_target[0] <- 0;

    // Build closure pair: [fn_ptr, env_ptr]
    pair <- fresh("%cpair");
    emit("  " + pair + " = call ptr @arena_alloc(i64 16)");
    fn_as_i64 <- fresh("%cfn");
    emit("  " + fn_as_i64 + " = ptrtoint ptr @" + fn_name + " to i64");
    emit("  store i64 " + fn_as_i64 + ", ptr " + pair);
    env_slot <- fresh("%cesl");
    emit("  " + env_slot + " = getelementptr i64, ptr " + pair + ", i64 1");
    if (len(captures) > 0) {
        env_as_i64 <- fresh("%cei");
        emit("  " + env_as_i64 + " = ptrtoint ptr " + env_reg + " to i64");
        emit("  store i64 " + env_as_i64 + ", ptr " + env_slot);
    } else {
        emit("  store i64 0, ptr " + env_slot);
    }
    pair_as_i64 <- fresh("%cpi");
    emit("  " + pair_as_i64 + " = ptrtoint ptr " + pair + " to i64");
    return {reg: pair_as_i64, type: "fn", fields: fn_name};
}

// ── Emit function ───────────────────────

fn emit_function(nd) {
    // Build param list
    params_str <- "";
    i <- 0;
    while (i < len(nd.params)) {
        if (i > 0) { params_str <- params_str + ", "; }
        params_str <- params_str + "i64 %" + nd.params[i] + ".arg";
        i <- i + 1;
    }

    emit("define i64 @" + nd.name + "(" + params_str + ") {");
    emit("entry:");

    // Save old vars and types, start fresh for this function
    old_vars <- alloc_vars[0];
    old_types <- var_types[0];
    old_layouts <- struct_layouts[0];
    old_arr_types <- array_elem_types[0];
    alloc_vars[0] <- [];
    var_types[0] <- [];
    struct_layouts[0] <- [];
    array_elem_types[0] <- [];
    old_fn <- current_fn[0];
    current_fn[0] <- nd.name;

    // Collect all variables used in body
    vars <- [];
    collect_vars(nd.body, vars);

    // Add params as vars
    i <- 0;
    while (i < len(nd.params)) {
        if (!var_exists(vars, nd.params[i])) {
            push(vars, nd.params[i]);
        }
        i <- i + 1;
    }

    // Alloca all variables
    i <- 0;
    while (i < len(vars)) {
        reg <- "%" + vars[i];
        push(alloc_vars[0], {name: vars[i], reg: reg});
        emit("  " + reg + " = alloca i64");
        i <- i + 1;
    }

    // Also alloca _for_idx if any for-in loops
    push(alloc_vars[0], {name: "_for_idx", reg: "%_for_idx"});
    emit("  %_for_idx = alloca i64");

    // Store params into allocas with types from call-site analysis
    fi_info <- find_fn(nd.name);
    i <- 0;
    while (i < len(nd.params)) {
        emit("  store i64 %" + nd.params[i] + ".arg, ptr %" + nd.params[i]);
        if (fi_info != false && i < len(fi_info.param_types)) {
            set_var_type(nd.params[i], fi_info.param_types[i]);
        } else {
            set_var_type(nd.params[i], mk_any());
        }
        i <- i + 1;
    }

    // Run type inference on body to populate var_types before emission
    infer_body(nd.body);

    // Run type checker against user annotations
    check_body(nd.body);

    // Emit body
    emit_block(nd.body);

    // Default return
    emit("  ret i64 0");
    emit("}");
    emit("");

    // Restore vars and types
    alloc_vars[0] <- old_vars;
    var_types[0] <- old_types;
    struct_layouts[0] <- old_layouts;
    array_elem_types[0] <- old_arr_types;
    current_fn[0] <- old_fn;
}

// ── Emit arena allocator helper ─────────

fn emit_arena_helper() {
    emit("@arena_base = global ptr null");
    emit("@arena_offset = global i64 0");
    emit("@arena_cap = global i64 0");
    emit("");
    emit("define void @arena_init(i64 %size) {");
    emit("entry:");
    emit("  %p = call ptr @malloc(i64 %size)");
    emit("  store ptr %p, ptr @arena_base");
    emit("  store i64 0, ptr @arena_offset");
    emit("  store i64 %size, ptr @arena_cap");
    emit("  ret void");
    emit("}");
    emit("");
    emit("define ptr @arena_alloc(i64 %size) {");
    emit("entry:");
    emit("  %off = load i64, ptr @arena_offset");
    emit("  %cap = load i64, ptr @arena_cap");
    emit("  %s1 = add i64 %size, 7");
    emit("  %aligned = and i64 %s1, -8");
    emit("  %new_off = add i64 %off, %aligned");
    emit("  %fits = icmp sle i64 %new_off, %cap");
    emit("  br i1 %fits, label %bump, label %fallback");
    emit("fallback:");
    emit("  %fb = call ptr @malloc(i64 %aligned)");
    emit("  ret ptr %fb");
    emit("bump:");
    emit("  %base = load ptr, ptr @arena_base");
    emit("  %ptr = getelementptr i8, ptr %base, i64 %off");
    emit("  store i64 %new_off, ptr @arena_offset");
    emit("  ret ptr %ptr");
    emit("}");
    emit("");
}

// ── Emit safe strcmp helper ─────────────
// Handles "any" type comparisons safely: if either value looks like
// a small integer (< 1MB), use pointer/integer comparison.
// Otherwise, treat as string pointers and use strcmp.
fn emit_safe_strcmp_helper() {
    emit("define i32 @arrow_safe_strcmp(ptr %a, ptr %b) {");
    emit("entry:");
    emit("  %ai = ptrtoint ptr %a to i64");
    emit("  %bi = ptrtoint ptr %b to i64");
    emit("  %a_small = icmp ult i64 %ai, 1048576");
    emit("  %b_small = icmp ult i64 %bi, 1048576");
    emit("  %either_small = or i1 %a_small, %b_small");
    emit("  br i1 %either_small, label %intcmp, label %strcmp");
    emit("strcmp:");
    emit("  %sr = call i32 @strcmp(ptr %a, ptr %b)");
    emit("  ret i32 %sr");
    emit("intcmp:");
    emit("  %eq = icmp eq i64 %ai, %bi");
    emit("  %ir = select i1 %eq, i32 0, i32 1");
    emit("  ret i32 %ir");
    emit("}");
    emit("");

    // arrow_to_str: runtime conversion of "any" value to string pointer
    // If value < 1MB, it's an integer → convert via itoa
    // Otherwise, it's already a string pointer → use as-is
    emit("define ptr @arrow_to_str(i64 %val) {");
    emit("entry:");
    emit("  %small = icmp ult i64 %val, 1048576");
    emit("  br i1 %small, label %do_itoa, label %use_ptr");
    emit("do_itoa:");
    emit("  %s = call ptr @arrow_itoa(i64 %val)");
    emit("  ret ptr %s");
    emit("use_ptr:");
    emit("  %p = inttoptr i64 %val to ptr");
    emit("  ret ptr %p");
    emit("}");
    emit("");
}

// ── Emit push helper ────────────────────

fn emit_push_helper() {
    // arrow_push returns the (possibly reallocated) array pointer as i64
    emit("define i64 @arrow_push(i64 %arr.i, i64 %val) {");
    emit("entry:");
    emit("  %arr = inttoptr i64 %arr.i to ptr");
    emit("  %lenp = getelementptr i64, ptr %arr, i64 0");
    emit("  %len = load i64, ptr %lenp");
    emit("  %capp = getelementptr i64, ptr %arr, i64 1");
    emit("  %cap = load i64, ptr %capp");
    // Check if we need to grow
    emit("  %full = icmp sge i64 %len, %cap");
    emit("  br i1 %full, label %grow, label %store");
    emit("grow:");
    // Double capacity, realloc entire block
    emit("  %newcap = mul i64 %cap, 2");
    emit("  %newtotal = add i64 %newcap, 2");
    emit("  %newbytes = mul i64 %newtotal, 8");
    emit("  %newptr = call ptr @realloc(ptr %arr, i64 %newbytes)");
    // Update cap
    emit("  %ncapp = getelementptr i64, ptr %newptr, i64 1");
    emit("  store i64 %newcap, ptr %ncapp");
    // Store element
    emit("  %nlenp = getelementptr i64, ptr %newptr, i64 0");
    emit("  %nlen = load i64, ptr %nlenp");
    emit("  %noff = add i64 %nlen, 2");
    emit("  %nep = getelementptr i64, ptr %newptr, i64 %noff");
    emit("  store i64 %val, ptr %nep");
    emit("  %nlen2 = add i64 %nlen, 1");
    emit("  store i64 %nlen2, ptr %nlenp");
    emit("  %ri = ptrtoint ptr %newptr to i64");
    emit("  ret i64 %ri");
    emit("store:");
    emit("  %off = add i64 %len, 2");
    emit("  %ep = getelementptr i64, ptr %arr, i64 %off");
    emit("  store i64 %val, ptr %ep");
    emit("  %nlen3 = add i64 %len, 1");
    emit("  store i64 %nlen3, ptr %lenp");
    emit("  ret i64 %arr.i");
    emit("}");
    emit("");
}

// ── Emit pop helper ─────────────────────

fn emit_pop_helper() {
    // arrow_pop(arr) -> element at index len-1; decrements len in place.
    // On empty array: prints "Error: pop from empty array" and exits(1).
    emit("@.str.pop_empty = private constant [29 x i8] c\"Error: pop from empty array\\0A\\00\"");
    emit("define i64 @arrow_pop(i64 %arr.i) {");
    emit("entry:");
    emit("  %arr = inttoptr i64 %arr.i to ptr");
    emit("  %lenp = getelementptr i64, ptr %arr, i64 0");
    emit("  %len = load i64, ptr %lenp");
    emit("  %empty = icmp sle i64 %len, 0");
    emit("  br i1 %empty, label %fail, label %ok");
    emit("fail:");
    emit("  call i32 @printf(ptr @.str.pop_empty)");
    emit("  call void @exit(i32 1)");
    emit("  unreachable");
    emit("ok:");
    emit("  %newlen = sub i64 %len, 1");
    emit("  %off = add i64 %newlen, 2");
    emit("  %ep = getelementptr i64, ptr %arr, i64 %off");
    emit("  %val = load i64, ptr %ep");
    emit("  store i64 %newlen, ptr %lenp");
    emit("  ret i64 %val");
    emit("}");
    emit("");
}

// ── Emit keys helper ────────────────────
//
// arrow_keys(struct_ptr) returns a new [str] of the struct's field names.
// Struct layout (see emit_struct_lit):
//   slot 0      : count n
//   slots 1..n  : values
//   slots n+1.. : name pointers (as i64)
// Output array layout (see emit_array_lit):
//   slot 0      : len
//   slot 1      : cap
//   slots 2..   : elements
fn emit_keys_helper() {
    emit("define i64 @arrow_keys(i64 %s.i) {");
    emit("entry:");
    emit("  %s = inttoptr i64 %s.i to ptr");
    emit("  %np = getelementptr i64, ptr %s, i64 0");
    emit("  %n = load i64, ptr %np");
    // Allocate the result array. Same sizing rule as emit_array_lit: cap=max(n,4096).
    emit("  %cap1 = icmp slt i64 %n, 4096");
    emit("  %cap = select i1 %cap1, i64 4096, i64 %n");
    emit("  %total = add i64 %cap, 2");
    emit("  %bytes = mul i64 %total, 8");
    emit("  %arr = call ptr @malloc(i64 %bytes)");
    emit("  store i64 %n, ptr %arr");
    emit("  %capp = getelementptr i64, ptr %arr, i64 1");
    emit("  store i64 %cap, ptr %capp");
    // Copy name pointers from struct slots [n+1 .. 2n] into array slots [2 .. n+1].
    emit("  br label %loop_cond");
    emit("loop_cond:");
    emit("  %i = phi i64 [0, %entry], [%i_next, %loop_body]");
    emit("  %done = icmp sge i64 %i, %n");
    emit("  br i1 %done, label %exit, label %loop_body");
    emit("loop_body:");
    emit("  %src_off = add i64 %i, %n");
    emit("  %src_off1 = add i64 %src_off, 1");
    emit("  %src_p = getelementptr i64, ptr %s, i64 %src_off1");
    emit("  %name = load i64, ptr %src_p");
    emit("  %dst_off = add i64 %i, 2");
    emit("  %dst_p = getelementptr i64, ptr %arr, i64 %dst_off");
    emit("  store i64 %name, ptr %dst_p");
    emit("  %i_next = add i64 %i, 1");
    emit("  br label %loop_cond");
    emit("exit:");
    emit("  %ri = ptrtoint ptr %arr to i64");
    emit("  ret i64 %ri");
    emit("}");
    emit("");
}

// ── Emit read_file helper ───────────────

fn emit_read_file_helper() {
    emit("define ptr @arrow_read_file(ptr %path) {");
    emit("entry:");
    emit("  %fp = call ptr @fopen(ptr %path, ptr @.str.rb)");
    emit("  %fpv = ptrtoint ptr %fp to i64");
    emit("  %is_null = icmp eq i64 %fpv, 0");
    emit("  br i1 %is_null, label %fail, label %ok");
    emit("fail:");
    emit("  %empty = call ptr @arena_alloc(i64 1)");
    emit("  store i8 0, ptr %empty");
    emit("  ret ptr %empty");
    emit("ok:");
    emit("  call i32 @fseek(ptr %fp, i64 0, i32 2)");
    emit("  %size = call i64 @ftell(ptr %fp)");
    emit("  call i32 @fseek(ptr %fp, i64 0, i32 0)");
    emit("  %bufsz = add i64 %size, 1");
    emit("  %buf = call ptr @malloc(i64 %bufsz)");
    emit("  call i64 @fread(ptr %buf, i64 1, i64 %size, ptr %fp)");
    emit("  %endp = getelementptr i8, ptr %buf, i64 %size");
    emit("  store i8 0, ptr %endp");
    emit("  call i32 @fclose(ptr %fp)");
    emit("  ret ptr %buf");
    emit("}");
    emit("");
}

// ── Emit write_file helper ──────────────

fn emit_write_file_helper() {
    emit("define i64 @arrow_write_file(ptr %path, ptr %content) {");
    emit("entry:");
    emit("  %fp = call ptr @fopen(ptr %path, ptr @.str.wb)");
    emit("  %fpv = ptrtoint ptr %fp to i64");
    emit("  %is_null = icmp eq i64 %fpv, 0");
    emit("  br i1 %is_null, label %fail, label %ok");
    emit("fail:");
    emit("  ret i64 0");
    emit("ok:");
    emit("  %slen = call i64 @strlen(ptr %content)");
    emit("  %written = call i64 @fwrite(ptr %content, i64 1, i64 %slen, ptr %fp)");
    emit("  call i32 @fclose(ptr %fp)");
    emit("  ret i64 %written");
    emit("}");
    emit("");
}

fn emit_append_file_helper() {
    emit("define i64 @arrow_append_file(ptr %path, ptr %content) {");
    emit("entry:");
    emit("  %fp = call ptr @fopen(ptr %path, ptr @.str.ab)");
    emit("  %fpv = ptrtoint ptr %fp to i64");
    emit("  %is_null = icmp eq i64 %fpv, 0");
    emit("  br i1 %is_null, label %fail, label %ok");
    emit("fail:");
    emit("  ret i64 0");
    emit("ok:");
    emit("  %slen = call i64 @strlen(ptr %content)");
    emit("  %written = call i64 @fwrite(ptr %content, i64 1, i64 %slen, ptr %fp)");
    emit("  call i32 @fclose(ptr %fp)");
    emit("  ret i64 %written");
    emit("}");
    emit("");
}

// ── Emit input helper ───────────────────

fn emit_input_helper() {
    emit("define ptr @arrow_input() {");
    emit("entry:");
    emit("  %buf = call ptr @malloc(i64 4096)");
    if (is_win[0] = 1) {
        emit("  %stdin = call ptr @__acrt_iob_func(i32 0)");
    } else if (is_mac[0] = 1) {
        // macOS exposes stdio as __stdinp / __stdoutp / __stderrp.
        emit("  %stdin = load ptr, ptr @__stdinp");
    } else {
        emit("  %stdin = load ptr, ptr @stdin");
    }
    emit("  %result = call ptr @fgets(ptr %buf, i32 4096, ptr %stdin)");
    emit("  %slen = call i64 @strlen(ptr %buf)");
    emit("  %has = icmp sgt i64 %slen, 0");
    emit("  br i1 %has, label %strip, label %done");
    emit("strip:");
    emit("  %li = sub i64 %slen, 1");
    emit("  %lp = getelementptr i8, ptr %buf, i64 %li");
    emit("  %lc = load i8, ptr %lp");
    emit("  %is_nl = icmp eq i8 %lc, 10");
    emit("  %nv = select i1 %is_nl, i8 0, i8 %lc");
    emit("  store i8 %nv, ptr %lp");
    emit("  br label %done");
    emit("done:");
    emit("  ret ptr %buf");
    emit("}");
    emit("");
}

// ── Main compilation ────────────────────

fn compile(stmts) {
    // Preamble
    emit("; Arrow Lang -- compiled by self-hosted compiler");
    emit("");

    // External declarations
    emit("declare i32 @printf(ptr, ...)");
    emit("declare i32 @puts(ptr)");
    emit("declare i32 @fflush(ptr)");
    emit("declare ptr @malloc(i64)");
    emit("declare ptr @realloc(ptr, i64)");
    emit("declare void @free(ptr)");
    emit("declare i64 @strlen(ptr)");
    emit("declare ptr @strcpy(ptr, ptr)");
    emit("declare ptr @strcat(ptr, ptr)");
    emit("declare i32 @strcmp(ptr, ptr)");
    emit("declare i32 @system(ptr)");
    emit("declare void @exit(i32)");
    emit("declare ptr @fopen(ptr, ptr)");
    emit("declare i32 @fclose(ptr)");
    emit("declare i64 @fread(ptr, i64, i64, ptr)");
    emit("declare i64 @fwrite(ptr, i64, i64, ptr)");
    emit("declare i32 @fseek(ptr, i64, i32)");
    emit("declare i64 @ftell(ptr)");
    emit("declare ptr @fgets(ptr, i32, ptr)");
    if (is_win[0] = 1) {
        emit("declare ptr @__acrt_iob_func(i32)");
    } else if (is_mac[0] = 1) {
        emit("@__stdinp = external global ptr");
    } else {
        emit("@stdin = external global ptr");
    }
    emit("");


    // Pre-scan functions
    scan_fns(stmts);


    // Scan call sites to infer parameter types
    scan_call_sites(stmts);


    // Pre-scan top-level variables → emit as globals
    i <- 0;
    while (i < len(stmts)) {
        if (stmts[i].node != "FnDecl") {
            scan_globals(stmts[i]);
        }
        i <- i + 1;
    }


    // Emit global variable declarations
    i <- 0;
    while (i < len(global_vars)) {
        emit("@g_" + global_vars[i] + " = global i64 0");
        i <- i + 1;
    }
    emit("");


    // Emit user functions first
    i <- 0;
    while (i < len(stmts)) {
        if (stmts[i].node = "FnDecl") {
            emit_function(stmts[i]);
        }
        i <- i + 1;
    }


    // Emit helpers
    emit_arena_helper();
    emit_safe_strcmp_helper();
    emit_push_helper();
    emit_pop_helper();
    emit_keys_helper();
    emit_struct_find_helper();
    emit_itoa_helper();
    emit_read_file_helper();
    emit_write_file_helper();
    emit_append_file_helper();
    emit_input_helper();

    // Emit main with argc/argv for command line arg support
    emit("@g_argc = global i64 0");
    emit("@g_argv = global i64 0");
    emit("define i64 @main(i32 %argc, ptr %argv) {");
    emit("entry:");
    // Store argc and argv as globals
    emit("  %argc64 = sext i32 %argc to i64");
    emit("  store i64 %argc64, ptr @g_argc");
    emit("  %argv64 = ptrtoint ptr %argv to i64");
    emit("  store i64 %argv64, ptr @g_argv");
    emit("  call void @arena_init(i64 268435456)");


    // Collect all top-level vars
    vars <- [];
    top_stmts <- [];
    i <- 0;
    while (i < len(stmts)) {
        if (stmts[i].node != "FnDecl") {
            push(top_stmts, stmts[i]);
        }
        i <- i + 1;
    }
    collect_vars(top_stmts, vars);


    // Alloca all (skip globals — they're already emitted)
    alloc_vars[0] <- [];
    var_types[0] <- [];
    struct_layouts[0] <- [];
    array_elem_types[0] <- [];
    j <- 0;
    while (j < len(vars)) {
        if (!is_global(vars[j])) {
            reg <- "%" + vars[j];
            push(alloc_vars[0], {name: vars[j], reg: reg});
            emit("  " + reg + " = alloca i64");
        }
        j <- j + 1;
    }
    push(alloc_vars[0], {name: "_for_idx", reg: "%_for_idx"});
    emit("  %_for_idx = alloca i64");


    // Run type inference on top-level statements to populate var_types
    current_fn[0] <- "";
    infer_body(top_stmts);

    // Run type checker on top-level
    check_body(top_stmts);

    // Emit top-level statements (skip fn decls)
    i <- 0;
    while (i < len(stmts)) {
        if (stmts[i].node != "FnDecl") {
            emit_stmt(stmts[i]);
        }
        i <- i + 1;
    }


    emit("  ret i64 0");
    emit("}");
    emit("");

    // Emit deferred arrow functions
    i <- 0;
    while (i < len(deferred_ir)) {
        if (str_len(deferred_ir[i]) > 0) {
            push(ir_lines, deferred_ir[i]);
        }
        i <- i + 1;
    }

    // Emit string constants
    // Format string for integers (with newline)
    emit("@fmt_int = private constant [6 x i8] c\"%lld\\0A\\00\"");
    // File mode strings
    emit("@.str.rb = private constant [3 x i8] c\"rb\\00\"");
    emit("@.str.wb = private constant [3 x i8] c\"wb\\00\"");
    emit("@.str.ab = private constant [3 x i8] c\"ab\\00\"");

    i <- 0;
    while (i < len(str_constants)) {
        sc <- str_constants[i];
        escaped <- ir_escape(sc.text);
        slen <- ir_str_len(sc.text);
        emit("@" + sc.id + " = private constant [" + slen + " x i8] c\"" + escaped + "\\00\"");
        i <- i + 1;
    }
}


// ═══════════════════════════════════════════
//  MAIN — Read, lex, parse, compile, write, run clang
// ═══════════════════════════════════════════

// Detect platform: try "cmd /c exit 0" which only works on Windows; otherwise
// check whether `uname -s` reports Darwin to identify macOS (which has its own
// stdio symbol naming — __stdinp instead of stdin).
is_win[0] <- 0;
is_mac[0] <- 0;
rc_detect <- exec_cmd("cmd /c exit 0 2>nul");
if (rc_detect = 0) {
    is_win[0] <- 1;
} else {
    // Clean up "nul" file created by redirect on Unix
    exec_cmd("rm -f nul 2>/dev/null");
    // Probe for macOS via uname; redirect output to a temp file so we don't
    // pollute stdout, then read it back.
    exec_cmd("uname -s > /tmp/.arrow_uname 2>/dev/null");
    uname_out <- read_file("/tmp/.arrow_uname");
    if (str_len(uname_out) >= 6) {
        if (substring(uname_out, 0, 6) = "Darwin") {
            is_mac[0] <- 1;
        }
    }
    exec_cmd("rm -f /tmp/.arrow_uname 2>/dev/null");
}

if (args() < 1) {
    print("Usage: arrow <file.arrow> [-o output]");
    print("  Compiles Arrow Lang source to a native executable.");
}

// Phase-1 IR acceptance: build a tiny module by hand, render, print.
// Invoked as `arrow --ir-test`. The dispatch lives at the very end of the
// file so that all ir_* helper fns have been declared by lang.py's linear
// execution before run_ir_test is called.
fn run_ir_test() {
    m <- ir_module();
    f <- ir_function("add_one", [{name: "x", type: mk_int()}], mk_int());
    bb <- ir_block("entry");
    x_slot <- ir_reg("%x", mk_int());
    ir_push_inst(bb, ii_alloca("%x", mk_int()));
    x_arg <- ir_reg("%x.arg", mk_int());
    ir_push_inst(bb, ii_store(x_arg, x_slot));
    ld <- ir_reg("%ld", mk_int());
    ir_push_inst(bb, ii_load("%ld", mk_int(), x_slot));
    res <- ir_reg("%res", mk_int());
    ir_push_inst(bb, ii_add("%res", ld, ir_const_int(1)));
    ir_set_terminator(bb, ii_ret(res));
    ir_fn_add_block(f, bb);
    ir_mod_add_function(m, f);
    ir_mod_add_str(m, "hello");
    ir_mod_add_global(m, "counter", mk_int());
    ir_mod_add_extern(m, "printf", [mk_any()], mk_int(), 1);
    print(ir_render_module(m));
}

// Phase-2 IR acceptance: hand-build is_digit via IR, render it plus a main
// that exercises it. The output is a self-contained LLVM module that can
// be fed to clang. Same IR shape as the existing emitter in principle;
// register names may differ but semantics are equivalent.
fn build_is_digit_ir() {
    f <- ir_function("is_digit", [{name: "c", type: mk_int()}], mk_int());

    // entry: set up c's slot, allocate and zero out the && result slot,
    // evaluate the LHS (c >= 48), branch on truthiness.
    b0 <- ir_block("entry");
    ir_push_inst(b0, ii_alloca("%c", mk_int()));
    ir_push_inst(b0, ii_store(ir_reg("%c.arg", mk_int()), ir_reg("%c", mk_int())));
    ir_push_inst(b0, ii_alloca("%and_res", mk_int()));
    ir_push_inst(b0, ii_store(ir_const_int(0), ir_reg("%and_res", mk_int())));
    ir_push_inst(b0, ii_load("%ld1", mk_int(), ir_reg("%c", mk_int())));
    ir_push_inst(b0, ii_icmp("%cmp1", "sge", ir_reg("%ld1", mk_int()), ir_const_int(48)));
    ir_set_terminator(b0, ii_cond_br("%br1", ir_reg("%cmp1", mk_int()), "and_r1", "and_e2"));
    ir_fn_add_block(f, b0);

    // and_r1: the LHS was true, evaluate the RHS (c <= 57) and store it.
    b1 <- ir_block("and_r1");
    ir_push_inst(b1, ii_load("%ld2", mk_int(), ir_reg("%c", mk_int())));
    ir_push_inst(b1, ii_icmp("%cmp2", "sle", ir_reg("%ld2", mk_int()), ir_const_int(57)));
    ir_push_inst(b1, ii_store(ir_reg("%cmp2", mk_int()), ir_reg("%and_res", mk_int())));
    ir_set_terminator(b1, ii_br("and_e2"));
    ir_fn_add_block(f, b1);

    // and_e2: load the joined result and return it.
    b2 <- ir_block("and_e2");
    ir_push_inst(b2, ii_load("%result", mk_int(), ir_reg("%and_res", mk_int())));
    ir_set_terminator(b2, ii_ret(ir_reg("%result", mk_int())));
    ir_fn_add_block(f, b2);

    return f;
}

fn run_ir_is_digit() {
    m <- ir_module();
    ir_mod_add_function(m, build_is_digit_ir());

    // Append a main that calls is_digit with several inputs and prints results.
    main <- ir_function("main", [], mk_int());
    mb <- ir_block("entry");
    // Test 48 ('0'): expect 1
    ir_push_inst(mb, ii_call("%r1", mk_int(), "is_digit", [ir_const_int(48)]));
    ir_push_inst(mb, ii_call("%p1", mk_int(), "printf", [ir_const_str_raw("fmt"), ir_reg("%r1", mk_int())]));
    // Test 47 ('/'): expect 0
    ir_push_inst(mb, ii_call("%r2", mk_int(), "is_digit", [ir_const_int(47)]));
    ir_push_inst(mb, ii_call("%p2", mk_int(), "printf", [ir_const_str_raw("fmt"), ir_reg("%r2", mk_int())]));
    // Test 57 ('9'): expect 1
    ir_push_inst(mb, ii_call("%r3", mk_int(), "is_digit", [ir_const_int(57)]));
    ir_push_inst(mb, ii_call("%p3", mk_int(), "printf", [ir_const_str_raw("fmt"), ir_reg("%r3", mk_int())]));
    // Test 58 (':'): expect 0
    ir_push_inst(mb, ii_call("%r4", mk_int(), "is_digit", [ir_const_int(58)]));
    ir_push_inst(mb, ii_call("%p4", mk_int(), "printf", [ir_const_str_raw("fmt"), ir_reg("%r4", mk_int())]));
    ir_set_terminator(mb, ii_ret(ir_const_int(0)));
    ir_fn_add_block(main, mb);
    ir_mod_add_function(m, main);

    ir_mod_add_str_raw(m, "fmt", "%lld\n");
    ir_mod_add_extern(m, "printf", [mk_any()], mk_int(), 1);

    print(ir_render_module(m));
}

ir_test_mode <- [false];
if (args() > 0) {
    if (args(0) = "--ir-test") {
        ir_test_mode[0] <- true;
        // Call site moved to end-of-file. Setting the flag here is enough
        // to skip the real compile below.
    }
    if (args(0) = "--ir-is-digit") {
        ir_test_mode[0] <- true;
    }
    if (args(0) = "--ir-from-ast") {
        ir_test_mode[0] <- true;
    }
}

if (args() > 0 && !ir_test_mode[0]) {
    input_file <- args(0);

    // Parse -o flag
    out_name <- "";
    if (args() > 2) {
        if (args(1) = "-o") {
            out_name <- args(2);
        }
    }

    // Derive base name from input: foo.arrow -> foo
    base_name <- input_file;
    if (str_len(input_file) > 6) {
        suffix <- substring(input_file, str_len(input_file) - 6, str_len(input_file));
        if (suffix = ".arrow") {
            base_name <- substring(input_file, 0, str_len(input_file) - 6);
        }
    }

    // Set output filenames (platform-dependent extension)
    if (out_name != "") {
        exe_file <- out_name;
        ll_base <- out_name;
        // Strip .exe if present
        if (str_len(out_name) > 4) {
            ext <- substring(out_name, str_len(out_name) - 4, str_len(out_name));
            if (ext = ".exe") {
                ll_base <- substring(out_name, 0, str_len(out_name) - 4);
            }
        }
        ll_file <- ll_base + ".ll";
    } else {
        ll_file <- base_name + ".ll";
        if (is_win[0] = 1) {
            exe_file <- base_name + ".exe";
        } else {
            exe_file <- base_name;
        }
    }

    source <- read_file(input_file);

    toks <- tokenize(source);
    pos[0] <- 0;
    ast <- pp();
    src_filename[0] <- input_file;
    compile(ast);

    if (len(type_errors) > 0) {
        print_type_errors();
    } else {
        write_ir_lines(ll_file);

        // Build clang command (platform-dependent flags)
        if (is_win[0] = 1) {
            clang_cmd <- "clang " + ll_file + " -o " + exe_file + " -O2 -Wno-override-module -Xlinker /STACK:67108864";
        } else {
            clang_cmd <- "clang " + ll_file + " -o " + exe_file + " -O2 -Wno-override-module";
        }
        rc <- exec_cmd(clang_cmd);
        if (rc = 0) {
            print("Compiled " + exe_file + " successfully!");
            // Clean up .ll file (platform-dependent delete command)
            if (is_win[0] = 1) {
                exec_cmd("del " + ll_file);
            } else {
                exec_cmd("rm " + ll_file);
            }
        } else {
            print("Clang failed with exit code " + rc);
            print("IR written to " + ll_file);
        }
    }
}

// ═══════════════════════════════════════════
//  ARROW IR (Phase 1 — data structures & renderer)
//
//  Purpose: sit alongside the existing string-emitting codegen. Nothing in
//  this section is wired into emit_* yet. Phase 2 will migrate one function
//  through this pipeline as proof-of-concept.
//
//  Shapes (all are plain Arrow structs):
//
//    Value =
//      { kind: "reg",        name: str,  type: Type }   // %name
//      { kind: "const_int",  val: int,   type: Type }   // literal integer
//      { kind: "const_str",  id: str,    type: Type }   // @strN (pooled)
//      { kind: "label",      name: str,                 }  // basic-block label
//      { kind: "global",     name: str,  type: Type }   // @g_name
//
//    Instruction =
//      { op: str,            // "add", "strcat", "call", ...
//        dst: str,           // result register name, or "" when void
//        dst_type: Type,     // mk_none() when void
//        operands: [Value],  // inputs
//        extra: <any> }      // op-specific (call target, field name, etc.)
//
//    BasicBlock =
//      { label: str,
//        insts: [Instruction],     // non-terminator instructions
//        terminator: Instruction | false }   // br/cond_br/ret/ret_void
//
//    Function =
//      { name: str,
//        params: [{name: str, type: Type}],
//        ret_type: Type,
//        blocks: [BasicBlock],
//        // used during construction:
//        next_reg: [int],          // fresh-register counter (boxed)
//        next_label: [int] }       // fresh-label counter (boxed)
//
//    Module =
//      { functions: [Function],
//        str_table: [{id: str, text: str}],
//        globals:   [{name: str, type: Type}],
//        externs:   [{name: str, params: [Type], ret_type: Type, is_variadic: int}] }
//
//  Terminator discipline: every BasicBlock in a well-formed Function has a
//  non-false terminator at render time. During construction the field can be
//  false; set_terminator(bb, ...) fills it.
//
//  Opcode set (rendered by render_llvm; each backend will implement its own
//  lowering in a future phase):
//    Arithmetic (int):   add sub mul sdiv srem neg
//    Compare (int):      icmp_eq icmp_ne icmp_slt icmp_sle icmp_sgt icmp_sge
//    String-aware cmp:   strcmp_eq strcmp_ne  (higher-level than icmp)
//    Logical:            land lor lnot
//    Memory (stack):     alloca load store
//    Memory (heap):      malloc  (treated as extern call by some backends)
//    String ops:         strcat strlen char_code char_at substring from_char_code int_to_str
//    Array ops:          array_new array_len array_get array_set array_push array_pop array_keys
//    Struct ops:         struct_new struct_get struct_set
//    Calls:              call indirect_call
//    Control flow:       br cond_br ret ret_void unreachable
//    Misc:               print io_read_file io_write_file io_append_file io_exec io_input io_args
//                        ptrtoint inttoptr  (only used by the low-level slice of the IR)
//
//  The io_* and ptr*/* ops are placeholders: they may become regular `call`s
//  to externs when we settle the runtime-vs-IR split. For now they're first-
//  class so each backend can decide.
// ═══════════════════════════════════════════

// ── Value constructors ──────────────────────────────

fn ir_reg(name: str, t) {
    return {kind: "reg", name: name, type: t};
}

fn ir_const_int(n: int) {
    return {kind: "const_int", val: n, type: mk_int()};
}

fn ir_const_str(id: str) {
    // id is a string-table id like "str7" (produced by add_string-style API)
    return {kind: "const_str", id: id, type: mk_str()};
}

// Variant that takes a custom id (e.g. "fmt") rather than the auto-generated
// "strN". Used by hand-built IR code that wants specific global names.
fn ir_const_str_raw(id: str) {
    return {kind: "const_str", id: id, type: mk_str()};
}

fn ir_label(name: str) {
    return {kind: "label", name: name};
}

fn ir_global(name: str, t) {
    return {kind: "global", name: name, type: t};
}

// ── Instruction constructor ─────────────────────────

fn ir_inst(op: str, dst: str, dst_type, operands, extra) {
    return {op: op, dst: dst, dst_type: dst_type, operands: operands, extra: extra};
}

// Convenience: a void instruction (no result).
fn ir_void_inst(op: str, operands, extra) {
    return {op: op, dst: "", dst_type: mk_none(), operands: operands, extra: extra};
}

// ── BasicBlock ──────────────────────────────────────

fn ir_block(label: str) {
    return {label: label, insts: [], terminator: false};
}

fn ir_push_inst(bb, inst) {
    push(bb.insts, inst);
    return 0;
}

fn ir_set_terminator(bb, term) {
    bb.terminator <- term;
    return 0;
}

// ── Function ────────────────────────────────────────
//
// Fresh-name counters are boxed (length-1 arrays) so helper fns can mutate them.
fn ir_function(name: str, params, ret_type) {
    return {
        name: name,
        params: params,
        ret_type: ret_type,
        blocks: [],
        next_reg: [0],
        next_label: [0]
    };
}

fn ir_fn_fresh_reg(f, prefix: str): str {
    f.next_reg[0] <- f.next_reg[0] + 1;
    return "%" + prefix + f.next_reg[0];
}

fn ir_fn_fresh_label(f, prefix: str): str {
    f.next_label[0] <- f.next_label[0] + 1;
    return prefix + f.next_label[0];
}

fn ir_fn_add_block(f, bb) {
    push(f.blocks, bb);
    return 0;
}

// ── Module ──────────────────────────────────────────

fn ir_module() {
    return {
        functions: [],
        str_table: [],
        globals: [],
        externs: []
    };
}

fn ir_mod_add_function(m, f) {
    push(m.functions, f);
    return 0;
}

fn ir_mod_add_str(m, text: str): str {
    // Return the id used to refer to this string via ir_const_str.
    id <- "str" + len(m.str_table);
    push(m.str_table, {id: id, text: text});
    return id;
}

// Variant that takes an explicit id (e.g. "fmt"). Useful for hand-built
// IR test code that wants specific names. Caller is responsible for
// uniqueness.
fn ir_mod_add_str_raw(m, id: str, text: str) {
    push(m.str_table, {id: id, text: text});
    return 0;
}

fn ir_mod_add_global(m, name: str, t) {
    push(m.globals, {name: name, type: t});
    return 0;
}

fn ir_mod_add_extern(m, name: str, params, ret_type, is_variadic: int) {
    push(m.externs, {name: name, params: params, ret_type: ret_type, is_variadic: is_variadic});
    return 0;
}

// ── Convenience instruction builders ────────────────
//
// Each wraps ir_inst with the right operand ordering. Extra field carries
// op-specific data (the callee name for `call`, field name for struct_get, etc.).

fn ii_add(dst: str, l, r)       { return ir_inst("add",     dst, mk_int(), [l, r], false); }
fn ii_sub(dst: str, l, r)       { return ir_inst("sub",     dst, mk_int(), [l, r], false); }
fn ii_mul(dst: str, l, r)       { return ir_inst("mul",     dst, mk_int(), [l, r], false); }
fn ii_sdiv(dst: str, l, r)      { return ir_inst("sdiv",    dst, mk_int(), [l, r], false); }
fn ii_srem(dst: str, l, r)      { return ir_inst("srem",    dst, mk_int(), [l, r], false); }
fn ii_neg(dst: str, v)          { return ir_inst("neg",     dst, mk_int(), [v],    false); }

fn ii_icmp(dst: str, op: str, l, r) {
    // op is "eq","ne","slt","sle","sgt","sge"
    return ir_inst("icmp", dst, mk_int(), [l, r], op);
}

fn ii_strcmp(dst: str, op: str, l, r) {
    return ir_inst("strcmp", dst, mk_int(), [l, r], op);
}

fn ii_alloca(dst: str, t)       { return ir_inst("alloca",  dst, t,        [],     false); }
fn ii_load(dst: str, t, ptr)    { return ir_inst("load",    dst, t,        [ptr],  false); }
fn ii_store(val, ptr)           { return ir_void_inst("store",              [val, ptr], false); }

fn ii_strcat(dst: str, l, r)    { return ir_inst("strcat",  dst, mk_str(), [l, r], false); }
fn ii_strlen(dst: str, s)       { return ir_inst("strlen",  dst, mk_int(), [s],    false); }
fn ii_int_to_str(dst: str, n)   { return ir_inst("int_to_str", dst, mk_str(), [n], false); }

fn ii_array_new(dst: str, elem_type, elems) {
    // elems is [Value]; elem_type is a Type (element kind)
    return ir_inst("array_new", dst, mk_array(elem_type), elems, elem_type);
}
fn ii_array_len(dst: str, arr) { return ir_inst("array_len", dst, mk_int(), [arr], false); }
fn ii_array_get(dst: str, elem_type, arr, idx) {
    return ir_inst("array_get", dst, elem_type, [arr, idx], false);
}
fn ii_array_set(arr, idx, val)  { return ir_void_inst("array_set", [arr, idx, val], false); }
fn ii_array_push(dst: str, arr, val) {
    // Returns updated array pointer (realloc may move it)
    return ir_inst("array_push", dst, arr.type, [arr, val], false);
}
fn ii_array_pop(dst: str, elem_type, arr) {
    return ir_inst("array_pop", dst, elem_type, [arr], false);
}

fn ii_struct_new(dst: str, fields) {
    // fields: [{name: str, val: Value}]
    return ir_inst("struct_new", dst, mk_struct(), [], fields);
}
fn ii_struct_get(dst: str, field_type, s, field: str) {
    return ir_inst("struct_get", dst, field_type, [s], field);
}
fn ii_struct_set(s, field: str, val) {
    return ir_void_inst("struct_set", [s, val], field);
}
fn ii_struct_keys(dst: str, s) {
    return ir_inst("struct_keys", dst, mk_array(mk_str()), [s], false);
}

fn ii_call(dst: str, ret_type, callee: str, args) {
    return ir_inst("call", dst, ret_type, args, callee);
}
fn ii_indirect_call(dst: str, ret_type, fn_ptr, args) {
    ops <- [fn_ptr];
    i <- 0;
    while (i < len(args)) { push(ops, args[i]); i <- i + 1; }
    return ir_inst("indirect_call", dst, ret_type, ops, false);
}

fn ii_br(label: str)            { return ir_void_inst("br", [ir_label(label)], false); }
fn ii_cond_br(i1_reg: str, cond, then_lbl: str, else_lbl: str) {
    // i1_reg is the name for the intermediate icmp-ne result (e.g. "%br1").
    // Must be unique within the function — caller's responsibility.
    return ir_inst("cond_br", i1_reg, mk_none(), [cond, ir_label(then_lbl), ir_label(else_lbl)], false);
}
fn ii_ret(val)                  { return ir_void_inst("ret", [val], false); }
fn ii_ret_void()                { return ir_void_inst("ret_void", [], false); }
fn ii_unreachable()             { return ir_void_inst("unreachable", [], false); }

fn ii_print(val)                { return ir_void_inst("print", [val], false); }

// Low-level escape hatches for the current runtime:
fn ii_ptrtoint(dst: str, v)     { return ir_inst("ptrtoint", dst, mk_int(), [v], false); }
fn ii_inttoptr(dst: str, v)     { return ir_inst("inttoptr", dst, mk_any(), [v], false); }

// ── LLVM rendering ──────────────────────────────────
//
// render_llvm(module) returns a string of LLVM IR equivalent to what the
// existing string emitter produces. Type-to-LLVM translation is centralized
// in ir_llvm_type(t): every Arrow Type becomes i64 (ints, pointers as
// integers) or ptr (when we need ptr specifically, e.g. string constants).
// The current runtime is i64-everywhere with inttoptr/ptrtoint as needed —
// the renderer keeps that discipline.

fn ir_llvm_type(t): str {
    // For now: nearly everything is i64. The exceptions are rendered inline
    // (alloca uses ptr types; string constants use [N x i8] arrays).
    if (t.kind = "none") { return "void"; }
    return "i64";
}

// Render a Value as an LLVM operand (no type prefix).
fn ir_render_operand(v): str {
    if (v.kind = "reg")       { return v.name; }
    if (v.kind = "const_int") { return "" + v.val; }  // force int→str coercion via concat
    if (v.kind = "const_str") { return "@" + v.id; }  // caller typically ptrtoints it
    if (v.kind = "label")     { return "label %" + v.name; }
    if (v.kind = "global")    { return "@g_" + v.name; }
    return "<?>";
}

// Render a Value as a typed LLVM operand ("i64 %r", "i64 42", etc.).
// String constants render as "ptr @id" since LLVM wants a pointer type at
// call sites (printf / puts / our runtime helpers).
fn ir_render_typed_operand(v): str {
    if (v.kind = "const_str") { return "ptr @" + v.id; }
    return ir_llvm_type(v.type) + " " + ir_render_operand(v);
}

// Render one instruction as a single LLVM IR line (no leading indent; caller
// handles that). Terminators are rendered separately by ir_render_block.
fn ir_render_inst(inst): str {
    op <- inst.op;
    // Arithmetic: dst = <op> i64 %a, %b
    if (op = "add" || op = "sub" || op = "mul" || op = "sdiv" || op = "srem") {
        return inst.dst + " = " + op + " i64 " + ir_render_operand(inst.operands[0]) + ", " + ir_render_operand(inst.operands[1]);
    }
    if (op = "neg") {
        return inst.dst + " = sub i64 0, " + ir_render_operand(inst.operands[0]);
    }
    if (op = "icmp") {
        tmp <- inst.dst + ".cmp";
        return inst.dst + ".cmp = icmp " + inst.extra + " i64 " + ir_render_operand(inst.operands[0]) + ", " + ir_render_operand(inst.operands[1]) + "\n  " + inst.dst + " = zext i1 " + inst.dst + ".cmp to i64";
    }
    if (op = "alloca") {
        return inst.dst + " = alloca i64";
    }
    if (op = "load") {
        return inst.dst + " = load i64, ptr " + ir_render_operand(inst.operands[0]);
    }
    if (op = "store") {
        return "store i64 " + ir_render_operand(inst.operands[0]) + ", ptr " + ir_render_operand(inst.operands[1]);
    }
    if (op = "call") {
        args <- "";
        i <- 0;
        while (i < len(inst.operands)) {
            if (i > 0) { args <- args + ", "; }
            args <- args + ir_render_typed_operand(inst.operands[i]);
            i <- i + 1;
        }
        if (inst.dst = "") {
            return "call " + ir_llvm_type(inst.dst_type) + " @" + inst.extra + "(" + args + ")";
        }
        return inst.dst + " = call i64 @" + inst.extra + "(" + args + ")";
    }
    if (op = "strcat") {
        return inst.dst + " = call i64 @arrow_strcat(i64 " + ir_render_operand(inst.operands[0]) + ", i64 " + ir_render_operand(inst.operands[1]) + ")";
    }
    if (op = "strlen") {
        tmp <- inst.dst + ".p";
        return tmp + " = inttoptr i64 " + ir_render_operand(inst.operands[0]) + " to ptr\n  " + inst.dst + " = call i64 @strlen(ptr " + tmp + ")";
    }
    if (op = "int_to_str") {
        return inst.dst + " = call i64 @arrow_itoa(i64 " + ir_render_operand(inst.operands[0]) + ")";
    }
    if (op = "print") {
        // Lowering placeholder: actual print has type-dependent code paths.
        // For Phase 1 we just emit a call to a hypothetical arrow_print.
        return "call void @arrow_print(" + ir_render_typed_operand(inst.operands[0]) + ")";
    }
    if (op = "br") {
        return "br " + ir_render_operand(inst.operands[0]);
    }
    if (op = "cond_br") {
        // inst.dst is the fresh i1 register name supplied by the builder.
        // This makes the intermediate register explicit rather than trying to
        // synthesize one in the renderer (which can collide in the void case).
        return inst.dst + " = icmp ne i64 " + ir_render_operand(inst.operands[0]) + ", 0\n  br i1 " + inst.dst + ", " + ir_render_operand(inst.operands[1]) + ", " + ir_render_operand(inst.operands[2]);
    }
    if (op = "ret") {
        return "ret i64 " + ir_render_operand(inst.operands[0]);
    }
    if (op = "ret_void") {
        return "ret void";
    }
    if (op = "unreachable") {
        return "unreachable";
    }
    if (op = "ptrtoint") {
        return inst.dst + " = ptrtoint ptr " + ir_render_operand(inst.operands[0]) + " to i64";
    }
    if (op = "inttoptr") {
        return inst.dst + " = inttoptr i64 " + ir_render_operand(inst.operands[0]) + " to ptr";
    }
    return "; UNHANDLED OP: " + op;
}

fn ir_render_block(bb): str {
    s <- bb.label + ":\n";
    i <- 0;
    while (i < len(bb.insts)) {
        s <- s + "  " + ir_render_inst(bb.insts[i]) + "\n";
        i <- i + 1;
    }
    if (bb.terminator != false) {
        s <- s + "  " + ir_render_inst(bb.terminator) + "\n";
    }
    return s;
}

fn ir_render_function(f): str {
    // Signature
    params_s <- "";
    i <- 0;
    while (i < len(f.params)) {
        if (i > 0) { params_s <- params_s + ", "; }
        params_s <- params_s + "i64 %" + f.params[i].name + ".arg";
        i <- i + 1;
    }
    s <- "define " + ir_llvm_type(f.ret_type) + " @" + f.name + "(" + params_s + ") {\n";
    i <- 0;
    while (i < len(f.blocks)) {
        s <- s + ir_render_block(f.blocks[i]);
        i <- i + 1;
    }
    s <- s + "}\n";
    return s;
}

fn ir_render_module(m): str {
    s <- "";
    // Externs
    i <- 0;
    while (i < len(m.externs)) {
        ex <- m.externs[i];
        ps <- "";
        j <- 0;
        while (j < len(ex.params)) {
            if (j > 0) { ps <- ps + ", "; }
            ps <- ps + ir_llvm_type(ex.params[j]);
            j <- j + 1;
        }
        if (ex.is_variadic = 1) {
            if (len(ex.params) > 0) { ps <- ps + ", "; }
            ps <- ps + "...";
        }
        s <- s + "declare " + ir_llvm_type(ex.ret_type) + " @" + ex.name + "(" + ps + ")\n";
        i <- i + 1;
    }
    // String table
    i <- 0;
    while (i < len(m.str_table)) {
        ste <- m.str_table[i];
        bytelen <- ir_str_len(ste.text);  // already includes the null terminator
        s <- s + "@" + ste.id + " = private constant [" + bytelen + " x i8] c\"" + ir_escape(ste.text) + "\\00\"\n";
        i <- i + 1;
    }
    // Globals
    i <- 0;
    while (i < len(m.globals)) {
        s <- s + "@g_" + m.globals[i].name + " = global i64 0\n";
        i <- i + 1;
    }
    if (len(m.externs) + len(m.str_table) + len(m.globals) > 0) { s <- s + "\n"; }
    // Functions
    i <- 0;
    while (i < len(m.functions)) {
        s <- s + ir_render_function(m.functions[i]) + "\n";
        i <- i + 1;
    }
    return s;
}

// ═══════════════════════════════════════════
//  ARROW IR — Phase 3: AST → IR translator
//
//  A Builder struct carries state across an in-progress function build:
//    fn           — the IR Function being populated
//    cur_block    — the basic block currently receiving instructions
//    locals       — list of {name, reg} mapping source var → alloca slot
//    tmp_counter  — boxed int for fresh temporary register names
//    block_counter— boxed int for fresh basic-block labels
//
//  The emitter covers the subset of AST nodes needed by is_digit:
//  NumberLit, Identifier, BinOp (comparisons + &&), ReturnStmt, FnDecl.
//  Each additional node is a small incremental extension in later phases.
// ═══════════════════════════════════════════

fn ir_builder_new(f, entry_bb) {
    return {
        func: f,
        cur_block: entry_bb,
        locals: [],
        tmp_counter: [0],
        block_counter: [0]
    };
}

fn ir_fresh_tmp(b, prefix: str): str {
    b.tmp_counter[0] <- b.tmp_counter[0] + 1;
    return "%" + prefix + b.tmp_counter[0];
}

fn ir_fresh_block_lbl(b, prefix: str): str {
    b.block_counter[0] <- b.block_counter[0] + 1;
    return prefix + b.block_counter[0];
}

// Look up a local by name, allocating it (with an alloca in the entry block)
// if this is the first reference. Returns the slot register name (e.g. "%c").
fn ir_get_local_slot(b, name: str): str {
    i <- 0;
    while (i < len(b.locals)) {
        if (b.locals[i].name = name) { return b.locals[i].reg; }
        i <- i + 1;
    }
    reg <- "%" + name;
    push(b.locals, {name: name, reg: reg});
    // Always emit allocas in the entry block (first block of the function).
    // LLVM convention; also keeps alloca out of loops where it would reset each iter.
    ir_push_inst(b.func.blocks[0], ii_alloca(reg, mk_int()));
    return reg;
}

// Map an Arrow BinOp comparison op to the LLVM icmp predicate suffix.
fn ir_cmp_op(op: str): str {
    if (op = "=")  { return "eq"; }
    if (op = "!=") { return "ne"; }
    if (op = "<")  { return "slt"; }
    if (op = "<=") { return "sle"; }
    if (op = ">")  { return "sgt"; }
    if (op = ">=") { return "sge"; }
    return "";
}

fn ir_is_cmp_op(op: str): int {
    return op = "=" || op = "!=" || op = "<" || op = "<=" || op = ">" || op = ">=";
}

fn ir_emit_expr(b, nd) {
    if (nd.node = "NumberLit") {
        return ir_const_int(nd.value);
    }
    if (nd.node = "Identifier") {
        slot <- ir_get_local_slot(b, nd.name);
        tmp <- ir_fresh_tmp(b, "ld");
        ir_push_inst(b.cur_block, ii_load(tmp, mk_int(), ir_reg(slot, mk_int())));
        return ir_reg(tmp, mk_int());
    }
    if (nd.node = "BinOp") {
        return ir_emit_binop(b, nd);
    }
    // Fallback — unsupported node. Return a sentinel const_int(0) so that
    // we at least produce valid (but semantically wrong) IR. Future phases
    // will extend this with the full node set.
    print("ir_emit_expr: unsupported node " + nd.node);
    return ir_const_int(0);
}

fn ir_emit_binop(b, nd) {
    op <- nd.op;

    if (op = "&&") {
        // Short-circuit: allocate a result slot (entry-block alloca), store 0,
        // eval LHS, branch on truthiness; true path evaluates RHS and stores;
        // join block loads the result.
        res_slot_name <- ir_fresh_tmp(b, "and_res");
        ir_push_inst(b.func.blocks[0], ii_alloca(res_slot_name, mk_int()));
        ir_push_inst(b.cur_block, ii_store(ir_const_int(0), ir_reg(res_slot_name, mk_int())));

        lhs <- ir_emit_expr(b, nd.left);

        rhs_lbl <- ir_fresh_block_lbl(b, "and_r");
        end_lbl <- ir_fresh_block_lbl(b, "and_e");
        br_tmp  <- ir_fresh_tmp(b, "br");
        ir_set_terminator(b.cur_block, ii_cond_br(br_tmp, lhs, rhs_lbl, end_lbl));

        rhs_bb <- ir_block(rhs_lbl);
        ir_fn_add_block(b.func, rhs_bb);
        b.cur_block <- rhs_bb;
        rhs <- ir_emit_expr(b, nd.right);
        ir_push_inst(b.cur_block, ii_store(rhs, ir_reg(res_slot_name, mk_int())));
        ir_set_terminator(b.cur_block, ii_br(end_lbl));

        end_bb <- ir_block(end_lbl);
        ir_fn_add_block(b.func, end_bb);
        b.cur_block <- end_bb;

        result_tmp <- ir_fresh_tmp(b, "andres");
        ir_push_inst(b.cur_block, ii_load(result_tmp, mk_int(), ir_reg(res_slot_name, mk_int())));
        return ir_reg(result_tmp, mk_int());
    }

    if (op = "||") {
        // Mirror of && with the default set to 1; LHS true short-circuits to end.
        res_slot_name <- ir_fresh_tmp(b, "or_res");
        ir_push_inst(b.func.blocks[0], ii_alloca(res_slot_name, mk_int()));
        ir_push_inst(b.cur_block, ii_store(ir_const_int(1), ir_reg(res_slot_name, mk_int())));

        lhs <- ir_emit_expr(b, nd.left);

        rhs_lbl <- ir_fresh_block_lbl(b, "or_r");
        end_lbl <- ir_fresh_block_lbl(b, "or_e");
        br_tmp  <- ir_fresh_tmp(b, "br");
        // LHS true → skip to end; LHS false → compute RHS.
        ir_set_terminator(b.cur_block, ii_cond_br(br_tmp, lhs, end_lbl, rhs_lbl));

        rhs_bb <- ir_block(rhs_lbl);
        ir_fn_add_block(b.func, rhs_bb);
        b.cur_block <- rhs_bb;
        rhs <- ir_emit_expr(b, nd.right);
        ir_push_inst(b.cur_block, ii_store(rhs, ir_reg(res_slot_name, mk_int())));
        ir_set_terminator(b.cur_block, ii_br(end_lbl));

        end_bb <- ir_block(end_lbl);
        ir_fn_add_block(b.func, end_bb);
        b.cur_block <- end_bb;

        result_tmp <- ir_fresh_tmp(b, "orres");
        ir_push_inst(b.cur_block, ii_load(result_tmp, mk_int(), ir_reg(res_slot_name, mk_int())));
        return ir_reg(result_tmp, mk_int());
    }

    // Arithmetic and comparison — both operands are eagerly evaluated.
    lhs <- ir_emit_expr(b, nd.left);
    rhs <- ir_emit_expr(b, nd.right);

    if (ir_is_cmp_op(op)) {
        tmp <- ir_fresh_tmp(b, "cmp");
        ir_push_inst(b.cur_block, ii_icmp(tmp, ir_cmp_op(op), lhs, rhs));
        return ir_reg(tmp, mk_int());
    }
    if (op = "+") { tmp <- ir_fresh_tmp(b, "add"); ir_push_inst(b.cur_block, ii_add(tmp, lhs, rhs)); return ir_reg(tmp, mk_int()); }
    if (op = "-") { tmp <- ir_fresh_tmp(b, "sub"); ir_push_inst(b.cur_block, ii_sub(tmp, lhs, rhs)); return ir_reg(tmp, mk_int()); }
    if (op = "*") { tmp <- ir_fresh_tmp(b, "mul"); ir_push_inst(b.cur_block, ii_mul(tmp, lhs, rhs)); return ir_reg(tmp, mk_int()); }
    if (op = "/") { tmp <- ir_fresh_tmp(b, "div"); ir_push_inst(b.cur_block, ii_sdiv(tmp, lhs, rhs)); return ir_reg(tmp, mk_int()); }
    if (op = "%") { tmp <- ir_fresh_tmp(b, "rem"); ir_push_inst(b.cur_block, ii_srem(tmp, lhs, rhs)); return ir_reg(tmp, mk_int()); }

    print("ir_emit_binop: unsupported op " + op);
    return ir_const_int(0);
}

fn ir_emit_stmt(b, stmt) {
    if (stmt.node = "ReturnStmt") {
        if (stmt.expr = false) {
            // bare `return;` — still require a terminator for well-formed IR.
            ir_set_terminator(b.cur_block, ii_ret(ir_const_int(0)));
        } else {
            v <- ir_emit_expr(b, stmt.expr);
            ir_set_terminator(b.cur_block, ii_ret(v));
        }
        return 0;
    }
    if (stmt.node = "Assignment") {
        slot <- ir_get_local_slot(b, stmt.name);
        v <- ir_emit_expr(b, stmt.expr);
        ir_push_inst(b.cur_block, ii_store(v, ir_reg(slot, mk_int())));
        return 0;
    }
    print("ir_emit_stmt: unsupported node " + stmt.node);
    return 0;
}

// Translate an AST FnDecl into an IR Function.
fn emit_function_via_ir(nd) {
    params <- [];
    i <- 0;
    while (i < len(nd.params)) {
        push(params, {name: nd.params[i], type: mk_int()});
        i <- i + 1;
    }
    f <- ir_function(nd.name, params, mk_int());

    ent_bb <- ir_block("entry");
    ir_fn_add_block(f, ent_bb);
    b <- ir_builder_new(f, ent_bb);

    // Prologue: allocate each param's local slot and store the arg into it.
    i <- 0;
    while (i < len(nd.params)) {
        pname <- nd.params[i];
        slot <- ir_get_local_slot(b, pname);
        ir_push_inst(b.cur_block, ii_store(ir_reg("%" + pname + ".arg", mk_int()), ir_reg(slot, mk_int())));
        i <- i + 1;
    }

    // Body
    i <- 0;
    while (i < len(nd.body)) {
        ir_emit_stmt(b, nd.body[i]);
        i <- i + 1;
    }

    return f;
}

// Phase-3 acceptance: parse a fixed test source, find is_digit, run it through
// the AST→IR translator, and print the result plus a main that exercises it.
// Takes a pre-parsed stmts list (parsing at top-level so the global `toks` is set).
fn run_ir_from_ast(stmts) {
    m <- ir_module();

    // Find is_digit and translate
    found <- false;
    i <- 0;
    while (i < len(stmts)) {
        if (stmts[i].node = "FnDecl") {
            if (stmts[i].name = "is_digit") {
                ir_mod_add_function(m, emit_function_via_ir(stmts[i]));
                found <- true;
            }
        }
        i <- i + 1;
    }
    if (!found) {
        print("; is_digit not found");
        return 0;
    }

    // Add a main that exercises is_digit with 48, 47, 57, 58.
    main <- ir_function("main", [], mk_int());
    mb <- ir_block("entry");
    ir_push_inst(mb, ii_call("%r1", mk_int(), "is_digit", [ir_const_int(48)]));
    ir_push_inst(mb, ii_call("%p1", mk_int(), "printf", [ir_const_str_raw("fmt"), ir_reg("%r1", mk_int())]));
    ir_push_inst(mb, ii_call("%r2", mk_int(), "is_digit", [ir_const_int(47)]));
    ir_push_inst(mb, ii_call("%p2", mk_int(), "printf", [ir_const_str_raw("fmt"), ir_reg("%r2", mk_int())]));
    ir_push_inst(mb, ii_call("%r3", mk_int(), "is_digit", [ir_const_int(57)]));
    ir_push_inst(mb, ii_call("%p3", mk_int(), "printf", [ir_const_str_raw("fmt"), ir_reg("%r3", mk_int())]));
    ir_push_inst(mb, ii_call("%r4", mk_int(), "is_digit", [ir_const_int(58)]));
    ir_push_inst(mb, ii_call("%p4", mk_int(), "printf", [ir_const_str_raw("fmt"), ir_reg("%r4", mk_int())]));
    ir_set_terminator(mb, ii_ret(ir_const_int(0)));
    ir_fn_add_block(main, mb);
    ir_mod_add_function(m, main);

    ir_mod_add_str_raw(m, "fmt", "%lld\n");
    ir_mod_add_extern(m, "printf", [mk_any()], mk_int(), 1);

    print(ir_render_module(m));
}

// End-of-file dispatch for --ir-test / --ir-is-digit / --ir-from-ast.
if (ir_test_mode[0]) {
    if (args(0) = "--ir-is-digit") {
        run_ir_is_digit();
    } else if (args(0) = "--ir-from-ast") {
        // Parse at top level so the global `toks` is populated (pp reads it).
        toks <- tokenize("fn is_digit(c: int): int { return c >= 48 && c <= 57; }");
        pos[0] <- 0;
        stmts <- pp();
        run_ir_from_ast(stmts);
    } else {
        run_ir_test();
    }
}
