// EXPECT: ok
//OUT: 1
//OUT: a
//OUT: 2
//OUT: extra
//OUT: 99
//OUT: 0

// A [union] array is passed by handle (reference), pushed to, and returned —
// no implicit copy. push wraps the value into the union; an empty array literal
// satisfies a [union] parameter.
fn tag_all(items: [int | str]): [int | str] {
    push(items, "extra");
    push(items, 99);
    return items;
}
fn count(items: [int | str]): int {
    return len(items);
}
var xs: [int | str] <- [1, "a", 2];
var ys: [int | str] <- tag_all(xs);
var i <- 0;
while (i < len(ys)) {
    match (ys[i]) {
        n: int => { print(n); }
        s: str => { print(s); }
    }
    i <- i + 1;
}
print(count([]));
