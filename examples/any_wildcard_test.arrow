// EXPECT: ok
//OUT: 2
//OUT: 3

// T3: none is not type checked, not even at runtime. A value whose
// static type is unknowable at the decl site (a call to a fn defined
// later in walk order) flows through any into a concrete edge without
// trapping, and an unannotated slot takes the raw payload unchecked.
fn f() {
    var v: any <- mk();
    var n: int <- v;
    print(n + 1);
    var r <- v;
    print(r + 2);
}
fn mk() { return 1; }
f();
