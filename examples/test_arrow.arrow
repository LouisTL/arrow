// EXPECT: ok
//OUT: 7
//OUT: 42
//OUT: hello world
//OUT: 30
//OUT: wow!
//OUT: 15
//OUT: 1
//OUT: 2
//OUT: 3
//OUT: arrow: captured!

// Test 1: Simple expression arrow fn
var add <- (x, y) => x + y;
print(add(3, 4));

// Test 2: Arrow fn with single arg
var double <- (x) => x * 2;
print(double(21));

// Test 3: Arrow fn with block body
var greet <- (name) => {
    print("hello " + name);
};
greet("world");

// Test 4: Passing arrow fn as argument
fn apply(f, x) {
    return f(x);
}
var triple <- (x) => x * 3;
print(apply(triple, 10));

// Test 5: Arrow fn returning string
var shout <- (s) => s + "!";
print(shout("wow"));

// Test 6: Closure capturing a value
fn make_adder(n) {
    return (x) => x + n;
}
var add5 <- make_adder(5);
print(add5(10));

// Test 7: Closure capturing boxed mutable state
fn make_counter() {
    var count <- [0];
    return () => {
        count[0] <- count[0] + 1;
        return count[0];
    };
}
var c <- make_counter();
print(c());
print(c());
print(c());

// Test 8: Closure capturing a string from enclosing scope
var prefix <- "arrow: ";
var prefixed <- (msg) => {
    print(prefix + msg);
};
prefixed("captured!");
