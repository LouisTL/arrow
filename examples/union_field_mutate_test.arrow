// EXPECT: ok
//OUT: {tag: 1}
//OUT: {tag: "hello"}
//OUT: {tag: 42}
//OUT: 43
//OUT: {outer: {inner: "deep"}}
//OUT: {outer: {inner: 9}}
//OUT: {a: "aa", b: 7, n: 5}
//OUT: {a: "aa", b: 7, n: 6}

// Direct mutation of a union-typed struct field (DotAssign): the new value is
// wrapped into the field's {tag,payload} cell, so subsequent reads/print/match
// see the active member. Covers int<->str switches, nested fields, and several
// union fields mutated independently alongside a plain field.

var p: {tag: int | str} <- {tag: 1};
print(p);
p.tag <- "hello";
print(p);
p.tag <- 42;
print(p);
print(match (p.tag) { n: int => n + 1, s: str => str_len(s) });

// nested field mutation two levels deep
var nest: {outer: {inner: int | str}} <- {outer: {inner: 1}};
nest.outer.inner <- "deep";
print(nest);
nest.outer.inner <- 9;
print(nest);

// several union fields plus a plain field, mutated independently
var m: {a: int | str, b: int | str, n: int} <- {a: 1, b: "x", n: 5};
m.a <- "aa";
m.b <- 7;
print(m);
m.n <- 6;
print(m);
