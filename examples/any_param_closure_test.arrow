// EXPECT: ok
//OUT: 40
//OUT: 5
//OUT: s
//OUT: 21
//OUT: 9
//OUT: in

fn double(n: int): int {
    return n * 2;
}
fn apply(f: any, v: int): int {
    return f(v);
}
print(apply(double, 20));

var h <- (x: any) => {
    print(x);
    return 0;
};
h(5);
h("s");

var g: any <- (x: int) => x * 3;
print(g(7));

fn run(): int {
    var f <- (x: any) => {
        print(x);
        return 1;
    };
    f(9);
    f("in");
    return 0;
}
run();
