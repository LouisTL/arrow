// Should produce multiple struct-related type errors

// 1. Wrong field type: x should be int, given str
bad1: {x: int, y: int} <- {x: "hello", y: 4};

// 2. Missing field: needs y but only has x
bad2: {x: int, y: int} <- {x: 5};

// 3. Function parameter type mismatch
fn dist(p: {x: int, y: int}): int {
    return p.x + p.y;
}
print(dist({x: "no", y: 2}));

// 4. Return type mismatch
fn make(): {x: int, y: int} {
    return {x: 1, y: "bad"};
}
