// Arrow Lang — Recursion (compiler test)
// Cases not covered by functions_test (which has factorial(5)/factorial(10),
// fib(10)/fib(20), gcd). This file focuses on:
//   - boundary cases (factorial(0), fib(0))
//   - mutual recursion
//   - recursion over arrays
//   - recursion over a struct-of-structs tree
//   - self-recursive ArrowFn (named via outer assignment)

// ── Factorial boundaries ──────────────────
fn factorial(n) {
    if (n <= 1) { return 1; }
    return n * factorial(n - 1);
}
print(factorial(0));    // 1
print(factorial(1));    // 1

// ── Fibonacci boundaries ──────────────────
fn fib(n) {
    if (n <= 1) { return n; }
    return fib(n - 1) + fib(n - 2);
}
print(fib(0));     // 0
print(fib(1));     // 1
print(fib(15));    // 610

// ── Mutual recursion ─────────────────────
// is_even/is_odd defined as siblings; each calls the other. We return
// 1/0 rather than true/false because a function whose return type can't
// be statically inferred prints as int natively but as bool in the
// interpreter — see bool_test for that gotcha.
fn is_even(n) {
    if (n = 0) { return 1; }
    return is_odd(n - 1);
}
fn is_odd(n) {
    if (n = 0) { return 0; }
    return is_even(n - 1);
}
print(is_even(0));   // 1
print(is_even(7));   // 0
print(is_even(10));  // 1
print(is_odd(7));    // 1

// ── Recursive sum on array ────────────────
fn sum_from(arr, i) {
    if (i >= len(arr)) { return 0; }
    return arr[i] + sum_from(arr, i + 1);
}
print(sum_from([1, 2, 3, 4, 5], 0));    // 15
print(sum_from([], 0));                  // 0

// ── Recursive descent on a struct tree ────
// Tree nodes: {val: int, left: <node|nil>, right: <node|nil>}
// We use -1 as a stand-in for "no child" since we don't have a real
// nil/null type yet.
fn make_leaf(v) {
    return {val: v, left: -1, right: -1};
}
fn make_node(v, l, r) {
    return {val: v, left: l, right: r};
}

//        4
//       / \
//      2   5
//     / \
//    1   3
tree <- make_node(4,
    make_node(2, make_leaf(1), make_leaf(3)),
    make_leaf(5));

fn tree_sum(t) {
    if (t = -1) { return 0; }
    return t.val + tree_sum(t.left) + tree_sum(t.right);
}
print(tree_sum(tree));    // 1+2+3+4+5 = 15

fn tree_depth(t) {
    if (t = -1) { return 0; }
    ld <- tree_depth(t.left);
    rd <- tree_depth(t.right);
    if (ld > rd) { return ld + 1; }
    return rd + 1;
}
print(tree_depth(tree));   // 3

// ── Recursion via ArrowFn (named via assignment) ──────
// Captures itself by name from the enclosing scope.
fact <- (n) => {
    if (n <= 1) { return 1; }
    return n * fact(n - 1);
};
print(fact(6));    // 720

print("Done!");
