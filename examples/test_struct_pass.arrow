// All struct annotations correct
var pt: {x: int, y: int} <- {x: 3, y: 4};

fn make_point(x: int, y: int): {x: int, y: int} {
    return {x: x, y: y};
}

var p: {x: int, y: int} <- make_point(10, 20);
print(p.x + p.y);

// Array of structs
var people: [{name: str, age: int}] <- [{name: "Ada", age: 30}, {name: "Bob", age: 25}];
print(people[0].name);
print(people[1].age);

// Struct containing an array
var team: {name: str, members: [str]} <- {name: "Reds", members: ["a", "b"]};
print(team.name);
print(team.members[0]);

print("ok");
