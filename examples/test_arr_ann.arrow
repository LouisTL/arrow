// Array type annotations should parse and run (interpreter ignores types)
nums: [int] <- [1, 2, 3];
words: [str] <- ["hi", "there"];
nested: [[int]] <- [[1, 2], [3, 4]];

fn sum(xs: [int]): int {
    total: int <- 0;
    for (n in xs) {
        total <- total + n;
    }
    return total;
}

fn first_word(ws: [str]): str {
    return ws[0];
}

print(sum(nums));
print(first_word(words));
print(nested[0][1]);
