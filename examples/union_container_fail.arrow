// EXPECT: type_fail
//ERR: union inside an array or struct is not supported yet

// 3a/3b support arrays of unions: [int | str] can be declared, passed, returned,
// and pushed to. A union inside a STRUCT field is still unsupported (deferred),
// so the checker rejects the type.
var p: {tag: int | str} <- {tag: 1};
print(p);
