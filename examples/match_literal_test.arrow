// EXPECT: ok
//OUT: matched 42
//OUT: 42
//OUT: other int
//OUT: 7
//OUT: hello world
//OUT: other str
//OUT: bye
//OUT: is true
//OUT: neg one
//OUT: done

// Literal patterns refine a union member: an arm `42 =>` fires only when the
// scrutinee is the int 42. Dispatch checks the member tag first, then the
// value, so `1` never matches `true`. A matched literal binds the scrutinee
// (narrowed to the member type) just like a typed arm. Literals do not satisfy
// exhaustiveness — a typed arm or `_` must still cover each member.

var n: int | str <- 42;
match (n) {
    42 => { print("matched 42"); print(n); }   // binds n, narrowed to int
    int => { print("other int"); print(n); }
    str => { print("other str"); print(n); }
}
n <- 7;
match (n) {
    42 => { print("matched 42"); }
    int => { print("other int"); print(n); }   // 7 falls through to here
    str => { print("other str"); print(n); }
}

var s: int | str <- "world";
match (s) {
    "world" => { print("hello world"); }
    str => { print("other str"); print(s); }
    int => { print("other int"); print(s); }
}
s <- "bye";
match (s) {
    "world" => { print("hello world"); }
    str => { print("other str"); print(s); }   // bye falls through to here
    int => { print("other int"); print(s); }
}

var b: int | bool <- true;
match (b) {
    1 => { print("one"); }        // distinct tag: never matches the bool true
    true => { print("is true"); }
    int => { print("an int"); }
    bool => { print("some bool"); }
}

var m: int | str <- 0 - 1;
match (m) {
    -1 => { print("neg one"); }   // negative integer literal
    int => { print("other int"); print(m); }
    str => { print("other str"); print(m); }
}
print("done");
