// Arrow Lang v0.4 — Closures (compiler test)

// ── Basic functions still work ──────────
fn add(a, b) {
    return a + b;
}
print(add(3, 4));

// ── Arrow function ──────────────────────
var mul <- (a, b) => a * b;
print(mul(6, 7));

// ── Recursion ───────────────────────────
fn factorial(n) {
    if (n <= 1) { return 1; }
    return n * factorial(n - 1);
}
print(factorial(10));

// ── Closure: make_adder ─────────────────
fn make_adder(n) {
    return (x) => x + n;
}
var add5 <- make_adder(5);
var add10 <- make_adder(10);
print(add5(3));
print(add10(3));

// ── Closure: make_multiplier ────────────
fn make_multiplier(factor) {
    return (x) => x * factor;
}
var double <- make_multiplier(2);
var triple <- make_multiplier(3);
print(double(7));
print(triple(7));

// ── Pass function as argument ───────────
fn apply(f, x, y) {
    return f(x, y);
}
print(apply(add, 10, 20));
print(apply(mul, 5, 8));

// ── Compose ─────────────────────────────
fn compose(f, g) {
    return (x) => f(g(x));
}
var inc <- (x) => x + 1;
var dbl <- (x) => x * 2;
var inc_after_dbl <- compose(inc, dbl);
print(inc_after_dbl(5));

// ── Higher-order with arrays ────────────
fn map(arr, f) {
    var result <- [];
    var i <- 0;
    while (i < len(arr)) {
        push(result, f(arr[i]));
        i <- i + 1;
    }
    return result;
}

var doubled <- map([1, 2, 3, 4], (x) => x * 2);
print(doubled);

fn filter(arr, pred) {
    var result <- [];
    var i <- 0;
    while (i < len(arr)) {
        if (pred(arr[i])) {
            push(result, arr[i]);
        }
        i <- i + 1;
    }
    return result;
}

var evens <- filter([1, 2, 3, 4, 5, 6, 7, 8], (x) => x % 2 = 0);
print(evens);

// ── Reduce ──────────────────────────────
fn reduce(arr, init, f) {
    var acc <- init;
    var i <- 0;
    while (i < len(arr)) {
        acc <- f(acc, arr[i]);
        i <- i + 1;
    }
    return acc;
}

var product <- reduce([1, 2, 3, 4, 5], 1, (a, b) => a * b);
print(product);

// ── ForEach with closure ────────────────
fn forEach(arr, f) {
    var i <- 0;
    while (i < len(arr)) {
        f(arr[i]);
        i <- i + 1;
    }
}

forEach([10, 20, 30], (x) => {
    print("value: " + x);
});

// ── Indirect calls via expression ────────
// The callee here is the result of an expression, not a plain identifier.
// Each of these used to bail with "indirect calls not yet supported".
fn make_inc() {
    return (x) => x + 1;
}
print(make_inc()(5));        // 6
print(make_adder(10)(7));    // 17

// Triple-nested currying — every (b)(c) is an indirect call.
var add3 <- (a) => (b) => (c) => a + b + c;
print(add3(1)(2)(3));        // 6

// Indirect call via array index and struct field.
var fns <- [(x) => x + 1, (x) => x * 10, (x) => x - 100];
print(fns[0](5));            // 6
print(fns[1](5));            // 50

var ops <- {inc: (x) => x + 1, dec: (x) => x - 1};
print(ops.inc(10));          // 11
print(ops.dec(10));          // 9

// ── Nested ArrowFn capture ───────────────
// The outer ArrowFn must forward `outer_var` through its env so the inner
// can read it. Before fixing capture detection, the outer wouldn't notice
// the inner needed `outer_var` and the inner would read garbage.
fn factory() {
    var outer_var <- 100;
    var f <- (mult) => (x) => x * mult + outer_var;
    return f;
}
var make <- factory();
print(make(2)(5));           // 5*2 + 100 = 110
print(make(3)(7));           // 7*3 + 100 = 121

// Capture chain through three levels via FnDecl wrapper.
fn triple_capture() {
    var a <- 1;
    return (b) => (c) => a * 100 + b * 10 + c;
}
var g <- triple_capture();
print(g(2)(3));              // 123
print(g(5)(7));              // 157

// Closures with conditional bodies (and indirect call via the var).
fn clamp_factory(lo, hi) {
    return (x) => {
        if (x < lo) { return lo; }
        if (x > hi) { return hi; }
        return x;
    };
}
var clamp <- clamp_factory(0, 10);
print(clamp(-5));            // 0
print(clamp(5));             // 5
print(clamp(15));            // 10

// Captures are by-value snapshots: each closure stores its own copy of
// captured values at creation time. To "modify" the captured value, the
// closure has to explicitly shadow it with `var` — the snapshot then
// reads the captured `n`, and the new local `n` lives only for this call.
fn make_counter() {
    var n <- 0;
    return () => {
        var n <- n + 1;
        return n;
    };
}
var c1 <- make_counter();
print(c1());                 // 1
print(c1());                 // 1   ← snapshot semantics
var c2 <- make_counter();
print(c2());                 // 1   ← independent counter

print("Done!");
