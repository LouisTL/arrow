// EXPECT: ok
// Regression for the type_eq fix: unions compare member-wise and
// order-insensitively (a past bug accepted ANY two unions as equal).
// Observed at the language level: reordered spellings of the same union
// interchange at a decl edge, a param edge, and a reassignment, and a
// union value widens into a superset union. union_eq_fail.arrow pins
// the rejection side (differing member, narrowing).
type AB <- int | str;
type BA <- str | int;

var a: AB <- 5;
var b: BA <- a;
match (b) {
    int => { print("int"); },
    str => { print("s"); },
}
//OUT: int

fn takes_ba(u: BA): int {
    match (u) { int => { return 1; }, str => { return 2; } }
    return 0;
}
var c: int | str <- "x";
print(takes_ba(c));
//OUT: 2

var d: str | int <- 7;
d <- a;
match (d) { int => { print("d-int"); }, str => { print("d-s"); } }
//OUT: d-int

var wv: int | str | bool <- a;
match (wv) {
    int => { print("w-int"); },
    str => { print("w-s"); },
    bool => { print("w-b"); },
}
//OUT: w-int
