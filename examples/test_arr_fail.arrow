// 2. Function expects [int], called with [str]
fn sum(xs: [int]): int {
    var total: int <- 0;
    for (n in xs) { total <- total + n; }
    return total;
}

var names: [str] <- ["x", "y"];
print(sum(names));

// 3. Function declared to return [int] but returns int
fn bad(): [int] {
    return 42;
}
