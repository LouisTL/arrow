// === Function annotations ===

// Test 1: Annotated function
fn add(x: int, y: int): int {
    return x + y;
}
print(add(3, 4));

// Test 2: Annotated with string param
fn greet(name: str) {
    print("hello " + name);
}
greet("world");

// Test 3: Mixed — some annotated, some not
fn mix(a: str, b) {
    print(a + " and " + b);
}
mix("cats", "dogs");

// Test 4: Unannotated (backward compat)
fn double(x) {
    return x * 2;
}
print(double(21));

// Test 5: Return type annotation
fn exclaim(s: str): str {
    return s + "!";
}
print(exclaim("wow"));

// === Typed declarations ===

// Test 6: Typed int declaration
x: int <- 42;
print(x);

// Test 7: Typed string declaration
msg: str <- "typed";
print(msg);

// Test 8: Untyped (old style, still works)
count <- 10;
print(count);

// Test 9: Reassignment after typed declaration
x <- x + 1;
print(x);

// Test 10: Typed declaration inside function
fn make_greeting(who: str): str {
    result: str <- "hi " + who;
    return result;
}
print(make_greeting("world"));

// Test 11: Mix of typed and untyped
old_style <- 99;
new_style: int <- 100;
print(old_style + new_style);
