// EXPECT: ok
//OUT: 30
//OUT: 7
//OUT: 99

// Union member ORDER must not change runtime tags: a value built under one
// member ordering must match correctly under a different but structurally
// equal ordering. union_normalize canonicalizes same-rank compound members so
// {p:int}|{q:int,r:int} and {q:int,r:int}|{p:int} tag identically.
fn make(): {p: int} | {q: int, r: int} {
    return {q: 10, r: 20};
}
fn use_rev(s: {q: int, r: int} | {p: int}): int {     // reversed order
    return match (s) {
        {p: int} => s.p,
        {q: int, r: int} => s.q + s.r,
    };
}
print(use_rev(make()));     // 30

fn mk2(): {a: int} | {b: int} { return {b: 7}; }
fn rev2(s: {b: int} | {a: int}): int {
    return match (s) {
        {a: int} => s.a,
        {b: int} => s.b,
    };
}
print(rev2(mk2()));         // 7

fn mk3(): {a: int} | {b: int} | {c: int} { return {c: 99}; }
fn rev3(s: {c: int} | {a: int} | {b: int}): int {
    return match (s) {
        {a: int} => s.a,
        {b: int} => s.b,
        {c: int} => s.c,
    };
}
print(rev3(mk3()));         // 99
