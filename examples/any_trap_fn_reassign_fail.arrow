// EXPECT: runtime_fail
//OUT: 6
//ERR: Error: expected fn in any, got int

// The closure registry is a compile-time record — after the var is
// reassigned to a non-fn value, the call still routes through the
// closure path and the runtime tag check traps.
var h: any <- (x: int) => x * 3;
print(h(2));
h <- 5;
h(1);
