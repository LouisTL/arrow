// EXPECT: type_fail
//ERR: 'x' annotated as int but assigned str
//ERR: argument 2 expected int but got str
//ERR: argument 1 expected str but got int
//ERR: 3 type error(s)

// Three intentional type errors
var x: int <- "this is a string, not int";

fn add(a: int, b: int): int {
    return a + b;
}

fn greet(name: str): str {
    return name;
}

print(add(1, "two"));    // arg 2 should be int, got str
print(greet(42));        // arg 1 should be str, got int
