// EXPECT: ok
//OUT: circle
//OUT: 5
//OUT: square
//OUT: 3
//OUT: round
//OUT: boxy
//OUT: 3
//OUT: 1
//OUT: 2

// Structural type aliases (3d): aliases resolve to their underlying type in
// annotations and match patterns; type_eq/types_compat see only structure.
type Circle <- {radius: int};
type Square <- {side: int};
type Shape <- Circle | Square;

fn describe(s: Shape) {
    match (s) {
        Circle => { print("circle"); print(radius); }
        Square => { print("square"); print(side); }
    }
}

fn kind(s: Shape): str {
    return match (s) {
        Circle => "round",
        Square => "boxy"
    };
}

var c: Shape <- {radius: 5};
var sq: Shape <- {side: 3};
describe(c);
describe(sq);
print(kind(c));
print(kind(sq));

type IntList <- [int];
var xs: IntList <- [10, 20, 30];
print(len(xs));

type Point <- {x: int, y: int};
var p: Point <- {x: 1, y: 2};
print(p.x);
print(p.y);
