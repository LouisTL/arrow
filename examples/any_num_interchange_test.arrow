// EXPECT: ok
//OUT: 2
//OUT: 1

// T3: int/bool/float form one numeric class at check time — an
// expected-int edge accepts a bool payload raw, and expected-bool
// accepts an int. No value conversions on these edges, so the test
// observes through arithmetic and truthiness, not direct prints.
var v: any <- true;
var n: int <- v;
print(n + 1);
var w: any <- 1;
var b: bool <- w;
if (b) { print(1); }
