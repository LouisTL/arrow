// ═══════════════════════════════════════════
//  Arrow Lang — Self-Hosted Evaluator
//  Lexes, parses, and evaluates Arrow Lang.
// ═══════════════════════════════════════════

// ── Lexer (same as parser.arrow) ────────

fn is_digit(c) { return c >= 48 && c <= 57; }
fn is_alpha(c) { return (c >= 65 && c <= 90) || (c >= 97 && c <= 122) || c = 95; }
fn is_alnum(c) { return is_digit(c) || is_alpha(c); }
fn is_ws(c) { return c = 32 || c = 9 || c = 10 || c = 13; }
fn mktok(t, v, l, c) { return {type: t, value: v, line: l, col: c}; }

fn is_kw(w) {
    if (w="if"){return true;} if (w="else"){return true;} if (w="while"){return true;}
    if (w="for"){return true;} if (w="in"){return true;} if (w="print"){return true;}
    if (w="fn"){return true;} if (w="return"){return true;}
    if (w="true"){return true;} if (w="false"){return true;} return false;
}

fn tokenize(src) {
    ts <- []; p <- 0; ln <- 1; cl <- 1; sl <- str_len(src);
    while (p < sl) {
        ch <- char_code(char_at(src, p));
        if (is_ws(ch)) { if (ch=10){ln<-ln+1;cl<-1;} else {cl<-cl+1;} p<-p+1; }
        else if (ch=47&&p+1<sl&&char_code(char_at(src,p+1))=47) { while(p<sl&&char_code(char_at(src,p))!=10){p<-p+1;} }
        else if (is_digit(ch)) { s<-p;sc<-cl; while(p<sl&&is_digit(char_code(char_at(src,p)))){p<-p+1;cl<-cl+1;} push(ts,mktok("NUMBER",substring(src,s,p),ln,sc)); }
        else if (ch=34) { sc<-cl;p<-p+1;cl<-cl+1;sv<-"";
            while(p<sl&&char_code(char_at(src,p))!=34){c<-char_at(src,p);
                if(c="\\"){p<-p+1;cl<-cl+1;nx<-char_at(src,p);if(nx="n"){sv<-sv+from_char_code(10);}else if(nx="t"){sv<-sv+from_char_code(9);}else if(nx="\\"){sv<-sv+"\\";}else{sv<-sv+nx;}}
                else{sv<-sv+c;} p<-p+1;cl<-cl+1;}
            p<-p+1;cl<-cl+1;push(ts,mktok("STRING",sv,ln,sc)); }
        else if (is_alpha(ch)) { s<-p;sc<-cl; while(p<sl&&is_alnum(char_code(char_at(src,p)))){p<-p+1;cl<-cl+1;} w<-substring(src,s,p);
            if(w="true"||w="false"){push(ts,mktok("BOOL",w,ln,sc));} else if(is_kw(w)){push(ts,mktok(w,w,ln,sc));} else{push(ts,mktok("IDENT",w,ln,sc));} }
        else if(ch=60&&p+1<sl&&char_code(char_at(src,p+1))=45){push(ts,mktok("ARROW","<-",ln,cl));p<-p+2;cl<-cl+2;}
        else if(ch=61&&p+1<sl&&char_code(char_at(src,p+1))=62){push(ts,mktok("FAT_ARROW","=>",ln,cl));p<-p+2;cl<-cl+2;}
        else if(ch=60&&p+1<sl&&char_code(char_at(src,p+1))=61){push(ts,mktok("LTE","<=",ln,cl));p<-p+2;cl<-cl+2;}
        else if(ch=62&&p+1<sl&&char_code(char_at(src,p+1))=61){push(ts,mktok("GTE",">=",ln,cl));p<-p+2;cl<-cl+2;}
        else if(ch=33&&p+1<sl&&char_code(char_at(src,p+1))=61){push(ts,mktok("NEQ","!=",ln,cl));p<-p+2;cl<-cl+2;}
        else if(ch=38&&p+1<sl&&char_code(char_at(src,p+1))=38){push(ts,mktok("AND","&&",ln,cl));p<-p+2;cl<-cl+2;}
        else if(ch=124&&p+1<sl&&char_code(char_at(src,p+1))=124){push(ts,mktok("OR","||",ln,cl));p<-p+2;cl<-cl+2;}
        else if(ch=43){push(ts,mktok("PLUS","+",ln,cl));p<-p+1;cl<-cl+1;}
        else if(ch=45){push(ts,mktok("MINUS","-",ln,cl));p<-p+1;cl<-cl+1;}
        else if(ch=42){push(ts,mktok("STAR","*",ln,cl));p<-p+1;cl<-cl+1;}
        else if(ch=47){push(ts,mktok("SLASH","/",ln,cl));p<-p+1;cl<-cl+1;}
        else if(ch=37){push(ts,mktok("PERCENT","%",ln,cl));p<-p+1;cl<-cl+1;}
        else if(ch=60){push(ts,mktok("LT","<",ln,cl));p<-p+1;cl<-cl+1;}
        else if(ch=62){push(ts,mktok("GT",">",ln,cl));p<-p+1;cl<-cl+1;}
        else if(ch=33){push(ts,mktok("NOT","!",ln,cl));p<-p+1;cl<-cl+1;}
        else if(ch=61){push(ts,mktok("EQ","=",ln,cl));p<-p+1;cl<-cl+1;}
        else if(ch=46){push(ts,mktok("DOT",".",ln,cl));p<-p+1;cl<-cl+1;}
        else if(ch=58){push(ts,mktok("COLON",":",ln,cl));p<-p+1;cl<-cl+1;}
        else if(ch=40){push(ts,mktok("LPAREN","(",ln,cl));p<-p+1;cl<-cl+1;}
        else if(ch=41){push(ts,mktok("RPAREN",")",ln,cl));p<-p+1;cl<-cl+1;}
        else if(ch=123){push(ts,mktok("LBRACE","{",ln,cl));p<-p+1;cl<-cl+1;}
        else if(ch=125){push(ts,mktok("RBRACE","}",ln,cl));p<-p+1;cl<-cl+1;}
        else if(ch=91){push(ts,mktok("LBRACKET","[",ln,cl));p<-p+1;cl<-cl+1;}
        else if(ch=93){push(ts,mktok("RBRACKET","]",ln,cl));p<-p+1;cl<-cl+1;}
        else if(ch=59){push(ts,mktok("SEMI",";",ln,cl));p<-p+1;cl<-cl+1;}
        else if(ch=44){push(ts,mktok("COMMA",",",ln,cl));p<-p+1;cl<-cl+1;}
        else{p<-p+1;cl<-cl+1;}
    }
    push(ts,mktok("EOF","",ln,cl)); return ts;
}

// ── Parser ──────────────────────────────
toks <- []; pos <- [0];
fn ci(e){return toks[pos[0]].type=e;} fn pi(o,e){x<-pos[0]+o;if(x<len(toks)){return toks[x].type=e;}return false;}
fn adv(){pos[0]<-pos[0]+1;} fn cv(){return toks[pos[0]].value;}
fn eat(e){t<-toks[pos[0]];if(t.type!=e){print("Parse error: expected "+e+" got "+t.type);}pos[0]<-pos[0]+1;return t;}
fn ev(e){t<-toks[pos[0]];pos[0]<-pos[0]+1;return t.value;}

fn pp(){ss<-[];while(!ci("EOF")){push(ss,ps());}return ss;}
fn ps(){
    if(ci("fn")){return pfd();} if(ci("return")){return prt();}
    if(ci("if")){return pif();} if(ci("while")){return pwh();}
    if(ci("for")){return pfi();} if(ci("print")){return ppr();}
    if(ci("LBRACE")){if(isl()){e<-pe();eat("SEMI");return e;}return {node:"Block",stmts:pb()};}
    if(ci("IDENT")){if(pi(1,"ARROW")){return pas();}if(pi(1,"LBRACKET")||pi(1,"DOT")){return ppa();}}
    e<-pe();eat("SEMI");return e;
}
fn isl(){if(pi(1,"RBRACE")){return true;}if(pi(1,"IDENT")&&pi(2,"COLON")){return true;}return false;}
fn pb(){eat("LBRACE");ss<-[];while(!ci("RBRACE")){push(ss,ps());}eat("RBRACE");return ss;}
fn pas(){n<-ev("IDENT");eat("ARROW");e<-pe();eat("SEMI");return{node:"Assignment",name:n,expr:e};}
fn ppa(){e<-pe();if(ci("ARROW")){eat("ARROW");v<-pe();eat("SEMI");if(e.node="IndexExpr"){return{node:"IndexAssign",obj:e.obj,index:e.index,value:v};}if(e.node="DotExpr"){return{node:"DotAssign",obj:e.obj,field:e.field,value:v};}}eat("SEMI");return e;}
fn ppr(){eat("print");eat("LPAREN");e<-pe();eat("RPAREN");eat("SEMI");return{node:"PrintStmt",expr:e};}
fn prt(){eat("return");if(ci("SEMI")){eat("SEMI");return{node:"ReturnStmt",expr:false};}e<-pe();eat("SEMI");return{node:"ReturnStmt",expr:e};}
fn pfd(){eat("fn");n<-ev("IDENT");p<-ppl();b<-pb();return{node:"FnDecl",name:n,params:p,body:b};}
fn ppl(){eat("LPAREN");p<-[];if(!ci("RPAREN")){push(p,ev("IDENT"));while(ci("COMMA")){eat("COMMA");push(p,ev("IDENT"));}}eat("RPAREN");return p;}
fn pif(){eat("if");eat("LPAREN");c<-pe();eat("RPAREN");tb<-pb();eb<-[];if(ci("else")){eat("else");if(ci("if")){eb<-[pif()];}else{eb<-pb();}}return{node:"IfStmt",cond:c,then_body:tb,else_body:eb};}
fn pwh(){eat("while");eat("LPAREN");c<-pe();eat("RPAREN");b<-pb();return{node:"WhileStmt",cond:c,body:b};}
fn pfi(){eat("for");eat("LPAREN");v<-ev("IDENT");eat("in");it<-pe();eat("RPAREN");b<-pb();return{node:"ForInStmt",var_name:v,iterable:it,body:b};}

fn pe(){if(ci("LPAREN")&&iaf()){return paf();}return por();}
fn iaf(){d<-0;i<-pos[0];while(i<len(toks)){t<-toks[i].type;if(t="LPAREN"){d<-d+1;}else if(t="RPAREN"){d<-d-1;if(d=0){if(i+1<len(toks)){return toks[i+1].type="FAT_ARROW";}return false;}}i<-i+1;}return false;}
fn paf(){p<-ppl();eat("FAT_ARROW");if(ci("LBRACE")&&!isl()){b<-pb();return{node:"ArrowFn",params:p,body:b,is_expr:false};}e<-pe();return{node:"ArrowFn",params:p,body:e,is_expr:true};}
fn por(){l<-pan();while(ci("OR")){eat("OR");l<-{node:"BinOp",op:"||",left:l,right:pan()};}return l;}
fn pan(){l<-peq();while(ci("AND")){eat("AND");l<-{node:"BinOp",op:"&&",left:l,right:peq()};}return l;}
fn peq(){l<-pcm();while(ci("EQ")||ci("NEQ")){o<-cv();adv();l<-{node:"BinOp",op:o,left:l,right:pcm()};}return l;}
fn pcm(){l<-pad();while(ci("LT")||ci("GT")||ci("LTE")||ci("GTE")){o<-cv();adv();l<-{node:"BinOp",op:o,left:l,right:pad()};}return l;}
fn pad(){l<-pmu();while(ci("PLUS")||ci("MINUS")){o<-cv();adv();l<-{node:"BinOp",op:o,left:l,right:pmu()};}return l;}
fn pmu(){l<-pun();while(ci("STAR")||ci("SLASH")||ci("PERCENT")){o<-cv();adv();l<-{node:"BinOp",op:o,left:l,right:pun()};}return l;}
fn pun(){if(ci("MINUS")){adv();return{node:"UnaryOp",op:"-",operand:pun()};}if(ci("NOT")){adv();return{node:"UnaryOp",op:"!",operand:pun()};}return ppf();}

fn ppf(){e<-ppm();dn<-false;while(!dn){if(ci("LPAREN")){eat("LPAREN");a<-[];if(!ci("RPAREN")){push(a,pe());while(ci("COMMA")){eat("COMMA");push(a,pe());}}eat("RPAREN");e<-{node:"CallExpr",callee:e,args:a};}
    else if(ci("LBRACKET")){eat("LBRACKET");x<-pe();eat("RBRACKET");e<-{node:"IndexExpr",obj:e,index:x};}
    else if(ci("DOT")){eat("DOT");f<-ev("IDENT");e<-{node:"DotExpr",obj:e,field:f};}
    else{dn<-true;}}return e;}

fn ppm(){
    if(ci("NUMBER")){v<-cv();adv();return{node:"NumberLit",value:v};}
    if(ci("STRING")){v<-cv();adv();return{node:"StringLit",value:v};}
    if(ci("BOOL")){v<-cv();adv();return{node:"BoolLit",value:v};}
    if(ci("IDENT")){v<-cv();adv();return{node:"Identifier",name:v};}
    if(ci("LBRACKET")){eat("LBRACKET");el<-[];if(!ci("RBRACKET")){push(el,pe());while(ci("COMMA")){eat("COMMA");push(el,pe());}}eat("RBRACKET");return{node:"ArrayLit",elements:el};}
    if(ci("LBRACE")){eat("LBRACE");fs<-[];if(!ci("RBRACE")){k<-ev("IDENT");eat("COLON");v<-pe();push(fs,{key:k,val:v});while(ci("COMMA")){eat("COMMA");if(ci("RBRACE")){eat("RBRACE");return{node:"StructLit",fields:fs};}k<-ev("IDENT");eat("COLON");v<-pe();push(fs,{key:k,val:v});}}eat("RBRACE");return{node:"StructLit",fields:fs};}
    if(ci("LPAREN")){eat("LPAREN");e<-pe();eat("RPAREN");return e;}
    print("Parse error");adv();return{node:"NumberLit",value:"0"};
}


// ═══════════════════════════════════════════
//  EVALUATOR
// ═══════════════════════════════════════════

fn make_env(par) { return {vars: [], parent: par}; }

fn env_get(env, name) {
    i <- 0;
    while (i < len(env.vars)) {
        if (env.vars[i].name = name) { return env.vars[i].value; }
        i <- i + 1;
    }
    if (env.parent != false) { return env_get(env.parent, name); }
    print("Error: undefined '" + name + "'");
    return 0;
}

fn env_set(env, name, val) {
    i <- 0;
    while (i < len(env.vars)) {
        if (env.vars[i].name = name) { env.vars[i] <- {name: name, value: val}; return val; }
        i <- i + 1;
    }
    push(env.vars, {name: name, value: val});
    return val;
}

fn is_truthy(v) {
    if (v = false) { return false; }
    if (v = 0) { return false; }
    if (v = "") { return false; }
    return true;
}

fn parse_int(s) {
    r <- 0; i <- 0; neg <- false;
    if (str_len(s) > 0 && char_at(s, 0) = "-") { neg <- true; i <- 1; }
    while (i < str_len(s)) { r <- r * 10 + (char_code(char_at(s, i)) - 48); i <- i + 1; }
    if (neg) { r <- 0 - r; }
    return r;
}

// ── Exec ────────────────────────────────

fn exec(nd, env) {
    if (nd.node = "Assignment") { env_set(env, nd.name, eval_expr(nd.expr, env)); return false; }
    if (nd.node = "PrintStmt") { print(eval_expr(nd.expr, env)); return false; }
    if (nd.node = "IfStmt") {
        if (is_truthy(eval_expr(nd.cond, env))) {
            r <- exec_block(nd.then_body, env);
            if (r != false) { return r; }
        } else {
            if (len(nd.else_body) > 0) { r <- exec_block(nd.else_body, env); if (r != false) { return r; } }
        }
        return false;
    }
    if (nd.node = "WhileStmt") {
        its <- 0;
        while (is_truthy(eval_expr(nd.cond, env))) {
            r <- exec_block(nd.body, env); if (r != false) { return r; }
            its <- its + 1; if (its > 100000) { print("Infinite loop"); return false; }
        }
        return false;
    }
    if (nd.node = "ForInStmt") {
        coll <- eval_expr(nd.iterable, env);
        i <- 0;
        while (i < len(coll)) {
            env_set(env, nd.var_name, coll[i]);
            r <- exec_block(nd.body, env); if (r != false) { return r; }
            i <- i + 1;
        }
        return false;
    }
    if (nd.node = "FnDecl") {
        env_set(env, nd.name, {is_func: true, is_expr: false, params: nd.params, body: nd.body, closure: env});
        return false;
    }
    if (nd.node = "ReturnStmt") {
        if (nd.expr = false) { return {is_return: true, value: false}; }
        return {is_return: true, value: eval_expr(nd.expr, env)};
    }
    if (nd.node = "Block") { return exec_block(nd.stmts, env); }
    if (nd.node = "IndexAssign") {
        obj <- eval_expr(nd.obj, env);
        idx <- eval_expr(nd.index, env);
        obj[idx] <- eval_expr(nd.value, env);
        return false;
    }
    // Expression statement
    eval_expr(nd, env);
    return false;
}

fn exec_block(stmts, env) {
    i <- 0;
    while (i < len(stmts)) {
        r <- exec(stmts[i], env);
        if (r != false) { if (r.is_return = true) { return r; } }
        i <- i + 1;
    }
    return false;
}

// ── Eval ────────────────────────────────

fn eval_expr(nd, env) {
    if (nd.node = "NumberLit") { return parse_int(nd.value); }
    if (nd.node = "StringLit") { return nd.value; }
    if (nd.node = "BoolLit") { return nd.value = "true"; }
    if (nd.node = "Identifier") { return env_get(env, nd.name); }

    if (nd.node = "BinOp") {
        l <- eval_expr(nd.left, env);
        if (nd.op = "&&") { if (!is_truthy(l)) { return false; } return eval_expr(nd.right, env); }
        if (nd.op = "||") { if (is_truthy(l)) { return l; } return eval_expr(nd.right, env); }
        r <- eval_expr(nd.right, env);
        if (nd.op = "+") { return l + r; }
        if (nd.op = "-") { return l - r; }
        if (nd.op = "*") { return l * r; }
        if (nd.op = "/") { return l / r; }
        if (nd.op = "%") { return l % r; }
        if (nd.op = "=") { return l = r; }
        if (nd.op = "!=") { return l != r; }
        if (nd.op = "<") { return l < r; }
        if (nd.op = ">") { return l > r; }
        if (nd.op = "<=") { return l <= r; }
        if (nd.op = ">=") { return l >= r; }
        return 0;
    }

    if (nd.node = "UnaryOp") {
        v <- eval_expr(nd.operand, env);
        if (nd.op = "-") { return 0 - v; }
        if (nd.op = "!") { return !is_truthy(v); }
        return 0;
    }

    if (nd.node = "ArrayLit") {
        a <- []; i <- 0;
        while (i < len(nd.elements)) { push(a, eval_expr(nd.elements[i], env)); i <- i + 1; }
        return a;
    }

    if (nd.node = "StructLit") {
        // Can't create arbitrary structs dynamically in Arrow Lang
        // Use a list-based representation: {_keys: [...], _vals: [...]}
        ks <- []; vs <- []; i <- 0;
        while (i < len(nd.fields)) {
            f <- nd.fields[i];
            push(ks, f.key); push(vs, eval_expr(f.val, env));
            i <- i + 1;
        }
        return {_keys: ks, _vals: vs};
    }

    if (nd.node = "IndexExpr") {
        obj <- eval_expr(nd.obj, env);
        idx <- eval_expr(nd.index, env);
        return obj[idx];
    }

    if (nd.node = "DotExpr") {
        obj <- eval_expr(nd.obj, env);
        // Check for our key-val struct repr
        i <- 0;
        while (i < len(obj._keys)) {
            if (obj._keys[i] = nd.field) { return obj._vals[i]; }
            i <- i + 1;
        }
        print("Error: no field '" + nd.field + "'");
        return 0;
    }

    if (nd.node = "CallExpr") {
        // Handle builtins by name
        if (nd.callee.node = "Identifier") {
            nm <- nd.callee.name;
            if (nm = "len") { return len(eval_expr(nd.args[0], env)); }
            if (nm = "push") { a <- eval_expr(nd.args[0], env); v <- eval_expr(nd.args[1], env); push(a, v); return v; }
            if (nm = "pop") { return pop(eval_expr(nd.args[0], env)); }
            if (nm = "char_code") { return char_code(eval_expr(nd.args[0], env)); }
            if (nm = "from_char_code") { return from_char_code(eval_expr(nd.args[0], env)); }
            if (nm = "char_at") { return char_at(eval_expr(nd.args[0], env), eval_expr(nd.args[1], env)); }
            if (nm = "str_len") { return str_len(eval_expr(nd.args[0], env)); }
            if (nm = "substring") { return substring(eval_expr(nd.args[0], env), eval_expr(nd.args[1], env), eval_expr(nd.args[2], env)); }
            if (nm = "read_file") { return read_file(eval_expr(nd.args[0], env)); }
            if (nm = "write_file") { write_file(eval_expr(nd.args[0], env), eval_expr(nd.args[1], env)); return false; }
            if (nm = "input") { return input(); }
            if (nm = "keys") { return keys(eval_expr(nd.args[0], env)); }
        }

        // User function
        callee <- eval_expr(nd.callee, env);
        args <- []; i <- 0;
        while (i < len(nd.args)) { push(args, eval_expr(nd.args[i], env)); i <- i + 1; }

        fn_env <- make_env(callee.closure);
        i <- 0;
        while (i < len(callee.params)) { env_set(fn_env, callee.params[i], args[i]); i <- i + 1; }

        // Body: expression or statement list
        if (callee.is_expr = true) {
            // Single expression body (arrow fn)
            return eval_expr(callee.body, fn_env);
        }
        r <- exec_block(callee.body, fn_env);
        if (r != false) { if (r.is_return = true) { return r.value; } }
        return false;
    }

    if (nd.node = "ArrowFn") {
        return {is_func: true, is_expr: nd.is_expr, params: nd.params, body: nd.body, closure: env};
    }

    print("Eval error: " + nd.node);
    return 0;
}


// ═══════════════════════════════════════════
//  MAIN
// ═══════════════════════════════════════════

target <- read_file("target.arrow");
toks <- tokenize(target);
pos[0] <- 0;
ast <- pp();
global <- make_env(false);
i <- 0;
while (i < len(ast)) {
    exec(ast[i], global);
    i <- i + 1;
}
