counter <- [0];
items <- [];

fn fresh(prefix) {
    counter[0] <- counter[0] + 1;
    return prefix + counter[0];
}

fn add_item(name) {
    push(items, {name: name, id: fresh("id")});
}

add_item("alpha");
add_item("beta");
add_item("gamma");

i <- 0;
while (i < len(items)) {
    it <- items[i];
    print(it.name + " -> " + it.id);
    i <- i + 1;
}